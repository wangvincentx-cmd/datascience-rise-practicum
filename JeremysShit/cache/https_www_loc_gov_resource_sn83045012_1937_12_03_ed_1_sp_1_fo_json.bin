ministration of the national labor relations act by the National Labor Relations Board that it is no longer safe to permit"], "digitized": true, "extract_timestamp": "2023-09-04T23:15:09.924Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045012/1937-12-03/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_buttercup_ver01:data:sn83045012:00340580527:1937120301:0698/full/pct:3.125/0/default.jpg#h=271&w=189", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_buttercup_ver01:data:sn83045012:00340580527:1937120301:0698/full/pct:6.25/0/default.jpg#h=543&w=378", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_buttercup_ver01:data:sn83045012:00340580527:1937120301:0698/full/pct:12.5/0/default.jpg#h=1086&w=756", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_buttercup_ver01/data/sn83045012/00340580527/1937120301/0698.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["butler", "ohio", "hamilton", "united states"], "location_city": ["hamilton"], "location_country": ["united states"], "location_county": ["butler"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "8", "3", "sn83045012", "4", "7", "0000000001", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn83045012"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "0", "5", "2", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the butler county press (hamilton, ohio) 1900-1946", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_titl