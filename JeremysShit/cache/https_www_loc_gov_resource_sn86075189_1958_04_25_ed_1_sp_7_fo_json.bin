": ["sn86075189", "1", "00414211057"], "number_edition": ["1"], "number_lccn": ["sn86075189"], "number_reel": ["00414211057"], "numeric_shelf_id": 195804251, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//mthi/batch_mthi_douglasfir_ver01/data/sn86075189/00414211057/1958042501/1958042501_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn86075189/marcxml"}], "partof": [{"count": 1252, "title": "the people's voice (helena, mont.) 1939-1969", "url": "https://www.loc.gov/search/?fa=partof:the+people%27s+voice+%28helena,+mont.%29+1939-1969&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the people's voice (helena, mont.) 1939-1969"], "place_of_publication": "Helena, Mont.", "publication_frequency": ["weekly"], "raw_lccn": "sn 86075189 ", "reel_numbers": ["00414211057"], "resources": [{"files": 8, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_douglasfir_ver01:data:sn86075189:00414211057:1958042501:0082/full/pct:6.25/0/default.jpg", "url": "https://www.loc.gov/resource/sn86075189/1958-04-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.655856, "shard": "09", "shelf_id": "sn86075189, 1958-04-25, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/mthi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["lewis and clark", "helena (mont.)", "history", "united states", "montana", "helena"], "subject_headings": ["Helena (Mont.)", "Montana--History", "Montana", "Montana--Helena", "United States--Montana--Lewis and Clark--Helena"], "subjects": [{"helena": "https://www.loc.gov/search/?fa=subject:helena&fo=json"}, {"helena (mont.)": "https://www.loc.gov/search/?fa=subject:helena+%28mont.%29&fo=json"}, {"history": "https://www.loc.gov/search/?fa=subject:history&fo=json"}, {"lewis and clark": "https://www.loc.gov/search/?fa=subject:lewis+and+clark&fo=json"}, {"montana": "https://www.loc.gov/search/?fa=subject:montana&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2023-07-05T20:59:51.960Z", "title": "The People's voice (Helena, Mont.), April 25, 1958", "type": ["issue"], "url": "https://www.loc.gov/item/sn86075189/1958-04-25/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn86075189/", "http://lccn.loc.gov/sn86075189", "https://search.catalog.loc.gov/instances/00e4c3a1-c7f5-55fd-a624-63280dfde2a3"], "batch": ["mthi_douglasfir_ver01"], "campaigns": [], "date": "1939", "description": ["Weekly Vol. 1, no. 1 (Dec. 6, 1939)-v. 30, no. 6 (Aug. 22, 1969). \"No Commercial Advertising except from Co-operative Business Institutions accepted.\" Archived issues are available in digital format from the Library of Congress Chronicling America online collection."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:15.450Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-13", "catalog", "united-states-newspaper-directory", "main-catalog-split-13"], "hassegments": false, "id": "http://www.loc.gov/item/sn86075189/", "image_url": [], "index": 7, "language": ["english"], "latlong": [46.5910708, -112.0203973], "location": ["lewis and clark", "helena", "united states", "montana"], "location_str": "", "lonlat": [-112.0203973, 46.5910708], "number": ["montana hist soc libr", "13646776", "microfilm master", "2766-2020", "original", "2026-04-13t21:30:13", "http://www.loc.gov/item/sn86075189/1939-12-06/ed-1/", "2025-07-01t13:40:54", "sn86075189", "2025-05-23t21:30:26", "http://www.loc.gov/item/sn86075189/1963-12-27/ed-1/", "1257", "online resource", "1", "microfilm service copy"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "catalog", "the people's voice (helena, mont.) 1939-1969", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 56.25052, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "history", "united states", "montana", "helena"], "timestamp": "2026-07-18T09:20:06.081Z", "title": "The people's voice", "type": ["title"], "url": "https://www.loc.gov/item/sn86075189/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271280/"], "campaigns": [], "date": "1939", "dates": ["[1939 TO 1969]"], "description": ["Weekly Began with vol. I, no. 1 (December 6, 1939); ceased v. 30, no. 6 (Aug. 22, 1969). \"No Commercial Advertising except from Co-operative Business Institutions accepted.\" Vol. I, No. 1 (December 6, 1939); title from masthead (Chroniclingamerica.loc.gov, viewed December 9, 2020). Vol. XXV, No. 4 (December 27, 1963) (Chroniclingamerica.loc.gov, viewed December 9, 2020)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:57.206Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271280/", "image_url": [], "index": 8, "language": ["english"], "location": ["lewis and clark", "helena", "united states", "montana"], "number": ["online resource", "1226328195", "2020271280", "2766-2039", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["the people's voice (helena, montana) 1939-1969 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 46.47218, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "united states", "montana", "helena"], "timestamp": "2026-05-26T21:01:07.415Z", "title": "The people's voice", "type": ["title"], "url": "https://www.loc.gov/item/2020271280/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218808/"], "campaigns": [], "date": "1906", "dates": ["[1906 TO 1911]"], "description": ["Weekly, i.e. irregular Began with vol. I, no. I (March 16, 1906); ceased with vol. III, 36 (September 8, 1911). \"We unhesitatingly subscribe to the principles of Republicanism.\" \"A complete Negro newspaper.\" Description based on print version record. Latest issue consulted: Vol. III, 36 (September 8, 1911) (Chroniclingamerica.loc.gov, viewed June 12, 2013)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:21.057Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013218808/", "image_url": [], "index": 9, "language": ["english"], "location": ["lewis and clark", "helena", "united states", "montana"], "number": ["online resource", "847788581", "2329-5538", "2026-04-13t21:30:13", "2013218808"], "original_format": ["newspaper"], "other_title": ["Montana plain dealer"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the montana plaindealer (helena, montana) 1906-1911 [online resource]"], "publication_frequency": ["weekly"], "score": 46.47218, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "african americans", "united states", "montana", "helena", "african american", "african american newspapers"], "timestamp": "2026-05-26T20:48:08.077Z", "title": "The Montana plaindealer", "type": ["title"], "url": "https://www.loc.gov/item/2013218808/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218597/"], "campaigns": [], "date": "1875", "dates": ["[1875 TO 1943]"], "description": ["Daily, November 25, 1889-November 21, 1943 Began August 12, 1875; ceased November 21, 1943. Vol. 19, no, 241 (January 13, 1884); title from PDF masthead (LLMC Digital, viewed December 31, 2020). Vol. 35, no. 311 (December 31, 1894) (Chroniclingamerica.loc.gov, viewed February 27, 2013). Publishers: The Independent Pub. Co. <December 31, 1894-> Available on microfilm from the Library of Congress, Photoduplication Service. Also issued in print. Merged with: Montana record-herald, to form: Independent-record (Helena, Mont.). Montana record-herald Independent-record (Helena, Mont.)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:19.469Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013218597/", "image_url": [], "index": 10, "language": ["english"], "location": ["lewis and clark", "united states", "montana", "lewis", "helena", "clark county"], "number": ["online resource", "828628958", "2326-9596", "2026-04-13t21:30:13", "2013218597"], "original_format": ["newspaper"], "other_title": ["Independent", "Daily independent", "Helena daily independent"], "partof": ["serial and government publications division", "the helena independent (helena, montana territory) 1875-1943 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 46.47218, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "lewis and clark county (mont.)", "united states", "montana", "helena", "lewis and clark county"], "timestamp": "2026-05-26T20:47:50.735Z", "title": "The Helena independent", "type": ["title"], "url": "https://www.loc.gov/item/2013218597/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218600/"], "campaigns": [], "contributor": ["ball, j. p., jr.,"], "date": "1894", "dates": ["[1894 TO 1894]"], "description": ["Weekly Began with vol. 1, no. 1 (September 3, 1894). Ceased with December 15, 1894. Cf. The Negro in Montana, 1800-1945. Editor: J. P. Ball, Jr., September 3-<November 5>, 1894. \"Devoted to the interests of Colored Americans.\" Description based on: Vol. 1, no. 1 (September 3, 1894); title from masthead (Chroniclingamerica.loc.gov, viewed Feb. 27, 2013). Latest issue consulted: Vol. 1, no. 10 (November 5, 1894) (Chroniclingamerica.loc.gov, viewed Feb. 27, 2013)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:19.469Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013218600/", "image_url": [], "index": 11, "language": ["english"], "location": ["lewis and clark", "helena", "united states", "montana"], "number": ["online resource", "2326-9693", "2013218600", "828631189", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the colored citizen (helena, montana) 1894-1894 [online resource]"], "publication_frequency": ["weekly"], "score": 46.47218, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "african americans", "united states", "montana", "helena", "african american"], "timestamp": "2026-05-26T20:47:50.735Z", "title": "The Colored citizen", "type": ["title"], "url": "https://www.loc.gov/item/2013218600/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013271998/"], "campaigns": [], "date": "1914", "dates": ["[1914 TO 1919]"], "description": ["Began September 22, 1914. \"Published...Sept. 22,23,24,25,26, 1914.\" Issues for Sept. 24-26, 1914 called: Montana State Fair Edition; issue for Nov. 2, 1914 called: Election Edition. Sept. 24-26, 1914 issues published by the Montana Equal Suffrage State Central Committee in Helena; Nov. 2, 1914 issue published by the Butte Equal Suffrage Association in Butte. Description based on: Number 3 (September 24, 1914); title from masthead (Chroniclingamerica.loc.gov, viewed January 23, 2014). Latest issue consulted: November 2, 1914 (Chroniclingamerica.loc.gov, viewed January 23, 2014)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:24.080Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013271998/", "image_url": [], "index": 12, "language": ["english"], "location": ["lewis and clark", "b