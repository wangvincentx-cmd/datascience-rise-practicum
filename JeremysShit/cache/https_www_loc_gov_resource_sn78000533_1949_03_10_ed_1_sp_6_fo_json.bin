ices/service/pnp/fsa/8b07000/8b07300/8b07396_150px.jpg#h=109&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b07000/8b07300/8b07396t.gif#h=109&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b07000/8b07300/8b07396r.jpg#h=465&w=640", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b07000/8b07300/8b07396v.jpg#h=745&w=1024"], "index": 6, "language": ["english"], "location": ["columbiana county", "ohio", "east liverpool", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/19638923", "2017-05-15t09:44:07", "2017693666", "http://www.loc.gov/item/2017693666", "http://www.loc.gov/item/oem2002004594/pp"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "farm security administration/office of war information black-and-white negatives", "catalog", "prints and photographs division", "american memory", "lot 1982"], "score": 23.05925, "shelf_id": "LC-USE6- D-006028 [P&P] LOT 1982  (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["columbiana county", "ohio", "united states", "east liverpool", "nitrate negatives"], "timestamp": "2022-04-25T15:25:43.098Z", "title": "Women in war. Filling station attendant. Tires need checking too? Shifting trends of employment in wartime America have opened up new jobs for such women as this young East Liverpool, Ohio, girl who has pioneered in two new fields since graduation from high school. She learned butchering first, and built up quite a reputation as a purveyor of choice cuts. Now she's one of the most efficient service station attendants in the neighborhood. Her name? Virginia Excell", "url": "https://www.loc.gov/item/2017693666/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017693667/", "http://www.loc.gov/item/2017693667/", "http://www.loc.gov/pictures/item/2017693667/", "