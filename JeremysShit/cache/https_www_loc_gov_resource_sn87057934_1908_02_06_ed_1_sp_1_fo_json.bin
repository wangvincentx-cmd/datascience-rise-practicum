aigns": [], "date": "1894", "dates": ["[1894 TO 1925]"], "description": ["Weekly Began with vol. IX, no. 21 (May 3, 1894); ceased May 1, 1925. Publisher varies. Numbered within the year, <1921-1924>. Vol. IX, No. 21 (May 3, 1894); title from masthead (Chroniclingamerica.loc.gov, viewed July 27, 2022). No. 52 (December 29, 1921) (Chroniclingamerica.loc.gov, viewed July 27, 2022). Audubon advocate Advocate-Republican"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:04.325Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2022270703/", "image_url": [], "index": 4, "language": ["english"], "location": ["audubon", "iowa", "united states"], "number": ["online resource", "1337414035", "2022270702", "2832-9732", "2022270703", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "audubon republican (audubon, iowa) 1894-1925 [online resource]"], "publication_frequency": ["weekly"], "score": 28.56505, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["audubon", "audubon (iowa)", "newspapers", "iowa", "united states"], "timestamp": "2026-05-26T21:06:24.810Z", "title": "Audubon Republican", "type": ["title"], "url": "https://www.loc.gov/item/2022270703/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn85049838/", "http://lccn.loc.gov/sn85049838", "https://search.catalog.loc.gov/instances/e6697f0c-a744-5f60-b4de-f101510b4d30"], "batch": ["iahi_gardevoir_ver02"], "campaigns": [], "date": "1885", "description": ["Weekly -v. 9, no. 20 (Apr. 26, 1894). Began with Dec. 24, 1885 issue. Cf. Bibl. of Iowa newspapers. \"Devoted to the news and interests of Audubon County.\" Publishers: Cousins & Foster, <Dec. 31, 1885>-Mar. 31, 1887; Cousins & McClure, Apr. 7, 1887-Feb. 8, 1894; J.E. Griffith, Feb. 15-Apr. 26, 1894. Editors: W.H. McClure, <Dec. 31, 1885>-June 7, 1888; Cousins & McClure, June 14, 1888-Feb. 8, 1894; J.E. Griffith, Feb. 15-Apr. 26, 1894. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Description based on: Vol. 1, no. 2 (Dec. 31, 1885). Audubon Republican 2832-9724 (DLC)sn 87057928 (OCoLC)14763554"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:11.942Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-14", "catalog", "united-states-newspaper-directory", "main-catalog-split-14"], "hassegments": false, "id": "http://www.loc.gov/item/sn85049838/", "image_url": [], "index": 5, "language": ["english"], "latlong": [41.71697, -94.93186], "location": ["audubon", "iowa", "united states"], "location_str": "", "lonlat": [-94.93186, 41.71697], "number": ["http://www.loc.gov/item/sn85049838/1885-12-31/ed-1/", "2024-05-12t17:17:02.191186", "439", "online resource", "2832-9708", "state hist soc of iowa, newsp col", "microfilm service copy", "sn87057928", "2025-07-01t13:40:43.100000", "http://www.loc.gov/item/sn85049838/1894-04-26/ed-1/", "2026-04-13t21:30:13", "1", "sn85049838", "12841260"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "audubon county republican (audubon, audubon co., iowa) 1885-1894", "catalog", "chronicling america"], "publication_frequency": ["weekly"], "score": 28.56505, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["audubon", "audubon (iowa)", "newspapers", "iowa", "united states"], "timestamp": "2026-07-18T09:16:44.016Z", "title": "Audubon County Republican", "type": ["title"], "url": "https://www.loc.gov/item/sn85049838/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn87057928/", "http://lccn.loc.gov/sn87057928", "https://search.catalog.loc.gov/instances/6ac2c89d-e71b-5b61-a72c-875b4c65bb13"], "batch": ["iahi_gardevoir_ver02"], "campaigns": [], "date