=640", "https://tile.loc.gov/storage-services/service/pnp/stereo/1s00000/1s08000/1s08200/1s08215v.jpg#h=590&w=1024"], "index": 2, "language": ["english"], "location": ["audubon", "montgomery county", "pennsylvania"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["sheet", "2017650979", "2019-07-26t12:00:16", "http://www.loc.gov/item/20082043"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 13654", "stereograph cards", "prints and photographs division", "prints & photographs online catalog (library of congress)", "catalog"], "score": 17.512644, "shelf_id": "LOT 13654, no. 27 [P&P]", "site": ["pictures", "catalog"], "subject": ["snow", "winter", "pennsylvania", "audubon", "montgomery county (pa.)", "stereographs", "outbuildings", "audubon (pa)", "photographic prints"], "timestamp": "2022-05-20T17:12:23.726Z", "title": "Wetherill place near Valley Forge \"Fatland\"", "url": "https://www.loc.gov/item/2017650979/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/04036331", "http://www.loc.gov/item/04036331/", "https://catalog.hathitrust.org/Record/100555603"], "campaigns": [], "contributor": ["calvin, samuel", "hobby, cicero mead", "pickard, josiah little", "mcclain, emlin", "state historical society of iowa"], "date": "1893", "dates": ["1893"], "digitized": true, "extract_timestamp": "2024-02-09T09:47:11.217Z", "group": ["catalog-split-04", "catalog", "main-catalog-split-04"], "hassegments": false, "id": "http://lccn.loc.gov/04036331", "image_url": [], "index": 3, "language": ["english"], "location": ["iowa"], "number": ["04036331", "2024-02-07t11:35:36"], "original_format": ["book"], "partof": ["catalog"], "score": 15.646871, "shelf_id": "F616 .I72", "site": ["catalog"], "subject": ["louisiana purchase", "law", "iowa indians", "iowa", "antiquities"], "timestamp": "2024-02-09T09:48:27.824Z", "title": "Iowa historical lectures", "type": ["text"], "url": "//lccn.loc.gov/04036331"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013433203/", "http://lccn.loc.gov/2013433203", "http://www.iowadot.gov/ole/documents/Booklet%20-%20Wever%20Bypass%20Excavations.pdf"], "campaigns": [], "contributor": ["iowa. department of transportation", "louis berger group", "withrow, randall m.", "united states. federal highway administration", "state historical society of iowa"], "date": "2012", "dates": ["2012"], "description": ["This is a story about a highway project near the small town of Wever, Iowa, and an American Indian village that existed at the location prior to the Europeans' arrival. The culture that lived in this village existed in a 10 state region of the Upper Midwest and may have been the ancestors of tribes living in the Midwest when European explorers entered the region. An archaeological recovery of information from the site was undertaken by the Iowa Department of Transportation because four-lane construction of U.S. 61 could not be accomplished without destroying most of the site. This site proved to be one of the richest archaeological finds in the State of Iowa. Iowa Department of Transportation. http://www.iowadot.gov/ole/publications.asp"], "digitized": true, "extract_timestamp": "2023-06-02T18:59:29.336Z", "group": ["catalog-split-05", "catalog", "main-catalog-split-05", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2013433203", "image_url": [], "index": 4, "language": ["english"], "location": ["lee county", "oneota", "united states highway 61", "ioway", "great river road", "iowa"], "number": ["2013433203", "2013-09-05t07:42:49", "n806032887"], "original_format": ["book"], "other_title": ["Highway archaeology along the Great River Road in southeast Iowa"], "partof": ["catalog"], "score": 15.646871, "shelf_id": "E78.I6 W58 2012", "site": ["catalog"], "subject": ["design and construction", "radiocarbon dating", "lee county", "united states highway 61", "oneota", "archaeology", "ioway", "historic sites", "roads", "great river road", "excavations (archaeology)", "lee county (iowa)", "native americans", "department of transportation", "iowa", "oneota indians (great plains)", "antiquities"], "timestamp": "2023-07-07T20:16:00.819Z", "title": "The Wever Bypass excavations : Highway archaeology along the Great River Road in southeast Iowa", "type": ["text"], "url": "//lccn.loc.gov/2013433203"}, {"access_restricted": false, "aka": ["http://www.iowahistory.org/index.html", "http://www.loc.gov/item/2003542944/", "http://lccn.loc.gov/2003542944"], "campaigns": [], "contributor": ["state historical society of iowa"], "date": "2003", "dates": ["2003"], "description": ["Provides access to the activities and offerings of the SHSI. Includes how to get involved, current events, important locations to visit, and educational material."], "digitized": true, "extract_timestamp": "2023-06-02T15:09:26.210Z", "group": ["catalog-split-01", "catalog", "main-catalog-split-01", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2003542944", "image_url": [], "index": 5, "language": ["english"], "location": ["iowa"], "number": ["2003-12-16t15:13:32", "2003542944"], "original_format": ["book"], "partof": ["catalog"], "score": 15.646871, "shelf_id": "F616", "site": ["catalog"], "subject": ["historic buildings", "historic sites", "state historical society of iowa", "preservation and restoration", "historic preservation", "iowa"], "timestamp": "2023-07-07T00:25:24.920Z", "title": "State Historical Society of Iowa", "type": ["text"], "url": "//lccn.loc.gov/2003542944"}, {"access_restricted": false, "aka": ["http://www.iowadot.gov/ole/documents/SiouxCitysGrandAvenueViaduct.pdf", "http://www.loc.gov/item/2013433934/", "http://lccn.loc.gov/2013433934"], "campaigns": [], "contributor": ["iowa. department of transportation", "united states. federal highway administration", "state historical society of iowa", "whye, mike", "price, jennifer a."], "date": "2010", "dates": ["2010"], "description": ["For almost 75 years, the Grand Avenue Viaduct (known today as the Gordon Drive Viaduct) has been a familiar feature of Sioux City's urban landscape.  With the exception of bridges over the Mississippi River, the Grand Avenue Viaduct is Iowa's longest grade separation as well as its longest bridge.  For nearly a mile, from the eastern suburbs west to the central business district, the viaduct carries Gordon Drive and the city route of U.S. 20 over the Floyd River valley, which includes the remnants of the city's famed stockyards and the South Bottoms neighborhood, as well as a maze of railroad tracks and the present channel of the Floyd River.  Constructed in 1937 and known simply as \"The Viaduct\" to local residents, the massive structure is as fundamental to Sioux City as were its stockyards just a few decades ago."], "digitized": true, "extract_timestamp": "2023-06-02T15:40:36.069Z", "group": ["catalog-split-00", "catalog", "main-catalog-split-00", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2013433934", "image_url": [], "index": 6, "language": ["english"], "location": ["grand avenue viaduct", "gordon drive viaduct", "iowa", "sioux city"], "number": ["2013433934", "2013-08-19t07:58:20", "n663975146"], "original_format": ["book"], "partof": ["catalog"], "score": 15.646871, "shelf_id": "F629.S6 P75 2010", "site": ["catalog"], "subject": ["ashton, edward l.", "viaducts", "sioux city", "grand avenue viaduct (sioux city, iowa)", "gordon drive viaduct (sioux city, iowa)", "sioux city (iowa)", "history", "iowa", "historic bridges"], "timestamp": "2023-07-07T07:17:30.763Z", "title": "Sioux City's Grand Avenue Viaduct, 1936-2010", "type": ["text"], "url": "//lccn.loc.gov/2013433934"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iahi/batch_iahi_kutcher_ver01/data/sn87057934/00415622685/1908020601/0765.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:n