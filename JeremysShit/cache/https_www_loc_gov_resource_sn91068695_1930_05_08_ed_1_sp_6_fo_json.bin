pdf", "segment_count": 11, "url": "https://www.loc.gov/resource/sn91068695/1930-05-08/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_dill_ver02/data/sn91068695/00279559307/1930050801/0185.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_dill_ver02:data:sn91068695:00279559307:1930050801:0180/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ncu/batch_ncu_dill_ver02/data/sn91068695/00279559307/1930050801/0185.pdf", "segment_count": 11, "url": "https://www.loc.gov/resource/sn91068695/1930-05-08/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ncu/batch_ncu_dill_ver02/data/sn91068695/00279559307/1930050801/0185.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn91068695/1930-05-08/ed-1/?sp=6"], "batch": ["ncu_dill_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/north carolina/", "2/united states/north carolina/mcdowell/", "3/united states/north carolina/mcdowell/marion/"], "contributor": ["university of north carolina at chapel hill library, chapel hill, nc"], "date": "1930-05-08", "dates": ["1930-05-08"], "description": ["MARION PROGRESS PUBLISHED EVERY THURSDAY BY THE Mcdowell publishing co MARION N C TELEPHONE 64 S E WHITTEN Editor and Prop W A COLLETT Associate Editor Entered at the Postoffice at Marion N C as second class matter SUBSCRIPTION RATES One Year 150 Six Months 75 Strictly in Advance MARION N C MAY 8 1930 THE SCHOOL A PUBLIC ENTERPRISE In no other public institution are people in general interested as they are in the schools This fact is alone very probably the biggest reason why the schools of North Carolina have made such remarkable prog ress in recent years That this intei est is a healthy one and one that should be encouraged is not denied All peopte should be interested in an institution that is spending pub lic money They should know how much and for what purpose the money is being spent In a recent school exhibit seen by the writer a chart of the percentage of school costs had been worked ont by a Math class showing the total income of the school and the way it is spent A great deal of interestwas taken in this particular exhibit by every patron that came by Every"], "digitized": true, "extract_timestamp": "2023-08-12T17:33:22.165Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn91068695/1930-05-08/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_dill_ver02:data:sn91068695:00279559307:1930050801:0185/full/pct:3.125/0/default.jpg#h=260&w=175", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_dill_ver02:data:sn91068695:00279559307:1930050801:0185/full/pct:6.25/0/default.jpg#h=520&w=351", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_dill_ver02:data:sn91068695:00279559307:1930050801:0185/full/pct:12.5/0/default.jpg#h=1040&w=703", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_dill_ver02/data/sn91068695/00279559307/1930050801/0185.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["marion", "mcdowell county", "mcdowell", "united states", "north carolina"], "location_city": ["marion"], "location_country": ["united states"], "location_county": ["mcdowell"], "location_state": ["north carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "5", "3", "sn91068695", "0000000006", "7", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn910