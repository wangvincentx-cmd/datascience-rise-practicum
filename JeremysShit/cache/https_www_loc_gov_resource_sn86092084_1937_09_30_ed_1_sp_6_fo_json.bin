_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wvu/batch_wvu_day_ver01/data/sn86092084/00517010881/1937093001/0726.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:wvu:batch_wvu_day_ver01:data:sn86092084:00517010881:1937093001:0721/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/wvu/batch_wvu_day_ver01/data/sn86092084/00517010881/1937093001/0726.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86092084/1937-09-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wvu/batch_wvu_day_ver01/data/sn86092084/00517010881/1937093001/0726.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:wvu:batch_wvu_day_ver01:data:sn86092084:00517010881:1937093001:0721/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/wvu/batch_wvu_day_ver01/data/sn86092084/00517010881/1937093001/0726.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86092084/1937-09-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/wvu/batch_wvu_day_ver01/data/sn86092084/00517010881/1937093001/0726.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86092084/1937-09-30/ed-1/?sp=6"], "batch": ["wvu_day_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/west virginia/", "2/united states/west virginia/mingo/", "3/united states/west virginia/mingo/williamson/"], "contributor": ["west virginia university"], "date": "1937-09-30", "dates": ["1937-09-30"], "description": ["WashingtonWall Street and the securities market generally have been undergoing a Bad Case of bad case of the Jitters jitters It has been several years since those dealing in money and shares of stock have been so un certain as to the future and this uncertainty dbviously is the cause of the jitters among all people who dabble in the stock market whether the dabbling be small or large on margin or for cash It seems a proper time there fore to examine the picture and try to see what lies beneath And let me hasten to say at the very out set that anyone who makes a posi tive statement about the securities market these days must be either a fool or a supermanand thus far the supermen who have lived on this earth number only one But that fact does not destroy the value of an examination of a con dition which exists as a fact In deed I think a review of the various factors and influences at work now can provide a clarification of gen eral conditions even though it may fail utterly to show why men and women act as they do with respect to"], "digitized": true, "extract_timestamp": "2025-05-27T16:58:31.855Z", "group": ["ndnp/wvu", "west-virginia-university-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86092084/1937-09-30/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:wvu:batch_wvu_day_ver01:data:sn86092084:00517010881:1937093001:0726/full/pct:6.25/0/default.jpg#h=475&w=359", "https://tile.loc.gov/image-services/iiif/service:ndnp:wvu:batch_wvu_day_ver01:data:sn86092084:00517010881:1937093001:0726/full/pct:12.5/0/default.jpg#h=951&w=719", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wvu/batch_wvu_day_ver01/data/sn86092084/00517010881/1937093001/0726.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["mingo", "williamson", "west virginia", "united states"], "location_city": ["williamson"], "location_country": ["united states"], "location_county": ["mingo"], "location_state": ["west virginia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg