rawing"], "partof": ["prints and photographs division", "catalog", "lot 1361", "american memory", "prints & photographs online catalog (library of congress)", "farm security administration/office of war information black-and-white negatives"], "score": 31.920849, "shelf_id": "LC-USF34- 052002-D", "site": ["catalog", "pictures"], "subject": ["maryland", "greenbelt", "prince george's county", "united states", "safety film negatives"], "timestamp": "2023-02-18T12:27:32.587Z", "title": "Swimming pool. Greenbelt, Maryland", "type": ["still image"], "url": "https://www.loc.gov/item/2017801242/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_annapolis_ver02/data/sn89061521/0041562640A/1938011901/0159.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_annapolis_ver02:data:sn89061521:0041562640A:1938011901:0144/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mdu/batch_mdu_annapolis_ver02/data/sn89061521/0041562640A/1938011901/0159.pdf", "segment_count": 18, "url": "https://www.loc.gov/resource/sn89061521/1938-01-19/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_annapolis_ver02/data/sn89061521/0041562640A/1938011901/0159.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_annapolis_ver02:data:sn89061521:0041562640A:1938011901:0144/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mdu/batch_mdu_annapolis_ver02/data/sn89061521/0041562640A/1938011901/0159.pdf", "segment_count": 18, "url": "https://www.loc.gov/resource/sn89061521/1938-01-19/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mdu/batch_mdu_annapolis_ver02/data/sn89061521/0041562640A/1938011901/0159.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89061521/1938-01-19/ed-1/?sp=16"], "batch": ["mdu_annapolis_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/maryland/", "2/united states/maryland/prince george's/", "3/united states/maryland/prince george's/greenbelt/"], "contributor": ["university of maryland, college park, md"], "date": "1938-01-19", "dates": ["1938-01-19"], "description": ["Page Sixteen THE STATE OF THE UNION By Henry Little j i i i The happy day when the Presidents message to a convening Congress could be couched solely in terms of the state of the Union is gene forever Presi dent Roosevelt made this clear in the first fev r paragraphs of his initial ad dress to Congress this year It was necessary for him to deal immediately with the State of the Union with regard to the rest of the world and thanks to radio the rest of the world even as we at home could hear his words as they were spoken It is impossible even to attempt a factual summary of a political speech without drawing the fire of the hyper political minded but it will not bo i gainsaid by anyone that parts of the Presidents speech were more significant than others I shall speak of those parts For instance no one will dispute the truth of these words Much of the trouble in our own lifetime has sprung from a long period of inactionfrom ig noring what fundamentally was happening to us and from a timeserving unwill ingness to face facts as they forced"], "digitized": true, "extract_timestamp": "2023-03-01T18:22:31.987Z", "group": ["ndnp/mdu", "university-of-maryland-college-park-college-park-md-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89061521/1938-01-19/ed-1/?sp=16", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_annapolis_ver02:data:sn89061521:004156