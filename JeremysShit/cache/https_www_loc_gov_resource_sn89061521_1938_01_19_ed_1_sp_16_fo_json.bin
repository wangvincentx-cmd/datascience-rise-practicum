: ["image"], "original_format": ["map"], "partof": ["geography and map division", "catalog", "county landownership maps", "cultural landscapes"], "score": 35.317318, "shelf_id": "G3843.M6 1862 .U5 G3843.M6 1862 .U5 Copy 2", "site": ["catalog"], "subject": ["montgomery county (md.)", "maryland", "military maps", "montgomery county", "landowners", "prince george's county", "prince george's county (md.)", "united states", "physical maps", "ravines", "maps"], "timestamp": "2026-04-29T16:08:35.525Z", "title": "Map of Montgomery County, Maryland", "type": ["cartographic"], "url": "https://www.loc.gov/item/2014585161/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/81690002", "http://www.loc.gov/item/81690002/", "https://search.catalog.loc.gov/instances/9b1ceb23-2f1c-5775-8554-d043ca8ef60f", "https://hdl.loc.gov/loc.gmd/g3843p.ct008737", "http://www.loc.gov/resource/g3843p.ct008737/"], "campaigns": [], "contributor": ["united states. soil conservation service"], "date": "1977", "dates": ["1977"], "description": ["Title in lower margin: Prince Georges Co., Md. : N3831.5-W7637.5/36.5 x 28, 1977. \"Compiled by USGS in 1977 from USGS and Army Map Service 1:24,000-scale topographic maps dated 1953-1971.\" \"Planimetry revised from aerial photographs taken 1976 and other source data.\" Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:04.864Z", "group": ["gmd.mar", "catalog-split-10", "catalog", "general-maps", "main-catalog-split-10"], "hassegments": false, "id": "http://www.loc.gov/item/81690002/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd384/g3843/g3843p/ct008737.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd384/g3843/g3843p/ct008737.gif#h=150&w=98", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd384:g3843:g3843p:ct008737/full/pct:12.5/0/default.jpg#h=958&w=627", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd384:g3843:g3843p:ct008737/full/pct:25/0/default.jpg#h=1917&w=1254"], "index": 17, "language": ["english"], "location": ["united states", "maryland", "prince george's county"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2018-02-05t10:28:36", "81690002", "2025-06-07t18:33:59.900000"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "catalog", "additional conservation and environment cartographic items"], "score": 35.317318, "shelf_id": "G3843.P7 1977 .U5", "site": ["catalog"], "subject": ["maryland", "prince george's county", "prince george's county (md.)", "united states", "maps"], "timestamp": "2026-04-29T16:20:02.142Z", "title": "Prince Georges County, Maryland", "type": ["cartographic"], "url": "https://www.loc.gov/item/81690002/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2002624036", "http://www.loc.gov/item/2002624036/", "https://search.catalog.loc.gov/instances/fab7b570-f259-5b41-8658-c9bd05dbfa76", "https://hdl.loc.gov/loc.gmd/g3843p.la000302", "http://www.loc.gov/resource/g3843p.la000302/"], "campaigns": [], "contributor": ["martenet, simon j."], "date": "1861", "dates": ["1861"], "description": ["Cadastral map showing landowners. Includes \"table of distances in miles and hundreths.\" Insets: Upper Marlborough. -- Laurel. -- Nottingham. -- Woodville. -- Piscataway. -- Bladensburg. LC copy imperfect: small holes. Scale 1:63,360: 1 mile in 1 in. LC Land ownership maps, 302 Available also through the Library of Congress Web site as a raster image. AACR2"], "digitized": true, "extract_timestamp": "2026-04-29T15:39:19.315Z", "group": ["gmd.mar", "catalog-split-09", "catalog", "general-maps", "main-catalog-split-09"], "hassegments": false, "id": "http://www.loc.gov/item/2002624036/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd384/g3843/g3843p/la000302.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd384/g3843/g3843p/la000302.gif#h=213&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd384:g3843:g3843p:la000302/full/pct:12.5/0/default.jpg#h=1658&w=1168", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd384:g3843:g3843p:la000302/full/pct:25/0/default.jpg#h=3316&w=2336"], "index": 18, "language": ["english"], "location": ["united states", "maryland", "prince george's county"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2002624036", "2025-06-07t22:50:53", "2002-12-14t20:39:10"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "catalog", "county landownership maps", "cultural landscapes"], "score": 35.317318, "shelf_id": "G3843.P7 1861 .M3", "site": ["catalog"], "subject": ["maryland", "prince george's county", "prince george's county (md.)", "real property", "united states", "maps"], "timestamp": "2026-04-29T15:44:13.233Z", "title": "Martenet's Map of Prince George's County, Maryland", "type": ["cartographic"], "url": "https://www.loc.gov/item/2002624036/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2024739262", "http://www.loc.gov/item/2024739262/", "https://search.catalog.loc.gov/instances/ad9b18b5-2949-5b38-8301-bab02164bbd6", "https://hdl.loc.gov/loc.gdc/gdcebookspublic.2024739262", "http://www.loc.gov/resource/gdcebookspublic.2024739262/"], "campaigns": [], "contributor": ["gahlon, grace", "king, christopher j.", "kranz, ashley m.", "chandra, anita", "rand social and economic well-being (program)", "blanchard, janice c.", "rand corporation", "madrigano, jaime", "ruder, teague"], "date": "2020", "dates": ["2020"], "description": ["With evolving demographics and a changing health system landscape, the Prince George's County Council, acting as the County Board of Health, is considering its future policy approaches and resource allocations related to health and well-being. To inform this path forward, the authors of this report used primary and secondary data to describe both the health needs of county residents and drivers of health within the county, inclusive of the social, economic, built, natural, and health service environments. This report integrates these findings, an analysis of budget documents, and a review of promising practices from other communities to situate recommendations in a Health in All Policies framework to foster aligned and integrated planning and budgeting across the county to promote health and well-being. Findings from the assessment indicate a shared interest among leaders and residents to embrace a holistic strategy for health and well-being in the county. Inefficient uses of the health care system are identified, highlighting a need to rebalance investments in health care use and drivers of health. Additionally, challenges in navigating health and human services and inequities in drivers of health across communities are noted, signaling broader concerns related to residents' access to health and human services that influence health and well-being outcomes. Recommendations are provided for several paths forward for the county to pursue a more integrated policy approach to influence health and well-being outcomes.-- Source other than the Library of Congress."], "digitized": true, "extract_timestamp": "2026-07-04T14:14:40.117Z", "group": ["gdc/scd", "catalog-split-05", "catalog", "general-collections-scan-on-demand-new", "main-catalog-split-05"], "hassegments": false, "id": "http://www.loc.gov/item/2024739262/", "image_url": ["https://tile.loc.gov/storage-services/master/gdc/gdcebookspublic/20/24/73/92/62/2024739262/2024739262.gif", "https://tile.loc.gov/storage-services/master/gdc/gdcebookspublic/20/24/73/92/62/2024739262/2024739262.gif#h=401&w=310"], "index": 19, "language": ["english"], "location": ["maryland", "prince george's county"], "mime_type": ["image/gif", "application/pdf"], "number": ["2026-07-01t13:55:48.900000", "2024739262", "online resource"], "online_format": ["image", "pdf"], "original_format": ["book"], "partof": ["general collections", "catalog"], "score": 34.207603, "shelf_id": "RA407.4.M4", "site": ["catalog"], "subject": ["maryland", "health services accessibility", "statistics, medical", "prince george's county", "prince george's county (md.)", "medical statistics", "public health", "health surveys"], "timestamp": "2026-07-04T14:17:26.713Z", "title": "Assessing Health and Human Services needs to support an integrated Health in All Policies plan for Prince George's County, Maryland", "type": ["text"], "url": "https://www.loc.gov/item/2024739262/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2024739172", "http://www.loc.gov/item/2024739172/", "https://search.catalog.loc.gov/instances/d2d0b04f-b426-5e86-a75e-d096c1cd0139", "https://hdl.loc.gov/loc.gdc/gdcebookspublic.2024739172", "http://www.loc.gov/resource/gdcebookspublic.2024739172/"], "campaigns": [], "contributor": ["gahlon, grace", "king, christopher j.", "kranz, ashley m.", "chandra, anita", "rand social and economic well-being (program)", "blanchard, janice c.", "rand corporation", "madrigano, jaime", "ruder, teague"], "date": "2021", "dates": ["2021"], "description": ["With evolving demographics and a changing health system landscape, the Prince George's County Council, acting as the County Board of Health, is considering its future policy approaches and resource allocations related to health and well-being. To inform this path forward, the authors of this report used primary and secondary data to describe both the health needs of county residents and drivers of health within the county, inclusive of the social, economic, built, natural, and health service environments. This report integrates these findings, an analysis of budget documents, and a review of promising practices from other communities to situate recommendations in a Health in All Policies framework to foster aligned and integrated planning and budgeting across the county to promote health and well-being. Findings from the assessment indicate a shared interest among leaders and residents to embrace a holistic strategy for health and well-being in the county. Inefficient uses of the health care system are identified, highlighting a need to rebalance investments in health care use and drivers of health. Additionally, challenges in navigating health and human services and inequities in drivers of health across communities are noted, signaling broader concerns related to residents' access to health and human services that influence health and well-being outcomes. Recommendations are provided for several paths forward for the county to pursue a more integrated policy approach to influence health and well-being outcomes."], "digitized": true, "extract_timestamp": "2026-07-04T14:14:48.884Z", "group": ["gdc/scd", "catalog-split-05", "catalog", "general-collections-scan-on-demand-new", "main-catalog-split-05"], "hassegments": false, "id": "http://www.loc.gov/item/2024739172/", "image_url": ["https://tile.loc.gov/storage-services/master/gdc/gdcebookspublic/20/24/73/91/72/2024739172/2024739172.gif", "https://tile.loc.gov/storage-services/master/gdc/gdcebookspublic/20/24/73/91/72/2024739172/2024739172.gif#h=401&w=310"], "index": 20, "language": ["english"], "location": ["maryland", "prince george's county"], "mime_type": ["image/gif", "application/pdf"], "number": ["2026-07-01t13:55:49.600000", "2024739172", "online resource"], "online_format": ["image", "pdf"], "original_format": ["book"], "partof": ["general collections", "catalog"], "score": 34.207603, "shelf_id": "RA407.4.M4", "site": ["catalog"], "subject": ["maryland", "health services accessibility", "statistics, medical", "prince george's county", "prince george's county (md.)", "medical statistics", "public health", "health surveys"], "timestamp": "2026-07-04T14:17:14.055Z", "title": "Assessing Health and Human Services needs to support an integrated Health in All Policies plan for Prince George's County, Maryland", 