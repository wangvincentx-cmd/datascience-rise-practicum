930-01-30/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/99614629", "http://www.loc.gov/item/99614629/", "https://hdl.loc.gov/loc.pnp/ppmsc.01904", "http://www.loc.gov/resource/ppmsc.01904/", "http://www.loc.gov/pictures/collection/ffcarp/item/99614629/", "http://www.loc.gov/pictures/item/99614629/"], "campaigns": [], "date": "1900-01-01", "dates": ["1900"], "description": ["Title transcribed from caption accompanying item. Forms part of: Frank and Frances Carpenter collection (Library of Congress). Gift; Mrs. W. Chapin Huntington; 1951."], "digitized": true, "extract_timestamp": "2022-11-29T18:38:17.616Z", "group": ["pp/mtfront", "ffcarp", "catalog-split-14", "catalog", "meeting-of-frontiers-prints-and-photographs", "carpenter", "main-catalog-split-14", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/99614629/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppmsc/01900/01904_150px.jpg#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/ppmsc/01900/01904t.gif#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/ppmsc/01900/01904r.jpg#h=511&w=640", "https://tile.loc.gov/storage-services/service/pnp/ppmsc/01900/01904v.jpg#h=818&w=1024"], "index": 4, "language": ["english"], "location": ["united states", "seward", "alaska"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["99614629", "http://www.loc.gov/item/12218036", "2007-01-17t10:46:43", "http://www.loc.gov/item/cap1999000349/pp", "http://www.loc.gov/item/99614629"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "carpenter collection", "prints and photographs division", "meeting of frontiers", "lot 11453", "catalog"], "score": 35.327488, "shelf_id": "LOT 11453-1, no. 349", "site": ["catalog", "pictures"], "subject": ["seward (alaska)", "mountains", "aerial views", "united states", "seward", "bodies of water", "cities & towns", "photographic prints", "alaska"], "timestamp": "2022-11-29T19:59:39.362Z", "title": "[Aerial view of Seward]", "type": ["still image"], "url": "https://www.loc.gov/item/99614629/"}, {"access_restricted": false, "aka": ["http://www.dggs.alaska.gov/webpubs/dggs/ri/text/ri2010%5F001.PDF", "http://www.dggs.alaska.gov/webpubs/dggs/ri/oversized/ri2010%5F001%5Fsh002.PDF", "http://lccn.loc.gov/2010532470", "http://www.loc.gov/item/2010532470/", "http://www.dggs.alaska.gov/webpubs/dggs/ri/oversized/ri2010%5F001%5Fsh003.PDF", "http://www.arlis.org/docs/vol1/B/645463739/index.html", "http://www.dggs.alaska.gov/webpubs/dggs/ri/oversized/ri2010%5F001%5Fsh001.PDF"], "campaigns": [], "contributor": ["nicolsky, dmitry j.", "alaska. division of geological and geophysical surveys", "hansen, roger a.", "alaska earthquake information center", "west, d. a.", "suleimani, e. n.", "combellick, r. a."], "date": "2010", "dates": ["2010"], "description": ["The purpose of this study is to evaluate tsunami hazard for the community of Seward and northern Resurrection Bay area, Alaska. This report will provide guidance to local emergency managers in tsunami hazard assessment. We used a numerical modeling method to estimate the extent of inundation by tsunami waves generated from earthquake and landslide sources. Our tsunami scenarios included a repeat of the tsunami of the 1964 Great Alaska Earthquake, as well as tsunami waves generated by two hypothetical Yakataga Gap earthquakes in northeastern Gulf of Alaska, hypothetical earthquakes in Prince William Sound and Kodiak asperities of the 1964 rupture, and local underwater landslides in Resurrection Bay. Results of numerical modeling combined with historical observations in the region are intended to help local emergency officials with evacuation planning and public education for reducing future tsunami risk."], "digitized": true, "extract_timestamp": "2023-06-02T20:42:02.750Z", "group": ["catalog-split-08", "catalog", "main-catalog-split-08", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2010532470", "image_url": [], "index": 5, "language": ["english"], "location": ["resurrection bay", "seward", "alaska"], "number": ["2010532470", "2010-12-29t12:38:35", "n645463739"], "original_format": ["book"], "partof": ["catalog"], "score": 34.040012, "shelf_id": "http://lccn.loc.gov/2010532470", "site": ["catalog"], "subject": ["seward (alaska)", "mathematical models", "tsunamis", "seward", "research", "earthquake hazard analysis", "remote-sensing maps", "resurrection bay", "resurrection bay (alaska)", "alaska"], "timestamp": "2023-07-14T00:27:16.101Z", "title": "Tsunami inundation maps of Seward and northern Resurrection Bay, Alaska", "type": ["text"], "url": "//lccn.loc.gov/2010532470"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/99614331", "http://www.loc.gov/item/99614331/", "https://hdl.loc.gov/loc.pnp/ppmsc.01606", "http://www.loc.gov/resource/ppmsc.01606/", "http://www.loc.gov/pictures/collection/ffcarp/item/99614331/", "http://www.loc.gov/pictures/item/99614331/"], "campaigns": [], "date": "1900-01-01", "dates": ["1900"], "description": ["Title transcribed from caption accompanying item. Photo by Gordons. Forms part of: Frank and Frances Carpenter collection (Library of Congress). Gift; Mrs. W. Chapin Huntington; 1951."], "digitized": true, "extract_timestamp": "2022-11-29T18:37:58.247Z", "group": ["pp/mtfront", "ffcarp", "catalog-split-04", "catalog", "meeting-of-frontiers-prints-and-photographs", "carpenter", "main-catalog-split-04", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/99614331/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppmsc/01600/01606_150px.jpg#h=91&w=150", "https://tile.loc.gov/storage-services/service/pnp/ppmsc/01600/01606t.gif#h=91&w=150", "https://tile.loc.gov/storage-services/service/pnp/ppmsc/01600/01606r.jpg#h=390&w=640", "https://tile.loc.gov/storage-services/ser