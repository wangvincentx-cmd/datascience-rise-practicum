": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/in", "indiana-state-library-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn86058226/1920-09-21/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_everettcase_ver01:data:sn86058226:00271745333:1920092101:0583/full/pct:6.25/0/default.jpg#h=479&w=370", "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_everettcase_ver01:data:sn86058226:00271745333:1920092101:0583/full/pct:12.5/0/default.jpg#h=958&w=740"], "index": 12, "item": {"batch": ["in_everettcase_ver01"], "call_number": ["Newspaper", "AN"], "contributor_names": ["Indiana State Library"], "created_published": ["Richmond, Ind., September 21, 1920"], "date": "1907", "date_issued": "1920-09-21", "dates": ["1920-09-21"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn86058226", "location": ["Richmond (Ind.)", "Wayne County (Ind.)", "Indiana--Richmond", "Indiana--Wayne County"], "medium": "12 pages", "newspaper_title": ["The Richmond palladium and sun-telegram"], "notes": ["Daily", "Vol. 31, no. 363 (Mar. 17, 1907)-v. 109, no. 6 (Jan. 7, 1939).", "Publisher's name from Miller, John W. Indiana newspaper bibliog.", "Issue called: 100th Anniversary ed., Jan. 1, 1931.", "Progressive party paper; opposed the Ku Klux Klan and the Republican party. Cf. Miller.", "Issues for Mar. 17-29, 1907 were numbered: v. 31, no. 363--as were all issues of the preceding title dating back to Feb. 16, 1907. Mar. 30, 1907 issue is numbered, v. 32, no. 78.", "There was a special supplement published on Jan. 1, 1931 which celebrated the 100th anniversary of the paper.", "Archived issues are available in digital format from the Library of Congress Chronicling America online collection.", "Formed by the merger of: Farm palladium, Richmond palladium (Richmond, Ind. : 1906