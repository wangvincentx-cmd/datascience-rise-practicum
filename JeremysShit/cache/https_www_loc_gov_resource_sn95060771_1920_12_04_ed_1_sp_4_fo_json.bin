Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271970/", "image_url": [], "index": 6, "language": ["english"], "location": ["arizona", "pima", "united states", "tucson", "pima county"], "number": ["2026-04-13t21:30:13", "2692-6857", "2020271971", "online resource", "2020271970", "1160169469"], "original_format": ["newspaper"], "other_title": ["Daily citizen"], "partof": ["arizona daily citizen (tucson, pima county, arizona territory) 1884-1901 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["daily"], "score": 48.069946, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["arizona", "pima", "tucson (ariz.)", "united states", "tucson", "pima county (ariz.)", "newspapers", "pima county"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "Arizona daily citizen", "type": ["title"], "url": "https://www.loc.gov/item/2020271970/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271971/"], "campaigns": [], "date": "1901", "dates": ["[1901 TO 1928]"], "description": ["Daily, Dec. 3, 1911-Dec. 31, 1928 Began with volume XXXVII, number 48 (December 16, 1901); ceased December 31, 1928. Republican. Cf. Ayer, 1928. Numbering is irregular. Also issued on microfilm from the Library of Congress, Photoduplication Service. Weekly eds.: Arizona weekly citizen, 1901, and: Arizona citizen (Tucson, Ariz. : 1902) and Arizona citizen and weekly tribune. Description based on: Volume XXXVII, number 48 (December 16, 1901); title from masthead (Chroniclingamerica.loc.gov, viewed June 28, 2020). Latest issue consulted: Volume XXXVIII, Number 43 (December 8, 1902) (Chroniclingamerica.loc.gov, viewed June 28, 2020). Tucson daily citizen"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:53.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "i