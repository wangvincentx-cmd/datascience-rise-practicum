regon", "publication_frequency": ["daily"], "raw_lccn": "sn 85042400 ", "reel_numbers": ["00271740190"], "resources": [{"files": 8, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:oru:batch_oru_reed_ver02:data:sn85042400:00271740190:1907102301:0160/full/pct:6.25/0/default.jpg", "url": "https://www.loc.gov/resource/sn85042400/1907-10-23/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.844794, "shard": "06", "shelf_id": "sn85042400, 1907-10-23, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/oru", "source_modified": "2000-01-01T12:00:00Z", "subject": ["astoria", "united states", "oregon", "astoria (or.)", "newspapers", "clatsop"], "subject_headings": ["Astoria (Or.)--Newspapers", "Oregon--Astoria", "United States--Oregon--Clatsop--Astoria"], "subjects": [{"astoria": "https://www.loc.gov/search/?fa=subject:astoria&fo=json"}, {"astoria (or.)": "https://www.loc.gov/search/?fa=subject:astoria+%28or.%29&fo=json"}, {"clatsop": "https://www.loc.gov/search/?fa=subject:clatsop&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"oregon": "https://www.loc.gov/search/?fa=subject:oregon&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2024-07-16T06:17:57.101Z", "title": "The morning Astorian (Astoria, Oregon), October 23, 1907", "type": ["issue"], "url": "https://www.loc.gov/item/sn85042400/1907-10-23/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn85042400/", "http://lccn.loc.gov/sn85042400"], "batch": ["oru_ashland_ver01"], "campaigns": [], "date": "1899", "description": ["Daily (except Mon.) Vol. 50, no. 83 (Sept. 2, 1899)-57th yr., no. 30 (Aug. 31, 1930). Some irregularities in numbering. Issues for Dec. 7-31, 1903 also carry vol. numbering for absorbed title, Astoria daily news. Also issued on microfilm from University of Oregon. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Other eds.: Weekly Astorian, 1899-<1901>, and: Astorian (Astoria, Or.), <1904-1905> Merged with: Astoria evening budget, to form: Evening Astorian-budget. Astoria evening budget (DLC)sn 96088012 (OCoLC)36853050 Evening Astorian-budget (DLC)sn 85042447 (OCoLC)12429955"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:11.942Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-08", "catalog", "united-states-newspaper-directory", "main-catalog-split-08"], "hassegments": false, "id": "http://www.loc.gov/item/sn85042400/", "image_url": [], "index": 3, "language": ["english"], "latlong": [46.1890904, -123.8347121], "location": ["united states", "astoria", "oregon", "clatsop"], "location_str": "", "lonlat": [-123.8347121, 46.1890904], "number": ["original", "sn96088012", "2024-06-05t12:26:16.235228", "2026-04-13t21:30:13", "3076", "http://www.loc.gov/item/sn85042400/1909-05-19/ed-1/", "kansas state hist soc, newsp proj", "12351987", "sn96088016", "2025-06-25t14:23:08", "sn96061150", "online resource", "microfilm master", "univ of oregon libr", "http://www.loc.gov/item/sn85042400/1899-09-02/ed-1/", "sn84022646", "1", "sn85042400", "sn96088013", "library of congress", "2373-3497", "microfilm service copy", "sn85042447"], "original_format": ["newspaper"], "other_title": ["Sunday issues for Dec. 22, 1918-Aug. 31, 1930 called: Sunday morning Astorian", "Issue for Dec. 7, 1903 called: Daily Astorian and daily news", "Issues for Dec. 8-31, 1903 called: Daily Astorian and Astoria daily news", "Daily Astorian"], "partof": ["chronicling america", "the morning astorian (astoria, oregon) 1899-1930", "directory of u.s. newspapers in american libraries", "serial and government publications division", "catalog"], "publication_frequency": ["daily"], "score": 58.310364, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["astoria", "united states", "oregon", "serial publications", "astoria (or.)", "newspapers", "clatsop"], "timestamp": "2026-07-18T09:15:53.161Z", "title": "The morning Astorian", "type": ["title"], "url": "https://www.loc.gov/item/sn85042400/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018270591/"], "campaigns": [], "contributor": ["heikkinen, knut"], "date": "188?", "dates": ["[1880 TO 1934]"], "description": ["Triweekly, syyskuun 2 p., 1926-<huhtikuun 25 p., 1931> Ceased in 1934? Title also in English: New homeland. Editors: 1881-1892, August Nylund; 1892- Felix Nylund; K. E. Heikkinen, <1923>. Published in: Minneapolis, Minn., 1881-1884; Astoria, Or., 1888-1890; Superior, Wis. 1931-<1934>. Publisher: 1919- Peoples' Voice Cooperative Pub. Co. \"Oldest Finnish Newspaper in the United States.\" Available on microfilm from The State Historical Society of Wisconsin and the Minnesota Historical Society. In Finnish. Description based on: 25:des vuosik., N:o 2 (January 11, 1906); title from masthead (Chroniclingamerica.loc.gov, viewed December 19, 2018). Latest issue consulted: Vol 41, No. 101 (December 26, 1922) (Chroniclingamerica.loc.gov, viewed December 19, 2018)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:46.349Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018270591/", "image_url": [], "index": 4, "language": ["finnish"], "location": ["minneapolis", "astoria", "otter tail county", "new york mills", "douglas county", "wisconsin", "united states", "oregon", "superior", "hennepin", "minnesota", "otter tail", "douglas", "clatsop"], "number": ["2026-04-13t21:30:13", "2018270591", "2641-001x", "online resource", "1079419589"], "original_format": ["newspaper"], "other_title": ["New homeland"], "partof": ["serial and government publications division", "uusi kotimaa (new york mills, minn.) 188?-1934 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["triweekly"], "score": 49.13573, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["astoria", "finns", "douglas county (wis.)", "united states", "superior", "finnish americans", "douglas county", "superior (wis.)", "hennepin", "astoria (or.)", "minneapolis (minn.)", "otter tail county (minn.)", "new york mills", "wisconsin", "oregon", "minnesota", "clatsop", "minneapolis", "otter tail county", "finnish", "newspapers", "otter tail", "new york mills (minn.)", "douglas"], "timestamp": "2026-05-26T20:57:23.162Z", "title": "Uusi kotimaa", "type": ["title"], "url": "https://www.loc.gov/item/2018270591/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218385/"], "campaigns": [], "date": "1899", "dates": ["[1899 TO 1930]"], "description": ["Daily (except Mon.) Began with vol. L, no. 83 (September 2, 1899)-57th yr., no. 30 (Aug. 31, 1930). Some irregularities in numbering. Issues for Dec. 7-31, 1903 also carry vol. numbering for absorbed title, Astoria daily news. Other eds.: Weekly Astorian (Astoria, Or. : 1874), 1899-<1901>, and: Astorian (Astoria, Or.), <1904-1905> Merged with: Astoria evening budget, to form: Evening Astorian-budget. Vol. L, no. 83 (September 2, 1899); title from masthead (Chroniclingamerica.loc.gov, viewed June 4, 2014). Vol. LIV, no. 179 (February 7, 1902) (Chroniclingamerica.loc.gov, viewed June 4, 2014). Astoria evening budget Evening Astorian-budget"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:26.498Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218385/", "image_url": [], "index": 5, "language": ["english"], "location": ["united states", "astoria", "oregon", "clatsop"], "number": ["2026-04-13t21:30:13", "2018260019", "2373-3500", "2014218385", "online resource", "880930474"], "original_format": ["newspaper"], "other_title": ["Sunday issues for Dec. 22, 1918-Aug. 31, 1930 called: Sunday morning Astorian", "Issue for Dec. 7, 1903 called: Daily Astorian and daily news", "Issues for Dec. 8-31, 1903 called: Daily Astorian and Astoria daily news", "Daily Astorian"], "partof": ["the morning astorian (astoria, oregon) 1899-1930 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["daily"], "score": 49.13573, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["astoria", "united states", "oregon", "serial publications", "astoria (or.)", "newspapers", "journaux", "clatsop"], "timestamp": "2026-05-26T20:50:11.310Z", "title": "The morning Astorian", "type": ["title"], "url": "https://www.loc.gov/item/2014218385/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2015270873/"], "campaigns": [], "contributor": ["mattson, helmi,", "nurmi, maiju,", "jokela-mccone, selma,"], "date": "19??", "dates": ["[1900 TO 1930]"], "description": ["Weekly Ceased with 20 vuosik., no. 40 (Syyskuun 30 p., 1930). Publisher varies. Editors: Selma Jokela-McCone, <November 9, 1915>-November 13, 1917; Maiju Nurmi, February 26, 1918-March 9, 1920; Helmi Mattson, May 18, 1920-April 4, 1922. Volumes for Nov. 27 1929- also bear volume numbering in English. Title, publication information, and date in masthead in Finnish and English; text in Finnish. 5 vuosik., no. 45 (Marrask. 9 P., 1915); title from masthead (Chroniclingamerica.loc.gov, viewed February 17, 2016). Vuosik., no. 52 (26 p., December 26, 1922) (Chroniclingamerica.loc.gov, viewed February 17, 2016)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:34.166Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2015270873/", "image_url": [], "index": 6, "language": ["finnish"], "location": ["west united states", "astoria", "united states", "oregon", "clatsop"], "number": ["2026-04-13t21:30:13", "2470-9158", "2015270873", "939559050", "online resource"], "original_format": ["newspaper"], "other_title": ["Tove ritar", "Editorial box has title also in English: Woman comrade"], "partof": ["toveritar (astoria, ore.) 19??-1930 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 49.13573, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["west united states", "west (u.s.)", "astoria", "finnish american women", "women communists", "united states", "finnish american communists", "oregon", "seria