32/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ohi/batch_ohi_myrtle_ver01/data/56022775/00541313400/1949062701/0136.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/56022775/1949-06-27/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_myrtle_ver01/data/56022775/00541313400/1949062701/0136.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_myrtle_ver01:data:56022775:00541313400:1949062701:0132/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ohi/batch_ohi_myrtle_ver01/data/56022775/00541313400/1949062701/0136.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/56022775/1949-06-27/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ohi/batch_ohi_myrtle_ver01/data/56022775/00541313400/1949062701/0136.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/56022775/1949-06-27/ed-1/?sp=5"], "batch": ["ohi_myrtle_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/ohio/", "2/united states/ohio/cuyahoga/", "3/united states/ohio/cuyahoga/cleveland/", "1/united states/indiana/", "2/united states/indiana/marion/", "3/united states/indiana/marion/indianapolis/"], "contributor": ["ohio history connection, columbus, oh"], "date": "1949-06-27", "dates": ["1949-06-27"], "description": ["BRT Reaps Benefits on 4 Properties ADA Calls for Action to Halt Economy Slides Charles LaFollette Indiana Liberal Is Appointed Director WASHINGTON Ameri cans for Democratic Action swung into the battle for al leviating the dangerous tend encies toward recession in American economy as a plan for action was outlined at an executive board meeting and a liberal national director was named A warning was sent President Truman and his Council of Eco nomic Advisors that it would be incredible folly if the nations leaders avoided the danger signs showing that all is not well Charles LaFollette former lib eral Republican congressman from Indiana accepted the post of national director and will head ADAs drive for membership and guide electoral activities Gets Unanimous OK Taking office July 1 his selection for the job won unanimous ap proval from ADA executives La Follette said he agrees with ADAs policy of supporting progressive legislators in both major parties He describes himself as an inde pendent He resigned from a post as gov ernor of WuertembergBadenone of the three states in the Ameri can Zone of Germanyafter a clash with U S Commander Gen Lucius Clay over an increasingly antilabor drift in policy"], "digitized": true, "extract_timestamp": "2025-09-14T05:41:39.821Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/56022775/1949-06-27/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_myrtle_ver01:data:56022775:00541313400:1949062701:0136/full/pct:6.25/0/default.jpg#h=322&w=220", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_myrtle_ver01:data:56022775:00541313400:1949062701:0136/full/pct:12.5/0/default.jpg#h=644&w=440", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_myrtle_ver01/data/56022775/00541313400/1949062701/0136.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["indiana", "marion", "ohio", "indianapolis", "united states", "cuyahoga", "cleveland"], "location_city": ["cleveland", "indianapolis"], "location_country": ["united states"], "location_county": ["cuyahoga", "marion"], "location_state": ["ohio", "indiana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", 