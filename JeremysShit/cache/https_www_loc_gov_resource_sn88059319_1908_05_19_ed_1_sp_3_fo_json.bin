, "id": "http://lccn.loc.gov/2022363356", "image_url": [], "index": 5, "language": ["english"], "location": ["nebraska", "howard county", "howard"], "number": ["n1231560700", "2022363356", "2023-11-09t11:18:28"], "original_format": ["book"], "partof": ["catalog"], "score": 16.883862, "shelf_id": "F672.H8 H57 2020", "site": ["catalog"], "subject": ["historic buildings", "historic sites", "howard county", "lieux historiques", "history", "howard county (neb.)", "nebraska", "howard"], "timestamp": "2023-11-11T09:24:53.125Z", "title": "A historic survey of Howard County, Nebraska", "type": ["text"], "url": "//lccn.loc.gov/2022363356"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/04036331", "http://www.loc.gov/item/04036331/", "https://catalog.hathitrust.org/Record/100555603"], "campaigns": [], "contributor": ["mcclain, emlin", "calvin, samuel", "state historical society of iowa", "hobby, cicero mead", "pickard, josiah little"], "date": "1893", "dates": ["1893"], "digitized": true, "extract_timestamp": "2024-02-09T09:47:11.217Z", "group": ["catalog-split-04", "catalog", "main-catalog-split-04"], "hassegments": false, "id": "http://lccn.loc.gov/04036331", "image_url": [], "index": 6, "language": ["english"], "location": ["iowa"], "number": ["04036331", "2024-02-07t11:35:36"], "original_format": ["book"], "partof": ["catalog"], "score": 15.646871, "shelf_id": "F616 .I72", "site": ["catalog"], "subject": ["iowa", "law", "louisiana purchase", "antiquities", "iowa indians"], "timestamp": "2024-02-09T09:48:27.824Z", "title": "Iowa historical lectures", "type": ["text"], "url": "//lccn.loc.gov/04036331"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013433203/", "http://lccn.loc.gov/2013433203", "http://www.iowadot.gov/ole/documents/Booklet%20-%20Wever%20Bypass%20Excavations.pdf"], "campaigns": [], "contributor": ["united states. federal highway administration", "iowa. department of transportation", "withrow, randall m.", "louis berger group", "state historical society of iowa"], "date": "2012", "dates": ["2012"], "description": ["This is a story about a highway project near the small town of Wever, Iowa, and an American Indian village that existed at the location prior to the Europeans' arrival. The culture that lived in this village existed in a 10 state region of the Upper Midwest and may have been the ancestors of tribes living in the Midwest when European explorers entered the region. An archaeological recovery of information from the site was undertaken by the Iowa Department of Transportation because four-lane construction of U.S. 61 could not be accomplished without destroying most of the site. This site proved to be one of the richest archaeological finds in the State of Iowa. Iowa Department of Transportation. http://www.iowadot.gov/ole/publications.asp"], "digitized": true, "extract_timestamp": "2023-06-02T18:59:29.336Z", "group": ["catalog-split-05", "catalog", "main-catalog-split-05", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2013433203", "image_url": [], "index": 7, "language": ["english"], "location": ["oneota", "iowa", "united states highway 61", "great river road", "lee county", "ioway"], "number": ["2013-09-05t07:42:49", "2013433203", "n806032887"], "original_format": ["book"], "other_title": ["Highway archaeology along the Great River Road in southeast Iowa"], "partof": ["catalog"], "score": 15.646871, "shelf_id": "E78.I6 W58 2012", "site": ["catalog"], "subject": ["oneota", "native americans", "design and construction", "iowa", "historic sites", "radiocarbon dating", "united states highway 61", "roads", "antiquities", "department of transportation", "lee county", "excavations (archaeology)", "oneota indians (great plains)", "great river road", "ioway", "lee county (iowa)", "archaeology"], "timestamp": "2023-07-07T20:16:00.819Z", "title": "The Wever Bypass excavations : Highway archaeology along the Great River Road in southeast Iowa", "type": ["text"], "url": "//lccn.loc.gov/2013433203"}, {"access_restricted": false, "aka": ["http://www.iowahistory.org/index.html", "http://www.loc.gov/item/2003542944/", "http://lccn.loc.gov/2003542944"], "campaigns": [], "contributor": ["state historical society of iowa"], "date": "2003", "dates": ["2003"], "description": ["Provides access to the activities and offerings of the SHSI. Includes how to get involved, current events, important locations to visit, and educational material."], "digitized": true, "extract_timestamp": "2023-06-02T15:09:26.210Z", "group": ["catalog-split-01", "catalog", "main-catalog-split-01", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2003542944", "image_url": [], "index": 8, "language": ["english"], "location": ["iowa"], "number": ["2003-12-16t15:13:32", "2003542944"], "original_format": ["book"], "partof": ["catalog"], "score": 15.646871, "shelf_id": "F616", "site": ["catalog"], "subject": ["iowa", "historic buildings", "historic sites", "historic preservation", "preservation and restoration", "state historical society of iowa"], "timestamp": "2023-07-07T00:25:24.920Z", "title": "State Historical Society of Iowa", "type": ["text"], "url": "//lccn.loc.gov/2003542944"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iahi/batch_iahi_frawley_ver01/data/sn88059319/00415622892/1908051901/0276.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iahi:batch_iahi_frawley_ver01:data:sn88059319:00415622892:1908051901:0274/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iahi/batch_iahi_frawley_ver01/data/sn88059319/00415622892/1908051901/0276.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn88059319/1908-05-19/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-serv