": "https://www.loc.gov/item/sn88059319/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218985/"], "campaigns": [], "contributor": ["mead, w. r."], "date": "1867", "dates": ["[1867 TO 1895]"], "description": ["Semiweekly, Mar. 27, 1894-1895 Began with vol. VIII, no. 26 (May 17, 1867); ceased April 5, 1895. Imprint varies: <1880>. Editor: W.R. Mead, <1876>, <1886>. Publisher varies. Issues for <Apr. 27, 1893>-Mar. 22, 1894 have alternate masthead with same v. and issue no. but called also whole no. <1746>-1793; end of the week issue only of semiweekly issues for Mar. 27, 1894-Apr. 5, 1895 called also whole no. 1794-1848. Description based on: Vol. VIII, No. 26 (May 17, 1867); title from masthead (Chroniclingamerica.loc.gov, viewed October 10, 2018). Latest issue consulted: Vol. XIV, No. 9 (Dec. 27, 1872) (Chroniclingamerica.loc.gov, viewed October 10, 2018). Twice-a-week plain dealer 2374-6971 (DLC) 2014218483 (OCoLC)887957821"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:44.751Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218985/", "image_url": [], "index": 4, "language": ["english"], "location": ["iowa", "new oregon", "united states", "howard county", "cresco", "howard"], "number": ["2026-04-13t21:30:13", "1056246273", "2018218985", "2018218988", "2639-6335", "online resource", "2014218483"], "original_format": ["newspaper"], "other_title": ["Plain dealer", "Twice a week plain dealer", "Twice-a-week plain dealer"], "partof": ["the iowa plain dealer (new oregon, howard county, iowa) 1867-1895 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["semiweekly"], "score": 52.816624, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["iowa", "new oregon", "cresco (iowa)", "united states", "howard county", "howard county (iowa)", "new oregon (iowa)", "news