rl": null}, {"number": 2, "url": "https://www.loc.gov/resource/sn89065008/1920-09-22/ed-1/?fo=json&sp=2"}, {"number": 3, "url": "https://www.loc.gov/resource/sn89065008/1920-09-22/ed-1/?fo=json&sp=3"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": null, "results": "1 - 1", "to": 1, "total": 4}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn89065008/1920-09-15/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/2016655420", "http://www.loc.gov/item/2016655420/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0129", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0129/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0129_mv07/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0129_ms01/"], "campaigns": [], "contributor": ["crosby, emilye", "greene, freddie", "civil rights history project (u.s.)", "bishop, john melville"], "date": "2015-01-01", "dates": ["2015"], "description": ["Freddie Greene was born in Greenwood, Mississippi on February 15, 1945. She discusses how living in a segregated community exposed her to the early efforts of the Civil Rights Movement. She reflects on her decision to leave Greenwood and attend Dillard University in New Orleans in 1962. Feeling disconnected with the movement, she became a participant in the McComb project during Freedom Summer 1964. After returning to school post-Freedom Summer, she decided to leave and joined the Student Nonviolent Coordinating Committee in 1965. She discusses her involvement working on voting registration and canvassing, as well as her role of working on the switchboard and in finance in SNCC's Atlanta Office."], "digitized": true, "extract_timestamp": "2022-10-04T17:36:09.417Z", "group": ["afc2010039", "catalog-split-15", "catalog", "civil-rights-history-project", "main-catalog-split-15", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2016655420/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0129/afc2010039_crhp0129_mv07.gif", "https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0129/afc2010039_crhp0129_ms01.gif#h=150&w=116"], "index": 1, "language": ["english"], "location": ["mississippi", "mccomb", "washington d.c.", "united states", "jackson", "greenwood"], "mime_type": ["image/gif", "application/pdf", "image/jpeg", "application/x-video"], "number": ["2020-01-23t09:40:22", "2016655420", "online resource"], "online_format": ["image", "pdf", "video"], "original_format": ["film, video"], "partof": ["civil rights history project", "american folklife center", "catalog"], "score": 33.18877, "shelf_id": "http://lccn.loc.gov/2016655420", "site": ["catalog"], "subject": ["oral histories", "civil rights demonstrations", "folk music festivals", "united states", "black power", "greene, freddie", "greene, george", "mississippi", "personal narratives", "filmed interviews", "jr", "jackson", "forman, james", "greenwood", "mccomb", "political aspects", "interviews", "african american civil rights workers", "video recordings", "race relations", "bombings", "greenwood (miss.)", "robinson, ruby doris smith", "civil rights movements", "voter registration", "student nonviolent coordinating committee (u.s.)", "mississippi freedom project", "heffner, albert w.", "history", "carmichael, stokely", "segregation in education"], "timestamp": "2022-10-17T14:38:46.135Z", "title": "Freddie Greene Biddle oral history interview conducted by Emilye Crosby in Washington, DC, District of Columbia, 2015 December 10", "type": ["moving image"], "url": "https://www.loc.gov/item/2016655420/"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2017879271/", "http://www.loc.gov/item/2017879271/", "http://www.loc.gov/pictures/item/2017879271/", "https://www.loc.gov/pictures/collection/highsm/item/2017879271/", "http://www.loc.gov/pictures/collection/highsm/it