], "contributor": ["rutgers university libraries"], "date": "1924-02-06", "dates": ["1924-02-06"], "description": ["Margate Boasts of Beautiful Highway Ventnor Parkway ii Widest Driveway Along Jersey Coast and General Plan Permits of Exceptional Enhancement With Trees By Carl M Voelker Extending nearly half a mile through Margate Park and merg ing with Ventnor Avenue nor mally 80 feet in width Ventnor Parkway is the widest public driveway along the Jersey coast while its unique landscape plan makes it the peer of beautiful drives rivalling the famous Rum son Road along the upper sea board of the State With a width between property lines of 185 feet the highway virtually has three driveways di vided by socalled park islands for grass shrubbery and trees The central driveway which is J MATHIS SON BUILDERS Guatymtee Trust Building Atlantic City When You Want the BestWeXsk Your Consideration 60 feet wide is now a county road It is expected that within the coming year the street will be improved with permanent paving Contemplated action by Mar gate City Commissioners to lay concrete sidewalks and curbs in front of every lot in Margate where such improvement has not as yet been made has aroused discussion as to the attitude to be taken by the city as touching the curbing"], "digitized": true, "extract_timestamp": "2025-12-01T12:42:00.300Z", "group": ["ndnp/njr", "rutgers-university-libraries-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92059905/1924-02-06/ed-1/?sp=27", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_jackson_ver01:data:sn92059905:00513685889:1924020601:0190/full/pct:6.25/0/default.jpg#h=283&w=243", "https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_jackson_ver01:data:sn92059905:00513685889:1924020601:0190/full/pct:12.5/0/default.jpg#h=566&w=487", "https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_jackson_ver01:data:sn92059905:00513685889:1924020601:0190/full/pct