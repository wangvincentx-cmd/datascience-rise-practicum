ice?segment=/service/ndnp/mnhi/batch_mnhi_caesar_ver01/data/sn91059411/00517011769/1930073101/0270.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_caesar_ver01:data:sn91059411:00517011769:1930073101:0265/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_caesar_ver01/data/sn91059411/00517011769/1930073101/0270.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn91059411/1930-07-31/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_caesar_ver01/data/sn91059411/00517011769/1930073101/0270.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_caesar_ver01:data:sn91059411:00517011769:1930073101:0265/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_caesar_ver01/data/sn91059411/00517011769/1930073101/0270.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn91059411/1930-07-31/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mnhi/batch_mnhi_caesar_ver01/data/sn91059411/00517011769/1930073101/0270.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn91059411/1930-07-31/ed-1/?sp=6"], "batch": ["mnhi_caesar_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/minnesota/", "2/united states/minnesota/kanabec/"], "contributor": ["minnesota historical society; saint paul, mn"], "date": "1930-07-31", "dates": ["1930-07-31"], "description": ["PAGE SIX THE TOWN DOCTOR Doctor of Towns 4 SATS BUSINESS DEPRESSION IS LARGELY A STATE OF MIND There have been given a thousand one reasons by as many experts for the recent falling off of business Twice as many articles have been written and published expounding and giving reasons why for this business depression and easily three times as many speeches and talks have been made before business or ganizations explaining cause and ef fect All of these opinions admit and agree that there is a depression In the face of and irrespective of all this I make so bold as to say that all socalled lack of business this admitted business depression is 90 percent mental and that the elimina tion of the hazard lies in proving that it is mental which requires nothing more than selling 1930 Selling Not selling as it is popular ly construed and thought of not just the motions of one person making transfer of ownership of a product service or thing in exchange for a consideration but 1930 Influenc ing There is no intent to make denial of the fact that as a whole the con sumer is not consuming as he"], "digitized": true, "extract_timestamp": "2024-01-03T23:17:34.315Z", "group": ["ndnp/mnhi", "minnesota-historical-society-saint-paul-mn-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn91059411/1930-07-31/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_caesar_ver01:data:sn91059411:00517011769:1930073101:0270/full/pct:3.125/0/default.jpg#h=293&w=207", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_caesar_ver01:data:sn91059411:00517011769:1930073101:0270/full/pct:6.25/0/default.jpg#h=587&w=414", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_caesar_ver01:data:sn91059411:00517011769:1930073101:0270/full/pct:12.5/0/default.jpg#h=1174&w=828", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_caesar_ver01/data/sn91059411/00517011769/1930073101/0270.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["kanabec", "minnesota", "united states", "kanabec county"], "location_country": ["un