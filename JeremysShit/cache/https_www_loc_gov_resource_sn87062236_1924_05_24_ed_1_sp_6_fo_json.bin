vices/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00064/full/pct:25/0/default.jpg#h=554&w=433"], "index": 6, "language": ["english"], "location": ["alexandria", "united states", "washington metropolitan area", "fairfax county", "virginia", "washington d.c.", "washington", "district of columbia"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2002-11-21t15:38:47"], "online_format": ["image"], "original_format": ["map"], "partof": ["civil war maps", "military battles and campaigns", "american memory", "geography and map division"], "score": 23.137972, "shelf_id": "http://www.loc.gov/item/001-CABIB20005856/", "site": ["ammem"], "subject": ["alexandria", "united states", "civil war", "fairfax county (va.)", "washington metropolitan area", "alexandria (va.)", "virginia", "history", "fairfax county", "washington (d.c.)", "maps", "washington", "district of columbia"], "timestamp": "2022-03-30T06:52:22.796Z", "title": "Map showing positions of Union and Rebel forces Septr 1861.", "url": "https://www.loc.gov/item/gvhs01.vhs00064/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/gvhs01.vhs00032/", "http://www.loc.gov/item/gvhs01.vhs00032/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00032", "http://www.loc.gov/item/001-CABIB20002753/"], "campaigns": [], "contributor": ["sneden, robert knox"], "date": "1861-01-01", "dates": ["1861"], "description": ["Illustrates Alexandria's central position in the defense of Washington, where at least 12 outlying forts surrounded the city. Military camps of various Union officers such as Samuel Peter Heintzelman are indicated on this map."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:09.205Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00032/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00032.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00032.gif#h=192&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00032/full/pct:12.5/0/default.jpg#h=279&w=218", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00032/full/pct:25/0/default.jpg#h=559&w=437"], "index": 7, "language": ["english"], "location": ["alexandria", "united states", "fort lyon", "virginia", "washington d.c.", "washington", "district of columbia"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2001-12-29t15:29:00"], "online_format": ["image"], "original_format": ["map"], "partof": ["american memory", "civil war maps", "military battles and campaigns", "geography and map division"], "score": 23.137972, "shelf_id": "http://www.loc.gov/item/001-CABIB20002753/", "site": ["ammem"], "subject": ["alexandria", "fort lyon (va.)", "united states", "heintzelman, samuel peter", "civil war", "alexandria (va.)", "virginia", "history", "fort lyon", "washington (d.c.)", "maps", "washington", "district of columbia"], "timestamp": "2022-03-30T06:52:22.796Z", "title": "[Map of Alexandria, Virginia]", "url": "https://www.loc.gov/item/gvhs01.vhs00032/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/gvhs01.vhs00256/", "http://www.loc.gov/item/001-CABIB20007590/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00256", "http://www.loc.gov/item/gvhs01.vhs00256/"], "campaigns": [], "contributor": ["sneden, robert knox"], "description": ["As a diversionary measure to take some of the pressure off of besieged Petersburg, Confederate forces under Jubal Early launched a northern offensive beginning in late June 1864. After stops near Harper's Ferry and Shepherdstown, W. Va., and Frederick and Baltimore, Md., they reached the outskirts of Washington, D.C., by July 11. Reconnaissance showed the Union had begun some intensive reinforcement, so an attack planned for July 12 was postponed and then abandoned. Settling for several skirmishes near Fort Stevens, and burning the house of Montgomery Blair (Lincoln's Postmaster General), the Confederates withdrew the night of July 12th and recrossed the Potomac at Leesburg."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:32.232Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00256/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00256.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00256.gif#h=193&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00256/full/pct:12.5/0/default.jpg#h=681&w=530", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00256/full/pct:25/0/default.jpg#h=1363&w=1061"], "index": 8, "language": ["english"], "location": ["united states", "washington d.c.", "maryland", "washington", "district of columbia"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-04-28t12:18:37"], "online_format": ["image"], "original_format": ["map"], "partof": ["civil war maps", "military battles and campaigns", "american memory", "geography and map division"], "score": 23.137972, "shelf_id": "http://www.loc.gov/item/001-CABIB20007590/", "site": ["ammem"], "subject": ["united states", "civil war", "early, jubal anderson", "homes and haunts", "blair, montgomery", "history", "washington (d.c.)", "maryland", "maryland campaign", "maps", "washington", "district of columbia"], "timestamp": "2022-03-30T06:52:35.344Z", "title": "Plan of the Rebel attack on Washington, D.C., July 11th and 12th, 1864.", "url": "https://www.loc.gov/item/gvhs01.vhs00256/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/glva01.lva00044/", "http://www.loc.gov/item/lva0000044/", "https://hdl.loc.gov/loc.ndlpcoop/glva01.lva00044"], "campaigns": [], "contributor": ["united states coast survey", "bache, a. d. (alexander dallas)"], "date": "1862-01-01", "dates": ["1862"], "description": ["Chart of the Potomac River from Washington, D.C. to its entrance into the Chesapeake Bay. Chart indicates soundings, tides, lighthouses, and the shoreline configuration. Description derived from published bibliography. Maps numbered 20-23 in upper left corners. Seal of U.S. Coast Survey Office printed below the map title. Similar to no. 35.2, LC Civil War maps (2nd ed.) This item is in the Map Collection of the Library of Virginia; please contact the Library's Archives Research Services department for more information. Swem, E.G. Maps relating to Virginia, 989-991, 1151 Available also through the Library of Congress web site as raster image. June 2002; L.S. Straight, June 1970, cd, Map Cataloging Team. Civil War Map Proj. no.: LVA00044. Conservation: Etherington Conservation Center, April 2002. Digital image available: 39 x 24 in. or smaller. Map accession no.: 3017 (1970) Previously filed as: 755.23 H9 1862-1864."], "digitized": true, "extract_timestamp": "2020-09-23T17:20:44.449Z", "group": ["gmd_lva.mar", "library-of-virginia-maps"], "hassegments": false, "id": "http://www.loc.gov/item/lva0000044/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00044.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00044.gif#h=150&w=557", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00044/full/pct:12.5/0/default.jpg#h=944&w=3508", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00044/full/pct:25/0/default.jpg#h=1888&w=7016"], "index": 9, "language": ["english"], "location": ["united states", "potomac river estuary", "potomac river", "washington d.c.", "washington", "district of columbia"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2002-07-10t09:31:44", "lva0000044"], "online_format": ["image"], "original_format": ["map"], "partof": ["civil war maps", "military battles and campaigns", "american memory", "geography and map division"], "score": 23.137972, "shelf_id": "http://www.loc.gov/item/lva0000044/", "site": ["ammem"], "subject": ["nautical charts", "united states", "washington", "potomac river estuary", "harbors", "washington (d.c.)", "maps", "potomac river", "district of columbia"], "timestamp": "2022-04-30T03:06:42.687Z", "title": "Potomac River (in four sheets)", "url": "https://www.loc.gov/item/lva0000044/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/lva0000020/", "http://www.loc.gov/resource/glva01.lva00020/", "https://hdl.loc.gov/loc.ndlpcoop/glva01.lva00020"], "campaigns": [], "contributor": ["united states. war dept. corps of topographical engineers", "schedler, j.", "mcdowell, irvin"], "date": "1862-01-01", "dates": ["1862"], "description": ["Accompanied by sheet: Presented to Brig. Genl. S. Williams, A.A. Genl. Hd. Qrs. Army, by order of Maj. Genl. McClellan, Comd. in Chf. U.S.A. [signed] A.W. Whipple, Maj. T.E. [1] leaf ; 21 x 13 cm. At head of title: Surveys for military defences. Includes \"Data used in compilation,\" table of \"Elevations above tide water,\" and \"Geological profile of Loudoun County.\" Mounted on cloth backing. Relief shown by hachures. Depths shown by soundings. Shows forts and batteries in the District of Columbia and immediate vicinity. Similar to no. 1005, Swem, C.E. Maps relating to Virginia. This item is in the Map Collection of the Library of Virginia; please contact the Library's Archives Research Services department for more information. LC Civil War maps (2nd ed.), 466 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2020-09-23T17:20:44.449Z", "group": ["gmd_lva.mar", "library-of-virginia-maps"], "hassegments": false, "id": "http://www.loc.gov/item/lva0000020/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00020.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00020.gif#h=201&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00020/full/pct:12.5/0/default.jpg#h=2158&w=1612", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00020/full/pct:25/0/default.jpg#h=4317&w=3225"], "index": 10, "language": ["english"], "location": ["united states", "washington metropolitan area", "virginia", "washington d.c.", "washington", "district of columbia"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-03-17t10:25:46", "lva0000020"], "online_format": ["image"], "original_format": ["map"], "partof": ["civil war maps", "military battles and campaigns", "american memory", "geography and map division"], "score": 23.137972, "shelf_id": "G3881.S5 1862 .U5", "site": ["ammem"], "subject": ["united states", "civil war", "washington metropolitan area", "maps, topographic", "virginia", "history", "fortification", "washington (d.c.)", "maps", "washington", "district of columbia"], "timestamp": "2022-04-30T03:06:42.687Z", "title": "Map of n. eastern Virginia and vicinity of Washington", "url": "https://www.loc.gov/item/lva0000020/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/glva01.lva00099/", "http://www.loc.gov/item/lva0000099/", "https://hdl.loc.gov/loc.ndlpcoop/glva01.lva00099"], "campaigns": [], "contributor": ["krebs, charles g.", "w.h. & o.h. morrison (firm)", "nicholson, w. l.", "bache, a. d. (alexander dallas)", "united states coast survey"], "date": "1863-01-01", "dates": ["1863"], "description": ["\"August 1863.\" \"Lith. by Chas. G. Krebs.\" Accompanied by cover: Map of Virginia / compiled in the office of the United States Coast Survey. Washington, D.C. : W.H. & O.H. Morrison : 15 x 10 cm. Also covers Delaware, Maryland, West Virginia and parts of adjacent states. Shows cities and towns, roads, rivers, and relief by hachures. Map has concentric circles centered on Richmond, Virginia and Washington, D.C. Includes table: Distances by railroads. Relief shown by hachures. Similar to no. 465.45 (1862), LC Civil War maps (2d ed.) This item is in the Map Collection of the Library of Virginia; please contact the Library's Archives Research Services department for more information. Available also through the Library of Congress web site as raster image. c.1, Jan. 1952, Argosy Book Store, h; c. 2, 1961 photocopy, LVA; Feb. 2003, Map Cataloging Team. C. 1, map accession no. 1462 (1952); c. 2 (negative photostat, LVA, 1961, approx. 16 x 23 1/2 in.), map accession no. 1844 (1961). Civil War project no.: lva00099. Conservation: copy 1 restored May 1961; Etherington Conservation Center, Dec. 2002. Digital image available: 23 x 34 3/4 in. Previously filed as: 755 R15 1863."], "digitized": true, "extract_timestamp": "2020-09-23T17:20:46.603Z", "group": ["gmd_lva.mar", "library-of-virginia-maps"], "hassegments": false, "id": "http://www.loc.gov/item/lva0000099/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00099.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00099.gif#h=150&w=226", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00099/full/pct:12.5/0/default.jpg#h=908&w=1368", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00099/full/pct:25/0/default.jpg#h=1816&w=2736"], "index": 11, "language": ["english"], "location": ["atlantic states", "united states", "delaware", "virginia", "washington d.c.", "maryland", "washington", "district of columbia"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-02-21t09:35:44", "lva0000099"], "online_format": ["image"], "original_format": ["map"], "other_title": ["Map of Virginia"], "partof": ["civil war maps", "military battles and campaigns", "american memory", "geography and map division"], "score": 23.137972, "shelf_id": "http://www.loc.gov/item/lva0000099/", "site": ["ammem"], "subject": ["atlantic states", "united states", "delaware", "civil war", "virginia", "history", "washington (d.c.)", "maryland", "maps", "washington", "district of columbia"], "timestamp": "2022-04-30T03:06:42.687Z", "title": "Map of the state of Virginia", "url": "https://www.loc.gov/item/lva0000099/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_arneaux_ver02/data/sn87062236/00542863766/1924052401/0158.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_arneaux_ver02:data:sn87062236:00542863766:1924052401:0153/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/dlc/batch_dlc_arneaux_ver02/data/sn87062236/00542863766/1924052401/0158.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_arneaux_ver02/data/sn87062236/00542863766/1924052401/0158.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_arneaux_ver02:data:sn87062236:00542863766:1924052401:0153/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/dlc/batch_dlc_arneaux_ver02/data/sn87062236/00542863766/1924052401/0158.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/dlc/batch_dlc_arneaux_ver02/data/sn87062236/00542863766/1924052401/0158.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?sp=6"], "batch": ["dlc_arneaux_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/district of columbia/", "3/united states/district of columbia/washington/"], "contributor": ["library of congress, washington, dc"], "date": "1924-05-24", "dates": ["1924-05-24"], "description": ["PAGE SIX THE ASHINGTON TRIBUNE Published Weekly at Washington D by THE WASHINGTON TRIBUNE PUBLISHING Co Inc 920 U Street NW Phone Potomac 1667 Entered as secondclass matter July 7 1922 at the Post Office at Washington D C under the Act of March 3 1879 F MORRIS MURRAY President WILLIAM 0 WALKER Managing Editor J A G Lu VALLE City Editor Subscription Rate One Year 250 Six Months 125 Delivered by Carrier 20c a month For Sale at All Newsstands 5c per copy Advertising Rates Furnished on Request THE NEGROS BUSINESS OUTLOOK A visitor here from Cincinnati this week was lamenting the lack of Negro business enterprises in his city as compared with those of Washington Yet we cannot pride ourselves on any thing like the number and quality of business establishments that a population of 112324 people would warrant Then the ques tion is Why not Theres a reason As an imitator of the follies and pleasures of the white man we grade up to a high per cent As imitators of the white mans efficiency in commercial and industrial ideas we grade very low There are certain essential qualities which the successful busi ness man must possess"], "digitized": true, "extract_timestamp": "2024-02-04T01:34:11.635Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8"], "hassegments": false, "id": "http://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_arneaux_ver02:data:sn87062236:00542863766:1924052401:0158/full/pct:3.125/0/default.jpg#h=267&w=212", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_arneaux_ver02:data:sn87062236:00542863766:1924052401:0158/full/pct:6.25/0/default.jpg#h=535&w=425", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_arneaux_ver02:data:sn87062236:00542863766:1924052401:0158/full/pct:12.5/0/default.jpg#h=1070&w=851", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_arneaux_ver02/data/sn87062236/00542863766/1924052401/0158.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["united states", "district of columbia", "washington", "washington d.c."], "location_city": ["washington"], "location_country": ["united states"], "location_state": ["district of columbia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0", "2", "4", "7", "1", "8", "sn87062236", "6", "0000000006", "5"], "number_edition": ["1"], "number_lccn": ["sn87062236"], "number_page": ["0000000006"], "number_reel": ["0", "0", "5", "4", "2", "8", "6", "3", "7", "6", "6"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the washington tribune (washington, d.c.) 1921-1946", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the washington tribune (washington, d.c.) 1921-1946"], "publication_frequency": ["semiweekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?sp=6"}], "segmentof": ["http://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/"], "shelf_id": "6", "site": ["chroniclingamerica"], "subject": ["united states", "african american", "washington", "newspapers", "washington (d.c.)", "african americans", "district of columbia"], "subject_ethnicity": ["african american"], "timestamp": "2024-02-04T02:31:50.543Z", "title": "Image 6 of The Washington tribune (Washington, D.C.), May 24, 1924", "type": ["segment"], "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?sp=6"}], "timestamp": 1784748188854, "title_url": "https://www.loc.gov/item/sn87062236", "type": "zoom", "viewer_pagination": {"current": 6, "first": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=1", "from": 6, "last": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=8", "next": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=7", "of": 8, "page_list": [{"number": 1, "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=1"}, {"number": "...", "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=3"}, {"number": 4, "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=4"}, {"number": 5, "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=5"}, {"number": 6, "url": null}, {"number": 7, "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=7"}, {"number": 8, "url": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=8"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=5", "results": "6 - 6", "to": 6, "total": 8}, "views": {"brief": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&st=brief", "current": "single", "epub": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&st=pdf", "gallery": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=1&st=gallery", "grid": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=1&st=grid", "image": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&st=image", "list": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=1&st=list", "pdf": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&st=pdf", "single": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=6", "slideshow": "https://www.loc.gov/resource/sn87062236/1924-05-24/ed-1/?fo=json&sp=1&st=slideshow", "text": "https://www.lo