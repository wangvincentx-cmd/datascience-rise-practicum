ces/iiif/service:ndnp:idhi:batch_idhi_doyle_ver01:data:sn86091100:00415666172:1914022601:0842/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/idhi/batch_idhi_doyle_ver01/data/sn86091100/00415666172/1914022601/0847.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86091100/1914-02-26/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/idhi/batch_idhi_doyle_ver01/data/sn86091100/00415666172/1914022601/0847.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_doyle_ver01:data:sn86091100:00415666172:1914022601:0842/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/idhi/batch_idhi_doyle_ver01/data/sn86091100/00415666172/1914022601/0847.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86091100/1914-02-26/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/idhi/batch_idhi_doyle_ver01/data/sn86091100/00415666172/1914022601/0847.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86091100/1914-02-26/ed-1/?sp=6"], "batch": ["idhi_doyle_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/idaho/", "2/united states/idaho/idaho/", "3/united states/idaho/idaho/grangeville/"], "contributor": ["idaho state historical society"], "date": "1914-02-26", "dates": ["1914-02-26"], "description": ["EDITORIAL PAGE OF THE FREE PRESS IDAHO COUNTY FREE PRES HAROLD HARRIS Local Editor L A WISENER Editor and Proprietor GRANGEVILLE IDAHO THURSDAY FEBRUARY 261914 THE PANAMA TOLLS The canal shall be free and open to the vessels of ali nations on terms of entire equality so that there shall be no discrimination in respect to the charges of traffic So runs Rule 1 of the HayPaunsefote Treaty And it is a highly creditable feeling on the part of many Amer cans reflected by President Wilson that we cannot afford to be un fair or unfaithful to our promises simply because we happen to be strong Volumes have been published about this matter of tolls through the Panama Canal but the biggest book would be the one containing what people dont know about it We afe be ginning to suspect at least that the country generally will not profit by the freepassage provisions of the law signed bk Mr Taft under exceptional conditions and that the exemptions in favor of our coastwise traffic will serce only to take expenses off the shoulders of the American shipping combine This trust is based largely on a monopoly of wharfage and steel mills"], "digitized": true, "extract_timestamp": "2023-07-06T12:34:17.126Z", "group": ["ndnp/idhi", "idaho-state-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86091100/1914-02-26/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_doyle_ver01:data:sn86091100:00415666172:1914022601:0847/full/pct:6.25/0/default.jpg#h=428&w=287", "https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_doyle_ver01:data:sn86091100:00415666172:1914022601:0847/full/pct:12.5/0/default.jpg#h=857&w=575", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/idhi/batch_idhi_doyle_ver01/data/sn86091100/00415666172/1914022601/0847.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["grangeville", "united states", "idaho county", "idaho"], "location_city": ["grangeville"], "location_country": ["united states"], "location_county": ["idaho"], "location_state": ["idaho"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "2", "4", "1", "7", "sn86091100", "6", "0000000006", "5"], "number_editio