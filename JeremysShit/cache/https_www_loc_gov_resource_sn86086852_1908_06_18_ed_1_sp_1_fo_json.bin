ER at store of J F IIENDRA Millinery Sale CLOSING OTT at reduced prices A good assortment of ladies and childrens Trim med Hats A MASTERS Mineral Point Wls 3S R A 1 S E YO U R CAL VE S WITHOUT MILK Milk is worth too much this year to feed it to the calves Martins 2alf Feed is a perfect milk substitute and good calves can be raised on it and water It is almost wholly digestible and is especially adapted to the delicate"], "digitized": true, "extract_timestamp": "2023-08-22T16:22:23.549Z", "group": ["ndnp/whi", "wisconsin-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86086852/1908-06-18/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_lucretia_ver01:data:sn86086852:00271768990:1908061801:0009/full/pct:3.125/0/default.jpg#h=317&w=233", "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_lucretia_ver01:data:sn86086852:00271768990:1908061801:0009/full/pct:6.25/0/default.jpg#h=634&w=467", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/whi/batch_whi_lucretia_ver01/data/sn86086852/00271768990/1908061801/0009.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["iowa", "mineral point", "united states", "wisconsin"], "location_city": ["mineral point"], "location_country": ["united states"], "location_county": ["iowa"], "location_state": ["wisconsin"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["sn86086852", "8", "0", "0000000001", "2", "7", "1", "6", "9"], "number_edition": ["1"], "number_lccn": ["sn86086852"], "number_page": ["0000000001"], "number_reel": ["0", "0", "2", "7", "1", "7", "6", "8", "9", "9", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Democrat"], "partof": ["iowa county democrat (mineral point, wis.) 1877-1938", "chronicling america", "serial and gover