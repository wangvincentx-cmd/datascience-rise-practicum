ublian measures be ginning with the late Mark Hannas ascendency in Washington in 1896 and continuing up to and including the last days of the Taft adminis"], "digitized": true, "extract_timestamp": "2023-06-30T14:55:39.234Z", "group": ["ndnp/nvln", "university-of-nevada-las-vegas-university-libraries-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020355/1913-12-30/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nvln:batch_nvln_manhattan_ver01:data:sn84020355:00279554905:1913123001:1218/full/pct:6.25/0/default.jpg#h=501&w=370", "https://tile.loc.gov/image-services/iiif/service:ndnp:nvln:batch_nvln_manhattan_ver01:data:sn84020355:00279554905:1913123001:1218/full/pct:12.5/0/default.jpg#h=1003&w=740", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nvln/batch_nvln_manhattan_ver01/data/sn84020355/00279554905/1913123001/1218.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["united states", "nevada", "elko"], "location_city": ["elko"], "location_country": ["united states"], "location_county": ["elko"], "location_state": ["nevada"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "1", "0000000002", "0", "5", "9", "sn84020355", "7", "2"], "number_edition": ["1"], "number_lccn": ["sn84020355"], "number_page": ["0000000002"], "number_reel": ["0", "0", "2", "7", "9", "5", "5", "4", "9", "0", "5"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Daily Elko independent", "Elko daily independent"], "partof": ["chronicling america", "daily independent (elko, nev.) 188?-1915", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["daily independent (elko, nev.) 188?-1915"], "publication_frequency": ["dail