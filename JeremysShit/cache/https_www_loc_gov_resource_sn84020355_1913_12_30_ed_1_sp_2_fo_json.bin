 ["1", "sn84020355", "00279554905"], "number_edition": ["1"], "number_lccn": ["sn84020355"], "number_reel": ["00279554905"], "numeric_shelf_id": 191312301, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//nvln/batch_nvln_manhattan_ver01/data/sn84020355/00279554905/1913123001/1913123001_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn84020355/marcxml"}], "other_title": ["Daily Elko independent", "Elko daily independent"], "partof": [{"count": 6156, "title": "daily independent (elko, nev.) 188?-1915", "url": "https://www.loc.gov/search/?fa=partof:daily+independent+%28elko,+nev.%29+188%3F-1915&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["daily independent (elko, nev.) 188?-1915"], "place_of_publication": "Elko, Nev.", "publication_frequency": ["daily"], "raw_lccn": "sn 84020355 ", "reel_numbers": ["00279554905"], "resources": [{"files": 4, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:nvln:batch_nvln_manhattan_ver01:data:sn84020355:00279554905:1913123001:1217/full/pct:6.25/0/default.jpg", "url": "https://www.loc.gov/resource/sn84020355/1913-12-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.45633, "shard": "04", "shelf_id": "sn84020355, 1913-12-30, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/nvln", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "nevada", "elko", "elko (nev.)", "united states"], "subject_headings": ["Elko (Nev.)--Newspapers", "Nevada--Elko", "United States--Nevada--Elko--Elko"], "subjects": [{"elko": "https://www.loc.gov/search/?fa=subject:elko&fo=json"}, {"elko (nev.)": "https://www.loc.gov/search/?fa=subject:elko+%28nev.%29&fo=json"}, {"nevada": "https://www.loc.gov/search/?fa=subject:nevada&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2023-07-01T02:15:37.036Z", "title": "Daily independent (Elko, Nev.), December 30, 1913", "type": ["issue"], "url": "https://www.loc.gov/item/sn84020355/1913-12-30/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://infoweb.newsbank.com/?db=EANX&s_browseRef=decades/111FCEB1C0035B60/all.xml", "http://www.loc.gov/item/sn84020355/", "http://lccn.loc.gov/sn84020355", "https://search.catalog.loc.gov/instances/f3e6aa79-5b61-5050-8296-ffe45285689d"], "batch": ["nvln_keystone_ver03"], "campaigns": [], "date": "188?", "description": ["Daily (except Sunday) -v. 48, no. 72 (Mar. 29, 1915). \"Democratic.\" Cf. Ayer, 1889. Also issued on microfilm from the Library of Congress, Photoduplication Service. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Weekly ed.: Weekly Elko independent, <July 1, 1885>-Jan. 23,1887; Weekly independent (Elko, Nev.), Jan. 30, 1887-<Jan. 14, 1914>. Description based on: Vol. 20, no. 1 (July 1, 1885). Elko independent 2577-5324 (DLC)sn 86076367 (OCoLC)14163651"], "digitized": true, "extract_timestamp": "2026-06-05T18:24:58.817Z", "group": ["newspaper-titles", "catalog-split-12", "catalog", "ndnp/newspapers", "main-catalog-split-12", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn84020355/", "image_url": [], "index": 2, "language": ["english"], "latlong": [40.8357337, -115.7594561], "location": ["elko county", "united states", "nevada", "elko"], "location_str": "", "lonlat": [-115.7594561, 40.8357337], "number": ["2577-5286", "1", "10665985", "sn86076366", "north las vegas library district", "online resource", "sn86076417", "http://www.loc.gov/item/sn84020355/1915-03-29/ed-1/", "http://www.loc.gov/item/sn84020355/1887-01-03/ed-1/", "2020-07-27t09:41:06.116128", "original", "2025-11-07t12:37:08.600000", "univ of nevada, las vegas", "sn86091341", "2026-04-13t21:30:13", "library of congress", "university of nevada reno", "sn86076367", "6209", "sn84020355", "microfilm service copy"], "original_format": ["newspaper"], "other_title": ["Daily Elko independent", "Elko daily independent"], "partof": ["chronicling america", "catalog", "serial and government publications division", "daily independent (elko, nev.) 188?-1915", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 47.75845, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "catalog", "usnd"], "subject": ["elko county (nev.)", "newspapers", "elko county", "nevada", "elko", "elko (nev.)", "united states"], "timestamp": "2026-07-22T07:34:31.418Z", "title": "Daily independent.", "type": ["title"], "url": "https://www.loc.gov/item/sn84020355/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218666/"], "campaigns": [], "date": "1869", "dates": ["[1869 TO 1872]"], "description": ["Weekly, Dec. 31, 1870-May 25, 1872 Began with volume I, number 1 (June 19, 1869); ceased with May 25, 1872. Publishers: Berry & Perkins, 1869; Berry, Perkins & Street, 1869-1870; J.C. Davis & W.B. Taylor, 1870-<1871>; Perkins & Street, <January 7, 1871>; Berry & Co., January 14, 1871; George G. Berry & Co., January 21-<June 17>; Berry & Taylor, 1872; Sears & Wright, 1872. \"Democratic.\" Supplements accompany some issues. Opposing publication during campaign of 1870: Elko chronicle. Description based on: Volume I, number 1 (June 19, 1869); title from masthead (Chroniclingamerica.loc.gov, viewed April 4, 2018). Latest issue consulted: Volume IV, number 28 (June 17, 1871) (Chroniclingamerica.loc.gov, viewed April 4, 2018). Weekly Elko independent 2577-5197 (DLC) 2018218667 (OCoLC)1030411919"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218666/", "image_url": [], "index": 3, "language": ["english"], "location": ["united states", "nevada", "elko"], "number": ["2026-04-13t21:30:13", "2018218666", "2018218667", "1030411546", "2577-5162", "online resource"], "original_format": ["newspaper"], "partof": ["the elko independent (elko, nevada) 1869-1872 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 38.582832, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "nevada", "elko", "elko (nev.)", "united states"], "timestamp": "2026-05-26T20:56:09.337Z", "title": "The Elko independent", "type": ["title"], "url": "https://www.loc.gov/item/2018218666/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218667/"], "campaigns": [], "date": "1872", "dates": ["[1872 TO 1887]"], "description": ["Weekly Began June 1, 1872; ceased with volume 21, number 4 (January 23, 1887). Publisher: W.B. Taylor, June 1, 1872; C. W. Grover, January 23, 1887. Supplements accompany some issues. Daily ed.: Daily independent (Elko, Nev.); Daily Elko independent. Description based on: Vol. 8, no. 13 (February 27, 1875); title from masthead (Chroniclingamerica.loc.gov, viewed April 4, 2018). Latest issue consulted: Volume 21, number 4 (January 23, 1887) (Chroniclingamerica.loc.gov, viewed April 4, 2018). Weekly independent (Elko, Nev. : 1887) 2577-5243 (DLC) 2018218668 (OCoLC)1030437185"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218667/", "image_url": [], "index": 4, "language": ["english"], "location": ["united states", "nevada", "elko"], "number": ["2026-04-13t21:30:13", "1030411919", "2018218666", "2018218667", "online resource", "2018218668", "2018218669", "2577-5197"], "original_format": ["newspaper"], "partof": ["weekly elko independent (elko, nevada) 1872-1887 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 38.582832, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "nevada", "elko", "elko (nev.)", "united states"], "timestamp": "2026-05-26T20:56:09.337Z", "title": "Weekly Elko independent", "type": ["title"], "url": "https://www.loc.gov/item/2018218667/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218668/"], "campaigns": [], "date": "1887", "dates": ["[1887 TO 1914]"], "description": ["Weekly Began with Volume 21, number 5 (January 30, 1887); ceased in December 1914. Publisher: Keith & Russell, <December 11, 1914>. Daily ed.: Daily independent (Elko, Nev.). Description based on: Volume 21, number 5 (January 30, 1887); title from masthead (Chroniclingamerica.loc.gov, viewed April 4, 2018). Latest issue consulted: Volume 49, number 50 (December 11, 1914) (Chroniclingamerica.loc.gov, viewed April 4, 2018)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218668/", "image_url": [], "index": 5, "language": ["english"], "location": ["united states", "nevada", "elko"], "number": ["2026-04-13t21:30:13", "1030437185", "2577-5243", "2018218667", "online resource", "2018218669", "2018218668"], "original_format": ["newspaper"], "other_title": ["Issues for August 1-October 17, 1913 called: Elko independent"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "weekly independent (elko, nevada) 1887-1914 [online resource]"], "publication_frequency": ["weekly"], "score": 38.582832, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "nevada", "elko", "elko (nev.)", "united states"], "timestamp": "2026-05-26T20:56:09.337Z", "title": "Weekly independent", "type": ["title"], "url": "https://www.loc.gov/item/2018218668/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218669/"], "camp