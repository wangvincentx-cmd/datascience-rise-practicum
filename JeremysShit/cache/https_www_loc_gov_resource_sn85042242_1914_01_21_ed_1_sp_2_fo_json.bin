"bismarck"], "location_str": "", "lonlat": [-100.783127, 46.805397], "number": ["kansas state hist soc, newsp proj", "microfilm master", "1", "sn85042242", "2330-5924", "online resource", "sn85042588", "2023-08-22t07:32:24.084270", "western illinois univ", "sn85042331", "http://www.loc.gov/item/sn85042242/1884-03-24/ed-1/", "http://www.loc.gov/item/sn85042242/1916-11-20/ed-1/", "sn85042243", "original", "11986756", "2026-04-13t21:30:13", "library of congress", "5233", "sn84022128", "2025-06-25t14:23:00", "western rsv hist soc, newsp proj", "state hist soc of n dakota", "microfilm service copy"], "original_format": ["newspaper"], "partof": ["chronicling america", "catalog", "serial and government publications division", "bismarck daily tribune (bismarck, dakota [n.d.]) 1881-1916", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 61.093494, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["burleigh", "newspapers", "north dakota", "bismarck (n.d.)", "united states", "bismarck"], "timestamp": "2026-07-22T07:42:55.512Z", "title": "Bismarck daily tribune", "type": ["title"], "url": "https://www.loc.gov/item/sn85042242/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218966/"], "campaigns": [], "date": "1906", "dates": ["[1906 TO 9999]"], "description": ["Weekly Began in 1906. \"Beiblatt zu der Pierce County tribune.\" Place of publication varies: <1906>-Nov. 23, 1911, Rugby, N.D.; Dec. 7, 1911-Apr. 25, 1912, Devils Lake, N.D.; May 2, 1912-July 13, 1945?, Bismarck, N.D.; <Nov. 27, 1945>-, with an office in Bismarck, which moved to Fredonia, N.D. <Feb. 9, 1968>. Description based on: 1. Jahrgang, no. 37 (11. April, 1907); title from masthead (Chroniclingamerica.loc.gov, viewed October 3, 2018). Latest issue consulted: 15. Jahrgang, no. 27 (19. Oktober 1920) (Chroniclingamerica.loc.gov, viewed October 3, 2018)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:44.751Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218966/", "image_url": [], "index": 3, "language": ["german"], "location": ["douglas", "burleigh", "pierce", "fredonia", "devils lake", "nebraska", "north dakota", "logan", "rugby", "ramsey", "omaha", "united states", "bismarck"], "number": ["2026-04-13t21:30:13", "online resource", "1055488809", "2018218966", "2639-5150"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "der staats=anzeiger (rugby, north dakota) 1906-current [online resource]"], "publication_frequency": ["weekly"], "score": 51.850834, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["douglas", "burleigh", "pierce", "fredonia", "devils lake", "newspapers", "united states", "devils lake (n.d.)", "north dakota", "nebraska", "logan", "rugby", "rugby (n.d.)", "bismarck (n.d.)", "ramsey", "omaha", "fredonia (n.d.)", "bismarck"], "timestamp": "2026-05-26T20:56:24.792Z", "title": "Der Staats=Anzeiger", "type": ["title"], "url": "https://www.loc.gov/item/2018218966/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218923/"], "campaigns": [], "date": "1875", "dates": ["[1875 TO 1881]"], "description": ["Triweekly Began with November 15, 1875 issue. Ceased with April 16, 1881 issue? Weekly eds.: Bismarck weekly tribune (Bismarck, N.D. : 1875), 1875-1878, and: Bismarck tribune (Bismarck, N.D. : 1878), 1878-1881. Description based on: Vol. 5, no. 1 (June 4, 1877); title from masthead (Chroniclingamerica.loc.gov, viewed August 21, 2013). Latest issue consulted: Vol. 5, no. 128 (April 9, 1878) (Chroniclingamerica.loc.gov, viewed August 21, 2013). Bismarck daily tribune (Online) 2330-5932 (DLC) 2013218925 (OCoLC)586060490"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:21.806Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013218923/", "image_url": [], "index": 4, "language": ["english"], "location": ["north dakota", "burleigh", "united states", "bismarck"], "number": ["2026-04-13t21:30:13", "2013218924", "2330-5819", "2013218923", "2013218927", "online resource", "849807600", "2013218925"], "original_format": ["newspaper"], "partof": ["bismarck tri-weekly tribune (bismarck, d.t. [n.d.]) 1875-1881 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["triweekly"], "score": 51.850834, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["burleigh", "newspapers", "north dakota", "bismarck (n.d.)", "periodicals", "electronic journals", "united states", "bismarck"], "timestamp": "2026-05-26T20:48:24.858Z", "title": "Bismarck tri-weekly tribune", "type": ["title"], "url": "https://www.loc.gov/item/2013218923/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218925/"], "campaigns": [], "date": "1881", "dates": ["[1881 TO 1916]"], "description": ["Daily (except Monday) Began April 18, 1881; ceased with thirty-six year, no. 280 (November 20, 1916). Available on microfilm from the State Historical Society of North Dakota, and the Library of Congress, Photoduplication Service. Weekly eds.: Bismarck tribune (Bismarck, N.D. : 1878), 1881-1884, and: Bismarck weekly tribune (Bismarck, N.D. : 1884), 1884-1916. Description based on: Twentieth year (January 2, 1900); title from masthead (Chroniclingamerica.loc.gov, viewed August 21, 2013). Latest issue consulted: Thirty-six year, no. 280 (November 20, 1916) (Chroniclingamerica.loc.gov, viewed August 21, 2013). Bismarck tribune (Bismarck, N.D. : 1916 : Online) 2330-5975 (DLC) 2013218926 (OCoLC)244293920"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:09.192Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.