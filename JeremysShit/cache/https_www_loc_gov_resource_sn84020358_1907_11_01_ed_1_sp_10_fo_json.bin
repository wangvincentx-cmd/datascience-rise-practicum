Is the Policy of President Roosevelt Toward Capital gound Mr Ailing said in part My policyrnot necessarily that of the Republican party but my policy for the carrying out of which I pledge my power as presi dent during my term and shall see to It that my successor shall be a pres ident who will also carry It out is that the federal government shall have and exercise the power to control regulate and restrain large business wealth engaged In interstate com merce Mr Ailing after quoting Pres ident Roosevelt continued President Roosevelt Has succeeded Jn creating the bureau of incorpora tions In procuring power in the ln Compare my advertising with the rest of the advertising In town Mine Is right up to date Isnt It It shows I am Jlmmie on"], "digitized": true, "extract_timestamp": "2023-06-01T13:35:21.907Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020358/1907-11-01/ed-1/?sp=10", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_dogwood_ver01:data:sn84020358:00271744511:1907110101:0389/full/pct:6.25/0/default.jpg#h=446&w=306", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_dogwood_ver01:data:sn84020358:00271744511:1907110101:0389/full/pct:12.5/0/default.jpg#h=892&w=613", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_dogwood_ver01/data/sn84020358/00271744511/1907110101/0389.xml&format=alto_xml"], "index": 10, "language": ["english"], "location": ["united states", "connecticut", "new haven"], "location_city": ["new haven"], "location_country": ["united states"], "location_county": ["new haven"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "0", "sn84020358", "5", "2", "7", "1", "0000000010"], "number_edition": ["1"], "number_lccn": ["sn84020358"], "number_pa