te": ["usnd"], "subject": ["newspapers", "new haven (conn.)", "connecticut", "new haven", "united states"], "timestamp": "2026-05-26T21:13:38.179Z", "title": "The New Haven union", "type": ["title"], "url": "https://www.loc.gov/item/2024271097/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019271072/"], "campaigns": [], "date": "191?", "dates": ["[1910 TO 1921]"], "description": ["Weekly Ceased with volume VII, number 21 (January 14, 1921). Also issued on microfilm from Connecticut State Library, Hartford, CT. Description based on: Vol. 3, no. 22 (February 16, 1918); title from masthead (Chroniclingamerica.loc.gov, viewed April 3, 2019). Latest issue consulted: Volume VII, Number 21 (January 14, 1921) (Chroniclingamerica.loc.gov, viewed April 3, 2019). Connecticut labor news 2642-7311 (DLC) 2019271073 (OCoLC)1091359433"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:47.120Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019271072/", "image_url": [], "index": 13, "language": ["english"], "location": ["united states", "connecticut", "new haven"], "number": ["2019271072", "online resource", "1091358878", "2019271073", "2642-729x", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the connecticut labor press (new haven, conn.) 191?-1921 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 29.881104, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "new haven (conn.)", "connecticut", "labor movement", "new haven", "united states"], "timestamp": "2026-05-26T20:58:32.070Z", "title": "The Connecticut labor press", "type": ["title"], "url": "https://www.loc.gov/item/2019271072/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019271073/"], "campaigns": [], "date": "1921", "dates": ["[1921 TO 1925]"], "description": ["Weekly Began wiith volume VII, number 22 (January 21, 1921); ceased with volume XIII, number 7 (March 14, 1925). \"Connecticut\" appears above title ornament. Also issued on microfilm from Connecticut State Library, Hartford, CT. Description based on: Volume VII, Number 22 (January 21, 1921); title from masthead (Chroniclingamerica.loc.gov, viewed April 3, 2019). Latest issue consulted: Volume XIII, Number 7 (March 14, 1925) (Chroniclingamerica.loc.gov, viewed April 3, 2019)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:47.120Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019271073/", "image_url": [], "index": 14, "language": ["english"], "location": ["united states", "connecticut", "new haven"], "number": ["2019271072", "online resource", "2642-7311", "2019271073", "1091359433", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Labor news"], "partof": ["directory of u.s. newspapers in american libraries", "the connecticut labor news (new haven, conn.) 1921-1925 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 29.881104, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "new haven (conn.)", "connecticut", "labor movement", "new haven", "united states"], "timestamp": "2026-05-26T20:58:32.070Z", "title": "The Connecticut labor news", "type": ["title"], "url": "https://www.loc.gov/item/2019271073/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019271078/"], "campaigns": [], "date": "1903", "dates": ["[1903 TO 1939]"], "description": ["Weekly, <Jan. 22, 1922-> Began in 1903. Published as: L'indipendente-alla baionetta!, 13 genn. 1917. \"Established 1903\"--Genn. 22, 1922 issue. Vol. 16, no. 3 designation repeated for Oct. 7 and Oct. 21, 1918 issues. Also issued on microfilm from Connecticut State Library, Hartford, CT. In Italian, <1907>. In Italian and English, <1916-1922, 1936> Description based on: Anno IV, Num. 1 (1 Gennaio 1907); title from masthead (Chroniclingamerica.loc.gov, viewed April 24, 2019). Latest issue consulted: Anno XXXIV, No. 19 (May 23, 1936) (Chroniclingamerica.loc.gov, viewed April 24, 2019)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:47.120Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019271078/", "image_url": [], "index": 15, "language": ["english", "italian"], "location": ["united states", "connecticut", "new haven county", "new haven"], "number": ["2643-3109", "online resource", "1098216610", "2019271078", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Indipendente-alla baionetta!"], "partof": ["l'indipendente (new haven, conn.) 1903-193? [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 29.881104, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "new haven county (conn.)", "new haven", "connecticut", "new haven (conn.)", "italian", "italian americans", "united states", "italians", "new haven county"], "timestamp": "2026-05-26T20:58:32.070Z", "title": "L'indipendente", "type": ["title"], "url": "https://www.loc.gov/item/2019271078/"}], "next_resource": {"label": "Next Issue", "url": "https://www.loc.gov/resource/sn84020358/1907-11-02/ed-1/?fo=json&sp=1"}, "options": {"access_group": [""], "access_group_raw": "", "all": null, "api_version": "1", "app_context": null, "application_version": "$Revision$", "attribute": null, "attribute!": null, "attribute_map": null, "cache_tags": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee", "newspaper-titles", "catalog-split-15", "catalog", "ndnp/newspapers", "main-catalog-split-15", "united-states-newspaper-directory", "rbpebib.mar", "catalog-split-14", "bro