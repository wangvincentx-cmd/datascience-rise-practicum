58308/00340584144/1913121801/1132.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87058308/1913-12-18/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iahi/batch_iahi_feebas_ver01/data/sn87058308/00340584144/1913121801/1132.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iahi:batch_iahi_feebas_ver01:data:sn87058308:00340584144:1913121801:1129/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iahi/batch_iahi_feebas_ver01/data/sn87058308/00340584144/1913121801/1132.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87058308/1913-12-18/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/iahi/batch_iahi_feebas_ver01/data/sn87058308/00340584144/1913121801/1132.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn87058308/1913-12-18/ed-1/?sp=4"], "batch": ["iahi_feebas_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/iowa/", "2/united states/iowa/mahaska/", "3/united states/iowa/mahaska/oskaloosa/"], "contributor": ["state historical society of iowa"], "date": "1913-12-18", "dates": ["1913-12-18"], "description": ["w wmw a THE OSKALOOSA HERALD ttblUhed Weekly am Thirdys at Oskaloosa Mahaska Coiinty lowa OKALOOSA HERALD COMPANY Publishers Catered at the Postofflce at Oska loosa lowa as secondclass matter nbecriptlonTwo Dollars Per Tear Payable In Advance OFFICIAL COUNTY PAPER sjijgSP LETS BE DOING Lets put our selfish wants away And lay aside our labor To do some needful act today Which helps our weary neighbor Lets prove that were the kind of friend Most worth appreciating The friend indeed who doesnt spend Another day in waiting i t 1 Lets do today some kindly deed Which we have been delaying Lets give a precious moments heed And do instead of saving Lets help to make some burden light For one who needs befriending And do it now ere comes the night Instead of just intending Lets pause today at someones door Where long we have been knowing That someone should have paused before But they like we kept going Lets strive to soothe the fevered brow The heart thats crushed by sorrow And let us know tis needed now But may not be tomorrow Lets speak today that word of love If hate weve been enthroning A task weve"], "digitized": true, "extract_timestamp": "2023-05-16T11:54:56.966Z", "group": ["ndnp/iahi", "state-historical-society-of-iowa-state-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn87058308/1913-12-18/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:iahi:batch_iahi_feebas_ver01:data:sn87058308:00340584144:1913121801:1132/full/pct:6.25/0/default.jpg#h=433&w=339", "https://tile.loc.gov/image-services/iiif/service:ndnp:iahi:batch_iahi_feebas_ver01:data:sn87058308:00340584144:1913121801:1132/full/pct:12.5/0/default.jpg#h=866&w=679", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iahi/batch_iahi_feebas_ver01/data/sn87058308/00340584144/1913121801/1132.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["mahaska", "united states", "oskaloosa", "iowa"], "location_city": ["oskaloosa"], "location_country": ["united states"], "location_county": ["mahaska"], "location_state": ["iowa"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0", "sn87058308", "4", "1", "0000000004", "8", "5"], "number_edition": ["1"], "number_lccn": ["sn87058308"], "number_page": ["0000000004"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "4", "1", "4", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof":