 ownership maps, 197 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:18.487Z", "group": ["gmd.mar", "catalog-split-07", "catalog", "general-maps", "main-catalog-split-07"], "hassegments": false, "id": "http://www.loc.gov/item/2012587734/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd415/g4153/g4153m/la000197.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd415/g4153/g4153m/la000197.gif#h=182&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd415:g4153:g4153m:la000197/full/pct:12.5/0/default.jpg#h=2251&w=1860", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd415:g4153:g4153m:la000197/full/pct:25/0/default.jpg#h=4502&w=3720"], "index": 4, "language": ["english"], "location": ["iowa", "united states", "oskaloosa", "mahaska county"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t05:17:56", "2012-12-05t10:01:12", "sheet", "2012587734"], "online_format": ["image"], "original_format": ["map"], "partof": ["cultural landscapes", "county landownership maps", "catalog", "geography and map division"], "score": 33.671673, "shelf_id": "G4153.M25 1871 .W3", "site": ["catalog"], "subject": ["landowners", "united states", "real property", "cadastral maps", "oskaloosa", "mahaska county (iowa)", "mahaska county", "oskaloosa (iowa)", "maps", "iowa"], "timestamp": "2026-04-29T16:04:39.346Z", "title": "Map of Mahaska County, Iowa", "type": ["cartographic"], "url": "https://www.loc.gov/item/2012587734/"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2017707040/", "http://www.loc.gov/item/2017707040/", "http://www.loc.gov/pictures/item/2017707040/", "https://hdl.loc.gov/loc.pnp/mrg.04946", "https://hdl.loc.gov/loc.pnp/mrg.04946", "http://www.loc.gov/resource/mrg.04946/", "http://lccn.loc.gov/2017707040"], "campaigns": [], "contributor": ["margolies, john"], "date": "2003", "