n partial failure of the corn crop might invite serious con sequences Another four to six weeks must elapse before corn is fully mode Fortunately the latest reports are very favorable for a i big yield Wheat too leas been showing marked recuperative pow i ers from previous damage All things considered the crop outlook is mixed and might be better but still contains some features of pos I j itivo encouragement II Another"], "digitized": true, "extract_timestamp": "2020-09-15T15:57:26.831Z", "group": ["ndnp/uuml", "university-of-utah-marriott-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85058398/1910-08-09/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:uuml:batch_uuml_fifteen_ver01:data:sn85058398:paper:1910080901:0313/full/pct:3.125/0/default.jpg#h=274&w=197", "https://tile.loc.gov/image-services/iiif/service:ndnp:uuml:batch_uuml_fifteen_ver01:data:sn85058398:paper:1910080901:0313/full/pct:6.25/0/default.jpg#h=549&w=394", "https://tile.loc.gov/image-services/iiif/service:ndnp:uuml:batch_uuml_fifteen_ver01:data:sn85058398:paper:1910080901:0313/full/pct:12.5/0/default.jpg#h=1099&w=789", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/uuml/batch_uuml_fifteen_ver01/data/sn85058398/paper/1910080901/0313.xml&format=alto_xml"], "index": 3, "language": ["english"], "location": ["ogden", "weber", "utah", "united states"], "location_city": ["ogden"], "location_country": ["united states"], "location_county": ["weber"], "location_state": ["utah"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000003", "sn85058398", "1"], "number_edition": ["1"], "number_lccn": ["sn85058398"], "number_page": ["0000000003"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Evening standard", "Standard", "Daily standard"], "partof": ["the ogde