 night new arrivals 6top over here en route to Mexico and the hotels now enjoy a great part of the trade that for merly went to the Pullman Co The city park is fast becoming one of the most delightful places to rest in All day visitors and residents can be seen under the trees enjoying the"], "digitized": true, "extract_timestamp": "2024-01-09T14:47:13.989Z", "group": ["ndnp/az", "arizona-state-university-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn96060796/1908-05-30/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_bobwhite_ver01:data:sn96060796:00212476390:1908053001:0301/full/pct:6.25/0/default.jpg#h=403&w=344", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_bobwhite_ver01:data:sn96060796:00212476390:1908053001:0301/full/pct:12.5/0/default.jpg#h=806&w=689", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_bobwhite_ver01/data/sn96060796/00212476390/1908053001/0301.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["santa cruz county", "arizona", "santa cruz", "nogales", "united states"], "location_city": ["nogales"], "location_country": ["united states"], "location_county": ["santa cruz"], "location_state": ["arizona"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "4", "0", "2", "7", "1", "sn96060796", "6", "9", "0000000002"], "number_edition": ["1"], "number_lccn": ["sn96060796"], "number_page": ["0000000002"], "number_reel": ["0", "0", "2", "1", "2", "4", "7", "6", "3", "9", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "the border vidette (nogales, ariz.) 1894-1934", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_titl