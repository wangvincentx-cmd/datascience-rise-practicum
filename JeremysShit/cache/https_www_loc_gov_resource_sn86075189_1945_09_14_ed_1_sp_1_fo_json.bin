 "subject": ["lewis and clark", "helena (mont.)", "newspapers", "history", "united states", "montana", "helena"], "timestamp": "2026-07-18T09:20:06.081Z", "title": "The people's voice", "type": ["title"], "url": "https://www.loc.gov/item/sn86075189/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271280/"], "campaigns": [], "date": "1939", "dates": ["[1939 TO 1969]"], "description": ["Weekly Began with vol. I, no. 1 (December 6, 1939); ceased v. 30, no. 6 (Aug. 22, 1969). \"No Commercial Advertising except from Co-operative Business Institutions accepted.\" Vol. I, No. 1 (December 6, 1939); title from masthead (Chroniclingamerica.loc.gov, viewed December 9, 2020). Vol. XXV, No. 4 (December 27, 1963) (Chroniclingamerica.loc.gov, viewed December 9, 2020)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:57.206Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271280/", "image_url": [], "index": 2, "language": ["english"], "location": ["lewis and clark", "helena", "united states", "montana"], "number": ["online resource", "1226328195", "2020271280", "2766-2039", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["the people's voice (helena, montana) 1939-1969 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 46.47197, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "united states", "montana", "helena"], "timestamp": "2026-05-26T21:01:07.415Z", "title": "The people's voice", "type": ["title"], "url": "https://www.loc.gov/item/2020271280/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218808/"], "campaigns": [], "date": "1906", "dates": ["[1906 TO 1911]"], "description": ["Weekly, i.e. irregular Began with vol. I, no. I (March 16, 1906); ceased with vol. III, 36 (September 8, 1911). \"We unhesitatingly subscribe to the principles of Republicanism.\" \"A complete Negro newspaper.\" Description based on print version record. Latest issue consulted: Vol. III, 36 (September 8, 1911) (Chroniclingamerica.loc.gov, viewed June 12, 2013)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:21.057Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013218808/", "image_url": [], "index": 3, "language": ["english"], "location": ["lewis and clark", "helena", "united states", "montana"], "number": ["online resource", "847788581", "2329-5538", "2026-04-13t21:30:13", "2013218808"], "original_format": ["newspaper"], "other_title": ["Montana plain dealer"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the montana plaindealer (helena, montana) 1906-1911 [online resource]"], "publication_frequency": ["weekly"], "score": 46.47197, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "african americans", "united states", "montana", "helena", "african american", "african american newspapers"], "timestamp": "2026-05-26T20:48:08.077Z", "title": "The Montana plaindealer", "type": ["title"], "url": "https://www.loc.gov/item/2013218808/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218597/"], "campaigns": [], "date": "1875", "dates": ["[1875 TO 1943]"], "description": ["Daily, November 25, 1889-November 21, 1943 Began August 12, 1875; ceased November 21, 1943. Vol. 19, no, 241 (January 13, 1884); title from PDF masthead (LLMC Digital, viewed December 31, 2020). Vol. 35, no. 311 (December 31, 1894) (Chroniclingamerica.loc.gov, viewed February 27, 2013). Publishers: The Independent Pub. Co. <December 31, 1894-> Available on microfilm from the Library of Congress, Photoduplication Service. Also issued in print. Merged with: Montana record-herald, to form: Independent-record (Helena, Mont.). Montana record-herald Independent-record (Helena, Mont.)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:19.469Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013218597/", "image_url": [], "index": 4, "language": ["english"], "location": ["lewis and clark", "united states", "montana", "lewis", "helena", "clark county"], "number": ["online resource", "828628958", "2326-9596", "2026-04-13t21:30:13", "2013218597"], "original_format": ["newspaper"], "other_title": ["Independent", "Daily independent", "Helena daily independent"], "partof": ["serial and government publications division", "the helena independent (helena, montana territory) 1875-1943 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 46.47197, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "lewis and clark county (mont.)", "united states", "montana", "helena", "lewis and clark county"], "timestamp": "2026-05-26T20:47:50.735Z", "title": "The Helena independent", "type": ["title"], "url": "https://www.loc.gov/item/2013218597/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218600/"], "campaigns": [], "contributor": ["ball, j. p., jr.,"], "date": "1894", "dates": ["[1894 TO 1894]"], "description": ["Weekly Began with vol. 1, no. 1 (September 3, 1894). Ceased with December 15, 1894. Cf. The Negro in Montana, 1800-1945. Editor: J. P. Ball, Jr., September 3-<November 5>, 1894. \"Devoted to the interests of Colored Americans.\" Description based on: Vol. 1, no. 1 (September 3, 1894); title from masthead (Chroniclingamerica.loc.gov, viewed Feb. 27, 2013). Latest issue consulted: Vol. 1, no. 10 (November 5, 1894) (Chroniclingamerica.loc.gov, viewed Feb. 27, 2013)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:19.469Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013218600/", "image_url": [], "index": 5, "language": ["english"], "location": ["lewis and clark", "helena", "united states", "montana"], "number": ["online resource", "2326-9693", "2013218600", "828631189", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the colored citizen (helena, montana) 1894-1894 [online resource]"], "publication_frequency": ["weekly"], "score": 46.47197, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lewis and clark", "helena (mont.)", "newspapers", "african americans", "united states", "montana", "helena", "african american"], "timestamp": "2026-05-26T20:47:50.735Z", "title": "The Colored citizen", "type": ["title"], "url": "https://www.loc.gov/item/2013218600/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013271998/"], "campaigns": [], "date": "1914", "dates": ["[1914 TO 1919]"], "description": ["Began September 22, 1914. \"Published...Sept. 22,23,24,25,26, 1914.\" Issues for Sept. 24-26, 1914 called: Montana State Fair Edition; issue for Nov. 2, 1914 called: Election Edition. Sept. 24-26, 1914 issues published by the Montana Equal Suffrage State Central Committee in Helena; Nov. 2, 1914 issue published by the Butte Equal Suffrage Association in Butte. Description based on: Number 3 (September 24, 1914); title from masthead (Chroniclingamerica.loc.gov, viewed January 23, 2014). Latest issue consulted: November 2, 1914 (Chroniclingamerica.loc.gov, viewed January 23, 2014)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:24.080Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013271998/", "image_url": [], "index": 6, "language": ["english"], "location": ["le