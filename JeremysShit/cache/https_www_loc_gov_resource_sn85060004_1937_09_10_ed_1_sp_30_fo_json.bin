al outlook All of these have played their part in causing the break To begin with the market was shaky and very very thin In fact the big decline Tuesday amply certi fies the prediction of the critics of government regulation who forecast these wild gyrations as a result"], "digitized": true, "extract_timestamp": "2026-02-22T09:55:18.383Z", "group": ["ndnp/txdn", "university-of-north-texas-denton-tx-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85060004/1937-09-10/ed-1/?sp=30", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:txdn:batch_txdn_kestrel_ver01:data:sn85060004:00516994733:1937091001:0297/full/pct:6.25/0/default.jpg#h=332&w=259", "https://tile.loc.gov/image-services/iiif/service:ndnp:txdn:batch_txdn_kestrel_ver01:data:sn85060004:00516994733:1937091001:0297/full/pct:12.5/0/default.jpg#h=665&w=518", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/txdn/batch_txdn_kestrel_ver01/data/sn85060004/00516994733/1937091001/0297.xml&format=alto_xml"], "index": 30, "language": ["english"], "location": ["united states", "bexar", "san antonio", "texas"], "location_city": ["san antonio"], "location_country": ["united states"], "location_county": ["bexar"], "location_state": ["texas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "1", "4", "0000000030", "7", "9", "6", "sn85060004"], "number_edition": ["1"], "number_lccn": ["sn85060004"], "number_page": ["0000000030"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "4", "7", "3", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["San Antonio Sunday light"], "partof": ["chronicling america", "san antonio light (san antonio, tex.) 1911-1993", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications