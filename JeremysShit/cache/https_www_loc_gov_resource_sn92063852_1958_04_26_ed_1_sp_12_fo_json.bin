x", "26654010", "2026-04-13t21:30:13", "1", "2025-06-25t14:25:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the detroit tribune (detroit, mich.) 1935-1966", "catalog", "chronicling america"], "publication_frequency": ["weekly"], "score": 80.651054, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["michigan", "african american", "wayne county", "african americans", "detroit", "wayne county (mich.)", "wayne", "newspapers", "detroit (mich.)", "united states"], "timestamp": "2026-07-18T09:33:03.460Z", "title": "The Detroit tribune", "type": ["title"], "url": "https://www.loc.gov/item/sn92063852/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218642/"], "campaigns": [], "date": "1933", "dates": ["[1933 TO 1933]"], "description": ["Weekly Began with vol. XV, no. 21 (April 14, 1933); ceased with vol. XVI, no. 5 (Dec. 23, 1933). \"Independent.\" Cf. Ayer, 1967. \"Leading Negro weekly of Michigan.\" Merged with: Detroit independent, to form: Tribune independent of Michigan. Description based on: Vol. XV, no. 21 (April 14, 1933); title from masthead (Chroniclingamerica.loc.gov, viewed March 14, 2018). Latest issue consulted: Vol. XVI, no. 5 (Dec. 23, 1933) (Chroniclingamerica.loc.gov, viewed March 14, 2018). Detroit independent Tribune independent of Michigan 2577-2570 (DLC) 2018218643 (OCoLC)1028674923"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218642/", "image_url": [], "index": 13, "language": ["english"], "location": ["michigan", "wayne county", "detroit", "wayne", "united states"], "number": ["2577-2546", "2018218642", "online resource", "2018218643", "1028641252", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "detroit tribune (detroit, michigan) 1933-1933 [online resource]"], "publication_frequency": ["weekly"], "score": 71.443665, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["michigan", "african american", "wayne county", "african americans", "detroit", "race relations", "wayne county (mich.)", "wayne", "newspapers", "detroit (mich.)", "united states"], "timestamp": "2026-05-26T20:56:09.337Z", "title": "Detroit tribune", "type": ["title"], "url": "https://www.loc.gov/item/2018218642/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218643/"], "campaigns": [], "date": "1933", "dates": ["[1933 TO 1935]"], "description": ["Weekly Began with [volume XI], no. 38 (December 30, 1933); ceased with volume XIII, no. 25 (Sept. 7, 1935). \"On guard for Negro rights.\" Publisher: Midwest Publishing Company, Inc., <December 29, 1934>-September 7, 1935. Also available on microfilm from Xerox University Microfilms. Formed by the union of: Detroit tribune (Detroit, Mich. : 1933), and: Detroit independent. Description based on: [Volume XI], no. 38 (December 30, 1933); title from masthead (Chroniclingamerica.loc.gov, viewed March 14, 2018). Latest issue consulted: Volume XIII, no. 25 (Sept. 7, 1935) (Chroniclingamerica.loc.gov, viewed March 14, 2018). Detroit tribune (Detroit, Mich. : 1935) 2577-3518 (DLC) 2018218653 (OCoLC)1029203520"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218643/", "image_url": [], "index": 14, "language": ["english"], "location": ["michigan", "wayne county", "detroit", "wayne", "united states"], "number": ["2577-2570", "2018218642", "online resource", "2018218653", "2018218643", "1028674923", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Tribune independent"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the tribune independent of michigan (detroit, michigan) 1933-1935 [online resource]"], "publication_frequency": ["weekly"], "score": 71.443665, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["michigan", "african american", "wayne county", "african americans", "detroit", "wayne county (mich.)", "wayne", "newspapers", "detroit (mich.)", "united states"], "timestamp": "2026-05-26T20:56:09.337Z", "title": "The tribune independent of Michigan", "type": ["title"], "url": "https://www.loc.gov/item/2018218643/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218653/"], "campaigns": [], "date": "1935", "dates": ["[1935 TO 1966]"], "description": ["Weekly Began with volume XIII, no. 26 (September 14, 1935); ceased in 1966. Publisher: Detroit Tribune Publishing Co., Inc., <January 5-December 28, 1963>. Description based on: Description based on: Volume XIII, no. 26 (September 14, 1935); title from masthead (Chroniclingamerica.loc.gov, viewed March 21, 2018). Latest issue consulted: Volume 42, number 4 (December 28, 1963) (Chroniclingamerica.loc.gov, viewed March 21, 2018)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218653/", "image_url": [], "index": 15, "language": ["english"], "location": ["michigan", "wayne county", "detroit", "wayne", "united states"], "number": ["2577-3518", "online resource", "2018218653", "1029203520", "2018218643", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the detroit tribune (detroit, michigas[n]) 1935-1966 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 71.443665, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["michigan", "afr