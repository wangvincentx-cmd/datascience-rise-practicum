 ["weekly"], "score": 54.62555, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "butler", "tonopah (nev.)", "nevada", "nye county", "tonopah", "nye", "nye county (nev.)", "united states"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "Tonopah bonanza", "type": ["title"], "url": "https://www.loc.gov/item/2016271193/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/sn86076135", "http://www.loc.gov/item/sn86076135/"], "batch": ["nvln_fallon_ver02"], "campaigns": [], "date": "1901", "description": ["Weekly Vol. 1, no. 1 (June 15, 1901)-v. 9, no. 29 (Dec. 25, 1909). Butler, Nev. becomes Tonopah, Nev. on Mar. 3, 1905. Cf. Carlson, H.S. Nev. place names. Title from publisher's statement: Tonopah weekly bonanza, Mar. 2, 1907-Dec. 25, 1909. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Daily edition: Tonopah daily bonanza."], "digitized": true, "extract_timestamp": "2026-06-05T18:24:59.140Z", "group": ["newspaper-titles", "catalog-split-05", "catalog", "ndnp/newspapers", "main-catalog-split-05", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn86076135/", "image_url": [], "index": 4, "language": ["english"], "latlong": [38.06716, -117.23008], "location": ["butler", "nevada", "nye county", "tonopah", "nye", "united states"], "location_str": "", "lonlat": [-117.23008, 38.06716], "number": ["13539761", "univ of nevada, las vegas", "http://www.loc.gov/item/sn86076135/1909-12-25/ed-1/", "online resource", "2020-07-27t09:41:06.116128", "1", "microfilm service copy", "2025-06-25t14:23:35", "univ of texas at austin", "sn86076135", "carson valley public company", "http://www.loc.gov/item/sn86076135/1901-06-15/ed-1/", "2026-04-13t21:30:13", "southern california newsp", "original", "sn86076142", "2474-6193", "huntington libr art gallery & gardens", "434"], "original_format": ["newspaper"], "other_title": ["Tonopah weekly bonanza", "We