a/sn81002003/00517014163/1945092401/0649.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_housesparrow_ver01:data:sn81002003:00517014163:1945092401:0646/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/nbu/batch_nbu_housesparrow_ver01/data/sn81002003/00517014163/1945092401/0649.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn81002003/1945-09-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/nbu/batch_nbu_housesparrow_ver01/data/sn81002003/00517014163/1945092401/0649.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn81002003/1945-09-24/ed-1/?sp=4"], "batch": ["nbu_housesparrow_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/nebraska/", "2/united states/nebraska/douglas/", "3/united states/nebraska/douglas/omaha/"], "contributor": ["university of nebraska-lincoln libraries, lincoln, ne"], "date": "1945-09-24", "dates": ["1945-09-24"], "description": ["perhaps they will find some who ought to be replaced Leggete il giornale della vostra comunit\u00e0 ogni settimana e diffondetelo tra i vostri amici e conoscenti REGALI PER NATALE OLTRE MARE Nonostante Ih guerra sia fini ta anche questanno verranno mandati milioni di doni e rega li natalizi alle forze armate che sono ancora oltremare Se non si osservano certe regole sar\u00e0 difficile farli recapitare in tem RO Se il vostro soldato sta per tornare a casa non mandategli pacchi natalizi Date preciso e completo lindirizzo Spedite i pacchi natalizi tra il 15 Settembre ed il 15 Ottobre Usate una scatola forte e le gate con corda forte Leggete il nuovo ROMANZO dai titolo Il Sogno che Uccide Bello ed Interessante The American Citizen Office 323 LEFLANG BLDG OFFICIAL ORGAN OF THE ITALIANAMERICANS OF OMAHA LINCOLN NEBR AND COUNCIL BLUFFS IOWA PHONE WE 1111SIM OMAHA NEBR MONDAY SEPTEMBER 24 1945 Italian Close to Atom Secret in 35 Glad He Failed as Germans Would Have Got It SPOKANE WASH Dr Enrico Fermi an Italian scientist who participated in developing the atomic bomb in the United States almost discovered its secret 10 years ago which probably would have made it available to"], "digitized": true, "extract_timestamp": "2025-12-01T12:41:46.963Z", "group": ["ndnp/nbu", "university-of-nebraska-of-nebraska-lincoln-libraries-lincoln-ne-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn81002003/1945-09-24/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_housesparrow_ver01:data:sn81002003:00517014163:1945092401:0649/full/pct:6.25/0/default.jpg#h=427&w=315", "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_housesparrow_ver01:data:sn81002003:00517014163:1945092401:0649/full/pct:12.5/0/default.jpg#h=854&w=630", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_housesparrow_ver01/data/sn81002003/00517014163/1945092401/0649.xml&format=alto_xml"], "index": 4, "language": ["italian", "english"], "location": ["omaha", "united states", "douglas", "douglas county", "iowa", "nebraska"], "location_city": ["omaha"], "location_country": ["united states"], "location_county": ["douglas"], "location_state": ["nebraska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "3", "0000000004", "sn81002003", "4", "7", "6", "1"], "number_edition": ["1"], "number_lccn": ["sn81002003"], "number_page": ["0000000004"], "number_reel": ["0", "0", "5", "1", "7", "0", "1", "4", "1", "6", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "the american citizen (omaha, neb.) 1923-1985"], "partof_collection": ["chronicling amer