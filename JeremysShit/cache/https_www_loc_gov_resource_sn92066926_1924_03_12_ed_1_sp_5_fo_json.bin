t/product/purl/WSL/i/2a174b62-83f4-4ab5-84cc-ea13d7eb16c8", "https://wyomingdigitalcollections.ptfs.com/aw-server/rest/product/purl/WSL/i/966df524-4faf-4ec2-b824-b621120f8016"], "campaigns": [], "contributor": ["wyoming water development commission", "j-u-b engineers inc"], "date": "2024", "dates": ["2024"], "description": ["\"In recent years, the Willwood Irrigation District has performed several studies to identify areas of concern throughout the canal system.  These include the Willwood dam, several drop structures and chutes, and sections of canal reaches.  The identified facilities need rehabilitation to continue to service the Willwood Irrigation District (WID). This report provides a description of the proposed rehabilitation.\" Page 5"], "digitized": true, "extract_timestamp": "2025-09-30T15:01:16.732Z", "group": ["catalog-split-15", "catalog", "main-catalog-split-15"], "hassegments": false, "id": "http://lccn.loc.gov/2024438404", "image_url": [], "index": 5, "language": ["english"], "location": ["park county", "wyoming", "park"], "number": ["2025-07-10t17:35:39.200000", "1483681773", "2024438404"], "original_format": ["book"], "other_title": ["Willwood Irrigation District"], "partof": ["catalog"], "score": 38.22279, "shelf_id": "TC557.W8 J83 2024", "site": ["catalog"], "subject": ["park county", "dams", "entretien et r\u00e9parations", "irrigation", "wyoming", "maintenance and repair", "barrages", "park"], "timestamp": "2025-09-30T16:33:33.936Z", "title": "Willwood Irrigation District. Level II study", "type": ["text"], "url": "//lccn.loc.gov/2024438404"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2025465678", "http://www.loc.gov/item/2025465678/", "https://search.catalog.loc.gov/instances/34f3a88f-72b8-4e4d-9672-9bd9406cb4b3", "https://wyomingdigitalcollections.ptfs.com/aw-server/rest/product/purl/WSL/i/65c32d32-d03a-4f0c-8c64-f96bc469d22f", "https://wyomingdigitalcollections.ptfs.com/aw-server/rest/product/purl/WSL/i/5d795147-9591-48ae-961d-2f5644d8ea58"], "campaigns": [], "contributor": ["wyoming water development commission", "engineering associates (cody, wyo.)", "lakeview irrigation district"], "date": "2025", "dates": ["2025"], "description": ["\"The purpose of this study was centered around two main tasks, seepage analysis of specified sections of the Lakeview Irrigation District\u2019s (LID) main canal and the evaluation of a potential water exchange with the Cody Canal Irrigation District (CCID).\"- page 1"], "digitized": true, "extract_timestamp": "2025-12-13T19:53:25.457Z", "group": ["catalog-split-13", "catalog", "main-catalog-split-13"], "hassegments": false, "id": "http://lccn.loc.gov/2025465678", "image_url": [], "index": 6, "language": ["english"], "location": ["park county", "wyoming", "park"], "number": ["2025465678", "2025-12-03t12:00:03.900000", "1542849589"], "original_format": ["book"], "partof": ["catalog"], "score": 38.22279, "shelf_id": "http://lccn.loc.gov/2025465678", "site": ["catalog"], "subject": ["park county", "exploitation", "ressources en eau", "irrigation", "wyoming", "water resources development", "park"], "timestamp": "2025-12-13T20:48:03.690Z", "title": "Lakeview irrigation district rehabilitation: Level II study", "type": ["text"], "url": "//lccn.loc.gov/2025465678"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017884773", "http://www.loc.gov/item/2017884773/", "https://hdl.loc.gov/loc.pnp/highsm.48142", "http://www.loc.gov/resource/highsm.48142/", "https://www.loc.gov/pictures/item/2017884773/", "http://www.loc.gov/pictures/item/2017884773/", "https://www.loc.gov/pictures/collection/highsm/item/2017884773/", "http://www.loc.gov/pictures/collection/highsm/item/2017884773/"], "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2015-01-01", "dates": ["2015"], "description": ["Title, date and keywords based on information provided by the photographer. This was one of ten internment camps for Japanese Americans evicted in the American West during World War II by executive order of President Franklin Roosevelt after the bombing of Pearl Harbor, Hawaii, by Japanese planes in December 1941 This had been an irrigation project sit. Construction of 650 military-style barracks and surrounding guard towers began in June 1942, and the camp opened on August 11. Gift; Carol M. Highsmith Photography, Inc.; 2017; (DLC/PP-2002:038-13). Forms part of: Gates Frontiers Fund Wyoming Collection within the Carol M. Highsmith Archive. Credit line: Gates Frontiers Fund Wyoming Collection within the Carol M. Highsmith Archive, Library of Congress, Prints and Photographs Division."], "digitized": true, "extract_timestamp": "2022-08-02T12:47:07.843Z", "group": ["catalog", "highsm", "catalog-split-15", "main-catalog", "carol-m-highsmith", "main-catalog-split-15"], "hassegments": false, "id": "http://www.loc.gov/item/2017884773/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48142/full/pct:3.125/0/default.jpg#h=178&w=267", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48142/full/pct:6.25/0/default.jpg#h=356&w=534", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48142/full/pct:12.5/0/default.jpg#h=712&w=1068", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48142/full/pct:25/0/default.jpg#h=1424&w=2137"], "index": 7, "language": ["english"], "location": ["park county", "united states", "wyoming"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/hig2018005820", "http://www.loc.gov/item/2017884773", "http://www.loc.gov/item/20373334", "online resource", "2022-05-25t13:59:46", "2018-02-23t13:33:41", "2017884773"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "highsmith (carol m.) archive", "catalog", "prints and photographs division"], "score": 23.707708, "shelf_id": "LC-DIG-highsm- 48142", "sit