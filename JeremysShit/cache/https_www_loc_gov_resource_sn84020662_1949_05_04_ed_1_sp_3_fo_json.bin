commit tee should hear testimony in the i Territory PIONEER WATER DELIVERY SAND"], "digitized": true, "extract_timestamp": "2024-05-22T12:57:44.415Z", "group": ["ndnp/ak", "alaska-state-library-historical-collections-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020662/1949-05-04/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_chinooksalmon_ver03:data:sn84020662:00414185940:1949050401:1213/full/pct:6.25/0/default.jpg#h=424&w=316", "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_chinooksalmon_ver03:data:sn84020662:00414185940:1949050401:1213/full/pct:12.5/0/default.jpg#h=848&w=632", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_chinooksalmon_ver03/data/sn84020662/00414185940/1949050401/1213.xml&format=alto_xml"], "index": 3, "language": ["english"], "location": ["nome", "united states", "alaska"], "location_city": ["nome"], "location_country": ["united states"], "location_county": ["nome"], "location_state": ["alaska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "8", "0", "sn84020662", "5", "0000000003", "1", "9"], "number_edition": ["1"], "number_lccn": ["sn84020662"], "number_page": ["0000000003"], "number_reel": ["0", "0", "4", "1", "4", "1", "8", "5", "9", "4", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Nugget"], "partof": ["serial and government publications division", "chronicling america", "the nome nugget (nome, alaska) 1938-current"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the nome nugget (nome, alaska) 1938-current"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn84020662/1949-05-04/ed-1/?sp=3"}], "segmentof": ["http: