10262], "number": ["microfilm master", "27098353", "2533", "2766-6050", "chapel hill pub libr", "2025-07-01t13:41:10.400000", "east carolina univ", "sn92073233", "2026-04-13t21:30:13", "north carolina div of archives & hist", "sn92073229", "http://www.loc.gov/item/sn92073229/1963-12-29/ed-1/", "2023-08-09t16:16:15.715047", "online resource", "http://www.loc.gov/item/sn92073229/1923-03-01/ed-1/", "microfilm service copy"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "catalog", "the chapel hill weekly (chapel hill, n.c.) 1923-1972", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["semiweekly"], "score": 78.96721, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["chapel hill (n.c.)", "orange county", "newspapers", "orange", "united states", "north carolina", "orange county (n.c.)", "chapel hill"], "timestamp": "2026-07-18T09:33:58.694Z", "title": "The Chapel Hill weekly", "type": ["title"], "url": "https://www.loc.gov/item/sn92073229/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021270622/"], "campaigns": [], "date": "1923", "dates": ["[1923 TO 1972]"], "description": ["Semiweekly, May 10, 1955-Sept. 3, 1972 Began with vol. I, no. 1 (March 1, 1923); ceased v. 50, no. 70 (Sept. 3, 1972). \"Serving the Chapel Hill area since 1923.\" Also issued on microfilm. Vol. I, No. 1 (March 1, 1923); title from masthead (Chroniclingamerica.loc.gov, viewed January 19, 2021). Volume 41, Number 103 (December 29, 1963) (Chroniclingamerica.loc.gov, viewed January 19, 2021). Chapel Hill newspaper"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:58.293Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021270622/", "image_url": [], "index": 4, "language": ["english"], "location": ["orange county", "orange", "united states", "north carolina", "chapel hill"], "number": ["2026-04-13t21:30:13", "2021270622", "1231983097", "2766-6069", "online resource"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the chapel hill weekly (chapel hill, n. c.) 1923-1972 [online resource]"], "publication_frequency": ["semiweekly"], "score": 69.75982, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["chapel hill (n.c.)", "orange county", "newspapers", "orange", "united states", "north carolina", "orange county (n.c.)", "chapel hill"], "timestamp": "2026-05-26T21:02:54.346Z", "title": "The Chapel Hill weekly", "type": ["title"], "url": "https://www.loc.gov/item/2021270622/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271240/"], "campaigns": [], "date": "1879", "dates": ["[1879 TO 1999]"], "description": ["Weekly, Oct. 13, 1911- Began in 1879. Published as: Recorder and North Carolina tobacco journal, <Apr. 18, 1883->. Published as: Hillsboro recorder, Nov. 14, 1895 and Dec. 12, 1895. Published in Hillsboro, N.C., Aug. 7, 1895-<Dec. 19, 1895>. Publisher: The Durham Sun Publishing Company, <January 5-December 29, 1911>. Democratic. Issues for <July 2, 1879-Nov. 29, 1882> also called: Old ser., no. 59-63. Issues for <Apr. 18, 1883-Dec. 29, 1911> have vol. numbering as: Vol. 63, no. 29-v. 92, no. 35. Description based on: New Series----Vol. 1, No. 2 (July 2, 1879); title from masthead (Chroniclingamerica.loc.gov, viewed November 23, 2016). Latest issue consulted: Volume 92, Number 35 (December 29, 1911) (Chroniclingamerica.loc.gov, viewed November 23, 2016)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:37.472Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271240/", "image_url": [], "index": 5, "language": ["english"], "location": ["hillsboro", "orange county", "durham", "orange", "united states", "durham county", "hillsborough", "north carolina"], "number": ["online resource", "964078563", "2475-0891", "2016271240", "2016271239", "2016271238", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Recorder and North Carolina tobacco journal", "Hillsboro recorder"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the durham recorder (durham, n. c.) 1879-19?? [online resource]"], "publication_frequency": ["weekly"], "score": 44.17392, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["hillsboro", "orange county", "newspapers", "durham", "durham (n.c.)", "orange", "durham county", "hillsborough (n.c.)", "hillsborough", "united states", "durham county (n.c.)", "north carolina", "orange county (n.c.)"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "The Durham recorder", "type": ["title"], "url": "https://www.loc.gov/item/2016271240/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271244/"], "campaigns": [], "date": "1887", "dates": ["[1887 TO 1899]"], "description": ["Weekly Began with vol. I, No. 1 (August 11, 1887). Description based on: Vol. I, No. 1 (August 11, 1887); title from masthead (Chroniclingamerica.loc.gov, viewed November 30, 2016). Latest issue consulted: Vol. I, No. 52 (August 2, 1888) (Chroniclingamerica.loc.gov, viewed November 30, 2016)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:37.472Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271244/", "image_url": [], "index": 6, "language": ["english"], "location": ["hillsboro", "orange county", "orange", "united states", "hillsborough", "north carolina"], "number": ["online resource", "2016271240", "964614496", "2016271244", "2475-157x", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "hillsboro recorder (hillsboro, n.c.) 1887-18?? [online resource]"], "publication_frequency": ["weekly"], "score": 44.17392, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["hillsboro", "orange county", "newspapers", "orange", "united states", "hillsborough (n.c.)", "hillsborough", "north carolina", "orange county (n.c.)"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "Hillsboro recorder", "type": ["title"], "url": "https://www.loc.gov/item/2016271244/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271245/"], "campaigns": [], "date": "1820", "dates": ["[1820 TO 1879]"], "description": ["Weekly Began in 1820; ceased in 1879. Democratic. Issues for <Jan. 26, 1870-Mar. 5, 1879> have vol. numbering: New ser., v. 2, no. 1-v.7, no. 8 = old ser., v. 50-59. Suspended Apr. 19-May 3, May 17-June 26, 1865. Available on microfilm from North Carolina Dept. of Archives and History. Description based on: Vol. XVI, No. 805 (February 5, 1836); title from masthead (Chroniclingamerica.loc.gov, viewed November 30, 2016). Latest issue consulted: New Series----Vol. 7. No. 3---- (January 22, 1879) ----Old Series, Vol. 58. (Chroniclingamerica.loc.gov, viewed November 30, 2016). Durham recorder 2475-0891 (DLC) 2016271240 (OCoLC)964078563"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:37.472Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271245/", "image_url": [], "index": 7, "language": ["english"], "location": ["hillsboro", "orange county", "orange", "united states", "hillsborough", "north carolina"], "number": ["964624444", "online resource", "2016271240", "2475-1618", "2016271245", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the hillsborough recorder (hillsborough, n. c.) 1820-1879 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 44.17392, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["hillsboro", "orange county", "newspapers", "orange", "united states", "hillsborough (n.c.)", "hillsborough", "north carolina", "orange county (n.c.)"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "The Hillsborough recorder", "type": ["title"], "url": "https://www.loc.gov/item/2016271245/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271246/"], "campaigns": [], "date": "1880", "dates": ["[1880 TO 1918]"], "description": ["Weekly Began in 1880. Ceased in 1918? New ser. v. 8, no. 48 skipped in enumeration; n.s. v. 10, no. 51-52 skipped in enumeration. Two issues called n.s. v. 9, no. 28, Apr. 12, 1890 and Apr. 19, 1890. New ser. v. 10, no. 24, Apr. 4, 1891, misdated as Mar. 4, 1891 in masthead; n.s. v. 15, no. 2 Dec. 7, 1895, misdated as Nov. 7, 1895 in masthead. Some issues have \"Supplement\". Democratic. Description based on: New Series.-Vol. I.-No. 3. (October 23, 1880); title from masthead (Chroniclingamerica.loc.gov, viewed November 30, 2016). Latest issue consulted: New Series Vol. XXVIII, No 17 (May 11, 1916) (Chroniclingamerica.loc.gov, viewed November 30, 2016)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:37.472Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271246/", "image_url": [], "index": 8, "language": ["english"], "location": ["orange county", "orange", "united states", "hillsborough", "north carolina"], "number": ["online resource", "2475-1669", "964628528", "2026-04-13t21:30:13", "2016271246"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "orange county observer (hillsborough, n. c.;hillsborough, n.c.;hillsboro, n.c.) 1880-1918 [online resource]"], "publication_frequency": ["weekly"], "score": 44.17392, "shelf_id": "ISSN RECORD", "site": ["usnd"