ory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271084/", "image_url": [], "index": 10, "language": ["english"], "location": ["ada", "united states", "boise", "idaho"], "number": ["2020271084", "1184051840", "online resource", "2693-5821", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["the boise citizen (boise, idaho) 1906-1910 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 51.19147, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "boise (idaho)", "idaho", "ada", "united states", "boise"], "timestamp": "2026-05-26T21:00:49.563Z", "title": "The Boise citizen", "type": ["title"], "url": "https://www.loc.gov/item/2020271084/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2017218787/"], "campaigns": [], "date": "1913", "dates": ["[1913 TO 1914]"], "description": ["Weekly Began in 1913; ceased with vol. II, no. 28 (December 10, 1914) Publisher: C. H. Shepherd, November 7, 1914. Description based on: Vol. II, no. 24 (November 14, 1914); title from masthead (Chroniclingamerica.loc.gov, viewed September 13, 2017). Latest issue consulted: Vol. II, no. 28 (December 10, 1914) (Chroniclingamerica.loc.gov, viewed September 13, 2017). Gem worker and the Idaho labor herald"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:40.728Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2017218787/", "image_url": [], "index": 11, "language": ["english"], "location": ["ada", "united states", "boise", "idaho"], "number": ["1003531943", "online resource", "2574-9064", "2017218787", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "idaho labor herald (boise, idaho) 1913-1914 [online resource]", "serial and government publications division"],