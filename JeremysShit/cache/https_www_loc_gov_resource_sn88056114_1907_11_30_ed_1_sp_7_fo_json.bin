hi_everglades_ver01/data/sn88056114/0041421194A/1907113001/0074.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn88056114/1907-11-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/idhi/batch_idhi_everglades_ver01/data/sn88056114/0041421194A/1907113001/0074.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_everglades_ver01:data:sn88056114:0041421194A:1907113001:0068/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/idhi/batch_idhi_everglades_ver01/data/sn88056114/0041421194A/1907113001/0074.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn88056114/1907-11-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/idhi/batch_idhi_everglades_ver01/data/sn88056114/0041421194A/1907113001/0074.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn88056114/1907-11-30/ed-1/?sp=7"], "batch": ["idhi_everglades_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/idaho/", "2/united states/idaho/ada/", "3/united states/idaho/ada/boise/"], "contributor": ["idaho state historical society"], "date": "1907-11-30", "dates": ["1907-11-30"], "description": ["The Currency Problem If the eight 7 odd million inhabitants of the United States are not inextricably involved in bewilderment over the monetary situation it is because they have not read all the utterances of the statesmen to whom they look for advice After a number of specifics had been suggested for the cure of the ailment that is tantalizing the country the Secretary of the Treasury hit upon an expedient and put it in force in the confident be lief that it would restore the normal currency move He authorized the issue of 50000000 in ment government interest bearing bonds and 100000000 in government interest bearing certificates the latter practically the notes of the people to the people on which the people are to pay to themselves three cents each year on each dollar The President of the United States made haste to approve the action of his Secretary in a public letter in which he expressed a belief that the additional se curities put forth would in some way relieve the stringency and impart greater activity to business transactions The Secretary of the Treasury received like en couragement from other high authority which broke out in spots all"], "digitized": true, "extract_timestamp": "2023-07-06T12:34:47.049Z", "group": ["ndnp/idhi", "idaho-state-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88056114/1907-11-30/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_everglades_ver01:data:sn88056114:0041421194A:1907113001:0074/full/pct:6.25/0/default.jpg#h=403&w=305", "https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_everglades_ver01:data:sn88056114:0041421194A:1907113001:0074/full/pct:12.5/0/default.jpg#h=806&w=610", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/idhi/batch_idhi_everglades_ver01/data/sn88056114/0041421194A/1907113001/0074.xml&format=alto_xml"], "index": 7, "language": ["english"], "location": ["boise", "united states", "ada", "idaho"], "location_city": ["boise"], "location_country": ["united states"], "location_county": ["ada"], "location_state": ["idaho"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "0", "sn88056114", "2", "a", "1", "9", "0000000007"], "number_edition": ["1"], "number_lccn": ["sn88056114"], "number_page": ["0000000007"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "1", "9", "4", "a"], "onlin