gov/text-services/word-coordinates-service?segment=/service/ndnp/scu/batch_scu_kiwi_ver03/data/sn86063758/00517016585/1927031101/0363.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_kiwi_ver03:data:sn86063758:00517016585:1927031101:0363/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/scu/batch_scu_kiwi_ver03/data/sn86063758/00517016585/1927031101/0363.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86063758/1927-03-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/scu/batch_scu_kiwi_ver03/data/sn86063758/00517016585/1927031101/0363.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_kiwi_ver03:data:sn86063758:00517016585:1927031101:0363/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/scu/batch_scu_kiwi_ver03/data/sn86063758/00517016585/1927031101/0363.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86063758/1927-03-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/scu/batch_scu_kiwi_ver03/data/sn86063758/00517016585/1927031101/0363.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86063758/1927-03-11/ed-1/?sp=1"], "batch": ["scu_kiwi_ver03"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/south carolina/", "2/united states/south carolina/newberry/", "3/united states/south carolina/newberry/newberry/"], "contributor": ["university of south carolina; columbia, sc"], "date": "1927-03-11", "dates": ["1927-03-11"], "description": ["VOLUME LXIII NUMBER 20 NEWBERRY S C FRIDAY MARCH 11 1927 TWICE A WEEK 150 A YEAR BUSINESS OUTLOOK VERY PROMISWNG SO SAY NEWBERRY MER CHANTS AND BUSINESS MEN Interviews With Merchants and Business Men Who Attended Ban quet Monday Evening The Herald and News thought it would be a fine thing to find out what some of the merchants and business men thought of the meet ing and banquet given last Monday night and what effect if any it would have on the business outlook of the town in the future and would have been glad to have had an ex pression from all of those who were present but we just took them at random and tried not to overlook any one and if some one has beefl missed there was no intention to pick The spirit of optimism seem ed to fill the atmosphere at the meet ing and the enthusiasm about which several of the speakers talked as so necessary to the growth and development of any community was so much in evidence that The Herald and News thought it might have a good influence over some who were not present to get those present to"], "digitized": true, "extract_timestamp": "2025-04-13T07:56:15.099Z", "group": ["ndnp/scu", "university-of-south-carolina-columbia-sc-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86063758/1927-03-11/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_kiwi_ver03:data:sn86063758:00517016585:1927031101:0363/full/pct:6.25/0/default.jpg#h=493&w=381", "https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_kiwi_ver03:data:sn86063758:00517016585:1927031101:0363/full/pct:12.5/0/default.jpg#h=986&w=763", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/scu/batch_scu_kiwi_ver03/data/sn86063758/00517016585/1927031101/0363.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["south carolina", "newberry county", "united states", "newberry"], "location_city": ["newberry"], "location_country": ["united states"], "location_county": ["newberry"], "location_state": ["south carolina"], "mime_type": ["image/jp2", "application/pdf"