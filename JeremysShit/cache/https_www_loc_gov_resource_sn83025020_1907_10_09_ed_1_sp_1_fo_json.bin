v/static/images/original-format/group-of-images.svg"], "index": 5, "language": ["english"], "location": ["indian territory", "ponca indian reservation", "oklahoma"], "mime_type": ["image/jpg"], "number": ["http://www.loc.gov/item/91791473", "2015-02-05t10:03:44", "http://www.loc.gov/item/11586763", "91791473"], "online_format": ["image"], "original_format": ["photo, print, drawing", "collection"], "partof": ["lot 12831", "groups of images (lots)", "prints and photographs division", "catalog"], "score": 26.161497, "shelf_id": "LOT 12831 (F) [P&P]", "site": ["pictures", "catalog"], "subject": ["ponca indians", "indian territory", "group portraits", "indians of north america", "oklahoma", "gelatin silver prints", "sun dance", "ponca dance", "rites & ceremonies", "indian reservations", "spiritual life", "portrait photographs", "ponca indian reservation"], "timestamp": "2026-03-07T14:22:21.230Z", "title": "Ponca Indian sun dance at the Ponca Reservation, Indian Territory", "type": ["still image"], "url": "https://www.loc.gov/item/91791473/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2011590003", "http://www.loc.gov/item/2011590003/", "https://search.catalog.loc.gov/instances/fb7fea16-4296-58dc-854e-3fd0c4a83a97", "https://hdl.loc.gov/loc.gmd/g4021e.ct003199", "http://www.loc.gov/resource/g4021e.ct003199/"], "campaigns": [], "contributor": ["united states. army. corps of topographical engineers"], "date": "1866", "dates": ["1866"], "description": ["Relief shown by hachures. Annotated in red and black ink. \"Prepared from the Map of Danl. C. Major, U.S. Astt. showing the boundaries of the Choctaw and Chickasaw Nations, the Creek, Seminole, and Leased Indian Country established by authority of the Commrs. of Indian Affairs in 1858-59. and from Lieut. Col. J.E. Johnston's Map of the Southern Boundary of Kansas in 1857. The Map of the Creek Country by Lieut. L. C. Woodruff, Topl. Engrs., in 1850-51.\" Described in LC Many nations. Cut and mounted on cloth. Av