7, "language": ["english"], "location": ["new haven", "connecticut", "united states"], "number": ["online resource", "1091358878", "2019271072", "2026-04-13t21:30:13", "2642-729x", "2019271073"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the connecticut labor press (new haven, conn.) 191?-1921 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 29.881104, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["labor movement", "connecticut", "new haven (conn.)", "newspapers", "new haven", "united states"], "timestamp": "2026-05-26T20:58:32.070Z", "title": "The Connecticut labor press", "type": ["title"], "url": "https://www.loc.gov/item/2019271072/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019271073/"], "campaigns": [], "date": "1921", "dates": ["[1921 TO 1925]"], "description": ["Weekly Began wiith volume VII, number 22 (January 21, 1921); ceased with volume XIII, number 7 (March 14, 1925). \"Connecticut\" appears above title ornament. Also issued on microfilm from Connecticut State Library, Hartford, CT. Description based on: Volume VII, Number 22 (January 21, 1921); title from masthead (Chroniclingamerica.loc.gov, viewed April 3, 2019). Latest issue consulted: Volume XIII, Number 7 (March 14, 1925) (Chroniclingamerica.loc.gov, viewed April 3, 2019)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:47.120Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019271073/", "image_url": [], "index": 8, "language": ["english"], "location": ["new haven", "connecticut", "united states"], "number": ["1091359433", "online resource", "2019271072", "2642-7311", "2026-04-13t21:30:13", "2019271073"], "original_format": ["newspaper"], "other_title": ["Labor news"], "partof": ["directory of u.s. newspapers in american libraries", "the connecticut labor n