": ["connecticut", "new haven (conn.)", "aerial views", "new haven", "united states"], "timestamp": "2026-04-29T16:15:55.865Z", "title": "The city of New Haven, Conn. 1879", "type": ["cartographic"], "url": "https://www.loc.gov/item/75693153/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2022594804", "http://www.loc.gov/item/2022594804/", "https://search.catalog.loc.gov/instances/48ac1ec7-0e60-5cd0-a23a-2bd5718c1c76", "https://hdl.loc.gov/loc.gmd/gmdtitlecolfold.ct-058", "http://www.loc.gov/resource/gmdtitlecolfold.ct-058/"], "campaigns": [], "date": "1638", "dates": ["1638"], "description": ["This record covers single maps of Connecticut cities and towns, which are not represented in the LC database by separate catalog records. This collection includes single printed maps and photocopies of printed or manuscript single maps and may also include some multi-sheet single maps, plates from atlases, books or periodicals, and printed facsimiles. These maps may also show various subjects, such as land owners and recreation and tourism. To request a specific map or for more information, contact a reference librarian in the Geography & Map Division (202) 707-6277 or through the \"Ask a librarian\" link through the Geography & Map Division website https://ask.loc.gov/map-geography/. Title supplied by cataloger."], "digitized": true, "extract_timestamp": "2026-04-29T15:17:49.207Z", "group": ["gmd/multimap", "catalog-split-04", "catalog", "multimaps", "main-catalog-split-04"], "hassegments": true, "id": "http://www.loc.gov/item/2022594804/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:58:ct-058:ct-058-00001/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:58:ct-058:ct-058-00001/full/pct:12.5/0/default.jpg#h=454&w=348", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:58:ct-058:ct-058-00001/full/pct:25/0/default.jpg#h=908&w=697"], "ind