"sn82015425", "00529040982"], "number_edition": ["1"], "number_lccn": ["sn82015425"], "number_reel": ["00529040982"], "numeric_shelf_id": 195804091, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//gu/batch_gu_goblin_ver01/data/sn82015425/00529040982/1958040901/1958040901_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn82015425/marcxml"}], "other_title": ["Published occasionally in 1934-1945 as: Atlanta world"], "partof": [{"count": 10344, "title": "atlanta daily world (atlanta, georgia) 1932-current", "url": "https://www.loc.gov/search/?fa=partof:atlanta+daily+world+%28atlanta,+georgia%29+1932-current&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["atlanta daily world (atlanta, georgia) 1932-current"], "place_of_publication": "Atlanta, Georgia", "publication_frequency": ["weekly"], "raw_lccn": "sn 82015425 ", "reel_numbers": ["00529040982"], "resources": [{"files": 6, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_goblin_ver01:data:sn82015425:00529040982:1958040901:0585/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn82015425/1958-04-09/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn82015425, 1958-04-09, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/gu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "fulton county", "fulton county (ga.)", "african american", "atlanta (ga.)", "atlanta", "georgia", "african american newspapers", "united states", "fulton", "african americans"], "subject_ethnicity": ["african american"], "subject_headings": ["African Americans--Georgia--Atlanta--Newspapers", "African American newspapers--Georgia", "Atlanta (Ga.)--Newspapers", "Fulton County (Ga.)--Newspapers", "African American newspapers", "African Americans", "Georgia", "Georgia--Atlanta", "Georgia--Fulton County", "United States--Georgia--Fulton--Atlanta"], "subjects": [{"african american": "https://www.loc.gov/search/?fa=subject:african+american&fo=json"}, {"african american newspapers": "https://www.loc.gov/search/?fa=subject:african+american+newspapers&fo=json"}, {"african americans": "https://www.loc.gov/search/?fa=subject:african+americans&fo=json"}, {"atlanta": "https://www.loc.gov/search/?fa=subject:atlanta&fo=json"}, {"atlanta (ga.)": "https://www.loc.gov/search/?fa=subject:atlanta+%28ga.%29&fo=json"}, {"fulton": "https://www.loc.gov/search/?fa=subject:fulton&fo=json"}, {"fulton county": "https://www.loc.gov/search/?fa=subject:fulton+county&fo=json"}, {"fulton county (ga.)": "https://www.loc.gov/search/?fa=subject:fulton+county+%28ga.%29&fo=json"}, {"georgia": "https://www.loc.gov/search/?fa=subject:georgia&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "subjects_ethnicity": [{"african american": "https://www.loc.gov/search/?fa=subject_ethnicity:african+american&fo=json"}], "timestamp": "2025-07-06T05:17:15.320Z", "title": "Atlanta daily world (Atlanta, Georgia), April 9, 1958, (City Edition)", "type": ["issue"], "url": "https://www.loc.gov/item/sn82015425/1958-04-09/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn82015425/", "http://lccn.loc.gov/sn82015425", "https://search.catalog.loc.gov/instances/f2bd6460-edd4-541a-aaae-803c5c1c6311"], "batch": ["gu_falkor_ver01"], "campaigns": [], "date": "1932", "description": ["Weekly, <2013-> Vol. 5, no. 36 [i.e. 37] (Mar. 18, 1932)- <1932->, some issues include a separately titled section: S.N.S. weekly, a rotogravure which appears also as a section of certain newspapers published in Birmingham and Memphis. May be some irregularities in enumeration. Also issued on microfilm from Bell & Howell Information and Learning, and the Library of Congress, Photoduplication Service. Available on microfilm from ProQuest, <2001-> Some issues bear edition statement: City edition; some issues bear statement: National edition. It is unclear whether National edition is truly a separately published geographic edition, or whether both editions may have been issued as part of the same title, especially since other edition statements such as \"Church edition\" appear on occasional issues, <1932->, and the issue for July 3, 1932, bears the statement, \"2 sections, get both!\", which may indicate that the national and city \"editions\" actually indicate two sections of one issue. Latest issue consulted: Vol. 85, issue 22 (Jan. 3/9, 2013) (microfilm surrogate)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:15.450Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-12", "catalog", "united-states-newspaper-directory", "main-catalog-split-12"], "hassegments": false, "id": "http://www.loc.gov/item/sn82015425/", "image_url": [], "index": 1, "language": ["english"], "latlong": [33.748547, -84.391502], "location": ["fulton county", "atlanta", "georgia", "united states", "fulton"], "location_str": "", "lonlat": [-84.391502, 33.748547], "number": ["new york pub libr res libr", "microfilm master", "10343", "online resource", "center for res libr, newsp proj", "microfilm service copy", "8807951", "library of congress", "1528-6142", "chicago pub libr", "sn82015425", "sn85047544", "2025-11-07t15:09:00.300000", "http://www.loc.gov/item/sn82015425/1963-12-31/ed-1/", "univ of kentucky libr", "wisconsin hist soc, newsp proj", "original", "http://www.loc.gov/item/sn82015425/1932-03-18/ed-1/", "univ of georgia", "duke univ libr", "2025-05-23t21:30:26", "princeton univ", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Published occasionally in 1934-1945 as: Atlanta world"], "partof": ["chronicling america", "atlanta daily world (atlanta, georgia) 1932-current", "catalog", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"],