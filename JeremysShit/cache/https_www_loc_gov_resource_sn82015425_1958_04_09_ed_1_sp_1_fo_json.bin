nnounced Tuesday that following tonights nomination speeches the GTEA will hear various reports which will be submitted to the"], "digitized": true, "extract_timestamp": "2025-07-06T04:52:20.438Z", "group": ["ndnp/gu", "digital-library-of-georgia-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82015425/1958-04-09/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_goblin_ver01:data:sn82015425:00529040982:1958040901:0585/full/pct:3.125/0/default.jpg#h=266&w=214", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_goblin_ver01:data:sn82015425:00529040982:1958040901:0585/full/pct:6.25/0/default.jpg#h=532&w=429", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_goblin_ver01:data:sn82015425:00529040982:1958040901:0585/full/pct:12.5/0/default.jpg#h=1064&w=859", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_goblin_ver01/data/sn82015425/00529040982/1958040901/0585.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["fulton county", "atlanta", "georgia", "united states", "fulton"], "location_city": ["atlanta"], "location_country": ["united states"], "location_county": ["fulton"], "location_state": ["georgia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "8", "0", "0000000001", "5", "2", "1", "sn82015425", "9"], "number_edition": ["1"], "number_lccn": ["sn82015425"], "number_page": ["0000000001"], "number_reel": ["0", "0", "5", "2", "9", "0", "4", "0", "9", "8", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Published occasionally in 1934-1945 as: Atlanta world"], "partof": ["atlanta daily world (atlanta, georgia) 1932-current", "chronicling america", "serial and government publications division"], "partof_collection": ["chronicling america"], "pa