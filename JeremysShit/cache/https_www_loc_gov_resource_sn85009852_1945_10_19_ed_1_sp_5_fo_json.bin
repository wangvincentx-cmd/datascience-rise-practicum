vice/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945101901/0467.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn85009852/1945-10-19/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945101901/0467.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945101901:0463/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945101901/0467.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn85009852/1945-10-19/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945101901/0467.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85009852/1945-10-19/ed-1/?sp=5"], "batch": ["ct_carpsurprise_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/hartford/", "3/united states/connecticut/hartford/new britain/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1945-10-19", "dates": ["1945-10-19"], "description": ["te c Hy y Z f ____Jijfi HEAVY TRUCKING RIGGING STEEL ERECTION CRANE SERVICE The Roger Sherman Transfer Company East Hartford Tel 84153 Opticians Complete optical Laboratory for quick service in making new glasses or replacing broken lenses BIFOCAL AND COLORED LENSES ACCURATELY DUPLICATED LOWRY JOYCE Established 1916 43 Asylum St Near Main HARTFORD AND ST EXPRESS WAREHOUSE COMMERCIAL MOVING W and STORAGE BAGGAGE TRANSFER attended to LEO LUPOLI Owner 426 Woodland St Hartford Conn Phone 71121 SPRING FLOWERS GO TO YOUR HEAD ANNE SARY Millinery 57 PRATT STREET HARTFORD CONN Telephone 60436 BY APPOINTMENT ONLY Complete Line of Dairy Products HOMOGENIZED VITAMIN D MILK 4 4 For Prompt Courteous Service Phone 82131 SERVING HARTFORD WEST HARTFORD MANCHESTER EAST HARTFORD SO WINDSOR GLASTONBURY J A Rergren Dairy Farms York STRANGFELD FURRIER REPAIRING REMODELING CLEANING COLD FUR STORAGE Phone 68317 57 Pratt St 3rd Floor Hartford Complete SpringWheelAxle Service In this period of material shortages cars and part must last longer Springs are as necessary as gasoline It b true econ omy to have them put in order Our 31 years experience enables us to offer complete service and guarantee SATISFACTION SUPERIOR SPRING MFG CO HENRY KRAEKEMIER Prop 397 Washington St"], "digitized": true, "extract_timestamp": "2024-12-15T22:26:55.485Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85009852/1945-10-19/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945101901:0467/full/pct:3.125/0/default.jpg#h=282&w=205", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945101901:0467/full/pct:6.25/0/default.jpg#h=564&w=410", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945101901:0467/full/pct:12.5/0/default.jpg#h=1129&w=821", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945101901/0467.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["east windsor", "hartford", "connecticut", "new britain", "united states", "glastonbury", "south windsor", "east hartford"], "location_city": ["new britain"], "location_country": ["united states