ordinates-service"}], "segment_id": "/service/ndnp/mdu/batch_mdu_anhinga_ver01/data/sn88065202/00340588204/1930122501/0414.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn88065202/1930-12-25/ed-1/?sp=1"], "batch": ["mdu_anhinga_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/maryland/", "2/united states/maryland/garrett/", "3/united states/maryland/garrett/oakland/"], "contributor": ["university of maryland, college park, md"], "date": "1930-12-25", "dates": ["1930-12-25"], "description": ["VOLUME 54 FOR 1931 IN LOCAL TROOP 22 Scouts Earn 72 Merit Badges Throughout YearTroop Now Has Fortyone Members 26 ADVANCE IN SCOUTING Twentytwo first and second class scouts members of Oakland Troop No 1 passed 72 merit badges 26 members of the troop advanced at least one rank one member received the rank of Eagle scout and other achievements for the year 1930 are recorded in the annual report which has just been sent to National Head quarters by George H Hanst scout master This interest in class study coupled with the two weeks camping trip and participation in many other events has made the year 1930 an important one for the local troop At the present time there are 41 members of the troop 5 Tenderfoot scouts 15 second class and 21 first class scouts Three of the first class scouts are Eagle scouts and one of these is KnightEagle the highest rank any boy can obtain Only seven were removed from the troop roll during the past year and these were called away by school work moving away ete Those who advanced at least one rank during the past year are Eugene Show Willus Hull Leroy Stewart"], "digitized": true, "extract_timestamp": "2023-03-01T18:28:08.704Z", "group": ["ndnp/mdu", "university-of-maryland-college-park-college-park-md-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88065202/1930-12-25/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:ba