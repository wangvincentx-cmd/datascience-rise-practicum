"[1888 TO 1890]"], "description": ["Weekly Began with vol. 1, no. 1 (June 16, 1888); ceased April 9, 1890. Published every Saturday through 1888. Published every Wednesday starting in 1889. Description based on: Vol. 1, no. 1 (June 16, 1888); title from masthead (Chroniclingamerica.loc.gov, viewed August 8, 2014). Latest issue consulte: Vol. 1, no. 19 (October 13, 1888) (Chroniclingamerica.loc.gov, viewed August 8, 2014). Great Falls weekly leader (Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:26.498Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218460/", "image_url": [], "index": 23, "language": ["english"], "location": ["montana", "united states", "cascade", "great falls"], "number": ["2026-04-13t21:30:13", "online resource", "2374-1848", "885311417", "2014218460"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the great falls leader (great falls, mont.) 1888-1890 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 49.9419, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "montana", "cascade", "great falls (mont.)", "great falls", "united states"], "timestamp": "2026-05-26T20:50:29.180Z", "title": "The Great Falls leader", "type": ["title"], "url": "https://www.loc.gov/item/2014218460/"}], "next_resource": {"label": "Next Issue", "url": "https://www.loc.gov/resource/sn86075096/1958-05-01/ed-1/?fo=json&sp=1"}, "options": {"access_group": [""], "access_group_raw": "", "all": null, "api_version": "1", "app_context": null, "application_version": "$Revision$", "attribute": null, "attribute!": null, "attribute_map": null, "cache_tags": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee", "newspaper-titles", "ndnp/newspapers", "catalog-split-10", "catalog", "united-states-newspaper-directory", "main-catalog-split-10", "gmd.m