ory of u.s. newspapers in american libraries"], "publication_frequency": ["other"], "score": 68.33711, "shelf_id": "http://lccn.loc.gov/sn86075096", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "livestock", "montana", "periodicals", "agriculture", "cascade", "great falls (mont.)", "great falls", "united states"], "timestamp": "2026-07-18T09:20:06.081Z", "title": "Montana farmer-stockman", "type": ["title"], "url": "https://www.loc.gov/item/sn86075096/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013272187/"], "campaigns": [], "contributor": ["sutherlin, r. n."], "date": "1875", "dates": ["[1875 TO 1943]"], "description": ["Weekly Began with vol. 1, no. 1 (November 25, 1875); ceased January 7, 1943. \"A Journal Devoted to Agriculture, Livestock, Home Reading, and General News.\". \"Pioneer agricultural and stock journal of Montana.\". Issues from 1925-1943 consists entirely of Montana News Association inserts with no independent content. Place of publication varies: Diamond City, Mont., Nov. 25, 1875-Nov. 20, 1879; White Sulphur Springs, Mont., Dec. 4, 1879-Mar. 24, 1904; Great Falls, Mont., Mar. 31, 1904-Jan. 7, 1943. Editor: R.N. Sutherlin. Description based on: Vol. 1, no. 1 (November 25, 1875); title from masthead (Chroniclingamerica.loc.gov, viewed December 18, 2013). Latest issue consulted: Vol. 5, no. 5 (Dec. 18, 1879) (Chroniclingamerica.loc.gov, viewed December 18, 2013)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:24.080Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013272187/", "image_url": [], "index": 19, "language": ["english"], "location": ["white sulphur springs", "montana", "diamond city", "cascade", "meagher", "great falls", "united states", "broadwater"], "number": ["862979362", "online resource", "2013272187", "2332-7537", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "rocky mountain husbandman (diamond city, m.t.) 1875-1943 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 49.9419, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "white sulphur springs", "white sulphur springs (mont.)", "diamond city (mont.)", "montana", "diamond city", "cascade", "great falls (mont.)", "meagher", "great falls", "electronic journals", "united states", "broadwater"], "timestamp": "2026-05-26T20:49:47.660Z", "title": "Rocky Mountain husbandman", "type": ["title"], "url": "https://www.loc.gov/item/2013272187/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218354/"], "campaigns": [], "date": "1918", "dates": ["[1918 TO 1918]"], "description": ["Weekly Began with volume 2, number 3 (September 14, 1918); ceased October 12, 1918. Official organ of: National Nonpartisan League of the State of Montana. Description based on: Volume 2, number 3 (September 14, 1918); title from masthead (Chroniclingamerica.loc.gov, viewed May 7, 2014). Latest issue consulted: Volume 2, number 6 (October 5, 1918) (Chroniclingamerica.loc.gov, viewed May 7, 2014). Montana nonpartisan (Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:25.703Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218354/", "image_url": [], "index": 20, "language": ["english"], "location": ["montana", "united states", "cascade", "great falls"], "number": ["2014218354", "online resource", "2372-885x", "879343459", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["montana leader (great falls, montana) 1918-1918 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 49.9419, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "montana", "national nonpartisan league", "cascade", "great falls (mont.)", "great falls", "united states"], "timestamp": "2026-05-26T20:50:11.310Z", "title": "Montana leader", "type": ["title"], "url": "https://www.loc.gov/item/2014218354/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218355/"], "campaigns": [], "date": "1918", "dates": ["[1918 TO 1929]"], "description": ["Weekly <Oct. 9-30, 1922> Began with volume 2, number 8 (October 19, 1918). Ceased in 1922? Last issue located: Vol. 5, no. 8 [i.e. 9] (Oct. 30, 1922). Place of publication varies: Great Falls, Oct. 19, 1918-May 7, 1921; Billings, June 10-<Oct. 30>, 1922. Suspended: Nov. 16-23, 1918; June 1921-May 1922. Official organ of: National Nonpartisan League in the State of Montana. Description based on: Volume 2, number 8 (October 19, 1918); title from masthead (Chroniclingamerica.loc.gov, viewed May 7, 2014). Latest issue consulted: Volume 3, number 51 (December 20, 1919) (Chroniclingamerica.loc.gov, viewed May 7, 2014)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:25.703Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218355/", "image_url": [], "index": 21, "language": ["english"], "location": ["yellowstone", "billings", "montana", "cascade", "great falls", "united states"], "number": ["2372-8884", "online resource", "2014218355", "879345154", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the montana nonpartisan (great falls, montana) 1918-192? [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 49.9419, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "yellowstone", "billings (mont.)", "billings", "montana", "national nonpartisan league", "cascade", "great falls (mont.)", "great falls", "united states"], "timestam