-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_hobson_ver01/data/sn86075250/00517178974/1930110701/0357.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_hobson_ver01:data:sn86075250:00517178974:1930110701:0357/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_hobson_ver01/data/sn86075250/00517178974/1930110701/0357.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86075250/1930-11-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_hobson_ver01/data/sn86075250/00517178974/1930110701/0357.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86075250/1930-11-07/ed-1/?sp=1"], "batch": ["mthi_hobson_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/blaine/", "3/united states/montana/blaine/harlem/"], "contributor": ["montana historical society; helena, mt"], "date": "1930-11-07", "dates": ["1930-11-07"], "description": ["A Constructive Newspaper TWENTYSEVENTH YEAR BEET YIELD REACHES 40000 TON MARK CAMPAIGN ENDING The Harlem beet dump closed Wed nesday and it is expected that all beets in the valley will be on their way to the factory by the end of this week The Sadler dump is the only one still running Adams North Fork and Malta dumps having closed early this week The beet yields are running above the estimations made early in the sea son and the fair weather has made it possible to harvest every beet this year Threatening weather and an early freeze put fear into tho hearts of the entire valley about three weeks ago with less than a third of the crop on the way to market but conditions during the past two weeks were far more favorable than average Some shrinkage was caused by the freeze but despite that the tonnage will ex ceed the 40000 mark The tonnage shipped from Harlem neared 4000 The beets that remained in the ground until the frost went out of them show little effects of the freeze The beet harvest should be com pleted by Nov 15 and the plowing of the fields this fall"], "digitized": true, "extract_timestamp": "2023-09-02T23:05:19.774Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075250/1930-11-07/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_hobson_ver01:data:sn86075250:00517178974:1930110701:0357/full/pct:6.25/0/default.jpg#h=368&w=267", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_hobson_ver01:data:sn86075250:00517178974:1930110701:0357/full/pct:12.5/0/default.jpg#h=736&w=535", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_hobson_ver01/data/sn86075250/00517178974/1930110701/0357.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["blaine", "montana", "united states", "harlem"], "location_city": ["harlem"], "location_country": ["united states"], "location_county": ["blaine"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "8", "0", "0000000001", "5", "7", "1", "sn86075250", "9"], "number_edition": ["1"], "number_lccn": ["sn86075250"], "number_page": ["0000000001"], "number_reel": ["0", "0", "5", "1", "7", "1", "7", "8", "9", "7", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the harlem news (harlem, mont.) 1908-current", "chronicling america", "serial and government publications division"], "partof_collection"