apter", "url": "https://www.loc.gov/item/2017872444/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2007627952", "http://www.loc.gov/item/2007627952/", "https://search.catalog.loc.gov/instances/84573cfd-800f-5cff-8985-961fd80ff818", "https://hdl.loc.gov/loc.gmd/g3913y.cws00157", "http://www.loc.gov/resource/g3913y.cws00157/"], "campaigns": [], "contributor": ["moore, gordon", "mills, robert"], "date": "1825", "dates": ["1825"], "description": ["Relief shown by hachures. Scale from Stephenson's Civil War Maps, 1989. \"Approved, Chas. R. Suter, 1st Lt., U.S. Engrs., Chf. Engr., D. S.\" Pen and ink tracing of a map in Robert Mills's Atlas of the State of South Carolina . . . Baltimore, F. Lucas, Jr. [1825] LC Civil War maps (2nd ed.), S157 Available also through the Library of Congress web site as raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:06.313Z", "group": ["gmd.mar", "catalog-split-08", "catalog", "general-maps", "main-catalog-split-08"], "hassegments": false, "id": "http://www.loc.gov/item/2007627952/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd391/g3913/g3913y/cws00157.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd391/g3913/g3913y/cws00157.gif#h=150&w=228", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd391:g3913:g3913y:cws00157/full/pct:12.5/0/default.jpg#h=623&w=946", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd391:g3913:g3913y:cws00157/full/pct:25/0/default.jpg#h=1246&w=1893"], "index": 9, "language": ["english"], "location": ["south carolina", "york county", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2007-05-04t07:13:50", "sheet", "2007627952", "2025-06-07t02:00:45.900000"], "online_format": ["image"], "original_format": ["map"], "partof": ["civil war maps", "geography and map division", "military battles and campaigns", "catalog"], "score": 30.582323, "shelf_id": "G3913.Y6 1820 .M5", "site": ["catalog"], "subject": ["south carolina", "york county (s.c.)", "york county", "maps, manuscript", "united states"], "timestamp": "2026-04-29T15:54:17.394Z", "title": "York District, South Carolina", "type": ["cartographic"], "url": "https://www.loc.gov/item/2007627952/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2012590161", "http://www.loc.gov/item/2012590161/", "https://search.catalog.loc.gov/instances/7bfbd642-d0d2-5ba6-9a8b-7a29e8a364b3", "https://hdl.loc.gov/loc.gmd/g3823y.la000825", "http://www.loc.gov/resource/g3823y.la000825/"], "campaigns": [], "contributor": ["lake, d. j.", "shearer, william otis"], "date": "1860", "dates": ["1860"], "description": ["General-content county map showing townships, rural buildings, and householders' names; the city/borough insets show building coverage and some occupants' names; Goldsborough inset shows lot lines, lot numbers, and owners' names. Hand colored in red watercolor to emphasize township boundaries. Relief shown by hachures. \"Entered according to Act of Congress by W.O. Shearer & D.J. Lake in the year 1860 in the ... Eastern District of Pennsylvania.\" Originally printed on 4 sheets (later conjoined). LC copy imperfect: Fold-lined, darkened at fold/cut lines, annotated in lead-pencil on backing, sectioned to 6 panels to enable folding. Includes distance table, local business directories, 36 city/borough/village insets (including York, Dover, Hanover, Wrightsville), and illustrations of selected business prem0ises. LC Land ownership maps, 825 Available also through the Library of Congress Web site as a raster image. 3 copies"], "digitized": true, "extract_timestamp": "2026-04-29T15:39:24.912Z", "group": ["gmd.mar", "catalog-split-11", "catalog", "general-maps", "main-catalog-split-11"], "hassegments": false, "id": "http://www.loc.gov/item/2012590161/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd382/g3823/g3823y/la000825.gif", "https://tile.loc.gov/storage-services/service/gmd/g