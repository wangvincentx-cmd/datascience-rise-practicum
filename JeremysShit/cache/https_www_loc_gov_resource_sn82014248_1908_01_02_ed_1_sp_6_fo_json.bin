014248/0051368244A/1908010201/0024.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82014248/1908-01-02/ed-1/?sp=6"], "batch": ["me_burdin_ver03"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/maine/", "3/united states/maine/augusta/"], "contributor": ["maine state library"], "date": "1908-01-02", "dates": ["1908-01-02"], "description": ["Daily Kennebec Journal E8TABLI8HED 182 M notice whatever will ba takaa af unsigned communication The Journal cannot be held responsible for tbe preservation or return of re Jected communications Address all communications relating to subscriptions and advertisements to BURLEIGH FLYNT Publisher Augusta Maine Thursday January 2 1908 Everything seems to be ready for the annual ice harvest on the Kenne bec except the ice Well what if you did crack one or two of those resolutions yesterday Patch them up and start in over again today A New Yorker aged 86 has just eloped with a young woman over half ft century his junior and this is a reminder that nothing has been heard of late about the contemplated matrimonial venture of Uncle Gassa way Davis A dispatch from Texas says that William J llryan is on a hunting trip in that state and that he shot 25 ducks on one day recently But alas dis patches of this kind do not mean what t hey 4used to It will henceforth be necessary to add of Florida or of Nebraska when William J Bryans name appears In the newspapers One hundred brandnew 10 gold pieces Can you imagine a prettier"], "digitized": true, "extract_timestamp": "2023-07-03T14:05:54.853Z", "group": ["ndnp/me", "maine-state-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82014248/1908-01-02/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:me:batch_me_burdin_ver03:data:sn82014248:0051368244A:1908010201:0024/full/pct:6.25/0/default.jpg#h=436&w=338", "https://tile.loc.gov/image-services/iiif/service:ndnp:me:batch_me_