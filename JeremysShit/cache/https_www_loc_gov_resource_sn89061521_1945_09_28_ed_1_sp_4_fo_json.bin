oordinates-service?segment=/service/ndnp/mdu/batch_mdu_columbine_ver02/data/sn89061521/print/1945092801/0004.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_columbine_ver02:data:sn89061521:print:1945092801:0001/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mdu/batch_mdu_columbine_ver02/data/sn89061521/print/1945092801/0004.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn89061521/1945-09-28/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_columbine_ver02/data/sn89061521/print/1945092801/0004.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_columbine_ver02:data:sn89061521:print:1945092801:0001/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mdu/batch_mdu_columbine_ver02/data/sn89061521/print/1945092801/0004.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn89061521/1945-09-28/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mdu/batch_mdu_columbine_ver02/data/sn89061521/print/1945092801/0004.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89061521/1945-09-28/ed-1/?sp=4"], "batch": ["mdu_columbine_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/maryland/", "2/united states/maryland/prince george's/", "3/united states/maryland/prince george's/greenbelt/"], "contributor": ["university of maryland, college park, md"], "date": "1945-09-28", "dates": ["1945-09-28"], "description": ["Four Greenbelt Cooperator September 28 1945 Legislative Lineup RECONVERSION In our first peacetime column we would like to shout our merry hoorays and nothing moore But the problems of reconversion where have you heard that before are too momentous to be over looked even for one day Both government leaders and business men have made no secret of the fastmounting menace of largescale unemployment There is still time to avert the worst of the situation if the President and Congress act quickly Its up to us to let them know thats just what we want them to do Here are some of the measures which coun teract the long confused and painful period of adjustment otherwise facing us 1 To safeguard and expand the purchasing power of the American people now threatened by loss of jobs lower rates of pay in civilian industries and low unemployment compensation the President should issue an immediate Executive Order permitting a wage raise to 65 cents an hour minimum Awaiting Congress is the Pepper Amendment to the Fair Labor Standards Act establishing such a minimum wage with options to specific industries for a 75 cent minimum 2 Pending passage of the Wag nerDingellMurray Social"], "digitized": true, "extract_timestamp": "2023-03-01T18:28:18.363Z", "group": ["ndnp/mdu", "university-of-maryland-college-park-college-park-md-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89061521/1945-09-28/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_columbine_ver02:data:sn89061521:print:1945092801:0004/full/pct:6.25/0/default.jpg#h=455&w=314", "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_columbine_ver02:data:sn89061521:print:1945092801:0004/full/pct:12.5/0/default.jpg#h=910&w=629", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_columbine_ver02/data/sn89061521/print/1945092801/0004.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["prince george's county", "united states", "greenbelt", "prince george's", "maryland"], "location_city": ["greenbelt"], "location_country":