ta/sn95060771/00517019227/1924030801/1218.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_bentonite_ver02:data:sn95060771:00517019227:1924030801:1215/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_bentonite_ver02/data/sn95060771/00517019227/1924030801/1218.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn95060771/1924-03-08/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_bentonite_ver02/data/sn95060771/00517019227/1924030801/1218.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_bentonite_ver02:data:sn95060771:00517019227:1924030801:1215/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_bentonite_ver02/data/sn95060771/00517019227/1924030801/1218.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn95060771/1924-03-08/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/az/batch_az_bentonite_ver02/data/sn95060771/00517019227/1924030801/1218.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn95060771/1924-03-08/ed-1/?sp=4"], "batch": ["az_bentonite_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arizona/", "2/united states/arizona/pima/", "3/united states/arizona/pima/ajo/"], "contributor": ["arizona state library, archives and public records; phoenix, az"], "date": "1924-03-08", "dates": ["1924-03-08"], "description": ["CONDITION OF THE ARIZONA COPPER MINING INDUSTRY By DR L D RICKETTS President Inspiration Consolidated Copper Company Director New Cornelia Copper Co The three chief producing in dustries of Arizona are copper min ing agriculture and live stock A fourth industry transportation is essential to them and to the inter ests of the state generally It is very evident that the welfare of these industries and the prosperity of the entire state are inseparable because the degree of prosperity of these four industries measures the amount of employment for the work men and the amount of general business for the merchant and the professional man If one industry suffers we must all suffer The recent panic is too fresh in our minds to be forgotten I well remember the huge stack of unsal able copper over 30000 tons of it piled in the yard of one of our smelters We all remember the acres of unsalable bales of cotton about the railway sidings And I hope we all remember the courage of our substantial business houses We Handle All Necessary GOLF SUPPLIES Everything needed on the new Ajo course They are not expensive Call and see them and get our"], "digitized": true, "extract_timestamp": "2024-02-18T00:48:56.642Z", "group": ["ndnp/az", "arizona-state-university-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn95060771/1924-03-08/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_bentonite_ver02:data:sn95060771:00517019227:1924030801:1218/full/pct:6.25/0/default.jpg#h=351&w=238", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_bentonite_ver02:data:sn95060771:00517019227:1924030801:1218/full/pct:12.5/0/default.jpg#h=703&w=477", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_bentonite_ver02/data/sn95060771/00517019227/1924030801/1218.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["pima county", "arizona", "pima", "united states", "ajo"], "location_city": ["ajo"], "location_country": ["united states"], "location_county": ["pima"], "location_state": ["arizona"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image