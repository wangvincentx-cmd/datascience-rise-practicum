1/0122.pdf", "segment_count": 24, "url": "https://www.loc.gov/resource/sn78000090/1949-03-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_bobcats_ver01/data/sn78000090/0041418067A/1949031101/0122.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bobcats_ver01:data:sn78000090:0041418067A:1949031101:0113/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/fu/batch_fu_bobcats_ver01/data/sn78000090/0041418067A/1949031101/0122.pdf", "segment_count": 24, "url": "https://www.loc.gov/resource/sn78000090/1949-03-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/fu/batch_fu_bobcats_ver01/data/sn78000090/0041418067A/1949031101/0122.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn78000090/1949-03-11/ed-1/?sp=12"], "batch": ["fu_bobcats_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/florida/", "2/united states/florida/duval/", "3/united states/florida/duval/jacksonville/"], "contributor": ["university of florida"], "date": "1949-03-11", "dates": ["1949-03-11"], "description": ["Page Twelve Savannah Georgia ENGELS OUTSTANDING FILMS BY LEON GUTTERMAN Copyright 1949 Jewish Telegraphic Agency Inc When Toastmaster George Jessel last week presented to 20th Century Fox Producer Samuel G Engel the annual Photoplay Maga zine gold medal at the swankiest cinemaland affair of the year for having produced the nations most enjoyed motion pictures Sitting Pretty and A Street With No Name according to the nationwide yearlong election conducted by the magazine among Americas moviegoers Producer Engel found himself sitting pretty solidly on top of the movie world ladderthe result of intelligence talent ability and many years of hard work But what made many Filmland citizens so proud of Engels win ning this honor was the fact that this extremely wellliked uni quely popular motionpicture creative artist was also a man loved and admired by the people PURIM GREETINGS COAL IN BAGS ORTONS Guaranteed Quality Joseph F Griffin FUEL SUPPLY CO PHONE 22165 PURIM GREETINGS PT A7A RESTAURANT 12 W BROUGHTON ST SAVANNAH GEORGIA GREETINGS AND BEST WISHES ROWLAND INSURANCE and REAL ESTATE AGENCY Inc HARRY PALMER LOUISE YARBROUGH 18 East Bryan Street Phone 35183 SAVANNAH GEORGIA PURIM GREETINGS AND BEST WISHES COASTAL PROPERTIES Plantation Estates Farms Timber lands"], "digitized": true, "extract_timestamp": "2026-01-27T16:58:05.115Z", "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn78000090/1949-03-11/ed-1/?sp=12", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bobcats_ver01:data:sn78000090:0041418067A:1949031101:0122/full/pct:3.125/0/default.jpg#h=266&w=167", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bobcats_ver01:data:sn78000090:0041418067A:1949031101:0122/full/pct:6.25/0/default.jpg#h=532&w=335", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bobcats_ver01:data:sn78000090:0041418067A:1949031101:0122/full/pct:12.5/0/default.jpg#h=1064&w=670", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_bobcats_ver01/data/sn78000090/0041418067A/1949031101/0122.xml&format=alto_xml"], "index": 12, "language": ["english"], "location": ["jacksonville", "duval county", "duval", "united states", "florida"], "location_city": ["jacksonville"], "location_country": ["united states"], "location_county": ["duval"], "location_state": ["florida"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4",