{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn78000090/?st=calendar", "cite_this": {"apa": "(1949, March 11)  <cite>The Southern Jewish weekly</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn78000090/1949-03-11/ed-1/.", "chicago": "<cite>The Southern Jewish weekly</cite>. (Jacksonville, FL), Mar. 11 1949. https://www.loc.gov/item/sn78000090/1949-03-11/ed-1/.", "mla": "<cite>The Southern Jewish weekly</cite>. (Jacksonville, FL) 11 Mar. 1949, p. 12. Retrieved from the Library of Congress, www.loc.gov/item/sn78000090/1949-03-11/ed-1/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_bobcats_ver01/data/sn78000090/0041418067A/1949031101/0122.xml&format=alto_xml&full_text=1", "item": {"_version_": 1855502445036175360, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn78000090/1949-03-11/ed-1/", "http://www.loc.gov/resource/sn78000090/1949-03-11/ed-1/"], "batch": ["fu_bobcats_ver01"], "call_number": ["Newspaper"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/florida/", "2/united states/florida/duval/", "3/united states/florida/duval/jacksonville/"], "contributor_names": ["University of Florida"], "contributors": [{"university of florida": "https://www.loc.gov/search/?fa=contributor:university+of+florida&fo=json"}], "created_published": ["Jacksonville, Fla., March 11, 1949"], "date": "1949-03-11", "date_issued": "1949-03-11", "dates": [{"1949-03-11": "https://www.loc.gov/search/?dates=1949-03-11/1949-03-11&fo=json"}], "dates_of_publication": "1939-1992", "description": ["Jacksonville, Fla."], "digital_id": ["https://hdl.loc.gov/loc.sgp/chronam.sn78000090"], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2026-01-27T16:58:05.115Z", "extract_urls": ["file:/service/ndnp//fu/batch_fu_bobcats_ver01/data/sn78000090/0041418067A/1949031101/1949031101_1.xml#ndnp/fu"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn78000090/1949-03-11/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bobcats_ver01:data:sn78000090:0041418067A:1949031101:0113/full/pct:3.125/0/default.jpg#h=264&w=170", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bobcats_ver01:data:sn78000090:0041418067A:1949031101:0113/full/pct:6.25/0/default.jpg#h=529&w=340", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bobcats_ver01:data:sn78000090:0041418067A:1949031101:0113/full/pct:12.5/0/default.jpg#h=1058&w=681"], "index": 12, "item": {"batch": ["fu_bobcats_ver01"], "call_number": ["Newspaper"], "contributor_names": ["University of Florida"], "created_published": ["Jacksonville, Fla., March 11, 1949"], "date": "1939", "date_issued": "1949-03-11", "dates": ["1949-03-11"], "digital_id": ["https://hdl.loc.gov/loc.sgp/chronam.sn78000090"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn78000090", "location": ["Florida", "Jacksonville (Fla.)", "Duval County (Fla.)", "Florida--Duval County", "Florida--Jacksonville"], "medium": "24 pages", "newspaper_title": ["The Southern Jewish weekly"], "notes": ["Semimonthly, <1990-1992>", "Vol. 14, no. 39 (Aug. 11, 1939)-", "Ceased in 1992.", "\"Combining the Florida Jewish news and the Jewish citizen.\"", "Also issued on microfilm from the Library of Congress and the University of Florida.", "Archived issues are available in digital format from the Library of Congress Chronicling America online collection.", "Latest issue consulted: Vol. 69, no. 22 (Dec. 15, 1992).", "National Jewish advocate 1068-123X (DLC)sn 93004805 (OCoLC)27449951"], "other_formats": ["https://tile.loc.gov/storage-services/service/ndnp//fu/batch_fu_bobcats_ver01/data/sn78000090/0041418067A/1949031101/1949031101_1.xml", "http://lccn.loc.gov/sn78000090/marcxml"], "place_of_publication": "Jacksonville, Fla.", "raw_lccn": "sn 78000090 ", "reel_numbers": ["0041418067a"], "source_group": "ndnp/fu", "subjects": ["Jewish newspapers--Florida", "Jacksonville (Fla.)--Newspapers", "Duval County (Fla.)--Newspapers", "Jewish newspapers", "Florida", "Florida--Duval County", "Florida--Jacksonville", "United States--Florida--Duval--Jacksonville"], "summary": ["The Southern Jewish Weekly (sn78000090) began publication in 1939 when editor Isadore Moscovitz (a University of Florida Journalism graduate) merged the Florida Jewish News (sn 95047205) and the Jewish Citizen (sn 95047204) to create a new newspaper that would be \"an independent weekly serving American citizens of Jewish faith\". The Weekly considered itself the \"oldest and most widely circulated Jewish publication in this territory.\" The paper was a member of the Religious News Service, the Jewish Telegraphic Agency, the American Jewish Press Club, and the Independent Jewish Press Service. It was published in Jacksonville once a week, with every issue typically being eight pages. In October 1943,  Moscovitz published an announcement noting a change in publication frequency due to World War II. The Weekly became the Southern Jewish Monthly, publishing a single issue every third Friday of the month. During this time Moscovitz served in the war, leaving his wife Ethel Moscovitz to manage the paper and serve as its editor in the interim. The paper continued as a monthly until January 1947 when Moscovitz returned to the United States and resumed the paper's weekly publication schedule. The Southern Jewish Weekly was \"opposed to communism, fascism, and Nazism and is dedicated to the ideals of American democracy\". It reported on WWII, providing readers a unique perspective from the community most affected by the tragedies of the war. The newspaper often reported the murders and atrocities endured by the Jewish community. It also also reported on activities of antisemitc hate groups hate groups in the United States, like the Ku Klux Klan. Additionally, the Weekly served as a strong promoter of Jewish faith, including information about Jewish congregations from around the state. It published information to educate readers on Jewish holidays, including a mini-calendar for readers to refer to and coverage of local celebrations for Passover, Shavuot, Hanukkah, and Rosh Hashanah. Pensacola was home to the first known Jewish community in Florida in 1763 after the Treaty of Paris was signed. Once England acquired Florida, non-Catholics were allowed to freely settle in the colony. The Jewish community in Florida began to flourish in the late 1850s as they began to establish organizations that would meet their educational, social, and health-related needs. The Jacksonville Hebrew Cemetery was the first Jewish institution to be established in the state in 1857. By 1900 there were six established congregations across the state in Pensacola, Jacksonville, Key West, Ocala, and Tampa. The community continued to grow and by 1928 approximately 10,000 Jews lived in Florida, with approximately 10% of the community residing in Jacksonville. As of 2020, over 600,000 Jews are living in Florida, making up 3% of the overall state's population."], "title": "The Southern Jewish weekly (Jacksonville, Fla.), March 11, 1949"}, "language": ["english"], "languages": [{"english": "https://www.loc.gov/search/?fa=language:english&fo=json"}], "library_of_congress_control_number": "sn78000090", "location": ["jacksonville", "duval county", "duval", "united states", "florida"], "location_city": ["jacksonville"], "location_country": ["united states"], "location_county": ["duval"], "location_state": ["florida"], "locations": [{"duval": "https://www.loc.gov/search/?fa=location:duval&fo=json"}, {"duval county": "https://www.loc.gov/search/?fa=location:duval+county&fo=json"}, {"florida": "https://www.loc.gov/search/?fa=location:florida&fo=json"}, {"jacksonville": "https://www.loc.gov/search/?fa=location:jacksonville&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=location:united+states&fo=json"}], "locations_city": [{"jacksonville": "https://www.loc.gov/search/?fa=location_city:jacksonville&fo=json"}], "locations_country": [{"united states": "https://www.loc.gov/search/?fa=location_country:united+states&fo=json"}], "locations_county": [{"duval": "https://www.loc.gov/search/?fa=location_county:duval&fo=json"}], "locations_state": [{"florida": "https://www.loc.gov/search/?fa=location_state:florida&fo=json"}], "medium": "24 pages", "method": "mets_filesec", "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "newspaper_title": ["The Southern Jewish weekly"], "notes": ["Semimonthly, <1990-1992>", "Vol. 14, no. 39 (Aug. 11, 1939)-", "Ceased in 1992.", "\"Combining the Florida Jewish news and the Jewish citizen.\"", "Also issued on microfilm from the Library of Congress and the University of Florida.", "Archived issues are available in digital format from the Library of Congress Chronicling America online collection.", "Latest issue consulted: Vol. 69, no. 22 (Dec. 15, 1992).", "National Jewish advocate 1068-123X (DLC)sn 93004805 (OCoLC)27449951"], "number": ["1", "sn78000090", "0041418067a"], "number_edition": ["1"], "number_lccn": ["sn78000090"], "number_reel": ["0041418067a"], "numeric_shelf_id": 194903111, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//fu/batch_fu_bobcats_ver01/data/sn78000090/0041418067A/1949031101/1949031101_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn78000090/marcxml"}], "partof": [{"count": 762, "title": "the southern jewish weekly (jacksonville, fla.) 1939-1992", "url": "https://www.loc.gov/search/?fa=partof:the+southern+jewish+weekly+%28jacksonville,+fla.%29+1939-1992&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the southern jewish weekly (jacksonville, fla.) 1939-1992"], "place_of_publication": "Jacksonville, Fla.", "publication_frequency": ["semimonthly"], "raw_lccn": "sn 78000090 ", "reel_numbers": ["0041418067a"], "resources": [{"files": 24, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bobcats_ver01:data:sn78000090:0041418067A:1949031101:0113/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn78000090/1949-03-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.96732, "shard": "04", "shelf_id": "sn78000090, 1949-03-11, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/fu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "jacksonville", "duval county", "jewish", "jewish newspapers", "duval county (fla.)", "jacksonville (fla.)", "duval", "united states", "florida"], "subject_ethnicity": ["jewish"], "subject_headings": ["Jewish newspapers--Florida", "Jacksonville (Fla.)--Newspapers", "Duval County (Fla.)--Newspapers", "Jewish newspapers", "Florida", "Florida--Duval County", "Florida--Jacksonville", "United States--Florida--Duval--Jacksonville"], "subjects": [{"duval": "https://www.loc.gov/search/?fa=subject:duval&fo=json"}, {"duval county": "https://www.loc.gov/search/?fa=subject:duval+county&fo=json"}, {"duval county (fla.)": "https://www.loc.gov/search/?fa=subject:duval+county+%28fla.%29&fo=json"}, {"florida": "https://www.loc.gov/search/?fa=subject:florida&fo=json"}, {"jacksonville": "https://www.loc.gov/search/?fa=subject:jacksonville&fo=json"}, {"jacksonville (fla.)": "https://www.loc.gov/search/?fa=subject:jacksonville+%28fla.%29&fo=json"}, {"jewish": "https://www.loc.gov/search/?fa=subject:jewish&fo=json"}, {"jewish newspapers": "https://www.loc.gov/search/?fa=subject:jewish+newspapers&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "subjects_ethnicity": [{"jewish": "https://www.loc.gov/search/?fa=subject_ethnicity:jewish&fo=json"}], "summary": ["The Southern Jewish Weekly (sn78000090) began publication in 1939 when editor Isadore Moscovitz (a University of Florida Journalism graduate) merged the Florida Jewish News (sn 95047205) and the Jewish Citizen (sn 95047204) to create a new newspaper that would be \"an independent weekly serving American citizens of Jewish faith\". The Weekly considered itself the \"oldest and most widely circulated Jewish publication in this territory.\" The paper was a member of the Religious News Service, the Jewish Telegraphic Agency, the American Jewish Press Club, and the Independent Jewish Press Service. It was published in Jacksonville once a week, with every issue typically being eight pages. In October 1943,  Moscovitz published an announcement noting a change in publication frequency due to World War II. The Weekly became the Southern Jewish Monthly, publishing a single issue every third Friday of the month. During this time Moscovitz served in the war, leaving his wife Ethel Moscovitz to manage the paper and serve as its editor in the interim. The paper continued as a monthly until January 1947 when Moscovitz returned to the United States and resumed the paper's weekly publication schedule. The Southern Jewish Weekly was \"opposed to communism, fascism, and Nazism and is dedicated to the ideals of American democracy\". It reported on WWII, providing readers a unique perspective from the community most affected by the tragedies of the war. The newspaper often reported the murders and atrocities endured by the Jewish community. It also also reported on activities of antisemitc hate groups hate groups in the United States, like the Ku Klux Klan. Additionally, the Weekly served as a strong promoter of Jewish faith, including information about Jewish congregations from around the state. It published information to educate readers on Jewish holidays, including a mini-calendar for readers to refer to and coverage of local celebrations for Passover, Shavuot, Hanukkah, and Rosh Hashanah. Pensacola was home to the first known Jewish community in Florida in 1763 after the Treaty of Paris was signed. Once England acquired Florida, non-Catholics were allowed to freely settle in the colony. The Jewish community in Florida began to flourish in the late 1850s as they began to establish organizations that would meet their educational, social, and health-related needs. The Jacksonville Hebrew Cemetery was the first Jewish institution to be established in the state in 1857. By 1900 there were six established congregations across the state in Pensacola, Jacksonville, Key West, Ocala, and Tampa. The community continued to grow and by 1928 approximately 10,000 Jews lived in Florida, with approximately 10% of the community residing in Jacksonville. As of 2020, over 600,000 Jews are living in Florida, making up 3% of the overall state's population."], "timestamp": "2026-01-27T20:16:59.831Z", "title": "The Southern Jewish weekly (Jacksonville, Fla.), March 11, 1949", "type": ["issue"], "url": "https://www.loc.gov/item/sn78000090/1949-03-11/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn78000090/", "http://lccn.loc.gov/sn78000090", "https://search.catalog.loc.gov/instances/8b902b3e-40f0-5c3e-b916-6b5bd8bfe1a4"], "batch": ["fu_bobcats_ver01"], "campaigns": [], "date": "1939", "description": ["The Southern Jewish Weekly (sn78000090) began publication in 1939 when editor Isadore Moscovitz (a University of Florida Journalism graduate) merged the Florida Jewish News (sn 95047205) and the Jewish Citizen (sn 95047204) to create a new newspaper that would be \"an independent weekly serving American citizens of Jewish faith\". The Weekly considered itself the \"oldest and most widely circulated Jewish publication in this territory.\" The paper was a member of the Religious News Service, the Jewish Telegraphic Agency, the American Jewish Press Club, and the Independent Jewish Press Service. It was published in Jacksonville once a week, with every issue typically being eight pages. In October 1943, Moscovitz published an announcement noting a change in publication frequency due to World War II. The Weekly became the Southern Jewish Monthly, publishing a single issue every third Friday of the month. During this time Moscovitz served in the war, leaving his wife Ethel Moscovitz to manage the paper and serve as its editor in the interim. The paper continued as a monthly until January 1947 when Moscovitz returned to the United States and resumed the paper's weekly publication schedule. The Southern Jewish Weekly was \"opposed to communism, fascism, and Nazism and is dedicated to the ideals of American democracy\". It reported on WWII, providing readers a unique perspective from the community most affected by the tragedies of the war. The newspaper often reported the murders and atrocities endured by the Jewish community. It also also reported on activities of antisemitc hate groups hate groups in the United States, like the Ku Klux Klan. Additionally, the Weekly served as a strong promoter of Jewish faith, including information about Jewish congregations from around the state. It published information to educate readers on Jewish holidays, including a mini-calendar for readers to refer to and coverage of local celebrations for Passover, Shavuot, Hanukkah, and Rosh Hashanah. Pensacola was home to the first known Jewish community in Florida in 1763 after the Treaty of Paris was signed. Once England acquired Florida, non-Catholics were allowed to freely settle in the colony. The Jewish community in Florida began to flourish in the late 1850s as they began to establish organizations that would meet their educational, social, and health-related needs. The Jacksonville Hebrew Cemetery was the first Jewish institution to be established in the state in 1857. By 1900 there were six established congregations across the state in Pensacola, Jacksonville, Key West, Ocala, and Tampa. The community continued to grow and by 1928 approximately 10,000 Jews lived in Florida, with approximately 10% of the community residing in Jacksonville. As of 2020, over 600,000 Jews are living in Florida, making up 3% of the overall state's population."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.113Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-09", "catalog", "united-states-newspaper-directory", "main-catalog-split-09"], "hassegments": false, "id": "http://www.loc.gov/item/sn78000090/", "image_url": [], "index": 12, "language": ["english"], "latlong": [30.325968, -81.65676], "location": ["jacksonville", "duval county", "duval", "united states", "florida"], "location_str": "", "lonlat": [-81.65676, 30.325968], "number": ["new york pub libr res libr", "http://www.loc.gov/item/sn78000090/1939-08-11/ed-1/", "sn95047204", "sn78000090", "online resource", "american jewish historical society", "http://www.loc.gov/item/sn78000090/1956-12-28/ed-1/", "761", "1", "0038-4240", "original", "2025-11-07t12:33:03", "2025-05-23t21:30:26", "3929713", "sn93004805", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["catalog", "chronicling america", "serial and government publications division", "the southern jewish weekly (jacksonville, fla.) 1939-1992", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["semimonthly"], "score": 79.80792, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "jacksonville", "duval county", "jewish", "jewish newspapers", "duval county (fla.)", "jacksonville (fla.)", "duval", "united states", "florida"], "timestamp": "2026-07-18T09:02:06.495Z", "title": "The Southern Jewish weekly", "type": ["title"], "url": "https://www.loc.gov/item/sn78000090/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95026723/"], "batch": ["fu_freeport_ver01"], "campaigns": [], "date": "1943", "description": ["Biweekly, June 3, 1943-Jan. 18, 1945 Vol. 1, no. 1 (Feb. 1943)-v. 3, no. 9 (Jan. 18, 1945). Commentator of the Community Council (DLC)sn 95026724 (OCoLC)33132949"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.596Z", "group": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn95026723/", "image_url": [], "index": 13, "language": ["english"], "latlong": [30.325968, -81.65676], "location": ["jacksonville", "duval county", "duval", "united states", "florida"], "location_str": "", "lonlat": [-81.65676, 30.325968], "number": ["http://www.loc.gov/item/sn95026723/1945-01-18/ed-1/", "online resource", "45", "1", "sn95026724", "2025-05-23t21:30:26", "http://www.loc.gov/item/sn95026723/1943-02-01/ed-1/", "33132947", "sn95026723", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "chronicling america", "community council commentator ([jacksonville, fla.]) 1943-1945", "serial and government publications division"], "publication_frequency": ["biweekly"], "score": 70.66409, "shelf_id": "http://lccn.loc.gov/sn95026723", "site": ["chroniclingamerica", "usnd"], "subject": ["newspapers", "jacksonville", "duval county", "jewish", "jewish newspapers", "duval county (fla.)", "jacksonville (fla.)", "duval", "united states", "florida"], "timestamp": "2026-07-18T09:36:43.276Z", "title": "Community Council commentator", "type": ["title"], "url": "https://www.loc.gov/item/sn95026723/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95026724/"], "batch": ["fu_freeport_ver01"], "campaigns": [], "date": "1945", "description": ["Biweekly Vol. 3, no. 10 (Feb 1, 1945)- Latest issue consulted: May 11, 1966. Commentator (Jacksonville, Fla.) (DLC)sn 96027405 (OCoLC)34770297"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.596Z", "group": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn95026724/", "image_url": [], "index": 14, "language": ["english"], "latlong": [30.325968, -81.65676], "location": ["jacksonville", "duval county", "duval", "united states", "florida"], "location_str": "", "lonlat": [-81.65676, 30.325968], "number": ["http://www.loc.gov/item/sn95026724/1950-03-09/ed-1/", "sn96027405", "online resource", "http://www.loc.gov/item/sn95026724/1945-02-01/ed-1/", "33132949", "109", "1", "sn95026724", "2025-05-23t21:30:26", "sn95026723", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["commentator of the community council (jacksonville, fla.) 1945-19??", "chronicling america", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["biweekly"], "score": 70.66409, "shelf_id": "http://lccn.loc.gov/sn95026724", "site": ["chroniclingamerica", "usnd"], "subject": ["newspapers", "jacksonville", "duval county", "jewish", "jewish newspapers", "duval county (fla.)", "jacksonville (fla.)", "duval", "united states", "florida"], "timestamp": "2026-07-18T09:36:43.276Z", "title": "Commentator of the Community Council", "type": ["title"], "url": "https://www.loc.gov/item/sn95026724/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2007264076/"], "campaigns": [], "date": "1878", "dates": ["[1878 TO 1911]"], "description": ["Weekly Print began with v. 1, no. 1 (May 15, 1878); ceased with v. 38, no. 6 (June 1911). \"A journal devoted to state interests.\" Published at Jacksonville and DeLand, <Nov. 1905-Aug. 1906>. Issues for <Nov. 1905-Aug. 1906> also have whole numbering; numbering is irregular. Description based on: Vol. 32, no. 44 (Nov. 1, 1905); title from PDF caption (Library of Congress Chronicling America online collection, viewed Dec. 5, 2007). Latest issue consulted: Vol. 33, no. 32 [i.e. 35] (Aug. 29, 1906)."