 hachures. Cadastral map showing drainage, section lines and numbers, land ownership, landowners' names, school houses, roads, rail roads, etc. \"Copyright 1892 by E. Frank Peterson.\" Includes list of subdivisions of Union County, insets of \"Plat of the City of Elk Point\" and \"South part of Big Sioux Township,\" business directory, and ill. of buildings. LC Land ownership maps, 867 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:24.076Z", "group": ["gmd.mar", "catalog-split-13", "catalog", "general-maps", "main-catalog-split-13"], "hassegments": false, "id": "http://www.loc.gov/item/2012593007/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd418/g4183/g4183u/la000867.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd418/g4183/g4183u/la000867.gif#h=280&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd418:g4183:g4183u:la000867/full/pct:12.5/0/default.jpg#h=3150&w=1688", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd418:g4183:g4183u:la000867/full/pct:25/0/default.jpg#h=6300&w=3376"], "index": 7, "language": ["english"], "location": ["union county", "united states", "south dakota"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2012-11-05t07:59:01", "2025-06-07t05:20:52.900000", "sheet", "2012593007"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "catalog", "county landownership maps", "cultural landscapes"], "score": 33.074715, "shelf_id": "G4183.U5 1892 .P41", "site": ["catalog"], "subject": ["union county", "south dakota", "landowners", "real property", "united states", "cadastral maps", "union county (s.d.)", "maps"], "timestamp": "2026-04-29T16:06:16.839Z", "title": "Topographical map of Union County, South Dakota : compiled and drawn from official records and a special survey", "type": ["cartographic"], "url": "https://www.loc.gov