 State grand lodge sessions in this Friendly City of West Palm Beach where he is lending his able hand in steering the wheels which operate this rand Old Order Help The Scouts Stop Shop at Kings KINGS SUNDRIES 425 N W 20th STREET Always a Crowd SUGGESTIONS Try Our Delicious Grilled Sandwiches and Southern Dairies Ice Cream Arthur King Prop r Our candies taste better and are better for"], "digitized": true, "extract_timestamp": "2026-01-27T16:57:28.716Z", "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83004231/1949-05-14/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_armadillo_ver01:data:sn83004231:00414180863:1949051401:0296/full/pct:3.125/0/default.jpg#h=289&w=199", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_armadillo_ver01:data:sn83004231:00414180863:1949051401:0296/full/pct:6.25/0/default.jpg#h=578&w=399", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_armadillo_ver01:data:sn83004231:00414180863:1949051401:0296/full/pct:12.5/0/default.jpg#h=1157&w=799", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_armadillo_ver01/data/sn83004231/00414180863/1949051401/0296.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["dade county", "miami", "united states", "florida", "dade"], "location_city": ["miami"], "location_country": ["united states"], "location_county": ["dade"], "location_state": ["florida"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000008", "3", "4", "8", "0", "1", "sn83004231", "6"], "number_edition": ["1"], "number_lccn": ["sn83004231"], "number_page": ["0000000008"], "number_reel": ["0", "0", "4", "1", "4", "1", "8", "0", "8", "6", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof