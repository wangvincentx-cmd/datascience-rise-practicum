", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_archery_ver01:data:sn89064489:0039334006A:1930122501:0604/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_archery_ver01/data/sn89064489/0039334006A/1930122501/0605.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn89064489/1930-12-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_archery_ver01/data/sn89064489/0039334006A/1930122501/0605.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_archery_ver01:data:sn89064489:0039334006A:1930122501:0604/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_archery_ver01/data/sn89064489/0039334006A/1930122501/0605.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn89064489/1930-12-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mnhi/batch_mnhi_archery_ver01/data/sn89064489/0039334006A/1930122501/0605.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89064489/1930-12-25/ed-1/?sp=2"], "batch": ["mnhi_archery_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/minnesota/", "2/united states/minnesota/stearns/", "3/united states/minnesota/stearns/sauk centre/"], "contributor": ["minnesota historical society; saint paul, mn"], "date": "1930-12-25", "dates": ["1930-12-25"], "description": ["Page Two Continuing Publication Sauk Centre News Published by Sauk Centre Publishers Incorporated ASA M WALLACE eeeeseeeneeee BaditOT ED L RATHE ASSOciate Editor M J FLEMING eeveeeeenenn Gneral Managen Entered Postoffice at Sauk Centre Minn as second class matter under act of Congress of March 3 1879 SUBSCRIPTION RATES Domestic A QAVANCE oo eeeeeeeeeeecseaacncenneceeee 200 Canadian in AAVANCE coeeeeeeeeeeeeaneesccacaeeaneee 20 Festivals in celebration of the beginning of a new year have been traced back as far as 3000 B C to ancient Babylon They may have been held long before that Through out the ages various peoples have observed various days as New Years Day In view of the many calendars which have been employed to mark the passage of time much confusion has resulted Differ ent peoples have counted the years from some real or imaginary event and the length of the year itself has varied according to the calendar used The Mohammedan year for example is governed by the moon instead of the sun and consists of 12 lunar months or only 354 days The Hebrew calendar also consists of 354 days ordinarily but an extra month is inserted once in 19 years making 384 days in those"], "digitized": true, "extract_timestamp": "2024-01-03T22:31:00.853Z", "group": ["ndnp/mnhi", "minnesota-historical-society-saint-paul-mn-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89064489/1930-12-25/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_archery_ver01:data:sn89064489:0039334006A:1930122501:0605/full/pct:3.125/0/default.jpg#h=282&w=214", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_archery_ver01:data:sn89064489:0039334006A:1930122501:0605/full/pct:6.25/0/default.jpg#h=565&w=428", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_archery_ver01:data:sn89064489:0039334006A:1930122501:0605/full/pct:12.5/0/default.jpg#h=1131&w=857", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_archery_ver01/data/sn89064489/0039334006A/1930122501/0605.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["united states", "sauk centre", "stearns", "stearns county", "mi