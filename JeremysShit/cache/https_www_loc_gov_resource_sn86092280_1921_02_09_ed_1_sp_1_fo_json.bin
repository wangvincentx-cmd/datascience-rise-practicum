"], "subject": ["united states", "west virginia", "elkins", "randolph"], "timestamp": "2026-07-18T09:21:53.224Z", "title": "The weekly inter-mountain", "type": ["title"], "url": "https://www.loc.gov/item/sn86092276/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn86092277/"], "batch": ["wvu_fonda_ver01"], "campaigns": [], "date": "1892", "description": ["Weekly Began in 1892. Cf. Bosworth, A.S. Hist. of Randolph Co. Ceased in 1907? Herman C. Johnson edited the paper in 1898 and returned to Elkins in 1902 to buy the paper. Cf. Board of Trade. Elkins, W. Va. Editors: N.G. Keim, 1892-1894; M.S. Cornwell, 1894-1896; William S. Ryan, 1896-1896; Chas. E. Beans, 1896-Aug., 1898; Herman Johnson, Aug., 1898-1907. Cf. Bosworth, A.S. Hist. of Randolph Co. Description based on: Vol. 1, no. 47 (June 2, 1893). Weekly inter-mountain (Elkins, W. Va.) (DLC)sn 86092276"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:15Z", "group": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn86092277/", "image_url": [], "index": 3, "language": ["english"], "latlong": [38.923908, -79.8443931], "location": ["united states", "randolph", "elkins", "west virginia"], "location_str": "", "lonlat": [-79.8443931, 38.923908], "number": ["west virginia newsp proj", "165", "13201738", "2026-04-13t21:30:13", "sn86092276", "http://www.loc.gov/item/sn86092277/1903-08-20/ed-1/", "1", "2025-05-23t21:30:26", "online resource", "sn86092277", "http://www.loc.gov/item/sn86092277/1896-01-31/ed-1/", "microfilm service copy"], "original_format": ["newspaper"], "other_title": ["Elkins inter-mountain"], "partof": ["chronicling america", "the inter-mountain (elkins, w. va.) 1892-1907", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 40.129715, "shelf_id": "http://lccn.loc.gov/sn86092277", "site": ["chroniclinga