: Natrona County tribune, June 3, 1897-<1921>. Casper herald (DLC)sn 92067162 Casper tribune-herald (DLC)sn 86072161"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:02.120Z", "group": ["newspaper-titles", "catalog-split-15", "catalog", "ndnp/newspapers", "main-catalog-split-15", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn86072160/", "image_url": [], "index": 1, "language": ["english"], "latlong": [42.850087, -106.325203], "location": ["casper", "natrona", "united states", "wyoming", "natrona county"], "location_str": "", "lonlat": [-106.325203, 42.850087], "number": ["original", "sn92067162", "14909902", "2026-04-13t21:30:13", "2533", "sn92067159", "http://www.loc.gov/item/sn86072160/1926-01-31/ed-1/", "http://www.loc.gov/item/sn86072160/1917-01-02/ed-1/", "1", "2022-09-07t16:16:19.100270", "sn86072161", "2025-07-01t13:40:54.300000", "library of congress", "univ of wyoming libr, newsp proj", "online resource", "microfilm service copy", "sn86072160", "2833-8766"], "original_format": ["newspaper"], "other_title": ["Casper Sunday morning tribune and Wyoming weekly review", "Casper Sunday tribune and Wyoming weekly review", "Casper Sunday tribune", "Casper tribune-herald"], "partof": ["chronicling america", "directory of u.s. newspapers in american libraries", "serial and government publications division", "catalog", "casper daily tribune (casper, wyo.) 1916-1931"], "publication_frequency": ["daily"], "score": 91.30024, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "catalog", "usnd"], "subject": ["casper", "natrona county (wyo.)", "united states", "natrona", "casper (wyo.)", "newspapers", "wyoming", "natrona county"], "timestamp": "2026-07-18T09:20:06.081Z", "title": "Casper daily tribune", "type": ["title"], "url": "https://www.loc.gov/item/sn86072160/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2022270741/"], "campaigns": [], "date": "1916", "dates": ["[1916 TO 1931]"], "description": ["Daily (except Saturday), December 5, 1925-<January 31, 1926> Print began October 9, 1916; ceased with vol. 15, no. 142 (March 31, 1931). On Sunday published as: Casper Sunday morning tribune and Wyoming weekly review, Oct. 1, 1922-Aug. 26, 1923; Casper Sunday tribune and Wyoming weekly review, Sept. 2, 1923-Mar. 2, 1924; Casper Sunday tribune, Mar. 9, 1924-Nov. 29, 1925; Casper tribune-herald, Dec. 6, 1925-Mar. 29, 1931. Sunday issues have separate enumeration. Also issued on microfilm from Micro Photo Div., Bell & Howell Co. Weekly ed.: Natrona County tribune, June 3, 1897-<1921>. Volume One, Number 71 (January 2, 1917); title from masthead (Chroniclingamerica.loc.gov, viewed September 14, 2022). Vol. X, No. 84 (January 29, 1926) (Chroniclingamerica.loc.gov, viewed September 14, 2022). Casper herald Casper tribune-herald"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:05.065Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2022270741/", "image_url": [], "index": 2, "language": ["english"], "location": ["casper", "natrona", "united states", "wyoming", "natrona county"], "number": ["1344400697", "2026-04-13t21:30:13", "2833-8774", "online resource", "2022270741"], "original_format": ["newspaper"], "other_title": ["Casper Sunday morning tribune and Wyoming weekly review", "Casper Sunday tribune and Wyoming weekly review", "Casper Sunday tribune", "Casper tribune-herald"], "partof": ["serial and government publications division", "casper daily tribune (casper, wyo.) 1916-1931 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 82.092964, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["casper", "natrona county (wyo.)", "united states", "natrona", "casper (wyo.)", "newspapers", "wyoming", "natrona county"], "timestamp": "2026-05-26T21:06:42.779Z", "title": "Casper daily tribune", "type": ["title"]