011401/0020.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_frederick_ver03:data:sn89060127:00279522035:1938011401:0016/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522035/1938011401/0020.pdf", "segment_count": 11, "url": "https://www.loc.gov/resource/sn89060127/1938-01-14/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522035/1938011401/0020.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_frederick_ver03:data:sn89060127:00279522035:1938011401:0016/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522035/1938011401/0020.pdf", "segment_count": 11, "url": "https://www.loc.gov/resource/sn89060127/1938-01-14/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522035/1938011401/0020.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89060127/1938-01-14/ed-1/?sp=5"], "batch": ["mdu_frederick_ver03"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/maryland/", "2/united states/maryland/worcester/", "3/united states/maryland/worcester/pocomoke city/"], "contributor": ["university of maryland, college park, md"], "date": "1938-01-14", "dates": ["1938-01-14"], "description": ["Page 4 WORCESTER DEMOCRAT aND THE LEDGERENTERPRISE Published Every Friday at Pocomoke City Maryland EDWARD J CLARKE Editor and Owner 160 The Year In Advance Entered at the Postoffice at Pocomoke City Maryland as Second Class Matter Ofo NATIONAL EDITORIAL jn ASB CIAnor FRIDAY JANUARY 14 1938 A NEW FEATURE We would like to call the attention of our readers to our new feature a weekly magazine section which appears this week and will continue to do so every other week to all our subscribers and if the reaction to this venture is assuring it will be sent out every week This periodical known as Town is a sixteen page paper and contains matter interesting to almost all our readers and it goes to them without any extra cost in the way of subscripion price Its cover page is illuminated always by some beautiful works of art in the way of landscapes buildings personages and sea views The reading matter appeals to the home and fireside the traveller the sportsman fiction readers fashions and mind teas ers in the way of puzzles There are two pages of colored comics interesting radio news stories of screen artists lots of recipes fo"], "digitized": true, "extract_timestamp": "2023-03-01T18:25:24.776Z", "group": ["ndnp/mdu", "university-of-maryland-college-park-college-park-md-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89060127/1938-01-14/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_frederick_ver03:data:sn89060127:00279522035:1938011401:0020/full/pct:3.125/0/default.jpg#h=262&w=212", "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_frederick_ver03:data:sn89060127:00279522035:1938011401:0020/full/pct:6.25/0/default.jpg#h=524&w=425", "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_frederick_ver03:data:sn89060127:00279522035:1938011401:0020/full/pct:12.5/0/default.jpg#h=1048&w=851", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522035/1938011401/0020.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["worcester county", "pocomoke city", "united states", "mary