loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn90052005, 1914-01-01, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/vi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["virginia", "richmond (va.)", "newspapers", "united states", "richmond"], "subject_headings": ["Richmond (Va.)--Newspapers", "Virginia--Richmond", "United States--Virginia--Richmond"], "subjects": [{"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"richmond": "https://www.loc.gov/search/?fa=subject:richmond&fo=json"}, {"richmond (va.)": "https://www.loc.gov/search/?fa=subject:richmond+%28va.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"virginia": "https://www.loc.gov/search/?fa=subject:virginia&fo=json"}], "timestamp": "2024-02-08T00:08:26.846Z", "title": "The Richmond Virginian (Richmond, Va.), January 1, 1914", "type": ["issue"], "url": "https://www.loc.gov/item/sn90052005/1914-01-01/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn90052005/", "http://lccn.loc.gov/sn90052005", "https://search.catalog.loc.gov/instances/98e4c54c-54af-5444-9883-c32008ee0eed"], "batch": ["vi_mustang_ver01"], "campaigns": [], "date": "1910", "description": ["Daily (including Sunday), 1912-1920 Vol. 1, no. 1 (Jan. 28, 1910)-v. 12, no. 90 (May 15, 1920). Issues for July 4, 24 and Aug. 2, 1911 called: State ed. Available online. Archived issues are available in digital format from the Library of Congress Chronicling America online collection."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:09.423Z", "group": ["newspaper