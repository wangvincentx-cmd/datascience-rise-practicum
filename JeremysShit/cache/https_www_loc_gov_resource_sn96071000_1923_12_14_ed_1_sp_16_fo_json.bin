}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": "https://www.loc.gov/resource/sn96071000/1923-12-14/ed-1/?fo=json&sp=15", "results": "16 - 16", "to": 16, "total": 34}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn96071000/1923-12-07/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/73693375", "http://www.loc.gov/item/73693375/", "https://search.catalog.loc.gov/instances/16aa8dc4-df36-54d9-b6db-ebd245b242b6", "https://hdl.loc.gov/loc.gmd/g4104u.pm001890", "http://www.loc.gov/resource/g4104u.pm001890/"], "campaigns": [], "contributor": ["chicago lithographing co", "ruger, a."], "date": "1869", "dates": ["1869"], "description": ["Includes ill. and index to points of interest. Perspective map not drawn to scale. LC Panoramic maps (2nd ed.), 189 Available also through the Library of Congress Web site as a raster image. Vault AACR2: 100; 651/1; 710/1"], "digitized": true, "extract_timestamp": "2026-04-29T15:40:08.356Z", "group": ["gmd.mar", "catalog-split-11", "catalog", "general-maps", "main-catalog-split-11"], "hassegments": false, "id": "http://www.loc.gov/item/73693375/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd410/g4104/g4104u/pm001890.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd410/g4104/g4104u/pm001890.gif#h=150&w=190", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd410:g4104:g4104u:pm001890/full/pct:12.5/0/default.jpg#h=703&w=891", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd410:g4104:g4104u:pm001890/full/pct:25/0/default.jpg#h=1407&w=1782"], "index": 16, "language": ["english"], "location": ["illinois", "united states", "urbana"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["73693375", "2025-06-07t18:29:47.800000", "2005-01-05t17:17:28"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "cities and towns", "panoramic maps", "catalog"], "score": 31.663849, "shelf_id": "G4104.U7A3 1869 .R8", "site": ["catalog"], "subject": ["illinois", "aerial views", "united states", "urbana (ill.)", "urbana"], "timestamp": "2026-04-29T16:12:28.837Z", "title": "Bird's eye view of the city of Urbana, Champaign County, Illinois 1869", "type": ["cartographic"], "url": "https://www.loc.gov/item/73693375/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/73693348", "http://www.loc.gov/item/73693348/", "https://search.catalog.loc.gov/instances/77e1c725-024b-5dcf-9ab0-7ba89a5b090c", "https://hdl.loc.gov/loc.gmd/g4104c.pm001440", "http://www.loc.gov/resource/g4104c.pm001440/"], "campaigns": [], "contributor": ["chicago lithographing co", "ruger, a."], "date": "1869", "dates": ["1869"], "description": ["\"This panoramic map shows Champaign, Illinois, as it appeared in 1869. The view, looking from the southeast, shows an area that is a hub of rail activity, with tracks running on the outskirts of and through the city. Multiple trains traverse the intersecting lines, which are labeled: Illinois Central Railroad, Champaign & Monticello Railroad, and Indianapolis, Bloomington & Western Railroad. The index at the bottom of the map indicates various points of interest, including several schools, Baptist, Congregational, Presbyterian, \"Christian,\" Catholic, and two Methodist churches, the city park, the gas works, and two railroad depots. Two inset images at the bottom of the map show greater detail of two buildings: the public school and Illinois State Industrial University. The panoramic map was a cartographic form popularly used to depict U.S. and Canadian cities and towns in the late 19th and early 20th centuries. Also known as bird's-eye views or perspective maps, these maps are representations of cities portrayed as if viewed from above at an oblique angle. Not generally drawn to scale, they show street patterns, individual buildings, and major landscape features in perspective. This map is by Albert Ruger (1829-99), the first American to achieve success as a panoramic artist. Born in Prussia, Ruger immigrated to the United States and worked initially as a mason. While serving with the Ohio Volunteers during the Civil War, he drew views of Union campsites. After the war, Ruger settled in Battle Creek, Michigan, where he began his panoramic mapping career by sketching Michigan cities. In the late 1860s, Ruger formed a partnership with J.J. Stoner of Madison, Wisconsin, and together they published numerous city panoramas.\" World Digital Library."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:55.124Z", "group": ["gmd.mar", "catalog-split-11", "catalog", "general-maps", "main-catalog-split-11"], "hassegments": false, "id": "http://www.loc.gov/item/73693348/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd410/g4104/g4104c/pm001440.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd410/g4104/g4104c/pm001440.gif#h=150&w=192", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd410:g4104:g4104c:pm001440/full/pct:12.5/0/default.jpg#h=866&w=1106", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd410:g4104:g4104c:pm001440/full/pct:25/0/default.jpg#h=1732&w=2212"], "index": 17, "language": ["english"], "location": ["illinois", "united states", "champaign"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2022-07-14t10:56:26", "73693348", "2025-06-07t18:29:47.900000"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "panoramic maps", "catalog", "cities and towns", "world digital library"], "score": 30.973282, "shelf_id": "G4104.C5A3 1869 .R8", "site": ["catalog"], "subject": ["illinois", "aerial views", "united states", "champaign (ill.)", "champaign"], "timestamp": "2026-04-29T16:12:28.837Z", "title": "Bird's eye view of the city of Champaign, Champaign County, Illinois 1869", "type": ["cartographic"], "url": "http