np/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.45633, "shard": "04", "shelf_id": "sn89075140, 1945-08-30, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ohi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["grand rapids (ohio)", "wood", "grand rapids", "ohio", "newspapers", "united states"], "subject_headings": ["Grand Rapids (Ohio)--Newspapers", "United States--Ohio--Wood--Grand Rapids"], "subjects": [{"grand rapids": "https://www.loc.gov/search/?fa=subject:grand+rapids&fo=json"}, {"grand rapids (ohio)": "https://www.loc.gov/search/?fa=subject:grand+rapids+%28ohio%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"ohio": "https://www.loc.gov/search/?fa=subject:ohio&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"wood": "https://www.loc.gov/search/?fa=subject:wood&fo=json"}], "timestamp": "2025-04-13T08:55:51.061Z", "title": "The Tri-county news (Grand Rapids, Ohio), August 30, 1945", "type": ["issue"], "url": "https://www.loc.gov/item/sn89075140/1945-08-30/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn89075140/", "http://lccn.loc.gov/sn89075140"], "batch": ["ohi_kingsley_ver01"], "campaigns": [], "date": "1915", "description": ["Began in 1915?; ceased in 1949? Volume 18, number 12 (November 18, 1915); title from masthead (Surrogate). Volume 18, number 12 (November 18, 1915) (Surrogate). Wood County herald Tri-county herald news"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:15Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-03", "catalog", "united-states-newspaper-directory", "