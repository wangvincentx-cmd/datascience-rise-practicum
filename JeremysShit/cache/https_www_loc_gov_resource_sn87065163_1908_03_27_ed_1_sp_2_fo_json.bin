908032701/0152.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:msar:batch_msar_gabardine_ver01:data:sn87065163:00199916804:1908032701:0151/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/msar/batch_msar_gabardine_ver01/data/sn87065163/00199916804/1908032701/0152.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87065163/1908-03-27/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/msar/batch_msar_gabardine_ver01/data/sn87065163/00199916804/1908032701/0152.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:msar:batch_msar_gabardine_ver01:data:sn87065163:00199916804:1908032701:0151/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/msar/batch_msar_gabardine_ver01/data/sn87065163/00199916804/1908032701/0152.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87065163/1908-03-27/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/msar/batch_msar_gabardine_ver01/data/sn87065163/00199916804/1908032701/0152.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn87065163/1908-03-27/ed-1/?sp=2"], "batch": ["msar_gabardine_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/mississippi/", "2/united states/mississippi/forrest/", "3/united states/mississippi/forrest/hattiesburg/"], "contributor": ["mississippi department of archives and history"], "date": "1908-03-27", "dates": ["1908-03-27"], "description": ["rotter and Collins Allowed Bail at 500 The cases of John Trotter and Key Collins charged with manufactur ing or passing of counterfeit coin In Hattiesburg were called before the federal commissioner In Biloxi Wed nesday and the following account of the same Is given in a Biloxi special to the Gulfport RecordTribune Key Collins and John Trotter the two negroes charged with being im plicated m the manufacture of count erfeit coin at Hattiesburg were yes terday brought up from Gulfport by U S Marslml C C Buckley and haled before U S Commissioner Roy Chinn Both negroes waived prelim inary examination by agreement be tween TJ S Attorney Lee and the at torhey for the defendants their bonds being reduced from 1000 to 500 The two men were taken back to Gulfport and placed in jail but it is SOME GOOD VALUES SPECIAL BARGAINS I N UNIONMADE OVERALLS WORKMANS GLOVES 1 150 Gloves Legular price 100 going at_ 75c going at New Spring Shoes Have Arrived Latest shades in Tans Browns Blacks in Patent Kid Chrome Patent and Vici Kid HALfi HOSE in Lisle and Cotton Newest Colors EVERYTHING IN GENTS FURNISINGS And at Prices that are Real"], "digitized": true, "extract_timestamp": "2023-07-03T13:42:33.531Z", "group": ["ndnp/msar", "mississippi-department-of-archives-and-history"], "hassegments": false, "id": "http://www.loc.gov/resource/sn87065163/1908-03-27/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:msar:batch_msar_gabardine_ver01:data:sn87065163:00199916804:1908032701:0152/full/pct:6.25/0/default.jpg#h=343&w=290", "https://tile.loc.gov/image-services/iiif/service:ndnp:msar:batch_msar_gabardine_ver01:data:sn87065163:00199916804:1908032701:0152/full/pct:12.5/0/default.jpg#h=686&w=581", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/msar/batch_msar_gabardine_ver01/data/sn87065163/00199916804/1908032701/0152.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["forrest", "mississippi", "hattiesburg", "united states"], "location_city": ["hattiesburg"], "location_country": ["united states"], "location_county": ["forrest"], "location_state": ["mississippi"], "mime_type": ["image/jp2"