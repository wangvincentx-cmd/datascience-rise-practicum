vice"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_jig_ver01/data/sn85025570/00383348316/1930040901/0209.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_jig_ver01:data:sn85025570:00383348316:1930040901:0208/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_jig_ver01/data/sn85025570/00383348316/1930040901/0209.pdf", "segment_count": 15, "url": "https://www.loc.gov/resource/sn85025570/1930-04-09/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mnhi/batch_mnhi_jig_ver01/data/sn85025570/00383348316/1930040901/0209.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85025570/1930-04-09/ed-1/?sp=2"], "batch": ["mnhi_jig_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/minnesota/", "2/united states/minnesota/redwood/", "3/united states/minnesota/redwood/redwood falls/"], "contributor": ["minnesota historical society; saint paul, mn"], "date": "1930-04-09", "dates": ["1930-04-09"], "description": ["PAGE TWO THE REDWOOD GAZETTE Published by the REDWOOD GAZETTE PUBLISHING CO n INC Redwood Falls Minn W E BARNES Pres B E MARSH Vive Pres ESTHER DAVIS STENSVAD Secy and Treas B E Marsh and Esther Davis Stensvad Editors B E Marsh Business Manager Full Year In Advance 200 Canada and Foreign Countries 250 JL 5 TO OUR jSn FILIATING MEMBER WEDNESDAY APRIL 9 1930 Surest Farm Relief ANY farm relief worthy of the name must come from the farmer himself in the opinion of agri cultural authorities with governmental agencies ranking a poor secondbest in any real improvement of the farm situation Increased efficiency on the part of the farmer himself will go furthest towards im proving rural conditions There are certain basic principles which must be followed if a farmer is to succeed as he should The first of these is that a great share of the products used by the farm family should be produced at home second that the farm land should not be robbed year after year but should be kept up and improved and third that the farmer should keep livestock and grow more than one cash crop Failure to realize to the"], "digitized": true, "extract_timestamp": "2024-01-04T02:56:21.770Z", "group": ["ndnp/mnhi", "minnesota-historical-society-saint-paul-mn-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85025570/1930-04-09/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_jig_ver01:data:sn85025570:00383348316:1930040901:0209/full/pct:3.125/0/default.jpg#h=269&w=204", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_jig_ver01:data:sn85025570:00383348316:1930040901:0209/full/pct:6.25/0/default.jpg#h=538&w=408", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_jig_ver01:data:sn85025570:00383348316:1930040901:0209/full/pct:12.5/0/default.jpg#h=1076&w=817", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_jig_ver01/data/sn85025570/00383348316/1930040901/0209.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["redwood county", "united states", "redwood falls", "minnesota", "redwood"], "location_city": ["redwood falls"], "location_country": ["united states"], "location_county": ["redwood"], "location_state": ["minnesota"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "8", "3", "4", "6", "sn85025570", "0000000002", "1"], "number_edition": ["1"], "number_lccn": ["sn85025570"], "number_page": ["0000000002"], "number_reel": ["0", "0", "3", "8", "3", "3", "4", "8", "3", "1", "6"], "online_format": ["image", "pdf", "online text"], "original_format":