alf kidneys and a large cooking ap ple peeled cored and cut into rings Place the rings on a hot dish with a piece of fried bread and a halfkidney on each Sea son and sprinkle with lemon juice Put a scrap of butter on each and serve immediately Never hang a mirror where it faces a glare of light The back of the mirror should be protected so that no light or water could possibly enter Concerning Mirrors Manipulating VelvetThe usual method of pressing seams espe cially in velvet is to get a second person to hold one end of the mate rial while you hold the other Flatten out the"], "digitized": true, "extract_timestamp": "2023-07-03T13:46:51.042Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82006551/1937-12-02/ed-1/?sp=9", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_goosefoot_ver01:data:sn82006551:00340581350:1937120201:0407/full/pct:6.25/0/default.jpg#h=468&w=314", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_goosefoot_ver01:data:sn82006551:00340581350:1937120201:0407/full/pct:12.5/0/default.jpg#h=937&w=628", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_goosefoot_ver01/data/sn82006551/00340581350/1937120201/0407.xml&format=alto_xml"], "index": 9, "language": ["english"], "location": ["lincoln", "libby", "united states", "montana"], "location_city": ["libby"], "location_country": ["united states"], "location_county": ["lincoln"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "0000000009", "8", "3", "sn82006551", "4", "1"], "number_edition": ["1"], "number_lccn": ["sn82006551"], "number_page": ["0000000009"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "1", "3", "5", "0"], "online_format": ["image", "pdf", "online text"], "original_for