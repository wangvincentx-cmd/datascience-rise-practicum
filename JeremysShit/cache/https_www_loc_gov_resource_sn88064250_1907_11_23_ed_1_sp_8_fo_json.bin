ce In Every Twenty YearsPre dicts N Y Cash Payments by New Year The New Orleans Picayune in an exhaustive and comprehensive editor ial in last Sundays issue deals at length with financial panics and par ticularly that of 1893 It says that in every instance where the busines of this country has been overwhelmed by a financial panic it has been caused by excessive specula tion The American people pass all others as business gamblers says the Picayune Some of them may employ their leisure in betting on regular gambling games but that is a mere bagatelle The money lost and won in that"], "digitized": true, "extract_timestamp": "2020-10-12T13:32:25.502Z", "group": ["ndnp/lu", "louisiana-state-university-baton-rouge-la-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88064250/1907-11-23/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:lu:batch_lu_jacobi_ver01:data:sn88064250:00212475671:1907112301:0218/full/pct:6.25/0/default.jpg#h=508&w=369", "https://tile.loc.gov/image-services/iiif/service:ndnp:lu:batch_lu_jacobi_ver01:data:sn88064250:00212475671:1907112301:0218/full/pct:12.5/0/default.jpg#h=1017&w=739", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/lu/batch_lu_jacobi_ver01/data/sn88064250/00212475671/1907112301/0218.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["opelousas", "louisiana", "saint landry", "united states"], "location_city": ["opelousas"], "location_country": ["united states"], "location_county": ["saint landry"], "location_state": ["louisiana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "2", "1", "4", "sn88064250", "7", "0000000008", "6"], "number_edition": ["1"], "number_lccn": ["sn88064250"], "number_page": ["0000000008"], "number_reel": ["0", "0", "2", "1", "2", "4", "7", "5", "6", "7", "1"], "online_format": ["image", "pdf", "online text