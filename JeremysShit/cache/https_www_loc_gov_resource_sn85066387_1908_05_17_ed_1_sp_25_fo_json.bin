/1908051701/0412.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_llano_ver01:data:sn85066387:00175047876:1908051701:0388/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/curiv/batch_curiv_llano_ver01/data/sn85066387/00175047876/1908051701/0412.pdf", "segment_count": 56, "url": "https://www.loc.gov/resource/sn85066387/1908-05-17/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/curiv/batch_curiv_llano_ver01/data/sn85066387/00175047876/1908051701/0412.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_llano_ver01:data:sn85066387:00175047876:1908051701:0388/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/curiv/batch_curiv_llano_ver01/data/sn85066387/00175047876/1908051701/0412.pdf", "segment_count": 56, "url": "https://www.loc.gov/resource/sn85066387/1908-05-17/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/curiv/batch_curiv_llano_ver01/data/sn85066387/00175047876/1908051701/0412.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85066387/1908-05-17/ed-1/?sp=25"], "batch": ["curiv_llano_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/california/", "2/united states/california/san francisco/", "3/united states/california/san francisco/san francisco/"], "contributor": ["university of california, riverside; riverside, ca"], "date": "1908-05-17", "dates": ["1908-05-17"], "description": ["VOLUME CIIL NO 169 FIRST NEWS SECTION PROSPERITY ON ITS WAY BACK SAYS HARRIMAN Declares Business Outlook Is Excellent and Crops All Good Says There Has Been Too Much Unrest Among the Whole People Asserts He Is Out of Politics bat Will Spend Money His Own Way SPECIAL DISPATCH TO THE CALL WASHINGTON May 16 E H Harriman left this afternoon for New York He paid no calls on public offi cials but declared that prosperity was on its way back and would get here just about in proportion as the people returned to sound sensible under standing of business conditions The feeling is easier and all the country needs now is to be let alone There has been altogether too much unrest I dont mean on the part of anybody in particular but among the whole people The business outlook is excellent There has not been a spring In many years when the prospect for crops was better than now Everything else de pends on agriculture And about politics Mr Harrtman Oh Im I was going to say Im out of that But I really never rai In It i I dont know anything about politics and I dont"], "digitized": true, "extract_timestamp": "2025-09-02T13:57:07.107Z", "group": ["ndnp/curiv", "university-of-california-riverside-riverside-ca-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85066387/1908-05-17/ed-1/?sp=25", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_llano_ver01:data:sn85066387:00175047876:1908051701:0412/full/pct:3.125/0/default.jpg#h=274&w=202", "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_llano_ver01:data:sn85066387:00175047876:1908051701:0412/full/pct:6.25/0/default.jpg#h=549&w=405", "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_llano_ver01:data:sn85066387:00175047876:1908051701:0412/full/pct:12.5/0/default.jpg#h=1098&w=811", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/curiv/batch_curiv_llano_ver01/data/sn85066387/00175047876/1908051701/0412.xml&format=alto_xml"], "index": 25, "language": ["english"], "location": ["san francisco bay area", "san francisco", "united states", "california"], "location_city": ["san francis