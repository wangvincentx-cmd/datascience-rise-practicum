 awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.96732, "shard": "04", "shelf_id": "sn86069021, 1908-05-22, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/kyu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["pendleton", "united states", "pendleton county (ky.)", "falmouth (ky.)", "kentucky", "pendleton county", "newspapers", "falmouth"], "subject_headings": ["Falmouth (Ky.)--Newspapers", "Pendleton County (Ky.)--Newspapers", "Kentucky--Falmouth", "Kentucky--Pendleton County", "United States--Kentucky--Pendleton--Falmouth"], "subjects": [{"falmouth": "https://www.loc.gov/search/?fa=subject:falmouth&fo=json"}, {"falmouth (ky.)": "https://www.loc.gov/search/?fa=subject:falmouth+%28ky.%29&fo=json"}, {"kentucky": "https://www.loc.gov/search/?fa=subject:kentucky&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"pendleton": "https://www.loc.gov/search/?fa=subject:pendleton&fo=json"}, {"pendleton county": "https://www.loc.gov/search/?fa=subject:pendleton+county&fo=json"}, {"pendleton county (ky.)": "https://www.loc.gov/search/?fa=subject:pendleton+county+%28ky.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2026-03-29T10:37:47.868Z", "title": "The Falmouth outlook (Falmouth, Ky.), May 22, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn86069021/1908-05-22/ed-1/"}, "locations": null, "method": "mets_filesec", "more_lik