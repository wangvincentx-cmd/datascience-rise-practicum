0303/full/pct:25/0/default.jpg#h=734&w=468"], "index": 7, "language": ["english"], "location": ["georgia", "united states", "andersonville", "andersonville prison", "sumter county"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-06-13t15:34:21"], "online_format": ["image"], "original_format": ["map"], "partof": ["civil war maps", "military battles and campaigns", "american memory", "geography and map division"], "score": 32.538933, "shelf_id": "http://www.loc.gov/item/001-CABIB20008140/", "site": ["ammem"], "subject": ["georgia", "united states", "sumter county (ga.)", "andersonville prison", "andersonville (ga.)", "civil war", "sumter county", "history", "prisoners and prisons", "maps"], "timestamp": "2022-03-30T06:52:52.845Z", "title": "Andersonville Prison", "url": "https://www.loc.gov/item/gvhs01.vhs00303/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2015669162", "http://www.loc.gov/item/2015669162/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0063", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0063/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0063_mv02/", "http://www.loc.gov/resource/afc2010039text.afc2010039_crhp0063_Mahone_transcript/"], "campaigns": [], "contributor": ["mahone, sam", "jeffries, hasan kwame", "civil rights history project (u.s.)"], "date": "2013-01-01", "dates": ["2013"], "description": ["Sam Mahone discusses his experiences of racial segregation and discrimination in Americus, Georgia, and how he came to be involved in the Student Nonviolent Coordinating Committee (SNCC). After he joined SNCC, he participated in an array of activism: picketing a segregated movie theater, registering voters, and organizing in the black community. He also discusses the arrests that he and other activists experienced due to their activism, including the Americus Four case and the Leesburg Stockade. He concludes the interview by discussing his current involvement in showcasing African American art."], "digitized": true, "extract_timestamp": "2022-10-04T17:33:11.652Z", "group": ["afc2010039", "catalog-split-06", "catalog", "civil-rights-history-project", "main-catalog-split-06", "main-catalog"], "hassegments": true, "id": "http://www.loc.gov/item/2015669162/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0063/afc2010039_crhp0063_mv02.gif", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:25/0/default.jpg#h=443&w=339", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:50/0/default.jpg#h=887&w=678", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:100/0/default.jpg#h=1774&w=1356"], "index": 8, "language": ["english"], "location": ["georgia", "americus", "united states", "albany"], "mime_type": ["image/gif", "image/jpeg", "image/jp2", "application/x-video"], "number": ["2015669162", "http://www.loc.gov/item/afc2010039_crhp0063", "http://www.loc.gov/item/2015669162", "online resource", "2020-02-20t11:58:30"], "online_format": ["image", "video"], "original_format": ["film, video"], "partof": ["civil rights history project", "catalog", "american folklife center"], "score": 24.12532, "shelf_id": "http://lccn.loc.gov/2015669162", "site": ["catalog"], "subject": ["georgia", "americus", "african american civil rights workers", "united states", "interviews", "civil rights demonstrations", "mahone, sam", "discrimination in public accommodations", "student nonviolent coordinating committee (u.s.)", "civil rights movements", "oral histories", "filmed interviews", "video recordings"], "timestamp": "2022-10-17T14:38:32.195Z", "title": "Sam Mahone oral history interview conducted by Hasan Kwame Jeffries in Albany, Georgia, 2013 March 09", "type": ["moving image"], "url": "https://www.loc.gov/item/2015669162/"}, {"access_