: ["serial and government publications division", "yukon valley news (tanana, alaska) 1909-1909 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 37.602783, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["tanana", "united states", "tanana (alaska)", "alaska", "newspapers"], "timestamp": "2026-05-26T21:08:46.277Z", "title": "Yukon Valley news", "type": ["title"], "url": "https://www.loc.gov/item/2023270627/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270628/"], "campaigns": [], "date": "1910", "dates": ["[1910 TO 1913]"], "description": ["Weekly Began with new series vol. I, no. 1 (September 22, 1910); ceased January 17, 1913? News series designation dropped with v. 1, no. 48, (Oct. 28, 1911). Suspended July-Sept. 1911. Issue for Jan. 11, 1913 incorrectly called Jan. 11, 1912. Vol. numbering irregular. New Series Vol. I, No. 1 (September 22, 1910); title from masthead (Chroniclingamerica.loc.gov, viewed July 26, 2023). Vol. 2, No. 22 (August 10, 1912) (Chroniclingamerica.loc.gov, viewed July 26, 2023)."], "digitized": true, "extract_timestamp": "2026-05-19T21:38:10.033Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2023270628/", "image_url": [], "index": 6, "language": ["english"], "location": ["tanana", "alaska", "united states"], "number": ["online resource", "2026-04-13t21:30:13", "2993-6179", "2023270628", "2023270740", "1391143652"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "yukon valley news (tanana, alaska) 1910-1913 [online resource]"], "publication_frequency": ["weekly"], "score": 37.602783, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["tanana", "united states", "tanana (alaska)", "alaska", "newspapers"], "timestamp": "2026-05-26T21:08:46.277Z", "title": "Yukon Val