rdees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.141635, "shard": "05", "shelf_id": "sn84020645, 1908-03-05, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/au", "subject": ["montgomery county (ala.)", "montgomery", "newspapers", "united states", "montgomery (ala.)", "montgomery county", "alabama"], "subject_headings": ["Montgomery (Ala.)--Newspapers", "Montgomery County (Ala.)--Newspapers", "Alabama--Montgomery", "Alabama--Montgomery County", "United States--Alabama--Montgomery--Montgomery"], "subjects": [{"alabama": "https://www.loc.gov/search/?fa=subject:alabama&fo=json"}, {"montgomery": "https://www.loc.gov/search/?fa=subject:montgomery&fo=json"}, {"montgomery (ala.)": "https://www.loc.gov/search/?fa=subject:montgomery+%28ala.%29&fo=json"}, {"montgomery county": "https://www.loc.gov/search/?fa=subject:montgomery+county&fo=json"}, {"montgomery county (ala.)": "https://www.loc.gov/search/?fa=subject:montgomery+county+%28ala.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2022-11-23T04:02:17.537Z", "title": "The Montgomery advertiser (Montgomery, Ala.), March 5, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn84020645/1908-03-05/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83025485/1900-01-26/ed-1/", "http://www.loc.gov/resource/sn83025485/1900-01-26/ed-1/"], "batch": ["dlc_jean_ver01"], "campaigns": [], "contributor": ["library of congress, washington, dc"], "date": "1900-01-26", "dates": ["1900-01-26"], "descrip