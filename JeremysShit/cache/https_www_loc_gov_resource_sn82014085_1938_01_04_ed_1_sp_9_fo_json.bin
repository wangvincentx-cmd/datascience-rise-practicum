new era for Pitts burgh Although incorporated in 1933 the new company did not begin opera tion until New Years day when 21 steel executives named as a board of directors moved here to take up their duties Financial and policy problems of U S Steel will continue to be formulated at the companys New York headquarters Taylor Hints as to Future When organization of the Dela ware corporation was announced by Myron S Taylor retiring U S Steel chairman in New Yor one phrase of his statement was believed to in dicate possibility that all of the cor porations activities eventually will be directed from here He said The principal headquarters of the Delaware corporation will"], "digitized": true, "extract_timestamp": "2023-06-01T13:39:03.451Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82014085/1938-01-04/ed-1/?sp=9", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_grasso_ver02:data:sn82014085:00393346978:1938010401:0028/full/pct:6.25/0/default.jpg#h=442&w=328", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_grasso_ver02:data:sn82014085:00393346978:1938010401:0028/full/pct:12.5/0/default.jpg#h=884&w=656", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_grasso_ver02/data/sn82014085/00393346978/1938010401/0028.xml&format=alto_xml"], "index": 9, "language": ["english"], "location": ["connecticut", "united states", "waterbury", "new haven"], "location_city": ["waterbury"], "location_country": ["united states"], "location_county": ["new haven"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000009", "3", "0", "sn82014085", "1", "4", "8", "7", "9", "6"], "number_edition": ["1"], "number_lccn": ["sn82014085"], "number_page": ["0000000009"], "number_reel": ["0", "0", "3", "9"