tes-service?segment=/service/ndnp/ct/batch_ct_clash_ver01/data/sn84020351/00414219494/1930080201/0256.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn84020351:00414219494:1930080201:0254/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_clash_ver01/data/sn84020351/00414219494/1930080201/0256.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn84020351/1930-08-02/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ct/batch_ct_clash_ver01/data/sn84020351/00414219494/1930080201/0256.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020351/1930-08-02/ed-1/?sp=3"], "batch": ["ct_clash_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/fairfield/", "3/united states/connecticut/fairfield/bridgeport/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1930-08-02", "dates": ["1930-08-02"], "description": ["LA SENTINELLA Itala Gente RAFFAELLO LAMBRUSCHINI Il benefico movimento di idee che distinse la Toscana dellot tocento fu in gran parte opera del genovese abate Lambruschi ni il quale parve a un certo mo mento contrapporsi allo zio il famoso cardinale segretario di Stato di Gregorio VI e uomo di fiducia di Mettermeli non soloJ dirittura quale riformatore reliJ gioso per quellorbita del catto licesimo per quanto a Firenze 10 chiamassero scherzosamente luterino Quanto a me scriveva infatti il 15 novembre 1848 a Niccol\u00f2 Puccini credo venuto 11 momento dalzar pi\u00f9 che mai la bandiera della religione di Ges\u00f9 Cristo perci\u00f2 la vera cat tolica e quello che scriver\u00f2 sar\u00e0 a questo fine O mi bruce ranno come Savonarola o far\u00f2 del bene allItalia e al mondo Ma lillusione in lui stesso e negli amici fu di breve durata e il Lambruschini fu sempre e rimase come si defini una volta da s\u00e8 uno di quelli che il Saint Simon chiamava Divulgatori i quali fanno del bene anchessi e ci vogliono ma non mandano avanti la scienza Eppure proprio come divulga tore e poi anche come educatore egli ebbe uninfluenza enorme sullo spirito pubblico della To scana del suo tempo"], "digitized": true, "extract_timestamp": "2023-06-01T13:35:04.522Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020351/1930-08-02/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn84020351:00414219494:1930080201:0256/full/pct:3.125/0/default.jpg#h=285&w=227", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn84020351:00414219494:1930080201:0256/full/pct:6.25/0/default.jpg#h=570&w=454", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn84020351:00414219494:1930080201:0256/full/pct:12.5/0/default.jpg#h=1140&w=908", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_clash_ver01/data/sn84020351/00414219494/1930080201/0256.xml&format=alto_xml"], "index": 3, "language": ["italian", "english"], "location": ["fairfield", "bridgeport", "connecticut", "fairfield county", "united states"], "location_city": ["bridgeport"], "location_country": ["united states"], "location_county": ["fairfield"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "9", "sn84020351", "0000000003", "1", "4"], "number_edition": ["1"], "number_lccn": ["sn84020351"], "number_page": ["0000000003"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "9", "4", "9", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"