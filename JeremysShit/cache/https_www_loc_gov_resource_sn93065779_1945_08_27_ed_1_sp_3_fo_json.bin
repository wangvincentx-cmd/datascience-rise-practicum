", "catalog"], "subject": ["boys", "hours of labor", "textile machinery", "united states", "photographic prints", "textile mill workers", "mills", "lincolnton", "north carolina"], "timestamp": "2022-04-30T18:32:28.882Z", "title": "Daniel Mfg. Co., Lincolnton, N.C. Four doffers. Boy on left end (knee pants) said he had worked in mills for 7 years and some nights. At nights they work 12 hours, without any hour off for lunch. Eat when they can. Some of the[m] \"eat a-workin'.\"  Location: Lincolnton, North Carolina.", "url": "https://www.loc.gov/item/2018674574/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/nclc/item/2018674580/", "https://hdl.loc.gov/loc.pnp/nclc.01384", "http://www.loc.gov/item/2018674580/", "http://www.loc.gov/pictures/item/2018674580/", "http://www.loc.gov/resource/nclc.01384/", "http://lccn.loc.gov/2018674580"], "campaigns": [], "contributor": ["hine, lewis wickes"], "date": "1908-01-01", "dates": ["1908"], "description": ["1 photographic print."], "digitized": true, "extract_timestamp": "2021-09-01T22:53:34.532Z", "group": ["nclc", "catalog-split-09", "catalog", "national-child-labor-committee", "main-catalog-split-09", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2018674580/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/nclc/01300/01384_150px.jpg#h=107&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/01300/01384t.gif#h=106&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/01300/01384r.jpg#h=454&w=640", "https://tile.loc.gov/storage-services/service/pnp/nclc/01300/01384v.jpg#h=727&w=1024"], "index": 8, "language": ["english"], "location": ["lincolnton", "united states", "north carolina"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/2018674580", "http://www.loc.gov/item/20685141", "2018674580", "http://www.loc.gov/item/ncl2004000969/pp", "2018-11-02t16:38:30"], "online_format": ["image"], "origi