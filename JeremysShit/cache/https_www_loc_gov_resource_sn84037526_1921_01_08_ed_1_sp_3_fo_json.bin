lish"], "latlong": [17.746333, -64.7037], "location": ["virgin islands", "christiansted", "saint croix", "united states virgin islands", "united states"], "location_str": "", "lonlat": [-64.7037, 17.746333], "number": ["online resource", "microfilm service copy", "library of congress", "bureau of libr, mus & archeological serv", "2025-09-20t12:58:13.200000", "2996-9174", "sn84037536", "http://www.loc.gov/item/sn84037536/1936-12-18/ed-1/", "769", "original", "http://www.loc.gov/item/sn84037536/1934-01-02/ed-1/", "2026-04-13t21:30:13", "1", "10486779", "2023-10-20t08:56:28.548910"], "original_format": ["newspaper"], "other_title": ["Saint Croix tribune", "Tribune"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "st. croix tribune (christiansted, st. croix, v.i.) 1922-1937", "catalog", "chronicling america"], "publication_frequency": ["daily"], "score": 74.359634, "shelf_id": "Newspaper 10020 AN2.S2.C47 T75", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["christiansted (united states virgin islands)", "virgin islands", "african american", "christiansted", "african americans", "saint croix", "caribbean", "caribbean americans", "united states virgin islands", "newspapers", "african american newspapers", "united states"], "timestamp": "2026-07-18T09:12:23.572Z", "title": "St. Croix tribune", "type": ["title"], "url": "https://www.loc.gov/item/sn84037536/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2024271072/"], "campaigns": [], "date": "1955", "dates": ["[1955 TO 1978]"], "description": ["Daily (except Sunday) Print began with 26th year, no. 8712 (Aug. 1, 1955); ceased with 48th year, no. 12043 (May 17, 1978). \"The only independent Virgin Islands newspaper serving the people of the Virgin Islands.\" Editor: Ariel Melchior, Sr., Aug. 1, 1955-July 31, 1964; Ariel Melchior, Jr., Aug. 1, 1964-Dec. 31, 1976; Ronald Walker, Jan. 3, 1977-Apr. 19, 1977; John Thompson, Apr. 20-Oct. 11, 1977. Publisher: Ariel Melchior, Sr., <Jan. 2, 1963>-Dec. 31, 1976; Ariel Melchior, Jr., Jan. 3, 1977-May 17, 1978. Issue numbering is highly irregular and does not reflect actual number issued since publication began on Aug. 1, 1930. 40th anniversary ed., Aug. 1, 1970; 160 pp., 45th anniversary ed., Aug. 1, 1975. Contained ill. history of the islands and newspaper publishing in the territory. 26th year, no. 8712 (Aug. 1, 1955); title from banner (news.google.com, viewed Dec. 12, 2024). 48th year, no. 12043 (May 17, 1978) (news.google.com, viewed Dec. 12, 2024). Virgin Islands daily news (DLC) 2024239015 (OCoLC)729865957"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:15Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2024271072/", "image_url": [], "index": 7, "language": ["english"], "location": ["virgin islands", "saint thomas", "united states virgin islands", "charlotte amalie", "united states"], "number": ["online resource", "2996-914x", "2024239015", "2024271072", "2024238983", "2026-04-13t21:30:13", "1427515942"], "original_format": ["newspaper"], "other_title": ["Running title: Daily news"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the daily news of the virgin islands (charlotte amalie, st. thomas, v.i.) 1955-1978 [online resource]"], "publication_frequency": ["daily"], "score": 73.974846, "shelf_id": "ISSN RECORD AN2.V63.C5 D35", "site": ["usnd"], "subject": ["charlotte amalie", "virgin islands", "african american", "caribbean", "african americans", "saint thomas", "caribbean americans", "united states virgin islands", "charlotte amalie (united states virgin islands)", "newspapers", "united states"], "timestamp": "2026-05-26T21:13:38.179Z", "title": "The daily news of the Virgin Islands", "type": ["title"], "url": "https://www.loc.gov/item/2024271072/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2024271073/"], "campaigns": [], "contributor": ["ottley, earle b."], "date": "1951", "dates": ["[1951 TO 1973]"], "description": ["Daily (except Sun.), Dec. 1971-1973 Print began with 1st year, no. 1 (Jan. 25, 1951); ceased with 21st year, no. 6144 (Jan. 12, 1973). Issue numbering is continuous. Issues for Nov. 7, 1956-<Dec. 31, 1958> lack issue no. Vols. for Oct. 1969-Mar. 1971 include a monthly supplement called Carib. Includes a weekly supplement called Focus, Sundays to Nov. 1971; Saturdays, Dec. 1971-Dec. 1972. Available on microfilm from Library of Congress Photoduplication Service. Saturday edition, 1968-1969, distributed and sold separately on St. Croix as the Crucian journal. 2nd Year, No. 115 (February 4, 1952); title from masthead (Chroniclingamerica.loc.gov, viewed March 21, 2024). 7th Year (December 31, 1958) (Chroniclingamerica.loc.gov, viewed March 21, 2024). Weekly journal (Charlotte Amalie, United States Virgin Islands : 1973)"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:15Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2024271073/", "image_url": [], "index": 8, "language": ["english"], "location": ["virgin islands", "saint thomas", "united states virgin islands", "charlotte amalie", "united states"], "number": ["online resource", "2024271073", "1427518360", "2026-04-13t21:30:13", "2996-9166"], "original_format": ["newspaper"], "other_title": ["Sunday issues for <June 22, 1969-> have title: Sunday journal"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the home journal (st. thomas, virgin islands) 1951-1973 [online resource]"], "publication_frequency": ["daily"], "score": 73.974846, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["charlotte amalie", "virgin islands", "african american", "caribbean", "african americans", "saint thomas", "caribbean americans", 