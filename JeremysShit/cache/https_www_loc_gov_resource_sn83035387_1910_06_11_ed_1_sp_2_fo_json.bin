rvices/iiif/service:ndnp:dlc:batch_dlc_ferguson_ver01:data:sn83035387:00211664563:1910061101:0513/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/dlc/batch_dlc_ferguson_ver01/data/sn83035387/00211664563/1910061101/0514.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn83035387/1910-06-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/dlc/batch_dlc_ferguson_ver01/data/sn83035387/00211664563/1910061101/0514.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83035387/1910-06-11/ed-1/?sp=2"], "batch": ["dlc_ferguson_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/ohio/", "2/united states/ohio/cuyahoga/", "3/united states/ohio/cuyahoga/cleveland/"], "contributor": ["library of congress, washington, dc"], "date": "1910-06-11", "dates": ["1910-06-11"], "description": ["2 th E GAZ ETTE PUBLISHED EVERY SATURDAY SUBSCRIPTION RATES In Advance One Year 150 Six Months 100 Three Months 50 Subscribers are requested ta re mit by postoffice money or der or registered letter Entered at the postoffice in Cleveland Ohio as secondclass matter Address all communications to HARRY C SMITH Editor and proprietor THE GAZETTE Blackstone Building Cleveland O Member Ohio Legislature 1894 to 1896 1896 to 1898 1900 to 1902 Cleveland 0 June 11 1910 THE GAZETTE is the oldest and has the largest bona fide circulation double that of any newspaper in the interest of AfroAmericans published in the state of Ohio and comparison with any will immediately establish its rank as one of the NEWSIEST AND BEST in the country The first issue of the Rochester N Y Sentinel makes a very creditable appearance indeed Success confrere Those are indeed encouraging items in our Doings of the Race depart ment this week We are pleased to be able to give them Associate Justice Harlan of the U S Supreme Court was seventyseven years of age June 1 He is our best friend on that bench a grand jurist a MAN May his life be long"], "digitized": true, "extract_timestamp": "2024-02-25T01:32:34.571Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83035387/1910-06-11/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_ferguson_ver01:data:sn83035387:00211664563:1910061101:0514/full/pct:3.125/0/default.jpg#h=290&w=210", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_ferguson_ver01:data:sn83035387:00211664563:1910061101:0514/full/pct:6.25/0/default.jpg#h=581&w=420", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_ferguson_ver01:data:sn83035387:00211664563:1910061101:0514/full/pct:12.5/0/default.jpg#h=1163&w=841", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_ferguson_ver01/data/sn83035387/00211664563/1910061101/0514.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["cuyahoga county", "cleveland", "cuyahoga", "ohio", "united states"], "location_city": ["cleveland"], "location_country": ["united states"], "location_county": ["cuyahoga"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "6", "1", "3", "0", "0000000002", "sn83035387", "5", "2"], "number_edition": ["1"], "number_lccn": ["sn83035387"], "number_page": ["0000000002"], "number_reel": ["0", "0", "2", "1", "1", "6", "6", "4", "5", "6", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "the gazette (cleveland, ohio) 1892-194?", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof