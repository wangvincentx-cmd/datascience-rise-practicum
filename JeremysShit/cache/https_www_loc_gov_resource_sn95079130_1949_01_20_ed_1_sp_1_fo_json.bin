st week Although they went in sight of Blue Head they did not cross into that wild land where angels fear to tread Phillips who was in command of the ma rauders has a very healthy re spect for that line that was drawn on him and bears in mind that the law goes only to Bart lick If winter comes can John L Lewis be far behind to para phrase a line from Keats Marquis Childs in Roanoke Times The one left behind in this in stance is"], "digitized": true, "extract_timestamp": "2024-02-06T12:42:30.975Z", "group": ["ndnp/vi", "library-of-virginia-richmond-va-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn95079130/1949-01-20/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:vi:batch_vi_jennet_ver02:data:sn95079130:00393348574:1949012001:0012/full/pct:6.25/0/default.jpg#h=400&w=279", "https://tile.loc.gov/image-services/iiif/service:ndnp:vi:batch_vi_jennet_ver02:data:sn95079130:00393348574:1949012001:0012/full/pct:12.5/0/default.jpg#h=801&w=559", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/vi/batch_vi_jennet_ver02/data/sn95079130/00393348574/1949012001/0012.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["virginia", "clintwood", "dickenson", "united states"], "location_city": ["clintwood"], "location_country": ["united states"], "location_county": ["dickenson"], "location_state": ["virginia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000001", "0", "3", "9", "8", "7", "sn95079130", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn95079130"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "9", "3", "3", "4", "8", "5", "7", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Dickenson herald"], "partof": ["dickenson county herald (clintwood, va.) 1939-195?", "serial and government publica