segment"], "url": "https://www.loc.gov/resource/sn83045462/1937-11-15/ed-1/?sp=1&q=business+revival", "word_coordinates_url": "https://tile.loc.gov/text-services/word-coordinates-service?format=alto_xml&segment=%2Fservice%2Fndnp%2Fdlc%2Fbatch_dlc_1kahlo_ver01%2Fdata%2Fsn83045462%2F00280602061%2F1937111501%2F0007.xml&q=business+revival&relevant_snippet=1"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83045462/1938-03-20/ed-1/?sp=4"], "batch": ["dlc_1lichtenstein_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/district of columbia/", "3/united states/district of columbia/washington/"], "contributor": ["library of congress, washington, dc"], "date": "1938-03-20", "dates": ["1938-03-20"], "description": ["PLOT MUONS Russia Would Be Fascist if Plan Had Succeeded Troyanovsky Says A defense of the Soviet govern ments severity in dealing with the former bolshevik leaders convicted of treason in the recent Moscow trial is presented here by the Soviet Ambassador to the United States in an interview obtained by a noted journalist and commentator on foreign affairs The writer born in Russia and educated in the United States served for many years as foreign correspondent for ewN York and Chicago newspapers By ELIAS TOBENKIN With the curtain rung down on the BukhannRykov trial in Moscow by the summary execution of 18 of the 21 accused Alexander A Troyanovsky Soviet Ambassador to the United States in an exclusive interview with the writer defended the severity of the Soviet government in refusing to commute the sentence of a single one of the 18 defendants from death to imprisonment despite their own and international pleas for clemency Had their plots not been disclosed in time Russia would today be where Austria is under the yoke of a Fascist ruler Mr Troyanovsky said We cannot be soft toward individual criminals for the mere reason that in the past through our generosity thpy"], "digitized": true, "extract_timestamp"