s with a 200 booty Gaynell Loughney was declared Snow Queen and she was so pre sented at a dance held at the Labor Temple Saturday night Wheels were used"], "digitized": true, "extract_timestamp": "2023-07-03T13:45:05.328Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84036287/1938-03-11/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_clarkia_ver01:data:sn84036287:00340581830:1938031101:0074/full/pct:6.25/0/default.jpg#h=465&w=349", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_clarkia_ver01:data:sn84036287:00340581830:1938031101:0074/full/pct:12.5/0/default.jpg#h=930&w=698", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_clarkia_ver01/data/sn84036287/00340581830/1938031101/0074.xml&format=alto_xml"], "index": 22, "language": ["english"], "location": ["montana", "united states", "carbon", "red lodge"], "location_city": ["red lodge"], "location_country": ["united states"], "location_county": ["carbon"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "sn84036287", "1", "4", "8", "0000000001"], "number_edition": ["1"], "number_lccn": ["sn84036287"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "1", "8", "3", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "page_id": "sn84036287-1938-03-11-ed-1-0074", "partof": ["chronicling america", "serial and government publications division", "carbon county news (red lodge, mont.) 1936-current"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["carbon county news (red lodge, mont.) 1936-current"], "publication_frequency": ["weekly"], 