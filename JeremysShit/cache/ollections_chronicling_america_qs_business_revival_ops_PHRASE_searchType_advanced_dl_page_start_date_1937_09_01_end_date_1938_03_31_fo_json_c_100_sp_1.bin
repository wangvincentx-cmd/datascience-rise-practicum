er02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/district of columbia/", "3/united states/district of columbia/washington/"], "contributor": ["library of congress, washington, dc"], "date": "1938-01-02", "dates": ["1938-01-02"], "description": ["STORE SALES GAIN IN WEEK AND TEAR Retail Trade in Capital and Fifth District Is Ahead of 1936 Retail trade in Washington for the week ending Wednesday Decern ber 29 registered a sharp increase of 3082 per cent over the corresponding week a year ago the Commerce De partment reported in a summary cov ering 38 key cities The comparison however is a fiveday week with a fourday week last year Comparison with the previous week shows a decrease of 59 per cent as the fiveday week is compared with the six shopping days in the previous period Retail trade in the whole fifth Re serve district which includes Wash ington is expected to reveal a mod erate increase over 1936 for the full year the Commerce report states The district as a whole also scored a slight gain last week over the same week a year ago Batimores retail volume will un doubtedly show an advance for the full year over 1936 the report said So will Richmond and Norfolk Busi ness in Charleston S C will be up from 5 to 10 per cent for the full year Reports to the Department of Com merce from many cities"], "digitized": true, "extract_timestamp": "2020-09-15T06:38:30.388Z", "group": ["ndnp/dlc-2018_2019", "library-of-congress-washington-dc-awardee-7"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045462/1938-01-02/ed-1/?sp=58", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_1lichtenstein_ver02:data:sn83045462:00280601676:1938010201:0383/full/pct:6.25/0/default.jpg#h=486&w=348", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_1lichtenstein_ver02:data:sn83045462:00280601676:1938010201:0383/full/pct:12.5/0/default.jpg#h=973&w=697", "https://tile.loc.gov/text-services/word