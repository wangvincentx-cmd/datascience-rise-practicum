lection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the times-news (hendersonville, n.c.) 1927-current"], "publication_frequency": ["daily"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn86063811/1938-02-21/ed-1/?sp=3"}], "segmentof": ["http://www.loc.gov/resource/sn86063811/1938-02-21/ed-1/"], "shelf_id": "3", "site": ["chroniclingamerica"], "subject": ["hendersonville (n.c.)", "hendersonville", "united states", "henderson", "north carolina", "newspapers"], "timestamp": "2023-08-13T02:28:15.265Z", "title": "Image 3 of The times-news (Hendersonville, N.C.), February 21, 1938", "type": ["segment"], "url": "https://www.loc.gov/resource/sn86063811/1938-02-21/ed-1/?sp=3&q=business+revival", "word_coordinates_url": "https://tile.loc.gov/text-services/word-coordinates-service?format=alto_xml&segment=%2Fservice%2Fndnp%2Fncu%2Fbatch_ncu_endive_ver02%2Fdata%2Fsn86063811%2F0027955839A%2F1938022101%2F0277.xml&q=business+revival&relevant_snippet=1"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83045462/1937-11-27/ed-1/?sp=7"], "batch": ["dlc_1kahlo_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/district of columbia/", "3/united states/district of columbia/washington/"], "contributor": ["library of congress, washington, dc"], "date": "1937-11-27", "dates": ["1937-11-27"], "description": ["Surplus Tax Plea Goes Unheeded Administration Is In different to Busi ness Rv DAVID LAWRENCE AMERICAN business has pleaded with the Roosevelt administra tion to do something about the undistributed surplus tax The Treasury has indicated that it favors revision Congress has shown the same attitude but there is nevertheless a sort of rasualness and indifference toward the fact that every American business which lias a net income must know between now and Derern ber 31 whether there is going to be a change in the undistributed surplus tax Not only is it Important to know how to han dle the fourth quarter dividends but also in most instances it is vi tal to decide how much of what is earned in 1 9 3 7 l shall go into re serves and how much will have to be paid out lest a penalty be incurred For the present law penalizes a busi ness for saving its money or for trying to expand and give employment The undistributed surplus tax was properly termed last year during the campaign a cockeyed piece of legis lation but anybody who has studied the effects of it would have difficulty in using such temperate"], "digitized": true, "extract_timestamp": "2020-09-15T06:38:30.388Z", "group": ["ndnp/dlc-2018_2019", "library-of-congress-washington-dc-awardee-7"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045462/1937-11-27/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_1kahlo_ver01:data:sn83045462:00280602061:1937112701:0633/full/pct:6.25/0/default.jpg#h=486&w=347", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_1kahlo_ver01:data:sn83045462:00280602061:1937112701:0633/full/pct:12.5/0/default.jpg#h=973&w=694", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_1kahlo_ver01/data/sn83045462/00280602061/1937112701/0633.xml&format=alto_xml"], "index": 18, "language": ["english"], "location": ["united states", "washington", "washington d.c.", "district of columbia"], "location_city": ["washington"], "location_country": ["united states"], "location_state": ["district of columbia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "2", "1", "8", "0000000007", "sn83045462", "6"], "number_edition": ["1"], "number_lccn": ["sn83045462"], "number_page": ["0000000007"], "number_reel": ["0", "0", "2", "8", "0", "6", "0", "2", "0", "6", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"],