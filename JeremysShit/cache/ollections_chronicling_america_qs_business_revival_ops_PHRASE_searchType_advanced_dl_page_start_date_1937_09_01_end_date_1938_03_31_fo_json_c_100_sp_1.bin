": ["mthi_fireweed_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/carbon/", "3/united states/montana/carbon/red lodge/"], "contributor": ["montana historical society; helena, mt"], "date": "1937-12-24", "dates": ["1937-12-24"], "description": ["Carbon County News y If 0 H P SHELLEY Editor and Owner Published every Friday at Red Lodge Carbon Co Montana Entered at the Postoffice at Red Lodge Montana as Matter of Second Class under the Act of Congress of March 6 1879 SubscriptionPer year 250 six months 150 three months 76 All subscriptions payable in advance OFFICIAL PAPER OF CARBON COUNTY AND CITY OF RED LODGE TELEPHONE number nine THE DILEMMA Now that the national debt is approaching the forty bil lion mark and it seems vitally necessary that we have a policy of retrenchment pointed toward balancing the bud get the New Dealers at Washington are finding them selves between the two hornsof the dilemma There is danger that too much retrenchment may accelerate the present business recession by continuing deflation while on the other hand there is the peril that continued pump priming may lead us into uncontrolled inflation and dis aster The judgment of unbiased financial students at this time is that there is no prospect of budget balancing in the near future Expenditures are increasing while feder al revenues are falling off And the tendency is not now to impose new taxes in an effort"], "digitized": true, "extract_timestamp": "2023-07-03T13:46:22.504Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84036287/1937-12-24/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_fireweed_ver01:data:sn84036287:00340581891:1937122401:1247/full/pct:6.25/0/default.jpg#h=452&w=341", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_fireweed_ver01:data:sn8403628