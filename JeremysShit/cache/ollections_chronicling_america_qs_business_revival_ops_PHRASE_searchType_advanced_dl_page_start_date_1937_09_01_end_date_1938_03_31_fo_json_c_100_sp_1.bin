ion at the 25th legislative session is too well known to bear repetition It was a complete fiasco The blanket eight hour bill with which it was intend ed to put teeth in the eighthour amendment to the Constitution of Montana was defeated by a reac tionary senate The occupational disease silicosis bill was also de feated by the same body To cap the climax the eighthour collarto collar bill which would have affect ed thousands of miners throughout the sate was also"], "digitized": true, "extract_timestamp": "2023-07-03T13:47:31.812Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075141/1938-01-27/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075141:00340582032:1938012701:0705/full/pct:6.25/0/default.jpg#h=412&w=302", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075141:00340582032:1938012701:0705/full/pct:12.5/0/default.jpg#h=825&w=604", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075141/00340582032/1938012701/0705.xml&format=alto_xml"], "index": 24, "language": ["english"], "location": ["butte", "united states", "silver bow", "montana"], "location_city": ["butte"], "location_country": ["united states"], "location_county": ["silver bow"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "sn86075141", "0", "2", "1", "4", "8", "0000000006"], "number_edition": ["1"], "number_lccn": ["sn86075141"], "number_page": ["0000000006"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "2", "0", "3", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "page_id": "sn86075141-1938-01-27-ed-1-0705", "partof": ["montana labor news (bu