.loc.gov/resource/sn83045462/1938-02-07/ed-1/"], "shelf_id": "15", "site": ["chroniclingamerica"], "subject": ["washington (d.c.)", "district of columbia", "united states", "washington", "newspapers"], "timestamp": "2022-10-24T21:12:28.485Z", "title": "Image 15 of Evening star (Washington, D.C.), February 7, 1938", "type": ["segment"], "url": "https://www.loc.gov/resource/sn83045462/1938-02-07/ed-1/?sp=15&q=business+revival", "word_coordinates_url": "https://tile.loc.gov/text-services/word-coordinates-service?format=alto_xml&segment=%2Fservice%2Fndnp%2Fdlc%2Fbatch_dlc_1lichtenstein_ver02%2Fdata%2Fsn83045462%2F0028060169A%2F1938020701%2F0605.xml&q=business+revival&relevant_snippet=1"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84036287/1938-03-11/ed-1/?sp=1"], "batch": ["mthi_clarkia_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/carbon/", "3/united states/montana/carbon/red lodge/"], "contributor": ["montana historical society; helena, mt"], "date": "1938-03-11", "dates": ["1938-03-11"], "description": ["S CARBON COUNTY NEWS OFFICIAL PAPER OF CARBON COUNTY AND CITY OF RED LODGE RED LODGE DAILY nkus VOL 3 NO 296 CARBON COUNTY NEWS VOL XV NO 2 RED LODGE CARBON COUNTY MONTANA MARCH 1 1936 DERBY ATTENDED BY ABOUT 7000 PERSONS SUNDAY Celey Baum Captures First Place Other Acts Pleasing Red Lodge thrilled to an exhibi tion of dog racing here Sunday which marked the first demonstra tion of a dog derby ever to appear in Red Lodge Although run on snowless streets the derby was well attended by throngs from outside of the city It was estimated that approximate ly 7606 lined the streets to watch the event Celey Baum Ashton Ida was clocked first in the major event in the time of 29 minutes and one second Lloyd Van Sickle took sec ond and Bill Zink of West Yellow stone Mont was given third place money First prize of 500 went to Baum second prize of 300 went to Van Sickle while Bill Zink took third honors with a 200 booty Gaynell Loughney was declared Snow Queen and she was so pre sented at a dance held at the Labor Temple Saturday night Wheels were used"], "digitized": true, "extract_timestamp": "2023-07-03T13:45:05.328Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84036287/1938-03-11/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_clarkia_ver01:data:sn84036287:00340581830:1938031101:0074/full/pct:6.25/0/default.jpg#h=465&w=349", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_clarkia_ver01:data:sn84036287:00340581830:1938031101:0074/full/pct:12.5/0/default.jpg#h=930&w=698", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_clarkia_ver01/data/sn84036287/00340581830/1938031101/0074.xml&format=alto_xml"], "index": 22, "language": ["english"], "location": ["montana", "united states", "carbon", "red lodge"], "location_city": ["red lodge"], "location_country": ["united states"], "location_county": ["carbon"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "sn84036287", "1", "4", "8", "0000000001"], "number_edition": ["1"], "number_lccn": ["sn84036287"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "1", "8", "3", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "page_id": "sn84036287-1938-03-11-ed-1-0074", "partof": ["chronicling america", "serial and government publications division", "carbon county news (red lodge, mont.) 1936-current"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["carbon county news (red lodge, mont.) 1936-current"], "publication_f