y at this time 99 8 Unquestionably a German American 8 s Clapper trade agreement now would be used for political purposes both abroad and at home and altho little is said about these broader considerations they undoubtedly I have a strong influence here The Hitler I regime is extremely unpopular in Con gress and a trade agreement with Ger many would be used as a vehicle for at tack on the whole reciprocal program Abroad such an agreement might be"], "digitized": true, "extract_timestamp": "2025-09-28T04:52:14.430Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82016181/1937-11-27/ed-1/?sp=17", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_bullock_ver01:data:sn82016181:00516999615:1937112701:0901/full/pct:6.25/0/default.jpg#h=329&w=226", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_bullock_ver01:data:sn82016181:00516999615:1937112701:0901/full/pct:12.5/0/default.jpg#h=659&w=452", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_bullock_ver01/data/sn82016181/00516999615/1937112701/0901.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["united states", "washington", "washington d.c.", "district of columbia"], "location_city": ["washington"], "location_country": ["united states"], "location_state": ["district of columbia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "0000000017", "sn82016181", "1", "9", "6"], "number_edition": ["1"], "number_lccn": ["sn82016181"], "number_page": ["0000000017"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "9", "6", "1", "5"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "page_id": "sn82016181-1937-11-27-ed-1-0901", "partof": ["chronicling america", "the washington daily news