e rule applicable to every driver is this Always drive as though the persons behind the wheels of every other auto mobile are insane Drive as though every other driver were intending to"], "digitized": true, "extract_timestamp": "2025-09-02T13:59:44.364Z", "group": ["ndnp/curiv", "university-of-california-riverside-riverside-ca-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92070146/1937-11-24/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_roseheath_ver01:data:sn92070146:00414188849:1937112401:0066/full/pct:6.25/0/default.jpg#h=459&w=363", "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_roseheath_ver01:data:sn92070146:00414188849:1937112401:0066/full/pct:12.5/0/default.jpg#h=918&w=727", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/curiv/batch_curiv_roseheath_ver01/data/sn92070146/00414188849/1937112401/0066.xml&format=alto_xml"], "index": 28, "language": ["english"], "location": ["san diego county", "california", "imperial", "united states", "el centro", "imperial county"], "location_city": ["el centro"], "location_country": ["united states"], "location_county": ["imperial"], "location_state": ["california"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000004", "0", "sn92070146", "1", "8", "4", "9"], "number_edition": ["1"], "number_lccn": ["sn92070146"], "number_page": ["0000000004"], "number_reel": ["0", "0", "4", "1", "4", "1", "8", "8", "8", "4", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Imperial Valley press and El Centro progress", "Post-press", "Imperial Valley news-press", "Imperial Valley press/Brawley news", "Morning post-Imperial Valley press", "At head of title: Extra Imperial Valley press"], "page_id": "sn92070146-1937-11-24-ed-1-0066", "partof": ["chronicling a