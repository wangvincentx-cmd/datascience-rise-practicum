wife T4 who was killed in the wreck Mr Haynes who lives at 707 Rock Creek Church road NW testified he werved his machine to the right of the highway in a futile effort to avoid the crash After completing the Snyder in fluest the jury turned to an inquiry into the death of Miss Mary Clement 66 of 223 Pennsylvania avenue SE who died Sunday in Providence Hos pital of injuries received Saturday when struck by an automobile at Thirteenth and D streets NE George H Hughes 21 of 622 Morton place NE was listed by police as driver Coroner A Magruder MacDonald also planned to perform an autopsy to determine whether Charles Rawlings"], "digitized": true, "extract_timestamp": "2020-09-15T06:38:36.478Z", "group": ["ndnp/dlc-2018_2019", "library-of-congress-washington-dc-awardee-7"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045462/1938-01-11/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_1lichtenstein_ver02:data:sn83045462:00280601688:1938011101:0041/full/pct:6.25/0/default.jpg#h=490&w=351", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_1lichtenstein_ver02:data:sn83045462:00280601688:1938011101:0041/full/pct:12.5/0/default.jpg#h=980&w=703", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_1lichtenstein_ver02/data/sn83045462/00280601688/1938011101/0041.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["united states", "washington", "washington d.c.", "district of columbia"], "location_city": ["washington"], "location_country": ["united states"], "location_state": ["district of columbia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000003", "0", "2", "1", "8", "sn83045462", "6"], "number_edition": ["1"], "number_lccn": ["sn83045462"], "number_page": ["0000000003"], "number_reel": ["0", "0", "2", "8", "0", "6", "0", "1", "6", "8", 