 sections Bonds were higher Commodities tfter a mixed start pointed higher Foreign markets were irregular Livestock SO ST PUAL South St Paul Dec 8 W J S Dep AgrCattle 3000 slaughter steers opening steady good fed steers up to 900 some held higher good heifers 700800 plafti to medium cows 425550 bulls"], "digitized": true, "extract_timestamp": "2023-08-25T19:28:40.852Z", "group": ["ndnp/ndhi", "state-histrorical-society-of-north-dakota-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85042243/1937-12-08/ed-1/?sp=11", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_jemhadar_ver01:data:sn85042243:00383346162:1937120801:0884/full/pct:6.25/0/default.jpg#h=422&w=324", "https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_jemhadar_ver01:data:sn85042243:00383346162:1937120801:0884/full/pct:12.5/0/default.jpg#h=845&w=649", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ndhi/batch_ndhi_jemhadar_ver01/data/sn85042243/00383346162/1937120801/0884.xml&format=alto_xml"], "index": 32, "language": ["english"], "location": ["morton", "bismarck", "mandan", "united states", "north dakota", "burleigh"], "location_city": ["bismarck", "mandan"], "location_country": ["united states"], "location_county": ["burleigh", "morton"], "location_state": ["north dakota"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0", "2", "1", "4", "8", "sn85042243", "0000000011", "6"], "number_edition": ["1"], "number_lccn": ["sn85042243"], "number_page": ["0000000011"], "number_reel": ["0", "0", "3", "8", "3", "3", "4", "6", "1", "6", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Bismarck daily tribune", "Bismarck evening tribune"], "page_id": "sn85042243-1937-12-08-ed-1-0884", "partof": ["chronicling america", "serial and government publications divi