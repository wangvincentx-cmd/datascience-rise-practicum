-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn2008060405/00332898097/1910112501/0304.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_cinnabar_ver01:data:sn2008060405:00332898097:1910112501:0299/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn2008060405/00332898097/1910112501/0304.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn2008060405/1910-11-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn2008060405/00332898097/1910112501/0304.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn2008060405/1910-11-25/ed-1/?sp=6"], "batch": ["iune_cinnabar_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/illinois/", "2/united states/illinois/cook/", "3/united states/illinois/cook/chicago/", "2/united states/illinois/dupage/", "3/united states/illinois/dupage/downers grove/"], "contributor": ["university of illinois at urbana-champaign library, urbana, il"], "date": "1910-11-25", "dates": ["1910-11-25"], "description": ["A Foe to Union ILalbor In various ways and on many occasions the evil influence of the saloon has been recognized and pointed out by the labor unions of the United States While the liquor interests have sought to convey the impression that there was some common interest between trade unionism and the manufacture and sale of intoxicants this suggestion is repelled on every occasion when the matter is presented to the labor men in its true light and when the malign pur pose of the liquor interests is exposed to view I have no sympathy with the statement so often made that the manufacture and sale of liquor has contributed to the industrial development of the nation On the contrary I believe that liquor has contributed more to the moral intellectual and material deterioration of the people and has brought more misery to defenseless women and children than has any other agency in the history of mankindJohn Mitchell Labor Champion in a letter written to the Very Reverend James E Cassidy Fall River Mass THey Didnt Want Facts The socalled Citizens Defense Committee of St Louis who fought to keep the breweries and saloons in St Louis and Missouri"], "digitized": true, "extract_timestamp": "2025-05-21T10:17:57.074Z", "group": ["ndnp/iune", "university-of-illinois-at-urbana-champaign-library-urbana-il-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn2008060405/1910-11-25/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_cinnabar_ver01:data:sn2008060405:00332898097:1910112501:0304/full/pct:6.25/0/default.jpg#h=330&w=248", "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_cinnabar_ver01:data:sn2008060405:00332898097:1910112501:0304/full/pct:12.5/0/default.jpg#h=661&w=497", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn2008060405/00332898097/1910112501/0304.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["illinois", "chicago", "downers grove", "dupage", "cook", "united states"], "location_city": ["chicago", "downers grove"], "location_country": ["united states"], "location_county": ["cook", "dupage"], "location_state": ["illinois"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "1", "0", "9", "7", "0000000006", "8", "sn2008060405", "2"], "number_edition": ["1"], "number_lccn": ["sn2008060405"], "number_page": ["0000000006"], "number_reel": ["0", "0", "3", "3", "2", "8", "9", "8"