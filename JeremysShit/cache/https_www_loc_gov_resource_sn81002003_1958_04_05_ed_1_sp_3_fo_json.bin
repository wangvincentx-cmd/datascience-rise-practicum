yougo policy is chucked out th\u00e8 window How can th\u00e8 govern ili ent expeqt its citizens to be thrifty when it gives no heed to tomorrows bills NEW PHILADELPHIA OHIO Daily Times The communist world does a great deal of blatant advertis ing of its alleged charms for th\u00e8 masses of humanity In a recent CBS interview Mayor Willy Brandt of West Berlin said that every day 300 to 500 East Ger mans cross into West Berlin as refu gees Since 1950 th\u00e8 stream has"], "digitized": true, "extract_timestamp": "2025-12-01T12:41:50.593Z", "group": ["ndnp/nbu", "university-of-nebraska-of-nebraska-lincoln-libraries-lincoln-ne-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn81002003/1958-04-05/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_housesparrow_ver01:data:sn81002003:00517014217:1958040501:1001/full/pct:6.25/0/default.jpg#h=329&w=210", "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_housesparrow_ver01:data:sn81002003:00517014217:1958040501:1001/full/pct:12.5/0/default.jpg#h=658&w=420", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_housesparrow_ver01/data/sn81002003/00517014217/1958040501/1001.xml&format=alto_xml"], "index": 3, "language": ["english", "italian"], "location": ["douglas county", "iowa", "douglas", "nebraska", "united states", "omaha"], "location_city": ["omaha"], "location_country": ["united states"], "location_county": ["douglas"], "location_state": ["nebraska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "0", "5", "7", "2", "0000000003", "1", "sn81002003"], "number_edition": ["1"], "number_lccn": ["sn81002003"], "number_page": ["0000000003"], "number_reel": ["0", "0", "5", "1", "7", "0", "1", "4", "2", "1", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial 