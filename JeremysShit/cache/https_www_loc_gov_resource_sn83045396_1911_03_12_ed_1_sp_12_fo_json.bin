f Boston block", "url": "https://www.loc.gov/item/2013646211/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017587026", "http://www.loc.gov/item/2017587026/", "https://search.catalog.loc.gov/instances/08e59c5a-661e-5d0e-9b3b-c841b758b67d", "https://hdl.loc.gov/loc.gmd/g4344s.ct011426", "http://www.loc.gov/resource/g4344s.ct011426/", "https://hdl.loc.gov/loc.gmd/g4344s.ct011427", "http://www.loc.gov/resource/g4344s.ct011427/"], "campaigns": [], "contributor": ["sherwood, henry garlick", "pratt, orson"], "date": "1847", "dates": ["1847"], "description": ["Manuscript plat map, pen-and-ink on thick flexible sheepskin, signed and inscribed by H.G. Sherwood, nailed at the top to its original wooden roller. This manuscript plat map is believed to be the first map of Salt Lake City, Utah. Title supplied by acquisition specialist. Sherwood retained ownership of the plat while the city was being constructed. In 1852, it passed into the hands of Jesse William Fox, Sr., Sherwood's successor as Territory Surveyor General of Utah. Accompanied by text (property of Jesse W. Fox): Engineer's field book / by C.S. Cross. New York : Baptist & Taylor Book, 1855. 43 pages ; 19 cm. Includes notes and diagrams. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:11.686Z", "group": ["gmd.mar", "catalog-split-06", "catalog", "general-maps", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/2017587026/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd434/g4344/g4344s/ct011426.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd434/g4344/g4344s/ct011426.gif#h=150&w=100", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd434:g4344:g4344s:ct011426/full/pct:12.5/0/default.jpg#h=812&w=541", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd434:g4344:g4344s:ct011426/full/pct:25/0/default.jpg#h=1625&w=1082"], "index": 13, "languag