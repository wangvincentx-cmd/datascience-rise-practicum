nlzing of wines not made in Champagne will It Is hoped bo suppressed by the champagno bill which was passed in tho chamber of deputies a few days ago The duty of one halfpenny"], "digitized": true, "extract_timestamp": "2020-09-15T16:04:49.265Z", "group": ["ndnp/uuml", "university-of-utah-marriott-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045396/1911-03-12/ed-1/?sp=12", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:uuml:batch_uuml_pereiro_ver01:data:sn83045396:print:1911031201:0189/full/pct:3.125/0/default.jpg#h=263&w=206", "https://tile.loc.gov/image-services/iiif/service:ndnp:uuml:batch_uuml_pereiro_ver01:data:sn83045396:print:1911031201:0189/full/pct:6.25/0/default.jpg#h=527&w=413", "https://tile.loc.gov/image-services/iiif/service:ndnp:uuml:batch_uuml_pereiro_ver01:data:sn83045396:print:1911031201:0189/full/pct:12.5/0/default.jpg#h=1055&w=827", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/uuml/batch_uuml_pereiro_ver01/data/sn83045396/print/1911031201/0189.xml&format=alto_xml"], "index": 12, "language": ["english"], "location": ["united states", "utah", "salt lake city", "salt lake"], "location_city": ["salt lake city"], "location_country": ["united states"], "location_county": ["salt lake"], "location_state": ["utah"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["1", "sn83045396", "0000000012"], "number_edition": ["1"], "number_lccn": ["sn83045396"], "number_page": ["0000000012"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the salt lake tribune (salt lake city, utah) 1890-current", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the salt lake tribune (salt lake