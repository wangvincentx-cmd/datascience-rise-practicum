, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/scu/batch_scu_figs_ver02/data/sn84026897/00516990983/1923111401/0367.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_figs_ver02:data:sn84026897:00516990983:1923111401:0367/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/scu/batch_scu_figs_ver02/data/sn84026897/00516990983/1923111401/0367.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn84026897/1923-11-14/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/scu/batch_scu_figs_ver02/data/sn84026897/00516990983/1923111401/0367.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84026897/1923-11-14/ed-1/?sp=1"], "batch": ["scu_figs_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/south carolina/", "2/united states/south carolina/edgefield/", "3/united states/south carolina/edgefield/edgefield/"], "contributor": ["university of south carolina; columbia, sc"], "date": "1923-11-14", "dates": ["1923-11-14"], "description": ["Gifgefikm BaumsHeu Gl\u00fccki Newspapers\u00e5sovtb Gsroling VOL 88 EDGEFIELD S C WEDNESDAY NOV 14 1923 No 41 JOHNSTON LETTER Won Football Game Give a Pounding to Orphanage Death of Mr Milton Lott The football team of the Johnston high school went over to Abbeville on Friday to play the school team of that place The team from here was accompanied by Prof Arnold and Prof Chappell of the school besides others interested The game was an exciting one and while Abbeville team did good playing the Johnston team won by a large score In all the games that have been played a fine spirit has been manifested each time by both the winning and the losing sides Prof Fred L Parker organist at the Baptist church and Mr Avery Bland choir director are arranging a cantata for Sunday evening De cember 23rd this being The Man ger Prince and will occupy an hour This beautiful musical feature will be held in the Baptist church at the evening service instead of the regu lar preaching Members from the other choirs of the town will be in vited to join in This beautiful can tata was given last year in Colum bia and"], "digitized": true, "extract_timestamp": "2025-04-13T07:39:03.526Z", "group": ["ndnp/scu", "university-of-south-carolina-columbia-sc-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84026897/1923-11-14/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_figs_ver02:data:sn84026897:00516990983:1923111401:0367/full/pct:6.25/0/default.jpg#h=404&w=275", "https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_figs_ver02:data:sn84026897:00516990983:1923111401:0367/full/pct:12.5/0/default.jpg#h=808&w=551", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/scu/batch_scu_figs_ver02/data/sn84026897/00516990983/1923111401/0367.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["south carolina", "edgefield", "united states", "edgefield county"], "location_city": ["edgefield"], "location_country": ["united states"], "location_county": ["edgefield"], "location_state": ["south carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["sn84026897", "6", "1", "3", "0", "8", "9", "5", "0000000001"], "number_edition": ["1"], "number_lccn": ["sn84026897"], "number_page": ["0000000001"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "0", "9", "8", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "edgefield advertiser (edgefield, s.c.) 1836-current", "serial and government publications division"], "partof_collection": ["chronicling a