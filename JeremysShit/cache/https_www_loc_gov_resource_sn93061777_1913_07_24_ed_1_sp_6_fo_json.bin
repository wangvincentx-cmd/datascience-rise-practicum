lltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nmu/batch_nmu_barberry_ver04/data/sn93061777/00280774479/1913072401/0410.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:nmu:batch_nmu_barberry_ver04:data:sn93061777:00280774479:1913072401:0405/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/nmu/batch_nmu_barberry_ver04/data/sn93061777/00280774479/1913072401/0410.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn93061777/1913-07-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/nmu/batch_nmu_barberry_ver04/data/sn93061777/00280774479/1913072401/0410.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn93061777/1913-07-24/ed-1/?sp=6"], "batch": ["nmu_barberry_ver04"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/new mexico/", "2/united states/new mexico/curry/", "3/united states/new mexico/curry/clovis/", "2/united states/new mexico/roosevelt/", "3/united states/new mexico/roosevelt/clovis/"], "contributor": ["university of new mexico"], "date": "1913-07-24", "dates": ["1913-07-24"], "description": ["The Clovis News The News Printing Company Ir J E Curren Editor Arthur E Curren Manager Entered at the post office at Clovis N M as second class matter under the act of March 3 1879 TERMS OF SUBSCRIPTION One Year 100 Six Months 50 The folly of harboring a red light district in the heart of the city within a block of the main business thoroughfare and practicelly adjoining the freight depot is just now being brought to the attention of the Clovis people by evangelist Rev T 0 Reese who with his singer J P Scholfield ae couducting nightly revival meetings at the Baptist church Mr Reese is handling the sit uation without gloves as the saying is and his criticism of this public nuisance is timely and correct If the bawdy house is a nec essary evil then why not locate it in some remote section or se cluded spot on the outskirts of the city and not where the fam ilies of respectable residents can see them daily It is said that the denizens of the district are becoming so soliticious as to give the hailing sign to pas sengers on the trains fJgH Alderman Childers"], "digitized": true, "extract_timestamp": "2020-09-15T13:11:56.123Z", "group": ["ndnp/nmu", "university-of-new-mexico-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn93061777/1913-07-24/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nmu:batch_nmu_barberry_ver04:data:sn93061777:00280774479:1913072401:0410/full/pct:6.25/0/default.jpg#h=387&w=259", "https://tile.loc.gov/image-services/iiif/service:ndnp:nmu:batch_nmu_barberry_ver04:data:sn93061777:00280774479:1913072401:0410/full/pct:12.5/0/default.jpg#h=774&w=518", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nmu/batch_nmu_barberry_ver04/data/sn93061777/00280774479/1913072401/0410.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["roosevelt county", "united states", "roosevelt", "curry", "new mexico", "clovis", "curry county"], "location_city": ["clovis"], "location_country": ["united states"], "location_county": ["curry", "roosevelt"], "location_state": ["new mexico"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["sn93061777", "4", "0000000006", "1", "0", "8", "9", "7", "2"], "number_edition": ["1"], "number_lccn": ["sn93061777"], "number_page": ["0000000006"], "number_reel": ["0", "0", "2", "8", "0", "7", "7", "4", "4", "7", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Clovis news and Texico trumpet"], "partof": ["chronicling america", "the clovis news (clovis, n.m.) 1907-1929", "se