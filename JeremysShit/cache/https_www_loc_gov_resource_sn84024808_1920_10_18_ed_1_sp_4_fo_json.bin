h_mthi_bison_ver01/data/sn84024808/00295860704/1920101801/0180.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn84024808:00295860704:1920101801:0177/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn84024808/00295860704/1920101801/0180.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn84024808/1920-10-18/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn84024808/00295860704/1920101801/0180.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84024808/1920-10-18/ed-1/?sp=4"], "batch": ["mthi_bison_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/cascade/", "3/united states/montana/cascade/great falls/"], "contributor": ["montana historical society; helena, mt"], "date": "1920-10-18", "dates": ["1920-10-18"], "description": ["GREAT FALLS DAILY TRIBUNE LEONARD a D1EHL If Bustneu Managt cl Editor Manager EDITORIAL PAGE THE DEPARTMENT OF AGRICULTURE The record of achievements of the Department of Agriculture under Democratic rule stands in sharp contrast with the record of neglect of the American farmers by the Republican congress according to Secretary of Agriculture Edwin T Meredith In an interview recently Mr Mere dith cited many acts of the Democratic admin istration beneficial to the agricultural interests of the country and arraigned the Republican congress for its failure to appropriate funds to carry on important work of the Department of Agriculture Secretary Meredith asserted that many of the features of the Agricultural Department advo cated by Senator Hording the Republican candi date for president have been established by the Democrats He said these agencies for the bene fit of the American farmers would now be func tioning in full measure but for the indifference of the Republican congress The Republican leaders he said have cheated the farmers of these services by pretending to economize in order to secure votes In no six years of the history of the country has there been beneficient legislation in behalf of agriculture approaching in scope"], "digitized": true, "extract_timestamp": "2023-07-03T13:44:53.723Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84024808/1920-10-18/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn84024808:00295860704:1920101801:0180/full/pct:6.25/0/default.jpg#h=476&w=366", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn84024808:00295860704:1920101801:0180/full/pct:12.5/0/default.jpg#h=953&w=732", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn84024808/00295860704/1920101801/0180.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["great falls", "cascade", "united states", "montana"], "location_city": ["great falls"], "location_country": ["united states"], "location_county": ["cascade"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "9", "0", "8", "sn84024808", "0000000004", "4", "7", "6", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn84024808"], "number_page": ["0000000004"], "number_reel": ["0", "0", "2", "9", "5", "8", "6", "0", "7", "0", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "great falls daily tribune (great falls, mont.) 1895-1921"], "partof_collection": ["chronic