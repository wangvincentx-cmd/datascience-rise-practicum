 false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017693199/", "http://www.loc.gov/item/2017693199/", "http://www.loc.gov/pictures/item/2017693199/", "https://hdl.loc.gov/loc.pnp/fsa.8b03931", "http://www.loc.gov/resource/fsa.8b03931/", "http://lccn.loc.gov/2017693199"], "campaigns": [], "contributor": ["freeman, albert", "hollem, howard r.", "roberts, martha mcmillan", "liberman, howard", "united states. office of war information"], "date": "1942-01-01", "dates": ["1942"], "description": ["1 negative : safety ; 4 x 5 inches or smaller."], "digitized": true, "extract_timestamp": "2021-09-01T20:10:22.732Z", "group": ["fsa", "catalog-split-15", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-15", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017693199/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8b03000/8b03900/8b03931_150px.jpg#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b03000/8b03900/8b03931t.gif#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b03000/8b03900/8b03931r.jpg#h=513&w=640", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b03000/8b03900/8b03931v.jpg#h=821&w=1024"], "index": 2, "language": ["english"], "location": ["summit county", "akron", "united states", "ohio"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/19638447", "http://www.loc.gov/item/oem2002004127/pp", "2017693199", "2017-05-15t09:30:27", "http://www.loc.gov/item/2017693199"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 1936", "prints and photographs division", "farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "american memory", "catalog"], "score": 32.008778, "shelf_id": "LC-USE6- D-005529 [P&P] LOT 1936  (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["summit county", "safety film negatives", "ohio", "akron", "united states"], "timestamp": "2022-04-25T15:24:37.473Z", "title": "Salvage. Scrap rubber collection. Have you any old rubber lying around? Look at this picture closely and you will find many things that you too can contribute to the national scrap rubber pile. This accumulation in the yards of the Dowenthal Company in Akron, Ohio, contains old bicycle tires, hot water bottles, fruit jar rings, rubber heals and soles, floor mats, tire patches, hose connections, tubing, gaskets, fan belts, washers, in fact, everything but rubber checks", "url": "https://www.loc.gov/item/2017693199/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017699410/", "http://www.loc.gov/item/2017699410/", "http://www.loc.gov/pictures/item/2017699410/", "https://hdl.loc.gov/loc.pnp/fsa.8b01089", "http://www.loc.gov/resource/fsa.8b01089/", "http://lccn.loc.gov/2017699410"], "campaigns": [], "contributor": ["palmer, alfred t.", "united states. office of war information"], "date": "1941-01-01", "dates": ["1941"], "description": ["1 negative : safety ; 4 x 5 inches or smaller."], "digitized": true, "extract_timestamp": "2021-09-01T20:10:54.612Z", "group": ["fsa", "catalog-split-07", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-07", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017699410/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8b01000/8b01000/8b01089_150px.jpg#h=118&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b01000/8b01000/8b01089t.gif#h=118&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b01000/8b01000/8b01089r.jpg#h=503&w=640", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b01000/8b01000/8b01089v.jpg#h=805&w=1024"], "index": 3, "language": ["english"], "location": ["summit county", "akron", "united states", "ohio"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2017699410", "2017-05-15t14:24:28", "http://www.loc.gov/item/oem2002010340/pp", "http://www.loc.gov/item/2017699410", "http://www.loc.gov/item/19645204"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 2060", "prints and photographs division", "farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "american memory", "catalog"], "score": 32.008778, "shelf_id": "LC-USE6- D-001665 [P&P] LOT 2060  (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["summit county", "safety film negatives", "ohio", "akron", "united states"], "timestamp": "2022-04-25T15:41:37.634Z", "title": "Loading raw rubber. Bales of raw rubber, removed from wooden crates in which they have traveled from Singapore, are wheeled up to this endless chain loader, which will automatically feed it into the \"guillotine,\" the first step in making tires at an Ohio tire plant", "url": "https://www.loc.gov/item/2017699410/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017690675/", "http://www.loc.gov/item/2017690675/", "http://www.loc.gov/pictures/item/2017690675/", "https://hdl.loc.gov/loc.pnp/fsa.8b02052", "http://www.loc.gov/resource/fsa.8b02052/", "http://lccn.loc.gov/2017690675"], "campaigns": [], "contributor": ["palmer, alfred t.", "united states. office of war information"], "date": "1942-01-01", "dates": ["1942"], "description": ["1 negative : safety ; 4 x 5 inches or smaller."], "digitized": true, "extract_timestamp": "2021-09-01T20:10:10.699Z", "group": ["fsa", "catalog-split-11", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-11", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017690675/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02052_150px.jpg#h=150&w=118", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02052t.gif#h=150&w=118", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02052r.jpg#h=640&w=503", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02052v.jpg#h=1024&w=805"], "index": 4, "language": ["english"], "location": ["summit county", "akron", "united states", "ohio"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2017690675", "2017-05-15t08:24:42", "http://www.loc.gov/item/19635779", "http://www.loc.gov/item/2017690675", "http://www.loc.gov/item/oem2002001602/pp"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints and photographs division", "lot 2063", "farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "american memory", "catalog"], "score": 32.008778, "shelf_id": "LC-USE6- D-002805 [P&P] LOT 2063  (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["summit county", "safety film negatives", "ohio", "akron", "united states"], "timestamp": "2022-04-25T15:18:13.353Z", "title": "Giant tire manufacturer. This husky workman, standing six feet four inches tall, looks small indeed as he uses air pressure to clean the lid of the world's largest vulcanizing unit in an Eastern tire plant. The top section of this mold being prepared to vulcanize a large bullet-sealing gasoline tank, weighs sixteen tons and can also be used to vulcanize tires over ten feet in diameter", "url": "https://www.loc.gov/item/2017690675/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017690676/", "http://www.loc.gov/item/2017690676/", "http://www.loc.gov/pictures/item/2017690676/", "https://hdl.loc.gov/loc.pnp/fsa.8b02053", "http://www.loc.gov/resource/fsa.8b02053/", "http://lccn.loc.gov/2017690676"], "campaigns": [], "contributor": ["palmer, alfred t.", "united states. office for emergency management"], "date": "1942-01-01", "dates": ["1942"], "description": ["1 negative : safety ; 4 x 5 inches or smaller."], "digitized": true, "extract_timestamp": "2021-09-01T20:10:10.699Z", "group": ["fsa", "catalog-split-12", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-12", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017690676/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02053_150px.jpg#h=116&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02053t.gif#h=116&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02053r.jpg#h=493&w=640", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02053v.jpg#h=789&w=1024"], "index": 5, "language": ["english"], "location": ["summit county", "akron", "united states", "ohio"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/2017690676", "2017690676", "2017-05-15t08:24:43", "http://www.loc.gov/item/oem2002001603/pp", "http://www.loc.gov/item/19635780"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints and photographs division", "lot 2063", "farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "american memory", "catalog"], "score": 32.008778, "shelf_id": "LC-USE6- D-002806 [P&P] LOT 2063  (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["summit county", "safety film negatives", "ohio", "akron", "united states"], "timestamp": "2022-04-25T15:18:13.353Z", "title": "Giant tire manufacturer. Giant vulcanizer used in the vulcanization of bullet-sealing gasoline tanks, eight-foot high bomber tires and huge 3,600-pound earth mover tires. This unit at a large Eastern tire plant is the largest of its kind in the world. It must be thoroughly and constantly inspected as it is in frequent service on war production. Here the inspector is checking the steam and pressure fittings. The mold, when open, stands more than two-and-a-half stories high and weighs over 300,000 pounds. Firestone", "url": "https://www.loc.gov/item/2017690676/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017690677/", "http://www.loc.gov/item/2017690677/", "http://www.loc.gov/pictures/item/2017690677/", "https://hdl.loc.gov/loc.pnp/fsa.8b02054", "http://www.loc.gov/resource/fsa.8b02054/", "http://lccn.loc.gov/2017690677"], "campaigns": [], "contributor": ["palmer, alfred t.", "united states. office for emergency management"], "date": "1942-01-01", "dates": ["1942"], "description": ["1 negative : safety ; 4 x 5 inches or smaller."], "digitized": true, "extract_timestamp": "2021-09-01T20:10:10.699Z", "group": ["fsa", "catalog-split-13", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-13", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017690677/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02054_150px.jpg#h=150&w=120", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02054t.gif#h=150&w=120", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02054r.jpg#h=640&w=512", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b02000/8b02000/8b02054v.jpg#h=1024&w=819"], "index": 6, "language": ["english"], "location": ["summit county", "akron", "united states", "ohio"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/2017690677", "2017690677", "2017-05-15t08:24:45", "http://www.loc.gov/item/19635781", "http://www.loc.gov/item/oem2002001604/pp"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints and photographs division", "lot 2063", "farm security administration/office of war informat