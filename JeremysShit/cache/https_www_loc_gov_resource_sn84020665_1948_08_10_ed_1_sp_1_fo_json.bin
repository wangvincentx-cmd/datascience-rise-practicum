 [], "date": "1947", "dates": ["[1947 TO 1952]"], "description": ["Weekly, Sept. 15, 1948-May 8, 1952 Print began on September 17, 1947; ceased with volume V, no. 35 (May 8, 1952). Valdez news appears as a column in the issues for February 2, 9 and 16, 1951. Available on microfilm from the Library of Congress, Photoduplication Service. Includes: Valdez news, Mar. 10, 1950-Jan. 19, 1951. Vol. 1, No. 2 (September 20, 1947); title from masthead (Chroniclingamerica.loc.gov, viewed September 6, 2023). Volume V, No. 35 (May 8, 1952) (Chroniclingamerica.loc.gov, viewed September 6, 2023). Frontiersman (Palmer, Alaska)"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:11.484Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2023270695/", "image_url": [], "index": 2, "language": ["english"], "location": ["palmer", "alaska", "valdez", "united states"], "number": ["online resource", "1396196679", "2023270695", "2994-3590", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "valley frontiersman (palmer, alaska) 1947-1952 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 51.658012, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["valdez", "palmer", "alaska", "newspapers", "valdez (alaska)", "united states"], "timestamp": "2026-05-26T21:09:04.358Z", "title": "Valley frontiersman", "type": ["title"], "url": "https://www.loc.gov/item/2023270695/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019218583/"], "campaigns": [], "date": "1905", "dates": ["[1905 TO 1911]"], "description": ["Daily Began in 1905? Ceased in 1911? Published as: Prospector daily bulletin, Aug. 30-Sept. 4, 1907. Description based on: Vol. 4, No. 9 (November 14, 1907); title from masthead (Chroniclingamerica.loc.gov, viewed February 13, 2019). Latest issue consulted: Vol. 4, No. 9 (November 14, 1907) (Chroniclingamerica.loc.gov, viewed February 13, 2019)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:46.349Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019218583/", "image_url": [], "index": 3, "language": ["english"], "location": ["alaska", "valdez", "united states"], "number": ["online resource", "2019218583", "2641-7545", "2018218697", "1085541114", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Prospector daily bulletin"], "partof": ["daily prospector bulletin (valdez, alaska) 1905-1911 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["daily"], "score": 36.15872, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["valdez", "alaska", "newspapers", "valdez (alaska)", "united states"], "timestamp": "2026-05-26T20:57:55.117Z", "title": "Daily prospector bulletin", "type": ["title"], "url": "https://www.loc.gov/item/2019218583/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218696/"], "campaigns": [], "date": "1902", "dates": ["[1902 TO 1908]"], "description": ["Weekly Began February 13, 1902; ceased with vol. 7, no. 31 (August 13, 1908). Also issued on microfilm from the Library of Congress, Photoduplication Service. Description based on: Vol. 4 [6], no. 46 (January 2, 1908); title from masthead (Chroniclingamerica.loc.gov, viewed April 25, 2018). Latest issue consulted: Vol. 7, no. 31 (August 13, 1908) (Chroniclingamerica.loc.gov, viewed April 25, 2018). Valdez weekly prospector 2637-5397 (DLC) 2018218775 (OCoLC)1044755899"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:43.116Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218696/", "image_url": [], "index": 4, "language": ["english"], "location": ["alaska", "valdez", "united states"], "number": ["2578-1057", "2018218696", "online resource", "1032302444", "2018218697", "2026-04-13t21:30:13", "2018218775"], "original_format": ["newspaper"], "other_title": ["Alaska prospector and Valdez news"], "partof": ["directory of u.s. newspapers in american libraries", "the alaska prospector (valdez alaska) 1902-1908 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 36.15872, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["valdez", "alaska", "newspapers", "valdez (alaska)", "united states"], "timestamp": "2026-05-26T20:56:09.337Z", "title": "The Alaska prospector", "type": ["title"], "url": "https://www.loc.gov/item/2018218696/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218697/"], "campaigns": [], "date": "1905", "dates": ["[1905 TO 1918]"], "description": ["Daily Began in 1905? Ceased May 7, 1918. Vol. numbering irregular. Other eds. available: Daily prospector bulletin, <1905-1911>, and: Alaska prospector, <1905>-1908, and: Valdez weekly prospector, 1908-1912. Description based on: Vol. 4, no. 215 (July 15, 1908); title from masthead (Chroniclingamerica.loc.gov, viewed April 25, 2018). Latest issue consulted: Vol. 9, no. 69 (December 31, 1912) (Chroniclingamerica.loc.gov, viewed April 25, 2018)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:43.116Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218697/", "image_url": [], "index": 5, "language": ["english"], "location": ["alaska", "valdez", "united states"], "number": ["online resource", "2018218697", "2578-1073", "1032302083", "2026-04-13t21:30:13", "2018218775", "2018218696"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "valdez daily prospector (valdez, alaska) 1905-1918 [online resource]", "serial and government publicati