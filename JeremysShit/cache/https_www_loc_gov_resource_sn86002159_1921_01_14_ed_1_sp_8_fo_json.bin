], "date": "1921-01-14", "dates": ["1921-01-14"], "description": ["rmmlnguwmQ Your Interests and Ours It is as much to our advantage for you to buy P your goods at a reasonable price as it is to your p advantage We want you to come again I our customers came to buy but once we would soon p close our doors That has always been the basis of our policy in p \u00e9 running a mercantile business We shall continue to keep that policy in our minds and in each and p every transaction we have will endeavor to put ourselves in the position of the customer who is p 3 coming in the door b 8 P Buy at the store that has helped you along b g sTet i these many years We are all living in the same community and have at heart the interset of this bf Town and country Lets help each other when 9 P P ever we can do so There is no Mail Order House in the East or y 4 P elsewhere that cares a rap about the condition of our roads nor what kind of schools we have nor whether we have any churches nor the other interests thatare of"], "digitized": true, "extract_timestamp": "2023-12-27T15:19:11.675Z", "group": ["ndnp/cohi", "history-colorado-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86002159/1921-01-14/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_alta_ver01:data:sn86002159:00513680430:1921011401:1000/full/pct:6.25/0/default.jpg#h=314&w=217", "https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_alta_ver01:data:sn86002159:00513680430:1921011401:1000/full/pct:12.5/0/default.jpg#h=628&w=434", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/cohi/batch_cohi_alta_ver01/data/sn86002159/00513680430/1921011401/1000.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["colorado", "dolores", "united states", "montezuma"], "location_city": ["dolores"], "location_country": ["united states"], "location_county": ["montezuma"], "location_state": ["colorado"], 