:gmd:gmdtitlecolfold:ct:-0:41:ct-041:ct-041-00001/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:41:ct-041:ct-041-00001/full/pct:12.5/0/default.jpg#h=685&w=492", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:41:ct-041:ct-041-00001/full/pct:25/0/default.jpg#h=1370&w=985"], "index": 11, "language": ["english"], "location": ["groton", "connecticut", "united states"], "mime_type": ["image/tiff", "image/jpeg", "image/jp2"], "number": ["2022594779", "2024-05-11t20:56:37", "2025-06-07t11:51:26.700000", "sheet"], "online_format": ["image"], "original_format": ["map", "collection"], "other_title": ["Alternate supplied title: Connecticut title collection--drawer 41", "Alternate supplied title: Connecticut title collection--cities and towns Groton--Gz"], "partof": ["catalog", "geography and map division", "single sheet maps, title collection"], "score": 24.149664, "shelf_id": "G3784.A1 coll .M3 drawer 41", "site": ["catalog"], "subject": ["groton (conn.)", "tourist maps", "connecticut", "united states", "landowners", "maps", "cities and towns"], "timestamp": "2026-04-29T15:32:48.014Z", "title": "[Maps of Connecticut--cities and towns Groton--Gz]", "type": ["cartographic"], "url": "https://www.loc.gov/item/2022594779/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/03016250", "http://www.loc.gov/item/03016250/", "http://www.loc.gov/resource/gdcmassbookdig.stonerecordsofgr00caul/", "https://hdl.loc.gov/loc.gdc/scd0001.00141120797", "http://www.loc.gov/resource/scd0001.00141120797/"], "campaigns": [], "contributor": ["caulkins, frances manwaring", "gilman, emily serena"], "date": "1903", "dates": ["1903"], "description": ["\"Limited to 300 copies. no. 299.\" \"Authorities\": p. 90. Also available in digital form. LAC brd 2019-05-16 update (1 card)"], "digitized": true, "extract_timestamp": "2026-02-27T08:29:57.629Z", "group": ["paprika-iabooks", "catalog-split-01", "catalog", "ma