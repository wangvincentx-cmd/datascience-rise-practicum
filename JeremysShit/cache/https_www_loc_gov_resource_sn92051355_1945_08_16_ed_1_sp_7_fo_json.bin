3346723:1945081601:0719/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_aetna_ver02/data/sn92051355/00393346723/1945081601/0725.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn92051355/1945-08-16/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_aetna_ver02/data/sn92051355/00393346723/1945081601/0725.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_aetna_ver02:data:sn92051355:00393346723:1945081601:0719/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_aetna_ver02/data/sn92051355/00393346723/1945081601/0725.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn92051355/1945-08-16/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ct/batch_ct_aetna_ver02/data/sn92051355/00393346723/1945081601/0725.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn92051355/1945-08-16/ed-1/?sp=7"], "batch": ["ct_aetna_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/new london/", "3/united states/connecticut/new london/groton/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1945-08-16", "dates": ["1945-08-16"], "description": ["AFL Directs Peo to Congress __ By Common Consent By EUGENE MITCHELL Dept 334 99 A paragraph in the Declaration of Purposes of the National Grange contains food for thought It reads We long to see the an tagonism between Capital and La bor removed by common consent and by enlightened statesmanship worthy of the Twentieth Century Here in a few well chosen words written by some rural statesman is the key to the solution of one of Americas great permanent so far problems the antagonism between Capital and Labor Where will we find that en lightened statesmanship There is only one worthwhile place to look for itin our own councils If genuine and dynamic Labor Management committees dedicat ing themselves to the goal of peace in industry by common consent could start functioning in some important industry their course would be followed by the entire country Most all of us are getting pretty sick of industrial strife Only the Communists the Labor haters and the rabblerousers want more of it for obvious reasons They benefit by strikes lockouts and slow downs etc Trouble is their lifeblood If these birds are ever downed they will go down fighting we can"], "digitized": true, "extract_timestamp": "2023-06-01T13:39:27.069Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92051355/1945-08-16/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_aetna_ver02:data:sn92051355:00393346723:1945081601:0725/full/pct:6.25/0/default.jpg#h=430&w=291", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_aetna_ver02:data:sn92051355:00393346723:1945081601:0725/full/pct:12.5/0/default.jpg#h=860&w=582", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_aetna_ver02/data/sn92051355/00393346723/1945081601/0725.xml&format=alto_xml"], "index": 7, "language": ["english"], "location": ["new london", "groton", "connecticut", "united states"], "location_city": ["groton"], "location_country": ["united states"], "location_county": ["new london"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "0000000007", "3", "4", "7", "sn92051355", "2", "6", "1"], "number_edition": ["1"], "number_lccn": 