a:sn87093407:00200290847:1920070801:0839/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/wa/batch_wa_bainbridge_ver01/data/sn87093407/00200290847/1920070801/0846.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn87093407/1920-07-08/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/wa/batch_wa_bainbridge_ver01/data/sn87093407/00200290847/1920070801/0846.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn87093407/1920-07-08/ed-1/?sp=8"], "batch": ["wa_bainbridge_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/washington/", "2/united states/washington/king/", "3/united states/washington/king/seattle/"], "contributor": ["washington state library; olympia, wa"], "date": "1920-07-08", "dates": ["1920-07-08"], "description": ["PAGE 8 li COUNTRY HOMES t Rural Seattle Development Means Much for Washington Bureau Opened at Walker Building by Puget Mill Company A T HEART most of us are ruralistswe yearn for a country life of health and happiness and plenty But complex civilization has crowded us into cities And here we are each jammed into a particular niche surrendering our economic independence to relentless circumstance Who can say he has never dreamed of a garden spot some where some time Who has never hoped for a home blessed with abundance of good things to eat and free from the terrific toll of distribution costs Yet we are not free to revert to utter independence of cities Many of us are fitted to the job and would not if we could turn our backs to the city and to all the conveniences we have created to make mass life more comfortable Few of us would abandon Seattle with her gentle climate her majestic setting and her splendid opportunities for future gain Country Life Satisfaction for Man trees and strawberries and peas and potatoes and everything else that spells plen