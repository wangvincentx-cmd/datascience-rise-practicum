ead Lake some time back be defeated by popular disapproval 1 Several have mentioned a qualified approval of the project \u00ce Should the proposition ever re 1 ceive the approval of Congress which would be needed before it might become a project all pro 1 per tv along the Kootenai Valley which would be subject to overflow from waters backed up by the dam would have to be condemned and appraised by the government which would make settlement"], "digitized": true, "extract_timestamp": "2023-07-03T13:49:26.272Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82006551/1946-02-14/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_knapweed_ver01:data:sn82006551:00393341981:1946021401:0057/full/pct:6.25/0/default.jpg#h=457&w=330", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_knapweed_ver01:data:sn82006551:00393341981:1946021401:0057/full/pct:12.5/0/default.jpg#h=915&w=661", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_knapweed_ver01/data/sn82006551/00393341981/1946021401/0057.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["united states", "montana", "libby", "lincoln"], "location_city": ["libby"], "location_country": ["united states"], "location_county": ["lincoln"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0", "1", "4", "8", "sn82006551", "0000000002", "9"], "number_edition": ["1"], "number_lccn": ["sn82006551"], "number_page": ["0000000002"], "number_reel": ["0", "0", "3", "9", "3", "3", "4", "1", "9", "8", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the western news (libby, mont.) 1933-