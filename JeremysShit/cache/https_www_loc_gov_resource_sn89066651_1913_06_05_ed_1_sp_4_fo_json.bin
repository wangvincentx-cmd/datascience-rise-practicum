s/iiif/service:ndnp:mohi:batch_mohi_franklin_ver01:data:sn89066651:00211109476:1913060501:1082/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mohi/batch_mohi_franklin_ver01/data/sn89066651/00211109476/1913060501/1085.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn89066651/1913-06-05/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mohi/batch_mohi_franklin_ver01/data/sn89066651/00211109476/1913060501/1085.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_franklin_ver01:data:sn89066651:00211109476:1913060501:1082/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mohi/batch_mohi_franklin_ver01/data/sn89066651/00211109476/1913060501/1085.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn89066651/1913-06-05/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mohi/batch_mohi_franklin_ver01/data/sn89066651/00211109476/1913060501/1085.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89066651/1913-06-05/ed-1/?sp=4"], "batch": ["mohi_franklin_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/missouri/", "2/united states/missouri/pemiscot/", "3/united states/missouri/pemiscot/hayti/"], "contributor": ["state historical society of missouri; columbia, mo"], "date": "1913-06-05", "dates": ["1913-06-05"], "description": ["Think It Over To Tin Businicss Mkn op Hayti Whiii we started this paper nearly five years ago Hay ti had no paper and we under took the labor with the under standi nn that we were to receive a liberal supiort For the past three years however since the return of prosperity this paper sacrificed its own best interests and cut its own throat to bring to your town we have con ducted the paper largely at our own expense and with what pat ronage we could draw from Ca ruthersville and other towns and iit the same time we have em ployed labor cheap and worked day and night and Sunday to get out a credible paper Now there is going to be a change uid one that we have been figur ing on for many months We do not believe we have a subscriber outside of the Hayti list bub who takes the Herald on account of his personal feeling for the edi tor The two county seat and local option lights have incensed the people of the county against our city but not against us On account of our lairness and hon esty of purpose we"], "digitized": true, "extract_timestamp": "2020-09-15T11:58:50.289Z", "group": ["ndnp/mohi", "state-historical-society-of-missouri-columbia-mo-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89066651/1913-06-05/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_franklin_ver01:data:sn89066651:00211109476:1913060501:1085/full/pct:6.25/0/default.jpg#h=441&w=315", "https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_franklin_ver01:data:sn89066651:00211109476:1913060501:1085/full/pct:12.5/0/default.jpg#h=882&w=631", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mohi/batch_mohi_franklin_ver01/data/sn89066651/00211109476/1913060501/1085.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["missouri", "pemiscot", "hayti", "united states", "pemiscot county"], "location_city": ["hayti"], "location_country": ["united states"], "location_county": ["pemiscot"], "location_state": ["missouri"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000004", "9", "1", "sn89066651", "2", "4", "7", "0", "6"], "number_edition": ["1"], "number_lccn": ["sn8