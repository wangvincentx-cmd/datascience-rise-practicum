["ct_kent_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/fairfield/", "3/united states/connecticut/fairfield/bridgeport/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1920-10-22", "dates": ["1920-10-22"], "description": ["rvvo NOT A SERVICE MAN ATTHE GORE SPEECH 5 United States Senator Thomas P Gore of Oklahoma who since his s overwhelming defeat for renomina tlon because of the indignation he aroused in home state by his opposi tion to the entrance of the United States into the war against Germany and his consistent opposition to patri otic legislation during the war reach ed Bridgeport last night in his head 1 1ong flight eastward from his con A stltuents In company with two other j repudiated office seekers from out of f town Mr Gore addressed a meeting i last night at Armory Athletic Club hall under the auspices of an organi i zation calling Itself the AntiLeague Democrats The fact that a check of j the audience failed to disclose the presence of a single service button suggests the character of support to which the organization appeals In introducing Senator Gore the chairman praised Kaiser Wilhelmas a man who alwsy agreed with his cabinet and referred to Senator Gore as a victim of Wilsonian oppression Senator Gore spoke for nearly an hour and said that while America J could never hope to have a more s brilliant representative in"], "digitized": true, "extract_timestamp": "2023-06-01T13:37:33.261Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92051227/1920-10-22/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_kent_ver01:data:sn92051227:00415620743:1920102201:0263/full/pct:6.25/0/default.jpg#h=408&w=329", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_kent_ver01:data:sn92051227:00415620743:1920102201:0263