apers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271962/", "image_url": [], "index": 2, "language": ["english"], "location": ["alaska", "seward", "united states"], "number": ["online resource", "1159985970", "2020271962", "2692-6644", "2020271963", "2021270897", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "daily gateway (seward, alaska) 1905-1905 [online resource]"], "publication_frequency": ["daily"], "score": 35.073776, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["seward", "alaska", "seward (alaska)", "newspapers", "united states"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "Daily gateway", "type": ["title"], "url": "https://www.loc.gov/item/2020271962/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271963/"], "campaigns": [], "date": "1905", "dates": ["[1905 TO 1914]"], "description": ["Daily (except Sunday) Began with vol. I, no. 94 (November 23, 1905); ceased with vol. 8, number 241 (July 21, 1914). Also available on microfilm from the Alaska Historical Society. Description based on: Vol. I, No. 94 (November 23, 1905); title from masthead (Chroniclingamerica.loc.gov, viewed June 26, 2020). Latest issue consulted: Vol. 8, No. 241 (July 21, 1914) (Chroniclingamerica.loc.gov, viewed June 26, 2020). Seward gateway (Seward, Alaska : 1914) 2692-6733 (DLC) 2020271964 (OCoLC)1160004269"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:52.256Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271963/", "image_url": [], "index": 3, "language": ["english"], "location": ["alaska", "seward", "united states"], "number": ["online resource", "1159986219", "2020271964", "2020271962", "2020271963", "2692-6687", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "seward daily gateway (seward, alaska) 1905-1914 [online resource]", "serial and government publications division"], "publication_frequency": ["daily"], "score": 35.073776, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["seward", "alaska", "seward (alaska)", "newspapers", "united states"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "Seward daily gateway", "type": ["title"], "url": "https://www.loc.gov/item/2020271963/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271964/"], "campaigns": [], "date": "1914", "dates": ["[1914 TO 1917]"], "description": ["Daily (except Sunday) Began with vol. 8, no. 242 (July 22, 1914); ceased with vol. 10, no. 338 (Jan. 31, 1917). Also issued on microfilm from the Library of Congress, Photoduplication Service. Merged with: Alaska evening post, to form: Seward gateway and the Alaska evening post. Description based on: Vol. 8, No. 242 (July 22, 1914); title from masthead (Chroniclingamerica.loc.gov, viewed June 27, 2020). Latest issue consulted: Vol. 10, No. 338 (Jan. 31, 1917) (Chroniclingamerica.loc.gov, viewed June 27, 2020). Alaska evening post Seward gateway and the Alaska evening post 2692-675X (DLC) 2020271965 (OCoLC)1160004125"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:52.256Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271964/", "image_url": [], "index": 4, "language": ["english"], "location": ["alaska", "seward", "united states"], "number": ["online resource", "2020271964", "2020271965", "2020271963", "1160004269", "2026-04-13t21:30:13", "2692-6733"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the seward gateway (seward, alaska) 1914-1917 [online resource]"], "publication_frequency": ["daily"], "score": 35.073776, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["seward", "alaska", "seward (alaska)", "newspapers", "united states"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The Seward gateway", "type": ["title"], "url": "https://www.loc.gov/item/2020271964/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271965/"], "campaigns": [], "date": "1917", "dates": ["[1917 TO 1918]"], "description": ["Daily (except Sunday) Began with vol. 11, no. 65 (February 1, 1917); ceased with volume XI, number 226 (January 17, 1918). \"Independent.\" Cf. Ayer, 1918. Vol. 11, No. 65 (February 1, 1917); title from masthead (Chroniclingamerica.loc.gov, viewed June 27, 2020). Volume XI, Number 226 (January 17, 1918) (Chroniclingamerica.loc.gov, viewed June 27, 2020). Seward gateway daily edition, and the Alaska weekly post 2641-9696 (DLC) 2019218590 (OCoLC)1088563576"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:52.256Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271965/", "image_url": [], "index": 5, "language": ["english"], "location": ["alaska", "seward", "united states"], "number": ["online resource", "2019218590", "2020271964", "2020271965", "2692-675x", "1160004125", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Issues for Feb. 2-9, 1917 called: Seward gateway and Alaska evening post"], "partof": ["the seward gateway and the alaska evening post (seward, alaska) 1917-1918 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["daily"], "score": 35.073776, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["seward", "alaska", "seward (alaska)", "newspapers", "united states"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The Seward gateway and the Alaska evening post", "type": ["title"], "url": "https://www.loc.gov/item/2020271965/"}, {"access_restri