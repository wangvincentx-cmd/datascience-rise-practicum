 4, "page_list": [{"number": 1, "url": null}, {"number": 2, "url": "https://www.loc.gov/resource/sn98059811/1907-11-09/ed-1/?fo=json&sp=2"}, {"number": 3, "url": "https://www.loc.gov/resource/sn98059811/1907-11-09/ed-1/?fo=json&sp=3"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": null, "results": "1 - 1", "to": 1, "total": 4}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn98059811/1907-11-02/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/99614629", "http://www.loc.gov/item/99614629/", "https://hdl.loc.gov/loc.pnp/ppmsc.01904", "http://www.loc.gov/resource/ppmsc.01904/", "http://www.loc.gov/pictures/collection/ffcarp/item/99614629/", "http://www.loc.gov/pictures/item/99614629/"], "campaigns": [], "date": "1900-01-01", "dates": ["1900"], "description": ["Title transcribed from caption accompanying item. Forms part of: Frank and Frances Carpenter collection (Library of Congress). Gift; Mrs. W. Chapin Huntington; 1951."], "digitized": true, "extract_timestamp": "2022-11-29T18:38:17.616Z", "group": ["pp/mtfront", "ffcarp", "catalog-split-14", "catalog", "meeting-of-frontiers-prints-and-photographs", "carpenter", "main-catalog-split-14", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/99614629/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppmsc/01900/01904_150px.jpg#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/ppmsc/01900/01904t.gif#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/ppmsc/01900/01904r.jpg#h=511&w=640", "https://tile.loc.gov/storage-services/service/pnp/ppmsc/01900/01904v.jpg#h=818&w=1024"], "index": 1, "language": ["english"], "location": ["alaska", "seward", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2007-01-17t10:46:43", "http://www.loc.gov/item/cap1999000349/pp", "http://www.loc.gov/item/12218036", "99614629", "http://www.loc.gov/item/99614629"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 11453", "prints and photographs division", "meeting of frontiers", "prints & photographs online catalog (library of congress)", "carpenter collection", "catalog"], "score": 35.327488, "shelf_id": "LOT 11453-1, no. 349", "site": ["catalog", "pictures"], "subject": ["seward", "cities & towns", "mountains", "photographic prints", "alaska", "seward (alaska)", "aerial views", "united states", "bodies of water"], "timestamp": "2022-11-29T19:59:39.362Z", "title": "[Aerial view of Seward]", "type": ["still image"], "url": "https://www.loc.gov/item/99614629/"}, {"access_restricted": false, "aka": ["http://www.dggs.alaska.gov/webpubs/dggs/ri/text/ri2010%5F001.PDF", "http://www.dggs.alaska.gov/webpubs/dggs/ri/oversized/ri2010%5F001%5Fsh002.PDF", "http://lccn.loc.gov/2010532470", "http://www.loc.gov/item/2010532470/", "http://www.dggs.alaska.gov/webpubs/dggs/ri/oversized/ri2010%5F001%5Fsh003.PDF", "http://www.arlis.org/docs/vol1/B/645463739/index.html", "http://www.dggs.alaska.gov/webpubs/dggs/ri/oversized/ri2010%5F001%5Fsh001.PDF"], "campaigns": [], "contributor": ["hansen, roger a.", "nicolsky, dmitry j.", "alaska earthquake information center", "alaska. division of geological and geophysical surveys", "combellick, r. a.", "west, d. a.", "suleimani, e. n."], "date": "2010", "dates": ["2010"], "description": ["The purpose of this study is to evaluate tsunami hazard for the community of Seward and northern Resurrection Bay area, Alaska. This report will provide guidance to local emergency managers in tsunami hazard assessment. We used a numerical modeling method to estimate the extent of inundation by tsunami waves generated from earthquake and landslide sources. Our tsunami scenarios included a repeat of the tsunami of the 1964 Great Alaska Earthquake, as well as tsunami waves generated by two hypothetical Yakataga Gap earthquakes in northeastern Gulf of Alaska, hypothetical earthquakes in Prince William Sound and Kodiak asperities of the 1964 rupture, and local underwater landslides in Resurrection Bay. Results of numerical modeling combined with historical observations in the region are intended to help local emergency officials with evacuation planning and public education for reducing future tsunami risk."], "digitized": true, "extract_timestamp": "2023-06-02T20:42:02.750Z", "group": ["catalog-split-08", "catalog", "main-catalog-split-08", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2010532470", "image_url": [], "index": 2, "language": ["english"], "location": ["alaska", "seward", "resurrection bay"], "number": ["n645463739", "2010-12-29t12:38:35", "2010532470"], "original_format": ["book"], "partof": ["catalog"], "score": 34.040012, "shelf_id": "http://lccn.loc.gov/2010532470", "site": ["catalog"], "subject": ["seward", "mathematical models", "remote-sensing maps", "earthquake hazard analysis", "resurrection bay (alaska)", "alaska", "seward (alaska)", "tsunamis", "resurrection bay", "research"], "timestamp": "2023-07-14T00:27:16.101Z", "title": "Tsunami inundation maps of Seward and northern Resurrection Bay, Alaska", "type": ["text"], "url": "//lccn.loc.gov/2010532470"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/99614331", "http://www.loc.gov/item/99614331/", "https://hdl.loc.gov/loc.pnp/ppmsc.01606", "http://www.loc.gov/resource/ppmsc.01606/", "http://www.loc.gov/pictures/collection/ffcarp/item/99614331/", "http://www.loc.gov/pictures/item/99614331/"], "campaigns": [], "date": "1900-01-01", "dates": ["1900"], "description": ["Title transcribed from caption accompanying item. Photo by Gordons. Forms part of: Frank and Frances Carpenter collection (Library of Congress). Gift; Mrs. W. Chapin Huntington; 1951."], "digitized": true, "extract_timestamp": "2022-11-29T18:37:58.247Z", "group": ["pp/mtfront", "ffcarp", "catalog-split-04", "catalog", "meeting-of-frontiers-prints-and-photograp