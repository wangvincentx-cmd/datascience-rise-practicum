ms-high-demand", "main-catalog-split-04"], "hassegments": false, "id": "http://www.loc.gov/item/2001695535/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppmscd/03100/03173_150px.jpg#h=150&w=114"], "index": 5, "language": ["english"], "location": ["oklahoma", "vinita"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["sheet", "2001695535", "http://www.loc.gov/item/2001695535", "2026-01-30t12:24:58.600000", "online resource", "http://www.loc.gov/item/12329805"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "prints and photographs division", "lot 13087"], "score": 27.035385, "shelf_id": "LOT 13087, no. 2 [item] [P&P]", "site": ["pictures", "catalog"], "subject": ["oklahoma", "ethnic stereotypes", "vinita", "gelatin silver prints", "signs", "racism"], "timestamp": "2026-02-14T13:39:14.879Z", "title": "[Sign along road reading Grand Cafe and \"Eat nigger chicken\" in Vinita, Oklahoma]", "type": ["still image"], "url": "https://www.loc.gov/item/2001695535/"}, {"access_restricted": true, "aka": ["https://www.loc.gov/pictures/item/91791473/", "http://www.loc.gov/item/91791473/", "http://www.loc.gov/pictures/item/91791473/", "https://www.loc.gov/pictures/collection/coll/item/91791473/", "http://www.loc.gov/pictures/collection/coll/item/91791473/", "http://lccn.loc.gov/91791473"], "campaigns": [], "contributor": ["croft, thomas"], "date": "1894", "dates": ["1894"], "description": ["6 photoprints on cardboard mounts : gelatin silver ; 22 x 30 cm. or smaller. | Most of the images depict a line of male dancers dressed in traditional clothing, some with body paint, during the Sun Dance. One image portrays Ponca women in Euro-American dress holding cloth banners on poles. Also includes a group portrait of Ponca men and boys, and two Euro-American men (possibly Colonel George W. Miller and his son Joe C. Miller) on the dancing grounds with dancers in the background."], "digitized": true, "extr