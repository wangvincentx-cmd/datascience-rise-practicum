ttp://www.loc.gov/resource/highsm.68086/", "https://www.loc.gov/pictures/item/2021756307/", "http://www.loc.gov/pictures/item/2021756307/", "https://www.loc.gov/pictures/collection/highsm/item/2021756307/", "http://www.loc.gov/pictures/collection/highsm/item/2021756307/", "https://hdl.loc.gov/loc.pnp/highsm.68086"], "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2021-01-01", "dates": ["2021"], "description": ["Title, date, and keywords based on information provided by the photographer. The Moorish Revival-style building is, obviously, not made entirely of corn, but ears and stalks of the grain are lavishly employed in its facade and murals, the latter of which are redesigned each year. Various styles of grain palaces abounded across the Midwest in the 1800s and at least 34 corn versions were built, with only the Mitchell one still standing. Purchase Carol M. Highsmith Photography, Inc.; 2021  (DLC/PP-2021:107). Forms part of Carol M. Highsmith's America Project in the Carol M. Highsmith Archive. Credit Line: Photographs in Carol M. Highsmith's America Project in the Carol M. Highsmith Archive, Library of Congress, Prints and Photographs Division."], "digitized": true, "extract_timestamp": "2022-08-02T18:21:30.504Z", "group": ["catalog", "highsm", "catalog-split-01", "main-catalog", "carol-m-highsmith", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/2021756307/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/highsm/68000/68086_150px.jpg#h=113&w=150", "https://tile.loc.gov/storage-services/service/pnp/highsm/68000/68086r.jpg#h=483&w=640", "https://tile.loc.gov/storage-services/service/pnp/highsm/68000/68086v.jpg#h=773&w=1024"], "index": 10, "language": ["english"], "location": ["united states", "south dakota", "davison county", "mitchell"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/22635826", "online resource", "2021756307", "2022-06-09t14:46:20"], "on