at debt and much available property offers bet ter than eight per cent for a loan of twenty million dollars in New York it is needless to deny that money is scarce and high priced in Europe When the Anaconda Copper company offers its first mortgage bonds for an insignificant sum compared with"], "digitized": true, "extract_timestamp": "2023-07-03T13:44:54.549Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84024808/1920-12-09/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn84024808:00295860716:1920120901:0238/full/pct:6.25/0/default.jpg#h=473&w=366", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn84024808:00295860716:1920120901:0238/full/pct:12.5/0/default.jpg#h=946&w=732", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn84024808/00295860716/1920120901/0238.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["united states", "montana", "cascade", "great falls"], "location_city": ["great falls"], "location_country": ["united states"], "location_county": ["cascade"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["8", "0", "5", "2", "7", "1", "sn84024808", "6", "9", "0000000006"], "number_edition": ["1"], "number_lccn": ["sn84024808"], "number_page": ["0000000006"], "number_reel": ["0", "0", "2", "9", "5", "8", "6", "0", "7", "1", "6"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["great falls daily tribune (great falls, mont.) 1895-1921", "chronicling america", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], 