ka": ["http://www.loc.gov/resource/sn86091197/1924-04-24/ed-1/?sp=1"], "batch": ["idhi_hatra_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/idaho/", "2/united states/idaho/bingham/", "3/united states/idaho/bingham/blackfoot/"], "contributor": ["idaho state historical society"], "date": "1924-04-24", "dates": ["1924-04-24"], "description": ["I 3\u00f6alyn Wivpxtblxmn t 2 a Year BLACKFOOT IDAHO APRIL 24 1924 Vol XX No 17 10000 FIRE AT FORT HALL Dairy Bam Twentythree Head 1 J of Cows and Farm Machinery Completely Destroyed A fire believed to have been of in cendiary origin completely de stroyed the new 5000 dairy barn at the Ft Hall Indian agency school at 1230 Wednesday morning In addition to the total destruction of the barn twentythree head of reg istered Holstein cows and a quantity The of farm machinery was lost damage according to agency officials will amount to approximately 10 000 The barn was a two story structure and was completed only last August It was modern in every respect and the basement portion was used for housing the registered stock The second floor or loft was used for storage purposes The building was a mass of flames when the fire was discovered at 1230 Wednesday morning and had no doubt been burning for some lit tle time The large fire gong was sounded and the boys in the dormi tory which is a short distance from the barn lost no time in getting out and fighting the blaze The Indian boys"], "digitized": true, "extract_timestamp": "2023-07-06T12:35:51.833Z", "group": ["ndnp/idhi", "idaho-state-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86091197/1924-04-24/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_hatra_ver01:data:sn86091197:00279550973:1924042401:0566/full/pct:6.25/0/default.jpg#h=420&w=301", "https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_hatra_ver01:data:sn86091197:00279550973:19240