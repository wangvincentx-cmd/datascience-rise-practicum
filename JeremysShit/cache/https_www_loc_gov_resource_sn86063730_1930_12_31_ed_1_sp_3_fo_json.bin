itor-herald Published by Freedom Newspapers, <Apr. 14, 1987>- Issue for May 10, 1936 also called \"International seaport and airport number.\" Later editions issued with Spanish supplement called: El Heraldo de Brownsville. Sometimes called: Brownsville evening herald <Aug. 1, 1924-May 18, 1925>. Available on microfilm: New York : Recordak Corp. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. In English; also included a section in Spanish from April 20, 1914 to June 15, 1914. Description based on: Vol. 18, no. 279 (Oct. 10, 1910) Latest issue consulted: Vol. 95, no. 285 (Apr. 14, 1987)"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:13.718Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-02", "catalog", "united-states-newspaper-directory", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/sn86063730/", "image_url": [], "index": 3, "language": ["spanish", "english"], "latlong": [25.903046, -97.498884], "location": ["brownsville", "mcallen", "harlingen", "cameron county", "cameron", "hidalgo county", "texas", "united states"], "location_str": "", "lonlat": [-97.498884, 25.903046], "number": ["microfilm master", "microfilm service copy", "12903289", "http://www.loc.gov/item/sn86063730/1912-01-01/ed-1/", "center for research libraries", "sn86063730", "texas state libr", "0894-2064", "10241", "texas a&m univ, kingsville", "univ of texas at austin", "2026-04-13t21:30:13", "2022-03-09t15:39:29", "sn86099906", "http://www.loc.gov/item/sn86063730/1937-01-31/ed-1/", "baylor univ", "univ of texas, pan am", "kansas state hist soc, newsp proj", "online resource", "boston pub libr", "original", "daughters of the republic of texas libr", "2025-05-09t12:48:08.015499"], "original_format": ["newspaper"], "other_title": ["Valley Sunday star", "Valley Sunday star-monitor-herald", "Brownsville evening herald", "Brownsville daily herald"], "partof": ["directory 