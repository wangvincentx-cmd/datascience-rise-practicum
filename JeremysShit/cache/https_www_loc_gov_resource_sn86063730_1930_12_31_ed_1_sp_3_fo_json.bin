063730/00332893798/1930123101/0537.jp2", "use": "", "width": 6956}, {"mimetype": "application/pdf", "url": "https://tile.loc.gov/storage-services/service/ndnp/txdn/batch_txdn_evans_ver01/data/sn86063730/00332893798/1930123101/0537.pdf", "use": ""}, {"mimetype": "text/xml", "url": "https://tile.loc.gov/storage-services/service/ndnp/txdn/batch_txdn_evans_ver01/data/sn86063730/00332893798/1930123101/0537.xml", "use": ""}, {"height": 288, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/service:ndnp:txdn:batch_txdn_evans_ver01:data:sn86063730:00332893798:1930123101:0537/full/pct:3.125/0/default.jpg", "width": 217}, {"height": 576, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/service:ndnp:txdn:batch_txdn_evans_ver01:data:sn86063730:00332893798:1930123101:0537/full/pct:6.25/0/default.jpg", "width": 434}, {"height": 1152, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/service:ndnp:txdn:batch_txdn_evans_ver01:data:sn86063730:00332893798:1930123101:0537/full/pct:12.5/0/default.jpg", "width": 869}, {"height": 9217, "info": "https://tile.loc.gov/image-services/iiif/service:ndnp:txdn:batch_txdn_evans_ver01:data:sn86063730:00332893798:1930123101:0537/info.json", "language": ["english"], "mimetype": "application/json", "reel_number": "00332893798", "section_label": null, "size": 8013306, "title": "Image 3 of Brownsville herald (Brownsville, Tex.), December 31, 1930", "width": 6956}, {"fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/txdn/batch_txdn_evans_ver01/data/sn86063730/00332893798/1930123101/0537.xml&format=alto_xml&full_text=1", "mimetype": "text/plain", "use": "text"}], "pagination": {"current": 3, "first": "https://www.loc.gov/resource/sn86063730/1930-12-31/ed-1/?fo=json&sp=1", "from": 3, "last": "https://www.loc.gov/resource/sn86063730/1930-12-31/ed-1/?fo=json&sp=5", "next": "https://www.loc.gov/resource/sn86063730/1930-12-31/ed-1/?fo=json&sp=4", "of": 8, "page_list": [{"number": 1, "url": "https://www.loc.gov/resource/sn86063730/1930-12-31/ed-1/?fo=json&sp=1"}, {"number": 2, "url": "https://www.loc.gov/resource/sn86063730/1930-12-31/ed-1/?fo=json&sp=2"}, {"number": 3, "url": null}, {"number": 4, "url": "https://www.loc.gov/resource/sn86063730/1930-12-31/ed-1/?fo=json&sp=4"}, {"number": 5, "url": "https://www.loc.gov/resource/sn86063730/1930-12-31/ed-1/?fo=json&sp=5"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": "https://www.loc.gov/resource/sn86063730/1930-12-31/ed-1/?fo=json&sp=2", "results": "3 - 3", "to": 3, "total": 8}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn86063730/1930-12-30/ed-2/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/2020339183", "http://www.loc.gov/item/2020339183/", "http://www.amazon.com/exec/obidos/ASIN/1478737670/chopaconline-20"], "campaigns": [], "contributor": ["yona, nakitia"], "date": "2015", "dates": ["2015"], "description": ["Far from home: One woman's story of her life in South Texas. Eny Samuel enjoyed a life of privilege nearly all her life. With a devoted and loving family, she attended some of the best private schools in Kenya and England, and enjoyed vacations abroad. Hers was a life most could only dream of at that time. It wasn't until she married Dezo Nondo, a handsome yet calculating charmer, that her life as she knew it turned into a seemingly endless nightmare. This candid memoir is a mother's way of preparing her young son for the challenges he may face in his life. It poses questions about race and racism, relationships, and the identity crisis multi-racial kids often face especially those from broken homes. It's a lesson for a son on how an individual's difficult childhood can define his/her adulthood, for better rather than for worse-that it's a choice. Last, but not least, it is an expos? of one woman's experience with the unjust judicial system of Hidalgo County."], "digitized": true, "extract_timestamp": "2023-06-02T22:54:45.699Z", "group": ["catalog-split-15", "catalog", "main-catalog-split-15", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2020339183", "image_url": [], "index": 3, "language": ["english"], "location": ["mcallen", "texas", "edinburg", "hidalgo county"], "number": ["2020339183", "2020-10-22t03:37:36"], "original_format": ["book"], "partof": ["catalog"], "score": 47.20359, "shelf_id": "HQ541 .Y66 2015", "site": ["catalog"], "subject": ["hidalgo county (tex.)", "texas", "divorce", "biography", "edinburg (tex.)", "hidalgo county", "yona, nakitia", "mothers and sons", "mcallen (tex.)"], "timestamp": "2023-07-12T06:39:09.381Z", "title": "Surviving divorce in Hidalgo County : a memoir for a son lost in court", "type": ["text"], "url": "//lccn.loc.gov/2020339183"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017782222/", "http://www.loc.gov/item/2017782222/", "http://www.loc.gov/pictures/item/2017782222/", "https://hdl.loc.gov/loc.pnp/fsa.8b37275", "http://www.loc.gov/resource/fsa.8b37275/", "http://lccn.loc.gov/2017782222"], "campaigns": [], "contributor": ["lee, russell"], "date": "1939-01-01", "dates": ["1939"], "description": ["1 negative : nitrate ; 3 1/4 x 4 1/4 inches or smaller."], "digitized": true, "extract_timestamp": "2021-09-01T20:16:27.206Z", "group": ["fsa", "catalog-split-01", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-01", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017782222/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8b37000/8b37200/8b37275_150px.jpg#h=113&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b37000/8b37200/8b37275t.gif#h=109&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b37000/8b37200/8b37275r.jpg#h=483&w=640", "https://tile.loc.gov/storage-se