}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075141/00340582032/1938012701/0705.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075141:00340582032:1938012701:0700/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075141/00340582032/1938012701/0705.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn86075141/1938-01-27/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075141/00340582032/1938012701/0705.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86075141/1938-01-27/ed-1/?sp=6"], "batch": ["mthi_horsetail_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/silver bow/", "3/united states/montana/silver bow/butte/"], "contributor": ["montana historical society; helena, mt"], "date": "1938-01-27", "dates": ["1938-01-27"], "description": ["UNION ORGANIZERS 10 IN AOjf SCREEN R\u00c7 6\u00dcUD hEiW G A An artist depicts the active work being carried on by the famous comedians Charlie McCarthy and Edgar Bergen in building the Federated Pictures Screen Actors Guild JOINT COMMITTEE TO MEET FEBRUARY 6TH Continued from Page 1 and took no active part in the selec tion of candidates for the legisla ture except to make endorsements of individuals who had already filed for the primaries As a result about twentyfive candidates received la bor endorsements for ten jobs Many of the men endorsed did not deserve such endorsement as their records in the past were w\u00e8ll known The history of the passage or non passage of labor legislation at the 25th legislative session is too well known to bear repetition It was a complete fiasco The blanket eight hour bill with which it was intend ed to put teeth in the eighthour amendment to the Constitution of Montana was defeated by a reac tionary senate The occupational disease silicosis bill was also de feated by the same body To cap the climax the eighthour collarto collar bill which would have affect ed thousands of miners throughout the sate was also"], "digitized": true, "extract_timestamp": "2023-07-03T13:47:31.812Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075141/1938-01-27/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075141:00340582032:1938012701:0705/full/pct:6.25/0/default.jpg#h=412&w=302", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075141:00340582032:1938012701:0705/full/pct:12.5/0/default.jpg#h=825&w=604", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075141/00340582032/1938012701/0705.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["montana", "butte", "united states", "silver bow"], "location_city": ["butte"], "location_country": ["united states"], "location_county": ["silver bow"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "4", "8", "0", "5", "2", "sn86075141", "1", "0000000006"], "number_edition": ["1"], "number_lccn": ["sn86075141"], "number_page": ["0000000006"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "2", "0", "3", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "montana labor news (butte, mont.) 19??-1951", "serial and government publications di