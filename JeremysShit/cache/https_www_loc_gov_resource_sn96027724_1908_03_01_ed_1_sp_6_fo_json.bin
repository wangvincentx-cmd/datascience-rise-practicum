{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn96027724/?st=calendar", "cite_this": {"apa": "(1908, March 1)  <cite>The Florida agriculturist</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn96027724/1908-03-01/ed-1/.", "chicago": "<cite>The Florida agriculturist</cite>. (Jacksonville, FL), Mar. 1 1908. https://www.loc.gov/item/sn96027724/1908-03-01/ed-1/.", "mla": "<cite>The Florida agriculturist</cite>. (Jacksonville, FL) 1 Mar. 1908, p. 6. Retrieved from the Library of Congress, www.loc.gov/item/sn96027724/1908-03-01/ed-1/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_bathouse_ver01/data/sn96027724/00271761648/1908030101/0445.xml&format=alto_xml&full_text=1", "item": {"_version_": 1855498256816013312, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn96027724/1908-03-01/ed-1/", "http://www.loc.gov/resource/sn96027724/1908-03-01/ed-1/"], "batch": ["fu_bathouse_ver01"], "call_number": ["Newspaper"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/florida/", "2/united states/florida/duval/", "3/united states/florida/duval/jacksonville/", "2/united states/florida/volusia/", "3/united states/florida/volusia/de land/"], "contributor_names": ["University of Florida"], "contributors": [{"university of florida": "https://www.loc.gov/search/?fa=contributor:university+of+florida&fo=json"}], "created_published": ["DeLand, Fla., March 1, 1908"], "date": "1908-03-01", "date_issued": "1908-03-01", "dates": [{"1908-03-01": "https://www.loc.gov/search/?dates=1908-03-01/1908-03-01&fo=json"}], "dates_of_publication": "1878-1911", "description": ["DeLand, Fla."], "digital_id": ["https://www.loc.gov/chroniclingamerica/lccn/sn96027724/issues", "http://ufdc.ufl.edu/UF00047911"], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2026-01-27T16:57:42.656Z", "extract_urls": ["file:/service/ndnp//fu/batch_fu_bathouse_ver01/data/sn96027724/00271761648/1908030101/1908030101_1.xml#ndnp/fu"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn96027724/1908-03-01/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bathouse_ver01:data:sn96027724:00271761648:1908030101:0440/full/pct:3.125/0/default.jpg#h=321&w=228", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bathouse_ver01:data:sn96027724:00271761648:1908030101:0440/full/pct:6.25/0/default.jpg#h=643&w=456"], "index": 6, "item": {"batch": ["fu_bathouse_ver01"], "call_number": ["Newspaper"], "contributor_names": ["University of Florida"], "created_published": ["DeLand, Fla., March 1, 1908"], "date": "1878", "date_issued": "1908-03-01", "dates": ["1908-03-01"], "digital_id": ["https://www.loc.gov/chroniclingamerica/lccn/sn96027724/issues", "http://ufdc.ufl.edu/UF00047911"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn96027724", "location": ["Florida", "De Land (Fla.)", "Volusia County (Fla.)", "Jacksonville (Fla.)", "Duval County (Fla.)", "Florida--De Land", "Florida--Duval County", "Florida--Jacksonville", "Florida--Volusia County"], "medium": "16 pages", "newspaper_title": ["The Florida agriculturist"], "notes": ["Monthly, 1908-June 1911", "Vol. 1, no. 1 (May 15, 1878)-v. 38, no. 6 (June 1911).", "Publisher: E.O. Painter, <1887>.", "Editor: C. Codrington, 1878-", "\"A journal devoted to state interests.\"", "Published at Jacksonville and De Land, <1902>-1907; at Jacksonville, 1907-", "Numbering is irregular.", "Issues for 1911 also called \"New series.\"", "Archived issues are available in digital format as apart of the Library of Congress Chronicling America online collection."], "other_formats": ["https://tile.loc.gov/storage-services/service/ndnp//fu/batch_fu_bathouse_ver01/data/sn96027724/00271761648/1908030101/1908030101_1.xml", "http://lccn.loc.gov/sn96027724/marcxml"], "place_of_publication": "DeLand, Fla.", "raw_lccn": "sn 96027724 ", "reel_numbers": ["00271761648"], "source_group": "ndnp/fu", "subjects": ["Agriculture--Florida", "De Land (Fla.)--Newspapers", "Volusia County (Fla.)--Newspapers", "Jacksonville (Fla.)--Newspapers", "Duval County (Fla.)--Newspapers", "Agriculture", "Florida", "Florida--De Land", "Florida--Duval County", "Florida--Jacksonville", "Florida--Volusia County", "United States--Florida--Duval--Jacksonville", "United States--Florida--Volusia--De Land"], "summary": ["For many years, the Florida Agriculturist [LCCN: sn96027724] was the only agricultural publication in Florida. It began publishing in 1878 and ceased publication in 1911. In the 1884 edition of Edwin Aldin & Bro.'s American Newspaper Catalogue [LCCN a18000248], the publication is described as a large eight-page newspaper, the cost of a one-year subscription was two dollars. The newspaper was said to inform readers of \"the capabilities of the State of Florida, its productions and resources,\" and it was \"full of the experiences of Old Settlers and an instructor for the new.\" \"You will learn,\" the American Newspaper Catalogue continued, \"from it all about orange culture and other semi-tropical fruit, market gardening, etc., besides much general information of interest about all parts of the state.\" Prior to passage of the Chinese Exclusion Act of 1882, a surprising number of Chinese immigrants made their way to Florida, and their labor in state agriculture was strongly supported by the Florida Agriculturist (see the issues for 24 January 1874 and 9 March 1881). Growing agricultural businesses, shipping industries, railroad schedules and other topics of interest to Florida's agricultural communities is also reported. The address for subscriptions to the Florida Agriculturist was C. Codrington & Co., DeLand, Florida, the presumed publishing location. In 1878 and still at the turn of the 20th century, DeLand was a cross-roads of sorts for Florida. Located in Volusia County (FL) on the Atlantic Ocean, DeLand was, for a time, a terminal point and later a hub for railways reaching into southern Florida. With the expansion of railroad lines in Florida and the opening of the Port of Jacksonville in the later part of the first decade of the 20th century, DeLand would eventually be supplanted by Jacksonville (FL) as an economic hub of Florida. The Florida Agriculturist was a weekly from its start in 1878 through 1907. It became a monthly in 1908 continuing through June 1911 when it ceased publication. The editor was C. Codrington in 1878. Codrington, a native of Jamaica, was an importer of ornamental and exotic plants into Florida. Many Codrington plants were used in the landscaping of new Florida tourist attractions. Many catalogers of U.S. newspapers regard the Florida Agriculturist as a periodical rather than as a newspaper because plant orders could be sent to the newspaper's subscriptions office and others, because the newspaper functioned so well, and in all likelihood originally, as a catalog for the C. Codrington Company. One source (Geo. P. Rowell and Co.'s American Newspaper Directory [LCCN sn82007064]) suggests that the newspaper was established as early as 1874, but this may have been a forerunner of the newspaper, perhaps even a catalog for the C. Codrington Company. The Codrington family also published other newspapers in DeLand, among them the DeLand (FL) News [LCCN sn92062121]. E.O. Painter was publisher and editor in 1887. According to his obituary published in the Proceedings of the American Pomological Society, 33rd biennial session, Painter came to DeLand from New York with his parents at the age of sixteen, largely unschooled but an avid reader. He cleared land for his own orange grove and went to work for the Florida Agriculturist as a journeyman printer. In 1885, he bought a half-interest in the paper and later bought a whole interest paid for by the sale of an orange grove. Painter was so successful that the E.O. Painter Printing Company spun off from the Florida Agriculturist and, today (ca. 2008) remains as one of Florida's oldest and most successful printers. Painter continued as editor and owner of the Florida Agriculturist until 1907, when he sold all of his rights and interests in the paper, which was subsequently published in Jacksonville. The Port of Jacksonville had opened the previous year and the City of Jacksonville had begun to supplant DeLand as an economic center in Florida.--E. Kesse, University of Florida Digital Library Center."], "title": "The Florida agriculturist (DeLand, Fla.), March 1, 1908"}, "language": ["english"], "languages": [{"english": "https://www.loc.gov/search/?fa=language:english&fo=json"}], "library_of_congress_control_number": "sn96027724", "location": ["jacksonville", "duval county", "volusia", "de land", "duval", "volusia county", "united states", "florida"], "location_city": ["jacksonville", "de land"], "location_country": ["united states"], "location_county": ["duval", "volusia"], "location_state": ["florida"], "locations": [{"de land": "https://www.loc.gov/search/?fa=location:de+land&fo=json"}, {"duval": "https://www.loc.gov/search/?fa=location:duval&fo=json"}, {"duval county": "https://www.loc.gov/search/?fa=location:duval+county&fo=json"}, {"florida": "https://www.loc.gov/search/?fa=location:florida&fo=json"}, {"jacksonville": "https://www.loc.gov/search/?fa=location:jacksonville&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=location:united+states&fo=json"}, {"volusia": "https://www.loc.gov/search/?fa=location:volusia&fo=json"}, {"volusia county": "https://www.loc.gov/search/?fa=location:volusia+county&fo=json"}], "locations_city": [{"de land": "https://www.loc.gov/search/?fa=location_city:de+land&fo=json"}, {"jacksonville": "https://www.loc.gov/search/?fa=location_city:jacksonville&fo=json"}], "locations_country": [{"united states": "https://www.loc.gov/search/?fa=location_country:united+states&fo=json"}], "locations_county": [{"duval": "https://www.loc.gov/search/?fa=location_county:duval&fo=json"}, {"volusia": "https://www.loc.gov/search/?fa=location_county:volusia&fo=json"}], "locations_state": [{"florida": "https://www.loc.gov/search/?fa=location_state:florida&fo=json"}], "medium": "16 pages", "method": "mets_filesec", "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "newspaper_title": ["The Florida agriculturist"], "notes": ["Monthly, 1908-June 1911", "Vol. 1, no. 1 (May 15, 1878)-v. 38, no. 6 (June 1911).", "Publisher: E.O. Painter, <1887>.", "Editor: C. Codrington, 1878-", "\"A journal devoted to state interests.\"", "Published at Jacksonville and De Land, <1902>-1907; at Jacksonville, 1907-", "Numbering is irregular.", "Issues for 1911 also called \"New series.\"", "Archived issues are available in digital format as apart of the Library of Congress Chronicling America online collection."], "number": ["sn96027724", "00271761648", "1"], "number_edition": ["1"], "number_lccn": ["sn96027724"], "number_reel": ["00271761648"], "numeric_shelf_id": 190803011, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//fu/batch_fu_bathouse_ver01/data/sn96027724/00271761648/1908030101/1908030101_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn96027724/marcxml"}], "partof": [{"count": 787, "title": "the florida agriculturist (deland, fla.) 1878-1911", "url": "https://www.loc.gov/search/?fa=partof:the+florida+agriculturist+%28deland,+fla.%29+1878-1911&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the florida agriculturist (deland, fla.) 1878-1911"], "place_of_publication": "DeLand, Fla.", "publication_frequency": ["monthly"], "raw_lccn": "sn 96027724 ", "reel_numbers": ["00271761648"], "resources": [{"files": 16, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bathouse_ver01:data:sn96027724:00271761648:1908030101:0440/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn96027724/1908-03-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.96732, "shard": "04", "shelf_id": "sn96027724, 1908-03-01, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/fu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "jacksonville", "de land (fla.)", "duval county", "volusia", "agriculture", "duval county (fla.)", "de land", "jacksonville (fla.)", "duval", "volusia county", "volusia county (fla.)", "united states", "florida"], "subject_headings": ["Agriculture--Florida", "De Land (Fla.)--Newspapers", "Volusia County (Fla.)--Newspapers", "Jacksonville (Fla.)--Newspapers", "Duval County (Fla.)--Newspapers", "Agriculture", "Florida", "Florida--De Land", "Florida--Duval County", "Florida--Jacksonville", "Florida--Volusia County", "United States--Florida--Duval--Jacksonville", "United States--Florida--Volusia--De Land"], "subjects": [{"agriculture": "https://www.loc.gov/search/?fa=subject:agriculture&fo=json"}, {"de land": "https://www.loc.gov/search/?fa=subject:de+land&fo=json"}, {"de land (fla.)": "https://www.loc.gov/search/?fa=subject:de+land+%28fla.%29&fo=json"}, {"duval": "https://www.loc.gov/search/?fa=subject:duval&fo=json"}, {"duval county": "https://www.loc.gov/search/?fa=subject:duval+county&fo=json"}, {"duval county (fla.)": "https://www.loc.gov/search/?fa=subject:duval+county+%28fla.%29&fo=json"}, {"florida": "https://www.loc.gov/search/?fa=subject:florida&fo=json"}, {"jacksonville": "https://www.loc.gov/search/?fa=subject:jacksonville&fo=json"}, {"jacksonville (fla.)": "https://www.loc.gov/search/?fa=subject:jacksonville+%28fla.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"volusia": "https://www.loc.gov/search/?fa=subject:volusia&fo=json"}, {"volusia county": "https://www.loc.gov/search/?fa=subject:volusia+county&fo=json"}, {"volusia county (fla.)": "https://www.loc.gov/search/?fa=subject:volusia+county+%28fla.%29&fo=json"}], "summary": ["For many years, the Florida Agriculturist [LCCN: sn96027724] was the only agricultural publication in Florida. It began publishing in 1878 and ceased publication in 1911. In the 1884 edition of Edwin Aldin & Bro.'s American Newspaper Catalogue [LCCN a18000248], the publication is described as a large eight-page newspaper, the cost of a one-year subscription was two dollars. The newspaper was said to inform readers of \"the capabilities of the State of Florida, its productions and resources,\" and it was \"full of the experiences of Old Settlers and an instructor for the new.\" \"You will learn,\" the American Newspaper Catalogue continued, \"from it all about orange culture and other semi-tropical fruit, market gardening, etc., besides much general information of interest about all parts of the state.\" Prior to passage of the Chinese Exclusion Act of 1882, a surprising number of Chinese immigrants made their way to Florida, and their labor in state agriculture was strongly supported by the Florida Agriculturist (see the issues for 24 January 1874 and 9 March 1881). Growing agricultural businesses, shipping industries, railroad schedules and other topics of interest to Florida's agricultural communities is also reported. The address for subscriptions to the Florida Agriculturist was C. Codrington & Co., DeLand, Florida, the presumed publishing location. In 1878 and still at the turn of the 20th century, DeLand was a cross-roads of sorts for Florida. Located in Volusia County (FL) on the Atlantic Ocean, DeLand was, for a time, a terminal point and later a hub for railways reaching into southern Florida. With the expansion of railroad lines in Florida and the opening of the Port of Jacksonville in the later part of the first decade of the 20th century, DeLand would eventually be supplanted by Jacksonville (FL) as an economic hub of Florida. The Florida Agriculturist was a weekly from its start in 1878 through 1907. It became a monthly in 1908 continuing through June 1911 when it ceased publication. The editor was C. Codrington in 1878. Codrington, a native of Jamaica, was an importer of ornamental and exotic plants into Florida. Many Codrington plants were used in the landscaping of new Florida tourist attractions. Many catalogers of U.S. newspapers regard the Florida Agriculturist as a periodical rather than as a newspaper because plant orders could be sent to the newspaper's subscriptions office and others, because the newspaper functioned so well, and in all likelihood originally, as a catalog for the C. Codrington Company. One source (Geo. P. Rowell and Co.'s American Newspaper Directory [LCCN sn82007064]) suggests that the newspaper was established as early as 1874, but this may have been a forerunner of the newspaper, perhaps even a catalog for the C. Codrington Company. The Codrington family also published other newspapers in DeLand, among them the DeLand (FL) News [LCCN sn92062121]. E.O. Painter was publisher and editor in 1887. According to his obituary published in the Proceedings of the American Pomological Society, 33rd biennial session, Painter came to DeLand from New York with his parents at the age of sixteen, largely unschooled but an avid reader. He cleared land for his own orange grove and went to work for the Florida Agriculturist as a journeyman printer. In 1885, he bought a half-interest in the paper and later bought a whole interest paid for by the sale of an orange grove. Painter was so successful that the E.O. Painter Printing Company spun off from the Florida Agriculturist and, today (ca. 2008) remains as one of Florida's oldest and most successful printers. Painter continued as editor and owner of the Florida Agriculturist until 1907, when he sold all of his rights and interests in the paper, which was subsequently published in Jacksonville. The Port of Jacksonville had opened the previous year and the City of Jacksonville had begun to supplant DeLand as an economic center in Florida.--E. Kesse, University of Florida Digital Library Center."], "timestamp": "2026-01-27T19:10:17.655Z", "title": "The Florida agriculturist (DeLand, Fla.), March 1, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn96027724/1908-03-01/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn96027724/", "http://lccn.loc.gov/sn96027724", "https://search.catalog.loc.gov/instances/137fa6c5-1db1-587e-9e7a-1da4a48b8af0"], "batch": ["fu_albert_ver01"], "campaigns": [], "date": "1878", "description": ["For many years, the Florida Agriculturist [LCCN: sn96027724] was the only agricultural publication in Florida. It began publishing in 1878 and ceased publication in 1911. In the 1884 edition of Edwin Aldin & Bro.'s American Newspaper Catalogue [LCCN a18000248], the publication is described as a large eight-page newspaper, the cost of a one-year subscription was two dollars. The newspaper was said to inform readers of \"the capabilities of the State of Florida, its productions and resources,\" and it was \"full of the experiences of Old Settlers and an instructor for the new.\" \"You will learn,\" the American Newspaper Catalogue continued, \"from it all about orange culture and other semi-tropical fruit, market gardening, etc., besides much general information of interest about all parts of the state.\" Prior to passage of the Chinese Exclusion Act of 1882, a surprising number of Chinese immigrants made their way to Florida, and their labor in state agriculture was strongly supported by the Florida Agriculturist (see the issues for 24 January 1874 and 9 March 1881). Growing agricultural businesses, shipping industries, railroad schedules and other topics of interest to Florida's agricultural communities is also reported. The address for subscriptions to the Florida Agriculturist was C. Codrington & Co., DeLand, Florida, the presumed publishing location. In 1878 and still at the turn of the 20th century, DeLand was a cross-roads of sorts for Florida. Located in Volusia County (FL) on the Atlantic Ocean, DeLand was, for a time, a terminal point and later a hub for railways reaching into southern Florida. With the expansion of railroad lines in Florida and the opening of the Port of Jacksonville in the later part of the first decade of the 20th century, DeLand would eventually be supplanted by Jacksonville (FL) as an economic hub of Florida. The Florida Agriculturist was a weekly from its start in 1878 through 1907. It became a monthly in 1908 continuing through June 1911 when it ceased publication. The editor was C. Codrington in 1878. Codrington, a native of Jamaica, was an importer of ornamental and exotic plants into Florida. Many Codrington plants were used in the landscaping of new Florida tourist attractions. Many catalogers of U.S. newspapers regard the Florida Agriculturist as a periodical rather than as a newspaper because plant orders could be sent to the newspaper's subscriptions office and others, because the newspaper functioned so well, and in all likelihood originally, as a catalog for the C. Codrington Company. One source (Geo. P. Rowell and Co.'s American Newspaper Directory [LCCN sn82007064]) suggests that the newspaper was established as early as 1874, but this may have been a forerunner of the newspaper, perhaps even a catalog for the C. Codrington Company. The Codrington family also published other newspapers in DeLand, among them the DeLand (FL) News [LCCN sn92062121]. E.O. Painter was publisher and editor in 1887. According to his obituary published in the Proceedings of the American Pomological Society, 33rd biennial session, Painter came to DeLand from New York with his parents at the age of sixteen, largely unschooled but an avid reader. He cleared land for his own orange grove and went to work for the Florida Agriculturist as a journeyman printer. In 1885, he bought a half-interest in the paper and later bought a whole interest paid for by the sale of an orange grove. Painter was so successful that the E.O. Painter Printing Company spun off from the Florida Agriculturist and, today (ca. 2008) remains as one of Florida's oldest and most successful printers. Painter continued as editor and owner of the Florida Agriculturist until 1907, when he sold all of his rights and interests in the paper, which was subsequently published in Jacksonville. The Port of Jacksonville had opened the previous year and the City of Jacksonville had begun to supplant DeLand as an economic center in Florida.--E. Kesse, University of Florida Digital Library Center."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.113Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-06", "catalog", "united-states-newspaper-directory", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/sn96027724/", "image_url": [], "index": 6, "language": ["english"], "latlong": [29.0280928, -81.2992699], "location": ["jacksonville", "duval county", "volusia", "de land", "duval", "volusia county", "united states", "florida"], "location_str": "", "lonlat": [-81.2992699, 29.0280928], "number": ["sn96027724", "1940-7440", "online resource", "786", "sn95026893", "1376795", "new york state - lii", "1", "2025-11-07t14:59:38.300000", "original", "2025-05-23t21:30:26", "http://www.loc.gov/item/sn96027724/1878-05-15/ed-1/", "http://www.loc.gov/item/sn96027724/1910-06-01/ed-1/", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["catalog", "chronicling america", "serial and government publications division", "the florida agriculturist (deland, fla.) 1878-1911", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["monthly"], "score": 134.48409, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "jacksonville", "de land (fla.)", "duval county", "volusia", "agriculture", "duval county (fla.)", "de land", "jacksonville (fla.)", "duval", "volusia county", "volusia county (fla.)", "united states", "florida"], "timestamp": "2026-07-18T09:37:35.627Z", "title": "The Florida agriculturist", "type": ["title"], "url": "https://www.loc.gov/item/sn96027724/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2007264076/"], "campaigns": [], "date": "1878", "dates": ["[1878 TO 1911]"], "description": ["Weekly Print began with v. 1, no. 1 (May 15, 1878); ceased with v. 38, no. 6 (June 1911). \"A journal devoted to state interests.\" Published at Jacksonville and DeLand, <Nov. 1905-Aug. 1906>. Issues for <Nov. 1905-Aug. 1906> also have whole numbering; numbering is irregular. Description based on: Vol. 32, no. 44 (Nov. 1, 1905); title from PDF caption (Library of Congress Chronicling America online collection, viewed Dec. 5, 2007). Latest issue consulted: Vol. 33, no. 32 [i.e. 35] (Aug. 29, 1906)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:02.671Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2007264076/", "image_url": [], "index": 7, "language": ["english"], "location": ["jacksonville", "duval county", "volusia", "de land", "duval", "volusia county", "united states", "florida"], "number": ["online resource", "2007264076", "182776228", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["the florida agriculturist (jacksonville, fla.) 1878-1911 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 125.242455, "shelf_id": "https://s3.amazonaws.com/chronam-bib-derivatives/2007264076.xml", "site": ["usnd"], "subject": ["newspapers", "jacksonville", "de land (fla.)", "duval county", "volusia", "agriculture", "duval county (fla.)", "de land", "jacksonville (fla.)", "duval", "volusia county", "volusia county (fla.)", "united states", "florida"], "timestamp": "2026-05-26T20:43:14.516Z", "title": "The Florida agriculturist", "type": ["title"], "url": "https://www.loc.gov/item/2007264076/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95026697/", "http://lccn.loc.gov/sn95026697", "https://search.catalog.loc.gov/instances/b5985a9a-ad8b-5b42-a3bb-59b34715fa58"], "batch": ["fu_six_ver01"], "campaigns": [], "date": "1887", "description": ["The DeLand (FL) Weekly News [LCCN: sn95026697] began publishing in 1887. It was succeeded by the DeLand (FL) News [LCCN: sn92062121] sometime in 1907 or early 1908. The title, DeLand Weekly News, was used occasionally between 1908 and 1909. Its name change was inconsequential to its readership; the DeLand News remained a weekly. In 1921, DeLand News merged with the Volusia County (FL) Record [LCCN: sn95026693] to form the DeLand News and Volusia County Record [LCCN: sn95026694]. Christopher O. Codrington was the editor of both the DeLand Weekly News and the DeLand News. Very little is known about Codrington outside of a reference in the Miami (FL) Herald [LCCN: sn83016279] and trial summaries published in the Southern Reporter [LCCN sn88016989]. The Miami Herald's reference on December 26, 1914 names Codrington as the editor of the DeLand News. The Southern Reporter, in Vol. 45 (1908), p. 809-811, summarizes the history of the civil case of \"Steward vs. Codrington, et al.\" for libel stemming from reporting in a May 1906 issue of the DeLand Weekly News. Isaac A. Stewart held the office of Judge of the Criminal Court of Record in Volusia County (FL) in 1906. The review courts found that the case was not related to Stewart's official position as claimed. While the summary is not specific to the opinions of either Codrington or Stewart, it does establish that Codrington was acquitted in February 1908. It is doubtful that the conclusion of the case had any influence in the newspaper's title change. Steward was also one of three owners of the Georgia, Florida and Key West Railway Company, incorporated in Florida and running through Volusia County. The interests of the railway and tourism played large in DeLand and in Volusia County. Settled in 1874, DeLand, originally named Persimmon Hollow after its persimmon trees, was accessible only by steamboat. The railroad changed the city shortly after Henry DeLand, a New York industrialist, in 1876, visited, renamed and re-envisioned its future as a center for agriculture, particularly for citrus, and for tourism. The railroad arrived sometime after June 2, 1877 when the Georgia, Florida and Key West Railway Company was incorporated to run from the Florida/Georgia state line to New Smyrna (FL) on the Atlantic coast just east of DeLand and likely threatening the city's prospects. DeLand is known in Florida as a city of firsts. It was first in Florida to have electricity, most of it generated in New York. It hosted Florida's first private university, Stetson University, named after John B. Stetson of Western hat fame. Later, it would host Florida's first law school, established in 1900 at Stetson University. Although the county seat, readers of both the DeLand Weekly News and the DeLand News can see political and economic power shifts to the coast and to the city of Daytona Beach (FL). The Southern Reporter's summary is not specific to the date of publication of the words that were subject of the suit. Additional court reporting is currently (ca. 2008) not available.--E. Kesse, University of Florida Digital Library Center."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.596Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-13", "catalog", "united-states-newspaper-directory", "main-catalog-split-13"], "hassegments": false, "id": "http://www.loc.gov/item/sn95026697/", "image_url": [], "index": 8, "language": ["english"], "latlong": [29.0280928, -81.2992699], "location": ["volusia", "de land", "volusia county", "united states", "florida"], "location_str": "", "lonlat": [-81.2992699, 29.0280928], "number": ["online resource", "http://www.loc.gov/item/sn95026697/1903-01-01/ed-1/", "133", "2025-11-07t15:05:07.200000", "1941-076x", "1", "sn92062121", "kansas state hist soc, newsp proj", "original", "sn95026697", "http://www.loc.gov/item/sn95026697/1907-01-25/ed-1/", "2025-05-23t21:30:26", "1699465", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["De Land weekly news", "Weekly news"], "partof": ["the deland weekly news (deland, fla.) 1887-190?", "chronicling america", "catalog", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 75.53568, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "de land (fla.)", "volusia", "de land", "volusia county", "volusia county (fla.)", "united states", "florida"], "timestamp": "2026-07-18T09:36:43.276Z", "title": "The DeLand weekly news", "type": ["title"], "url": "https://www.loc.gov/item/sn95026697/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn92062121/", "http://lccn.loc.gov/sn92062121", "https://search.catalog.loc.gov/instances/e83844fd-8763-5110-b337-ff5299000726"], "batch": ["fu_six_ver01"], "campaigns": [], "date": "190?", "description": ["The DeLand (FL) News [LCCN: sn92062121] began publishing sometime in 1907 or early 1908. The newspaper succeeded the DeLand (FL) Weekly News [LCCN: sn95026697] in publication since 1887. The title, DeLand Weekly News, was used occasionally between 1908 and 1909. Its name change was inconsequential to its readership; the DeLand News remained a weekly. In 1921, DeLand News merged with the Volusia County (FL) Record [LCCN: sn95026693] to form the DeLand News and Volusia County Record [LCCN: sn95026694]. Christopher O. Codrington was the editor of both the DeLand Weekly News and the DeLand News. Very little is known about Codrington outside of a reference in the Miami (FL) Herald [LCCN: sn83016279] and trial summaries published in the Southern Reporter [LCCN sn88016989]. The Miami Herald's reference on December 26, 1914 names Codrington as the editor of the DeLand News. The Southern Reporter, in Vol. 45 (1908), p. 809-811, summarizes the history of the civil case of \"Steward vs. Codrington, et al.\" for libel stemming from reporting in a May 1906 issue of the DeLand Weekly News. Isaac A. Stewart held the office of Judge of the Criminal Court of Record in Volusia County (FL) in 1906. The review courts found that the case was not related to Stewart's official position as claimed. While the summary is not specific to the opinions of either Codrington or Stewart, it does establish that Codrington was acquitted in February 1908. It is doubtful that the conclusion of the case had any influence in the newspaper's title change. Steward as also one of three owners of the Georgia, Florida and Key West Railway Company, incorporated in Florida and running through Volusia County. The interests of the railway and tourism played large in DeLand and in Volusia County. Settled in 1874, DeLand, originally named Persimmon Hollow after its persimmon trees, was accessible only by steamboat. The railroad changed the city shortly after Henry DeLand, a New York industrialist, in 1876, visited, renamed and re-envisioned its future as a center for agriculture, particularly for citrus, and for tourism. The railroad arrived sometime after June 2, 1877 when the Georgia, Florida and Key West Railway Company was incorporated to run from the Florida/Georgia state line to New Symrna (FL) on the Atlantic coast just east of DeLand and likely threatening the city's prospects. DeLand is known in Florida as a city of firsts. It was first in Florida to have electricity, most of it generated in New York. It hosted Florida's first private university, Stetson University, named after John B. Stetson of Western hat fame. Later, it would host Florida's first law school, established in 1900 at Stetson University. Although the county seat, readers of both the DeLand Weekly News and the DeLand News can see political and economic power shifts to the coast and to the city of Daytona Beach (FL). The Southern Reporter's summary is not specific to the date of publication of the words that were subject of the suit. Additional court reporting is currently (ca. 2008) not available.--E. Kesse, University of Florida Digital Library Center"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.596Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-08", "catalog", "united-states-newspaper-directory", "main-catalog-split-08"], "hassegments": false, "id": "http://www.loc.gov/item/sn92062121/", "image_url": [], "index": 9, "language": ["english"], "latlong": [29.0280928, -81.2992699], "location": ["volusia", "de land", "volusia county", "united states", "florida"], "location_str": "", "lonlat": [-81.2992699, 29.0280928], "number": ["new york state - vx6", "online resource", "1941-0751", "sn95026694", "1699436", "sn95026693", "50", "1", "2025-11-07t15:00:26.700000", "sn95026697", "original", "2025-05-23t21:30:26", "sn92062121", "http://www.loc.gov/item/sn92062121/1909-12-31/ed-1/", "http://www.loc.gov/item/sn92062121/1909-01-22/ed-1/", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["De Land news", "DeLand weekly news"], "partof": ["deland news (deland, volusia county, fla.) 190?-1921", "catalog", "chronicling america", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 75.53568, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "de land (fla.)", "volusia", "periodicals", "de land", "volusia county", "volusia county (fla.)", "united states", "florida"], "timestamp": "2026-07-18T09:33:03.460Z", "title": "DeLand news", "type": ["title"], "url": "https://www.loc.gov/item/sn92062121/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn96027724/1890-01-01/ed-1/", "http://www.loc.gov/resource/sn96027724/1890-01-01/ed-1/"], "batch": ["fu_bathouse_ver01"], "campaigns": [], "contributor": ["university of florida"], "date": "1890-01-01", "dates": ["1890-01-01"], "description": ["DeLand, Fla."], "digitized": true, "extract_timestamp": "2026-01-27T16:57:39.377Z", "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn96027724/1890-01-01/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bathouse_ver01:data:sn96027724:00271761569:1890010101:0001/full/pct:3.125/0/default.jpg#h=275&w=197", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bathouse_ver01:data:sn96027724:00271761569:1890010101:0001/full/pct:6.25/0/default.jpg#h=550&w=394", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_bathouse_ver01:data:sn96027724:00271761569:1890010101:0001/full/pct:12.5/0/default.jpg#h=1101&w=789"], "index": 10, "language": ["english"], "location": ["jacksonville", "duval county", "volusia", "de land", "duval", "volusia county", "united states", "florida"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "number": ["sn96027724", "1", "00271761569"], "numeric_shelf_id": 189001011, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the florida agriculturist (deland, fla.) 1878-1911", "chronicling america", "serial and government publications division"], "publication_frequency": ["monthly"], "score": 67.39902, "shelf_id": "sn96027724, 1890-01-01, Edition 1", "site": ["chroniclingamerica"], "subject": ["newspapers