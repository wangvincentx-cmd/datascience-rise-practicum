xes which the Supreme court declared unconstitutional These taxes would be applied only to wheat cotton and rice3 cents a pound on cotton 20 cents a bushel on wheat and 2 cent a pound on rice The policy of congress is declared to be to maintain so far as prac ticable both parity of prices paid to farmers for all agricultural com modities marketed by them for do mestic consumption and export and parity income for farmers market ing such commodities Benefit payments would"], "digitized": true, "extract_timestamp": "2024-01-04T04:18:42.185Z", "group": ["ndnp/mnhi", "minnesota-historical-society-saint-paul-mn-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn90059182/1937-11-18/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_motocross_ver01:data:sn90059182:00513689536:1937111801:0470/full/pct:3.125/0/default.jpg#h=309&w=230", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_motocross_ver01:data:sn90059182:00513689536:1937111801:0470/full/pct:6.25/0/default.jpg#h=619&w=460", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_motocross_ver01/data/sn90059182/00513689536/1937111801/0470.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["ely", "united states", "saint louis county", "saint louis", "minnesota"], "location_city": ["ely"], "location_country": ["united states"], "location_county": ["saint louis"], "location_state": ["minnesota"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "sn90059182", "0", "1", "8", "0000000002", "9", "6"], "number_edition": ["1"], "number_lccn": ["sn90059182"], "number_page": ["0000000002"], "number_reel": ["0", "0", "5", "1", "3", "6", "8", "9", "5", "3", "6"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "the ely 