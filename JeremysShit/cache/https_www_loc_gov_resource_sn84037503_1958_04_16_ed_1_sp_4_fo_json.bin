10/1958041601/1958041601_1.xml#ndnp/vnstcsc"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/vnstcsc", "university-of-virgin-islands"], "hassegments": true, "id": "http://www.loc.gov/item/sn84037503/1958-04-16/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:vnstcsc:batch_vnstcsc_ensomned_ver01:data:sn84037503:00513689810:1958041601:0612/full/pct:6.25/0/default.jpg#h=298&w=235", "https://tile.loc.gov/image-services/iiif/service:ndnp:vnstcsc:batch_vnstcsc_ensomned_ver01:data:sn84037503:00513689810:1958041601:0612/full/pct:12.5/0/default.jpg#h=597&w=470", "https://tile.loc.gov/image-services/iiif/service:ndnp:vnstcsc:batch_vnstcsc_ensomned_ver01:data:sn84037503:00513689810:1958041601:0612/full/pct:25/0/default.jpg#h=1195&w=941"], "index": 4, "item": {"batch": ["vnstcsc_ensomned_ver01"], "call_number": ["Newspaper"], "contributor_names": ["University of the Virgin Islands"], "contributors": ["Ottley, Earle B."], "created_published": ["Charlotte Amalie, St. Thomas, V.I., April 16, 1958"], "date": "1951", "date_issued": "1958-04-16", "dates": ["1958-04-16"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn84037503", "location": ["United States Virgin Islands"], "medium": "8 pages", "newspaper_title": ["The home journal"], "notes": ["Daily (except Sun.), Dec. 1971-1973", "1st year, no. 1 (Jan. 25, 1951)-21st year, no. 6144 (Jan. 12, 1973).", "Vols. for Oct. 1969-Mar. 1971 include a monthly supplement called Carib.", "Includes a weekly supplement called Focus, Sundays to Nov. 1971; Saturdays, Dec. 1971-Dec. 1972.", "Available on microfilm from Library of Congress Photoduplication Service.", "Saturday edition, 1968-1969, distributed and sold separately on St. Croix as the Crucian journal.", "Weekly journal (Charlotte Amalie, United States Virgin Islands : 1973) (DLC