689810/1958041601/0615.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn84037503/1958-04-16/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/vnstcsc/batch_vnstcsc_ensomned_ver01/data/sn84037503/00513689810/1958041601/0615.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:vnstcsc:batch_vnstcsc_ensomned_ver01:data:sn84037503:00513689810:1958041601:0612/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/vnstcsc/batch_vnstcsc_ensomned_ver01/data/sn84037503/00513689810/1958041601/0615.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn84037503/1958-04-16/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/vnstcsc/batch_vnstcsc_ensomned_ver01/data/sn84037503/00513689810/1958041601/0615.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84037503/1958-04-16/ed-1/?sp=4"], "batch": ["vnstcsc_ensomned_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/virgin islands/", "2/united states/virgin islands/saint thomas/", "3/united states/virgin islands/saint thomas/charlotte amalie/"], "contributor": ["university of the virgin islands"], "date": "1958-04-16", "dates": ["1958-04-16"], "description": ["Speech of Atty John Maduro Over Radio Station WSTA of these states to take care of the unemployed have been exhausted because of the great demands on them and in some instances the Federal Government has had to make substantial contribution to the State funds Here in the Virgin Islands w e have 1 few programs designed t 2 asst the aged blind children and handicapped persons but there is no program in these Islands whic will render assistance to a man who has been laid off of his job for one reason or other except ifhe is a Federal employee for Federal employees are covered under the Federal Employee Insurance P ro gram We need legislation which will establish such a program thru which our unemployed will re ceive some assistance whenever the occasfon warrants it There is no doubt in our mi nds that should this recession in the United States continue we here in the Virgin Islands would be affected When we compare the placement figures of em p 10 yees Wwho obtained jobs through the Employment Office here we found that the number of placements bet ween the months of January to March 1958 were much"], "digitized": true, "extract_timestamp": "2023-10-30T12:57:27.985Z", "group": ["ndnp/vnstcsc", "university-of-virgin-islands"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84037503/1958-04-16/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:vnstcsc:batch_vnstcsc_ensomned_ver01:data:sn84037503:00513689810:1958041601:0615/full/pct:6.25/0/default.jpg#h=300&w=235", "https://tile.loc.gov/image-services/iiif/service:ndnp:vnstcsc:batch_vnstcsc_ensomned_ver01:data:sn84037503:00513689810:1958041601:0615/full/pct:12.5/0/default.jpg#h=601&w=470", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/vnstcsc/batch_vnstcsc_ensomned_ver01/data/sn84037503/00513689810/1958041601/0615.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["saint thomas", "charlotte amalie", "virgin islands", "united states virgin islands", "united states"], "location_city": ["charlotte amalie"], "location_country": ["united states"], "location_county": ["saint thomas"], "location_state": ["virgin islands"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0000000004", "8", "0", "5", "sn84037503", "1", "6", "9"], "number_edition": ["1"], "number_lccn": ["sn84037503"], "number_page": ["0000000004"], "n