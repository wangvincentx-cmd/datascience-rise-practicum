oc.gov/item/sn85053305/1918-04-26/ed-1/", "original", "sn85053306", "sn85053256", "2026-04-13t21:30:13", "2251783", "961", "sn85053326", "2025-05-23t21:30:26", "sn84036260", "montana hist soc libr", "sn85053269", "microfilm service copy", "2025-06-25t14:21:31"], "original_format": ["newspaper"], "partof": ["chronicling america", "catalog", "serial and government publications division", "directory of u.s. newspapers in american libraries", "the producers news (plentywood, mont.) 1918-1937"], "publication_frequency": ["weekly"], "score": 64.03915, "shelf_id": "Newspaper HD1401 .P76", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "montana", "plentywood", "sheridan", "plentywood (mont.)", "united states"], "timestamp": "2026-07-22T07:43:49.779Z", "title": "The producers news", "type": ["title"], "url": "https://www.loc.gov/item/sn85053305/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013271996/"], "campaigns": [], "date": "1918", "dates": ["[1918 TO 1937]"], "description": ["Weekly Began April 19, 1918; ceased March 5, 1937. Advocate of various radical agarian organizations. Published as \"county edition,\" Nov. 27, 1931-Feb. 23, 1934. \"National edition\" during this period was the official organ of the United Farmers League. Official organ of: Farmers Holiday Association of Montana, Sept. 13, 1935-Mar. 5, 1937. Description based on: Volume I, number 2 (April 26, 1918); title from masthead (Chroniclingamerica.loc.gov, viewed January 23, 2014). Latest issue consulted: Volume V, no. 38 (December 29, 1922) (Chroniclingamerica.loc.gov, viewed January 23, 2014)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:24.080Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013271996/", "image_url": [], "index": 3, "language": ["english"], "location": ["montana", "sheridan", "plentywood", "united states"], "number": ["2013271996", "2026-04-13t21: