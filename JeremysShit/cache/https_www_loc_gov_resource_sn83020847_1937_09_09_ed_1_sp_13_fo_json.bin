 regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.332207, "shard": "07", "shelf_id": "sn83020847, 1937-09-09, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/mb", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "hampden", "united states", "massachusetts", "springfield", "springfield (mass.)"], "subject_headings": ["Springfield (Mass.)--Newspapers", "Massachusetts--Springfield", "United States--Massachusetts--Hampden--Springfield"], "subjects": [{"hampden": "https://www.loc.gov/search/?fa=subject:hampden&fo=json"}, {"massachusetts": "https://www.loc.gov/search/?fa=subject:massachusetts&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"springfield": "https://www.loc.gov/search/?fa=subject:springfield&fo=json"}, {"springfield (mass.)": "https://www.loc.gov/search/?fa=subject:springfield+%28mass.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2025-04-13T07:50:41.651Z", "title": "Springfield weekly Republican (Springfield, Mass.), September 9, 1937", "type": ["issue"], "url": "https://www.loc.gov/item/sn83020847/1937-09-09/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83020847/", "http://lccn.loc.gov/sn83020847", "https://search.catalog.loc.gov/instances/8e8bcd00-fc32-51bd-bb75-1a84b8c102b1"], "batch": ["mb_basil_ver01"], "campaigns": [], "date": "1851", "description": ["Weekly Began in 1851? -123rd year (Sept. 26, 1946). \"Weekly\" appears in masthead ornament. Republican v. 27, no 1397 (June 4, 1851)-v. 31, no 1588 (Feb. 3, 1855) called also Gazette v. 20, no. 23-v. 24, no. 5. Vol. 31, no. 6 (Feb. 10, 1855)-v. 40, no. 52 (Dec. 27, 1872) called also whole no. 1589-2547. Also issued on microfilm from the Library of Congress, Photoduplication Service. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Country ed.: Springfield weekly Republican (Springfield, Mass. : Country ed.), 1854-1859. Daily ed.: Daily Republican (Springfield, Mass.), <1851>. Triweekly ed.: Springfield tri-weekly Republican, 1860-1863. Semiweekly ed.: Springfield semi-weekly Republican, 1863-<1871>. Description based on: Vol. 27, no. 1397 (June 4, 1851)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:12.885Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-01", "catalog", "united-states-newspaper-directory", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/sn83020847/", "image_url": [], "index": 13, "language": ["english"], "latlong": [42.102051, -72.585757], "location": ["springfield", "hampden", "massachusetts", "united states"], "location_str": "", "lonlat": [-72.585757, 42.102051], "number": ["2025-07-01t13:40:47.400000", "pennsylvania hist & mus comn libr", "windsor hist soc", "boston pub libr", "kansas state hist soc, newsp proj", "simsbury hist soc", "huntington libr art gallery & gardens", "center for res libr, newsp proj", "onondaga hist asn libr", "new york hist soc, newsp proj", "http://www.loc.gov/item/sn83020847/1946-09-26/ed-1/", "knox col", "unspecified", "sn83020847", "univ of kentucky libr", "american antiquarian soc, newsp proj", "http://www.loc.gov/item/sn83020847/1855-02-10/ed-1/", "wisconsin hist soc, newsp proj", "trinity col", "state hist soc of missouri", "salmon brook hist soc", "9584529", "4712", "hartford pub libr", "harriet beecher stowe ctr", "2025-04-13t02:12:48.261152", "new york pub libr res libr", "microfilm master", "new york state libr", "western rsv hist soc, newsp proj", "sn85038277", "sn83020848", "lewis cnty hist soc", "rutgers univ, newsp proj", "online resource", "original", "sn83020852", "duke univ libr", "univ of texas at austin", "sn83020846", "pennsylvania sta