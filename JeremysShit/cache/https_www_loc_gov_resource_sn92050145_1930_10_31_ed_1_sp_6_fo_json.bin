nrrni Tin FROLIC lMllH I COMPANY 414 MAIN TK E E 7 LITTLE ROCK ARKANSAS See Atlas Whenever you need money to carry out your financial plans Clear up your potty accountsthe little amounts here and therewith a loan from Atlas Finance Company Have one easily paid loan instead of several that are hard to pay Read How Simple It"], "digitized": true, "extract_timestamp": "2025-01-19T03:38:45.315Z", "group": ["ndnp/arhi", "arkansas-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92050145/1930-10-31/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_dioptase_ver02:data:sn92050145:00516990351:1930103101:0733/full/pct:6.25/0/default.jpg#h=330&w=268", "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_dioptase_ver02:data:sn92050145:00516990351:1930103101:0733/full/pct:12.5/0/default.jpg#h=661&w=537", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_dioptase_ver02/data/sn92050145/00516990351/1930103101/0733.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["pulaski", "united states", "arkansas", "little rock"], "location_city": ["little rock"], "location_country": ["united states"], "location_county": ["pulaski"], "location_state": ["arkansas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0", "5", "sn92050145", "1", "6", "9", "0000000006"], "number_edition": ["1"], "number_lccn": ["sn92050145"], "number_page": ["0000000006"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "0", "3", "5", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "union labor bulletin (little rock, ark.) 191?-1957", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications