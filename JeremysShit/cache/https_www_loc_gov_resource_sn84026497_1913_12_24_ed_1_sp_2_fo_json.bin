vice/pnp/mrg/02200/02296v.jpg#h=701&w=1024"], "index": 4, "language": ["english"], "location": ["mississippi", "forest", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/mrg2017002294", "2017704409", "2020-07-28t07:25:55", "http://www.loc.gov/item/19674467", "http://www.loc.gov/item/2017704409", "sheet"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["john margolies roadside america photograph archive", "prints and photographs division", "prints & photographs online catalog (library of congress)", "catalog"], "score": 16.372332, "shelf_id": "LC-MA05- 2296 [P&P]", "site": ["pictures", "catalog"], "subject": ["color", "signs (notices)", "slides", "forest", "united states", "ice cream & ices", "mississippi"], "timestamp": "2023-08-17T16:50:16.577Z", "title": "Tastee Freez Drive-Inn ice cream sign, Rt. 80, Forest, Mississippi", "type": ["still image"], "url": "https://www.loc.gov/item/2017704409/"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2004672607/", "http://www.loc.gov/item/2004672607/", "http://www.loc.gov/pictures/item/2004672607/", "https://www.loc.gov/pictures/collection/cph/item/2004672607/", "http://www.loc.gov/pictures/collection/cph/item/2004672607/", "http://www.loc.gov/resource/cph.3a22737/", "https://hdl.loc.gov/loc.pnp/cph.3a22737", "http://lccn.loc.gov/2004672607"], "campaigns": [], "contributor": ["bradford, william"], "date": "1765-01-01", "dates": ["1765"], "description": ["1 print : woodcut. | Print shows the masthead for The Pennsylvania Journal and Weekly Advertiser with a skull and crossbones representation of the official stamp required by the Stamp Act of 1765, \"An emblem of the effects of the STAMP - O! the fatal Stamp\", and a note about the times \"The TIMES are Dreadful, Dismal, Doleful, Dolorous, and Dollar-less.\" Includes statement by the publisher, William Bradford, \"I am sorry to be obliged to acquaint my Readers, that as the STAMP Act, is fear'd to be obligatory upon us after the First of November ensuing, (the fatal To morrow) the Publisher of this Paper unable to bear the Burthen, has thought it expedient to STOP awhile,....\""], "digitized": true, "extract_timestamp": "2021-08-26T01:49:57.769Z", "group": ["cph", "catalog-split-02", "catalog", "miscellaneous-items-high-demand", "main-catalog-split-02", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2004672607/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/cph/3a20000/3a22000/3a22700/3a22737_150px.jpg#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3a20000/3a22000/3a22700/3a22737t.gif#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3a20000/3a22000/3a22700/3a22737r.jpg#h=511&w=640"], "index": 5, "language": ["english"], "location": ["pennsylvania", "philadelphia", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2005-10-17t11:43:13", "http://www.loc.gov/item/13633584", "2004672607"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "microform reading room", "prints & photographs online catalog (library of congress)", "prints and photographs division", "miscellaneous items in high demand"], "score": 11.211847, "shelf_id": "Illus. in Newspaper [Microfilm RR]", "site": ["pictures", "catalog"], "subject": ["skull & crossbones", "philadelphia", "great britain", "revolution", "periodical illustrations", "pennsylvania", "newspapers", "united states", "stamp act (1765)", "history", "woodcuts", "causes"], "timestamp": "2022-05-02T00:55:16.951Z", "title": "The Pennsylvania journal and weekly advertiser - expiring: in hopes of a resurrection to life again", "url": "https://www.loc.gov/item/2004672607/"}, {"access_restricted": false, "aka": ["http://memory.loc.gov/cgi-bin/query/r?ammem/AMALL:@field(NUMBER+@band(rbpe+1440120a))", "http://www.loc.gov/item/rbpe.14401