1, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//mimtptc/batch_mimtptc_bath_ver01/data/sn92063852/00279551321/1958062801/1958062801_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn92063852/marcxml"}], "partof": [{"count": 1451, "title": "the detroit tribune (detroit, mich.) 1935-1966", "url": "https://www.loc.gov/search/?fa=partof:the+detroit+tribune+%28detroit,+mich.%29+1935-1966&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the detroit tribune (detroit, mich.) 1935-1966"], "place_of_publication": "Detroit, Mich.", "publication_frequency": ["weekly"], "raw_lccn": "sn 92063852 ", "reel_numbers": ["00279551321"], "resources": [{"files": 12, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mimtptc:batch_mimtptc_bath_ver01:data:sn92063852:00279551321:1958062801:0541/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn92063852/1958-06-28/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.017402, "shard": "02", "shelf_id": "sn92063852, 1958-06-28, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/mimtptc", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "wayne", "michigan", "wayne county (mich.)", "african american", "detroit (mich.)", "wayne county", "detroit", "united states", "african americans"], "subject_ethnicity": ["african american"], "subject_headings": ["African Americans--Michigan--Detroit--Newspapers", "Detroit (Mich.)--Newspapers", "Wayne County (Mich.)--Newspapers", "African Americans", "Michigan--Detroit", "Michigan--Wayne County", "United States--Michigan--Wayne--Detroit"], "subjects": [{"african american": "https://www.loc.gov/search/?fa=subject:african+american&fo=json"}, {"african americans": "https://www.loc.gov/search/?fa=subject:african+americans&fo=json"}, {"detroit": "https://www.loc.gov/search/?fa=subject:detroit&fo=json"}, {"detroit (mich.)": "https://www.loc.gov/search/?fa=subject:detroit+%28mich.%29&fo=json"}, {"michigan": "https://www.loc.gov/search/?fa=subject:michigan&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"wayne": "https://www.loc.gov/search/?fa=subject:wayne&fo=json"}, {"wayne county": "https://www.loc.gov/search/?fa=subject:wayne+county&fo=json"}, {"wayne county (mich.)": "https://www.loc.gov/search/?fa=subject:wayne+county+%28mich.%29&fo=json"}], "subjects_ethnicity": [{"african american": "https://www.loc.gov/search/?fa=subject_ethnicity:african+american&fo=json"}], "timestamp": "2024-01-17T00:32:03.923Z", "title": "The Detroit tribune (Detroit, Mich.), June 28, 1958", "type": ["issue"], "url": "https://www.loc.gov/item/sn92063852/1958-06-28/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn92063852/", "http://lccn.loc.gov/sn92063852"], "batch": ["mimtptc_albion_ver01"], "campaigns": [], "date": "1935", "description": ["Weekly Vol. 13, no. 26 (Sept. 14, 1935)- Ceased in 1966. Archived issues are available in digital format from the Library of Congress Chronicling America online collection."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:08.284Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-04", "catalog", "united-states-newspaper-directory", "main-catalog-split-04"], "hassegments": false, "id": "http://www.loc.gov/item/sn92063852/", "image_url": [], "index": 12, "language": ["english"], "latlong": [42.3329407, -83.0478365], "location": ["wayne", "michigan", "wayne county", "detroit", "united states"], "location_str": "", "lonlat": [-83.0478365, 42.3329407], "number": ["university of michigan", "1450", "2577-350x", "online resource", "26654010", "2025-06-25t14:25:13", "detroit public library", "http://www.loc.gov/item/sn92063852/1935-09-14/ed-1/", "1", "microfilm service copy", "sn92063852", "original", "sn96076588", "2024-01-10t18:39:57.321128", "library of michigan", "http://www.loc.gov/item/sn92063852/1963-12-28/ed-1/", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["catalog", "chronicling america", "the detroit tribune (detroit, mich.) 1935-1966", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 80.651184, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "wayne", "michigan", "wayne county (mich.)", "african american", "detroit (mich.)", "wayne county", "detroit", "united states", "african americans"], "timestamp": "2026-07-18T09:33:03.460Z", "title": "The Detroit tribune", "type": ["title"], "url": "https://www.loc.gov/item/sn92063852/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218642/"], "campaigns": [], "date": "1933", "dates": ["[1933 TO 1933]"], "description": ["Weekly Began with vol. XV, no. 21 (April 14, 1933); ceased with vol. XVI, no. 5 (Dec. 23, 1933). \"Independent.\" Cf. Ayer, 1967. \"Leading Negro weekly of Michigan.\" Merged with: Detroit independent, to form: Tribune independent of Michigan. Description based on: Vol. XV, no. 21 (April 14, 1933); title from masthead (Chroniclingamerica.loc.gov, viewed March 14, 2018). Latest issue consulted: Vol. XVI, no. 5 (Dec. 23, 1933) (Chroniclingamerica.loc.gov, viewed March 14, 2018). Detroit independent Tribune independent of Michigan 2577-2570 (DLC) 2018218643 (OCoLC)1028674923"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218642/", "image_url": [], "index": 13, "language": ["english"], "location": ["wayne", "michigan", "wayne county", "detroit", "united states"], "number": ["1028641252", "online resource", "2018218643", "2577-2546", "2018218642", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "detroit tribune (detroit, michigan) 1933-1933 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 71.443794, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "wayne", "michigan", "wayne county (mich.)", "african american", "detroit (mich.)", "wayne county", "race relations", "detroit", "united states", "african americans"], "timestamp": "2026-05-26T20:56:09.337Z", "title": "Detroit tribune", "type": ["title"], "url": "https://www.loc.gov/item/2018218642/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218643/"], "campaigns": [], "date": "1933", "dates": ["[1933 TO 1935]"], "description": ["Weekly Began with [volume XI], no. 38 (December 30, 1933); ceased with volume XIII, no. 25 (Sept. 7, 1935). \"On guard for Negro rights.\" Publisher: Midwest Publishing Company, Inc., <December 29, 1934>-September 7, 1935. Also available on microfilm from Xerox University Microfilms. Formed by the union of: Detroit tribune (Detroit, Mich. : 1933), and: Detroit independent. Description based on: [Volume XI], no. 38 (December 30, 1933); title from masthead (Chroniclingamerica.loc.gov, viewed March 14, 2018). Latest issue consulted: Volume XIII, no. 25 (Sept. 7, 1935) (Chroniclingamerica.loc.gov, viewed March 14, 2018). Detroit tribune (Detroit, Mich. : 1935) 2577-3518 (DLC) 2018218653 (OCoLC)1029203520"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218643/", "image_url": [], "index": 14, "language": ["english"], "location": ["wayne", "michigan", "wayne county", "detroit", "united states"], "number": ["1028674923", "online resource", "2018218653", "2577-2570", "2018218643", "2018218642", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Tribune independent"], "partof": ["the tribune in