mas and back than at any other time of the year There are a number of reasons for this For one thing the Christmas holiday season comes at a time of the year wdien there is more darkness and less daylight than during any other major holiday period of the year For another thing the Christmas holiday sea son is a long one extending un til after New Years Day Combined with weather con ditions which are often poor the long nights and the long holi day all"], "digitized": true, "extract_timestamp": "2023-07-03T13:47:58.016Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83004278/1957-12-19/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_ivy_ver01:data:sn83004278:00340581970:1957121901:0845/full/pct:6.25/0/default.jpg#h=461&w=352", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_ivy_ver01:data:sn83004278:00340581970:1957121901:0845/full/pct:12.5/0/default.jpg#h=923&w=705", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_ivy_ver01/data/sn83004278/00340581970/1957121901/0845.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["united states", "sidney", "montana", "richland"], "location_city": ["sidney"], "location_country": ["united states"], "location_county": ["richland"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "sn83004278", "1", "4", "8", "7", "0000000002", "9"], "number_edition": ["1"], "number_lccn": ["sn83004278"], "number_page": ["0000000002"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "1", "9", "7", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the sidney herald (sidney,