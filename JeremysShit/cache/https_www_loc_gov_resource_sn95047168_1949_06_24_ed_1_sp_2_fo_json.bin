"https://tile.loc.gov/storage-services/service/gmd/gmd393m/g3934m/g3934lm/g3934lm_g012931920/01293_1920-0001.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd393m/g3934m/g3934lm/g3934lm_g012931920/01293_1920-0001.gif#h=150&w=126", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd393m:g3934m:g3934lm:g3934lm_g012931920:01293_1920-0001/full/pct:12.5/0/default.jpg#h=956&w=806", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd393m:g3934m:g3934lm:g3934lm_g012931920:01293_1920-0001/full/pct:25/0/default.jpg#h=1912&w=1612"], "index": 3, "language": ["english"], "location": ["union county", "lake butler", "florida", "united states"], "mime_type": ["image/gif", "image/jpg", "image/jp2"], "number": ["2020-04-21t15:30:10"], "online_format": ["image"], "original_format": ["map"], "partof": ["sanborn maps", "geography and map division", "american memory"], "score": 16.972609, "shelf_id": "http://www.loc.gov/item/sanborn01293_002/", "site": ["ammem"], "timestamp": "2024-10-08T18:25:01.677Z", "title": "Sanborn Fire Insurance Map from Lake Butler, Union County, Florida.", "type": ["cartographic"], "url": "https://www.loc.gov/item/sanborn01293_002/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2012593682", "http://www.loc.gov/item/2012593682/", "https://search.catalog.loc.gov/instances/33079130-4e0c-5c50-ba82-8ccdbe2512c4", "https://hdl.loc.gov/loc.gmd/g3813u.la000467", "http://www.loc.gov/resource/g3813u.la000467/"], "campaigns": [], "contributor": ["crane, w. t.", "b. westermann & co", "witzel, p.", "meyer, ernest l."], "date": "1862", "dates": ["1862"], "description": ["General-content map showing built-up areas, urban buildings, rural buildings with occupants' names, extant/planned streets, woods, orchards, and marshes. Relief shown by hachures. Hand colored (watercolors) to emphasize township boundaries and territories. \"Orders for maps to be addressed to Ernest L. Meyer, City Surveyor, Elizabeth, N.J., or B. Westermann & Co., 440 Broadway, N.Y.\" \"Entered according to Act of Congress in the year 1861 by Ernest L. Meyer & P. Witzel in the ... Southern District of New York.\" Originally printed on 2 or 4 sheets (as wall map?) which may or may not correspond with the present fold lines. LC copy imperfect: Brittle, darkened, mounted on cloth backing, quartered to enable folding, missing small internal sections along fold lines, missing long strips of part of the illustrations along the lower and right-hand edges. Includes notes, statistical tables, embellished border containing illustrations of prominent buildings (identified), 2 bar scales, and 2 landscape \"Views sketched from nature by W.T. Crane\". LC Land ownership maps, 467 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:21.800Z", "group": ["gmd.mar", "catalog-split-06", "catalog", "general-maps", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/2012593682/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd381/g3813/g3813u/la000467.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd381/g3813/g3813u/la000467.gif#h=150&w=205", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3813:g3813u:la000467/full/pct:12.5/0/default.jpg#h=1579&w=2156", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3813:g3813u:la000467/full/pct:25/0/default.jpg#h=3159&w=4313"], "index": 4, "language": ["english"], "location": ["union county", "united states", "new jersey"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2014-06-09t13:08:51", "sheet", "2025-06-07t06:08:15", "2012593682"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "county landownership maps", "geography and map division", "cultural landscapes"], "score": 14.3194065, "shelf_id": "G3813.U5 1862 .M4", "site": ["catalog"], "subject": ["union county", "united states", "topographic maps", "landowners", "maps", "union county (n.j.)", "new jersey"], "timestamp": "2026-04-29T16:07:16.015Z", "title": "Topographical map of Union County, New Jersey", "type": ["cartographic"], "url": "https://www.loc.gov/item/2012593682/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2012592213", "http://www.loc.gov/item/2012592213/", "https://search.catalog.loc.gov/instances/253682fd-5a00-53f2-9213-82ed3aa4717f", "https://hdl.loc.gov/loc.gmd/g3823u.la000802a", "http://www.loc.gov/resource/g3823u.la000802a/", "https://hdl.loc.gov/loc.gmd/g3823u.la000802b", "http://www.loc.gov/resource/g3823u.la000802b/"], "campaigns": [], "contributor": ["camp, john henry", "leonhardt, theo. (theodore)", "paschall, thomas h.", "keily, james"], "date": "1856", "dates": ["1856"], "description": ["General-content county map also showing rural houses/buildings with householders' names. Relief shown by hachures. Shows road distances in perches. Hand col. to emphasize township boundaries. Originally printed on 2 sheets (now conjoined by cloth backing). Includes note, key to abbreviations, and ill. Borough/village insets showing lot lines, lot numbers, and buildings: Lewisburg -- Hartleton -- New Columbia -- Mifflinburg -- New Berlin. LC Land ownership maps, 802 Available also through the Library of Congress Web site as a raster image. 2 copies"], "digitized": true, "extract_timestamp": "2026-04-29T15:39:16.585Z", "group": ["gmd.mar", "catalog-split-11", "catalog", "general-maps", "main-catalog-split-11"], "hassegments": false, "id": "http://www.loc.gov/item/2012592213/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd382/g3823/g3823u/la000802a.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd382/g3823/g3823u/la000802a.gif#h=150&w=206", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd382:g3823:g3823u:la000802a/full/pct:12.5/0/default.jpg#h=1091&w=1501", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd382:g3823:g3823u:la0