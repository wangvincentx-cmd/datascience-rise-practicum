c Photographer The POWDER KEG receives Camp Newspaper Service Material What Are Your PostWar Plans7 Approximately twentyfive people on the Depot were asked this question this week What are your postwar plans With hut few exceptions the answer was the same If we lose our jobs here we dont have any plans It would seem that this is rather startling when you consider the fact that most people either experienced or know of the after math of World War I which brought inflation failures and suffering Then too there are many who know what it means to be without a job and its accompanying hardships"], "digitized": true, "extract_timestamp": "2025-12-01T12:37:51.978Z", "group": ["ndnp/nbu", "university-of-nebraska-of-nebraska-lincoln-libraries-lincoln-ne-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/2023271000/1945-08-24/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_bluejay_ver02:data:2023271000:0051701414A:1945082401:0649/full/pct:12.5/0/default.jpg#h=430&w=329", "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_bluejay_ver02:data:2023271000:0051701414A:1945082401:0649/full/pct:25/0/default.jpg#h=860&w=658", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_bluejay_ver02/data/2023271000/0051701414A/1945082401/0649.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["nebraska", "hastings", "united states", "adams"], "location_city": ["hastings"], "location_country": ["united states"], "location_county": ["adams"], "location_state": ["nebraska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "2023271000", "1", "4", "a", "0000000002", "7"], "number_edition": ["1"], "number_lccn": ["2023271000"], "number_page": ["0000000002"], "number_reel": ["0", "0", "5", "1", "7", "0", "1", "4", "1", "4", "a"], "online_format": ["image", "pdf