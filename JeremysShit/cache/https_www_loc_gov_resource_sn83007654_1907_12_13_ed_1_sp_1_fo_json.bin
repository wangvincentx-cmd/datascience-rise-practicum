per sent to his address Mr and Mrs H S Cuplin of Iowa Falls Iowa arrived Wednesday and will probably make Springdale their home A daughter was born to Mr and Mrs H E Bennet residing near the grammar school building on Tuesday night of last week The News will cheerfully ac cord space to all local ministers j for any announcements"], "digitized": true, "extract_timestamp": "2024-12-02T18:27:31.904Z", "group": ["ndnp/arhi", "arkansas-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83007654/1907-12-13/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_coldplay_ver02:data:sn83007654:00393342778:1907121301:0211/full/pct:6.25/0/default.jpg#h=476&w=327", "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_coldplay_ver02:data:sn83007654:00393342778:1907121301:0211/full/pct:12.5/0/default.jpg#h=953&w=655", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_coldplay_ver02/data/sn83007654/00393342778/1907121301/0211.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["washington", "arkansas", "united states", "springdale"], "location_city": ["springdale"], "location_country": ["united states"], "location_county": ["washington"], "location_state": ["arkansas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0000000001", "0", "3", "9", "8", "7", "1", "4", "sn83007654"], "number_edition": ["1"], "number_lccn": ["sn83007654"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "9", "3", "3", "4", "2", "7", "7", "8"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Springdale twice-a-week news", "Springdale semi-weekly news", "Springdale Sunday news"], "partof": ["chronicling america", "serial and government publications division", "the springdale news (springda