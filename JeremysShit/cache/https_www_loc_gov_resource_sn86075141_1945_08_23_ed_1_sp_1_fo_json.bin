lto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075141:00340582044:1945082301:0720/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075141/00340582044/1945082301/0720.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn86075141/1945-08-23/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075141/00340582044/1945082301/0720.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86075141/1945-08-23/ed-1/?sp=1"], "batch": ["mthi_horsetail_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/silver bow/", "3/united states/montana/silver bow/butte/"], "contributor": ["montana historical society; helena, mt"], "date": "1945-08-23", "dates": ["1945-08-23"], "description": ["fij Montana Labor New 4 VOL BEND YOUR GET IN ON THE MIGHTY V G SEVENTH IVAR LOAN MONEY THEY GIVE THEIR LIVES V HEIJP SPEED VICTORY PUBLISHED WEEKLY IN THE INTERESTS OF ORGANIZED LABOR d vvvv v v vvv BUTTE MONTANA THURSDAY AUGUST 25 1945 XXI No 25 VETERAN GETS FINANCIAL AID TO RUN HATCHERY ST IGNATIUS Aug 22Harold S Otter 37 exair corps mechanic should be the envy of every fisherman in Mon tana because he not only literally iwades in rainbow trout on his 53acre com mercial fish hatchery located four and onehalf miles north of here but he can dip a fly into Post creek bordering his place and catch his limit any day Through the veterans selfemployed readjustment allowance setup which is administered by the Montana unemploy ment compensation commission for the veterans administration Otter will be able to maintain himself for at least one year until his new venture a business of his own begins to produce rainbow trout for commercial consumption I am happy to say that through the selfemployed allowance I am receiving each month I will be able to live until my hatchery starts producing on a vol ume basis Otter"], "digitized": true, "extract_timestamp": "2023-07-03T13:47:32.325Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075141/1945-08-23/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075141:00340582044:1945082301:0720/full/pct:6.25/0/default.jpg#h=420&w=301", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075141:00340582044:1945082301:0720/full/pct:12.5/0/default.jpg#h=840&w=602", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075141/00340582044/1945082301/0720.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["butte", "montana", "united states", "silver bow"], "location_city": ["butte"], "location_country": ["united states"], "location_county": ["silver bow"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "8", "3", "sn86075141", "4", "0000000001", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn86075141"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "2", "0", "4", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "montana labor news (butte, mont.) 19??-1951", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["montana labor news (butte, mont.) 19??-1951"], "publication_frequency": ["weekly"], "resources": [{"file