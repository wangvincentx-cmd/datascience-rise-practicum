labor"], "date": "19??", "description": ["Weekly -v. 27, no. 6 (Feb. 8, 1951). \"Published Weekly in the Interests of Organized Labor.\" Issues for Aug. 8 and Aug. 15, 1946 both called v. 22, no. 22; actually constitute no. 23 and no. 24. Issues for Aug. 23, 1946-Mar. 13, 1947 called v. 22, no. 24-52; actually constitute no. 25-53. Issue for Dec. 30, 1948 called v. 24, no. 41; actually constitutes no. 42. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Official organ of: Montana State Federation of Labor. Description based on: Vol. 8, no. 7 (Apr. 28, 1932)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:15.450Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-01", "catalog", "united-states-newspaper-directory", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/sn86075141/", "image_url": [], "index": 1, "language": ["english"], "latlong": [46.01284, -112.535583], "location": ["butte", "montana", "united states", "silver bow"], "location_str": "", "lonlat": [-112.535583, 46.01284], "number": ["montana hist soc libr", "2025-09-22t11:57:52.200000", "microfilm master", "sn86075141", "original", "duke univ libr", "2831-4573", "http://www.loc.gov/item/sn86075141/1932-04-28/ed-1/", "13472012", "2026-04-13t21:30:13", "http://www.loc.gov/item/sn86075141/1951-02-08/ed-1/", "2025-05-23t21:30:26", "772", "online resource", "1", "microfilm service copy"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "catalog", "montana labor news (butte, mont.) 19??-1951", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 47.043453, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["butte", "newspapers", "united states", "montana", "silver bow", "butte (mont.)"], "timestamp": "2026-07-18T09:20:06.081Z", "title": "M