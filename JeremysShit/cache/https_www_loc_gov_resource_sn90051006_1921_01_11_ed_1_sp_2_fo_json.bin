d_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/cohi/batch_cohi_baldwin_ver01/data/sn90051006/00414214332/1921011101/0748.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn90051006/1921-01-11/ed-1/?sp=2"], "batch": ["cohi_baldwin_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/colorado/", "2/united states/colorado/clear creek/", "3/united states/colorado/clear creek/idaho springs/"], "contributor": ["history colorado"], "date": "1921-01-11", "dates": ["1921-01-11"], "description": ["The Idaho Springs SiftingsNews Published Every Tuesday and Friday Lee H Hoffman and Mrs Bertha C Hoffman Editors Entered as secondclass matter June 3 1905 at the ostofflce In Idaho Springs Colorado under the Act of Congress of March 3 1879 Official Paper of Clear Creek County Subscription 0300 Per Year Prosperity Ahead There is much comfort to be bad from the statement recently of Judge Elbert H Gary head of the United States Steel corporation the greatest business concern the world has ever produced Judge Gary says a loug period of wonderful prosperity is just ahead of the people of the United States When he opens his mouth he is in the habit of saying some thing and never says a thing un less he knows what he is talking about He has been a wise prophet in the past because he possesses the ability to read conditions and pos sibilities as they are There is no reason why his prophesy should not be one of wisdom in this case because there is no reason why we should not prosper and every rea son why we should Banks and financiers generally state that we have passed thru our worst"], "digitized": true, "extract_timestamp": "2023-12-27T15:50:58.716Z", "group": ["ndnp/cohi", "history-colorado-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn90051006/1921-01-11/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_baldwin_ver01:data:sn90051006:00414214332:1921011101:0748/full/pct:6.25/0/default.jpg#h=305&w=225", "https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_baldwin_ver01:data:sn90051006:00414214332:1921011101:0748/full/pct:12.5/0/default.jpg#h=611&w=450", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/cohi/batch_cohi_baldwin_ver01/data/sn90051006/00414214332/1921011101/0748.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["clear creek", "colorado", "idaho springs", "united states", "clear creek county"], "location_city": ["idaho springs"], "location_country": ["united states"], "location_county": ["clear creek"], "location_state": ["colorado"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0", "2", "1", "4", "0000000002", "sn90051006"], "number_edition": ["1"], "number_lccn": ["sn90051006"], "number_page": ["0000000002"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "4", "3", "3", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the idaho springs siftings-news (idaho springs, colo.) 1905-19??"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the idaho springs siftings-news (idaho springs, colo.) 1905-19??"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn90051006/1921-01-11/ed-1/?sp=2"}], "segmentof": ["http://www.loc.gov/resource/sn90051006/1921-01-11/ed-1/"], "shelf_id": "2", "site": ["chroniclingamerica"], "subject": ["clear creek county (colo.)", "clear creek", "colorado", "idaho springs", "idaho springs (colo.)", "united states", "newspapers", "clear creek county"], "timestamp": "2023-12-28T00:56:07.378Z", "title"