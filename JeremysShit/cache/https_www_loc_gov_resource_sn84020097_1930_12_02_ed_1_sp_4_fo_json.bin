ous Issue", "url": "https://www.loc.gov/resource/sn84020097/1930-12-01/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/mm2022086540", "http://www.loc.gov/item/mm2022086540/", "https://openn.library.upenn.edu/Data/0007/html/SCMS0142.html"], "campaigns": [], "contributor": ["mcalpine, william j. (william jarvis)"], "description": ["Letterbooks containing correspondence, memoranda, interim and final project reports, construction diagrams, measurements and data sets, and cost and expense tabulations and reports.  Documents McAlpine's work as chief or consulting civil engineer on aqueduct, bridge, canal, and dry dock projects, primarily in New York State and Chicago, Illinois.  Projects include the Albany Water Works, Albany, New York; dry docks, Brooklyn Navy Yard (New York Naval Shipyard) Brooklyn, New York; Brooklyn Water Works, Brooklyn, New York; Chicago Water Works, Chicago, Illinois; Croton Aqueduct, New York; Erie Canal, New York; and the Harlem Bridge (Washington Bridge), New York, New York."], "digitized": true, "extract_timestamp": "2025-05-24T06:01:48.494Z", "group": ["catalog-split-07", "catalog", "main-catalog-split-07"], "hassegments": false, "id": "http://lccn.loc.gov/mm2022086540", "image_url": [], "index": 4, "language": ["english"], "location": ["albany", "washington bridge", "new york", "erie canal", "illinois", "croton aqueduct", "chicago"], "number": ["2025-05-22t15:10:13", "mm2022086540"], "original_format": ["manuscript/mixed material", "collection"], "other_title": ["William J. McAlpine papers"], "partof": ["catalog", "manuscript division"], "score": 27.3759, "shelf_id": "http://lccn.loc.gov/mm2022086540", "site": ["catalog"], "subject": ["albany", "bridges", "chicago (ill.)", "brooklyn (new york, n.y.)", "design and construction", "water-supply", "erie canal (n.y.)", "new york", "albany (n.y.)", "canals", "croton aqueduct (n.y.)", "new york naval shipyard", "illinois", "chicago", "dry docks", "waterworks", "new york (state)", "civil engineering", "washington bridge (new york, n.y.)", "water works", "aqueducts"], "timestamp": "2025-05-24T06:03:50.170Z", "title": "William J. McAlpine letterbooks, 1837-1861", "type": ["manuscript"], "url": "//lccn.loc.gov/mm2022086540"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2010651409/", "http://www.loc.gov/item/2010651409/", "http://www.loc.gov/pictures/item/2010651409/", "https://www.loc.gov/pictures/collection/cph/item/2010651409/", "http://www.loc.gov/pictures/collection/cph/item/2010651409/", "http://www.loc.gov/resource/ppmsca.25528/", "https://hdl.loc.gov/loc.pnp/ppmsca.25528", "http://lccn.loc.gov/2010651409"], "campaigns": [], "contributor": ["dalrymple, louis"], "date": "1901-05-15", "dates": ["1901-05-15", "1901"], "description": ["1 print : chromolithograph. | Illustration shows a large elderly colonial man labeled \"N.Y.\" sitting atop buildings on New York City's waterfront, strings attached to his fingers extend to ships at dock and beyond, presumably to overseas connections. In the background is a small figure labeled \"Neptune\" holding a trident and standing on Chicago's waterfront area, with a sign stating \"Chicago 1000 miles to the sea\" and with factories spewing thick black smoke."], "digitized": true, "extract_timestamp": "2021-08-24T23:50:47.902Z", "group": ["cph", "catalog-split-12", "catalog", "miscellaneous-items-high-demand", "main-catalog-split-12", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2010651409/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528_150px.jpg#h=150&w=116", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528t.gif#h=150&w=116", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528r.jpg#h=640&w=494", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528v.jpg#h=1024&w=790"], "index": 5, "language": ["english"], "location": ["new york city", "illinois", "new york", "chicago"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/16506129", "2010-10-18t08:12:10", "2010651409"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "miscellaneous items in high demand", "prints & photographs online catalog (library of congress)", "prints and photographs division"], "score": 25.966146, "shelf_id": "Illus. in AP101.P7 1901 (Case X) [P&P]", "site": ["pictures", "catalog"], "subject": ["new york", "cartoons (commentary)", "periodical illustrations", "new york (state)", "chicago (ill.)", "tridents", "new york (n.y.)", "magazine covers", "shipping", "chromolithographs", "symbolic representation", "color"], "timestamp": "2022-05-02T05:35:51.632Z", "title": "The Chicago Neptune", "url": "https://www.loc.gov/item/2010651409/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/afc2011062.afc2011062_00387_ms01/", "http://www.loc.gov/item/2017655527/", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr01", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_ph/", "http://lccn.loc.gov/2017655527", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr02", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr03", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr01/", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr02/", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr03/"], "campaigns": [], "contributor": ["occupational folklife project", "keane, jimmy", "halker, bucky"], "date": "2013-01-01", "dates": ["2013"], "description": ["James \"Jimmy\" Keane, a prominent figure on the Irish music scene in Chicago and Ireland, discusses his career as an iron worker and member of Local 1 of the Iron Workers International Union. Keane, who was injured after ten years in the trade, then turned to music and selling real estate as a career. Keane's father, Jimmy \"Horse\" Keane, was a Local 1 member killed on the job in Chicago. Jimmy's three brothers also work in the iron trade. Jimmy Keane also discusses the music scene and the role of unions in America."], "digitized": true, "extract_timestamp": "2020-09-20T12:15:20.851Z", "group": ["afc/2011062", "catalog-split-08", "catalog", "iron-workers", "main-catalog-split-08", "main-catalog"], "hassegments": true, "id": "http://www.loc.gov/item/2017655527/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2011062/afc2011062_00387/afc2011062_00387_ph/afc2011062_00387_ph01.gif", "https://tile.loc.gov/storage-services/service/afc/afc2011062/afc2011062_00387/afc2011062_00387_ph/afc2011062_00387_ph01.gif#h=150&w=227", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:12.5/0/default.jpg#h=249&w=378", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:25/0/default.jpg#h=499&w=756", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:50/0/default.jpg#h=999&w=1512", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:100/0/default.jpg#h=1998&w=3024"], "index": 6, "language": ["english"], "location": ["middle west", "illinois", "chicago"], "mime_type": ["image/jpeg", "image/jp2", "audio/mp3", "image/gif", "audio/wav", "application/pdf", "application/x-audio"], "number": ["online resource", "2018-10-24t17:32:53", "2017655527"], "online_format": ["image", "audio", "pdf"], "original_format": ["sound recording"], "partof": ["occupational folklife project", "american folklife center", "catalog", "cultural traditions of ironworkers in america's upper midwest"], "score": 25.196415, "shelf_id": "http://lccn.loc.gov/2017655527", "site": ["catalog"], "subject": ["social life and customs", "wages", "interviews", "professional associations", "personal narratives", "chicago (ill.)", "irish american labor union members", "apprenticeship programs", "ironwork", "music", "irish americans", "work environment", "corporations", "work and family", "event place", "training of", "hazardous occupations", "labor contract", "interviews (sound recordings)", "iron and steel workers", "oral histories", "keane, jimmy", "employees", "illinois", "labor unions", "chicago", "middle west", "employee rights", "color", "industrial relations", "humor in the workplace", "industrial safety", "songs", "manners and customs", "blue collar workers", "self-employed", "digital photographs"], "timestamp": "2022-04-27T11:35:06.573Z", "title": "James Robert Keane interview conducted by Clark Douglas Halker, 2013-01-13.", "url": "https://www.loc.gov/item/2017655527/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/mm77035121", "http://www.loc.gov/item/mm77035121/", "https://hdl.loc.gov/loc.mss/collmss.ms000067"], "campaigns": [], "contributor": ["olmsted, frederick law", "olmsted, john", "olmsted, gideon"], "description": ["Correspondence, letterbooks, journals, drafts of articles and books, speeches and lectures, biographical and genealogical data, business papers, legal and financial papers, scrapbooks, printed material, maps, drawings, and other papers encompassing Olmsted's career and private life. The papers focus on Olmsted's career as a landscape architect, specifically as a designer of parks and the grounds of private estates and public buildings and as a city and regional planner.  Includes material pertaining to his designs chiefly of Central Park in New York, N.Y., of the area surrounding Niagara Falls, N.Y., of the U.S. Capitol grounds, Washington, D.C., and of the grounds of the World's Columbian Exposition, Chicago, Ill., 1893.  Material pertains, in part, to work undertaken by Olmsted and the firms of Olmsted and Vaux (1858), Frederick Law Olmsted (1858-1884), F.L. and J.C. Olmsted (1884-1889), F.L. Olmsted and Company (1889-1893), Olmsted, Olmsted, and Eliot (1893-1897), F.L. and J.C. Olmsted (1897-1898), and Olmsted Brothers (1898-1961).  Also documents Olmsted's writings, his investigation of slavery in the South (1850s), his role as general secretary of the U.S. Sanitary Commission during the Civil War, and his work as superintendent of John C. Fre\u0301mont's gold mining estates in Mariposa, Calif. Olmsted family papers include a journal and other papers of Gideon Olmsted documenting his adventures as a privateer during the Revolutionary war; journals kept by Frederick Law Olmsted's father, John, recording activities of the Olmsted family as well as local and national events; and correspondence of John Olmsted (father), John Hull Olmsted (brother), Frederick Law Olmsted, Jr. (son), and John Charles Olmsted (nephew). Correspondents include Henry W. Bellows, Samuel Bowles, Charles Loring Brace, Daniel Hudson Burnham, H.W.S. Cleveland, George William Curtis, Charles A. Dana, Edwin Lawrence Godkin, A.H. Green, Edward Everett Hale, William James, Clarence King, Frederick John Kingsbury, Frederick Newman Knapp, Charles Follen McKim, Charles Eliot Norton, Whitelaw Reid, H.H. Richardson, Charles N. Riotte, Carl Schurz, George Templeton Strong, George Washington Vanderbilt, Calvert Vaux, Henry Villard, George E. Waring, Jr., and Katherine Prescott Wormeley."], "digitized": true, "extract_timestamp": "2025-05-25T06:00:47.553Z", "group": ["catalog-split-04", "catalog", "main-catalog-split-04"], "hassegments": false, "id": "http://lccn.loc.gov/mm77035121", "image_url": [], "index": 7, "language": ["english"], "location": ["ontario", "washington d.c.", "new york", "mariposa", "california", "united states", "niagara falls", "illinois", "central park", "southern states", "chicago"], "number": ["2025-05-23t09:59:54", "mm77035121"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["catalog", "manuscript division"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/mm77035121", "site": ["catalog"], "subject": ["strong, george templeton", "frederick law olmsted (firm)", "gold mines and mining", "henry hobson)", "bowles, samuel", "washington (d.c.)", "united states", "olmsted and vaux (firm)", "correspondence", "united states capitol (washington, d.c.)", "design and construction", "southern states", "burnham, daniel hudson", "mckim, charles follen", "hale, edward everett", "central park (new york, n.y.)", "health aspects", "mariposa", "olmsted, olmsted, and eliot", "parks", "knapp, frederick newman", "regional planning", "fr\u00e9mont, john charles", "exhibitions", "kingsbury, frederick john", "horace william shaler)", "wormeley, katherine prescott", "george edwin)", "naval operations", "niagara falls (n.y. and ont.)", "f.l. olmsted and company", "chicago, ill.)", "brace, charles loring", "civil war", "villard, henry", "schurz, carl", "landscape architecture", "new york", "curtis, george william", "charles anderson)", "olmsted family", "olmsted, frederick law", "olmsted, john hull", "f.l. and j.c. olmsted (firm)", "world's columbian exposition", "history", "privateering", "bellows, henry w.", "godkin, edwin lawrence", "cleveland, h. w. s.", "waring, george e.", "illinois", "18th century", "king, clarence", "chicago", "james, william", "united states sanitary commission", "gold discoveries", "green, a. h.", "reid, whitelaw", "richardson, h. h.", "olmsted brothers", "olmsted, john charles", "new york (state)", "california", "vaux, calvert", "mariposa (calif.)", "andrew haswell)", "revolution", "dana, charles a.", "vanderbilt, george washington", "norton, charles eliot", "city planning", "riotte, carl nicolaus", "henry whitney)", "slavery"], "timestamp": "2025-05-25T06:04:13.927Z", "title": "Frederick Law Olmsted papers, 1777-1952", "type": ["manuscript"], "url": "//lccn.loc.gov/mm77035121"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/mm79032243", "http://www.loc.gov/item/mm79032243/", "https://search.catalog.loc.gov/instances/738e29de-abad-5d65-9aa6-686dafcb6951", "https://link.gale.com/apps/collection/6DDT/SAS?u=loc_main&sid=SAS"], "campaigns": [], "contributor": ["mckim, charles follen"], "description": ["Correspondence, letterbooks, memoranda, diary transcript, notes, legal and financial records, sketches, drawings, photographs, and other papers relating chiefly to the firm of McKim, Mead, & White, New York, New York. Documents McKim's designs for the Boston Public Library and Symphony Hall, Boston, Mass.; Columbia University's Morningside Heights campus and the University Club, New York, New York; Rhode Island State House, Providence, Rhode Island; restoration of the White House, Washington, D.C.; and the World's Columbian Exposition, Chicago, Illinois, 1893. Also documents McKim's work on the U.S. Senate Commission for the Improvement of the District of Columbia concerned with the location and treatment of public buildings and grounds along the Mall and his membership on the Grant Memorial Commission. Includes material pertaining to McKim's membership in societies and clubs including the American Institute of Architects, the Century Club, and the University Club. Subjects include the development of American architecture, establishment of the American Academy in Rome, and efforts of abolitionists to provide aid for newly freed slaves in the years following the Civil War. Diary includes McKim's account of an 1863 walking tour with Francis Jackson Garrison and Wendell Phillips Garrison to the Gettysburg battlefield and other areas in eastern Pennsylvania. Family correspondents include McKim's daughter, Margaret McKim; his father, J. Miller M'Kim; and other family members. Other correspondents include Daniel Chester French, John La Farge, Francis Jackson Garrison, Wendell Phillips Garrison, William Lloyd Garrison, Francis Davis Millet, Charles Moore, H. Siddons Mowbray, Frederick Law Olmsted, and Augustus Saint-Gaudens."], "digitized": true, "extract_timestamp": "2026-05-27T11:39:20.039Z", "group": ["catalog-split-08", "catalog", "main-catalog-split-08"], "hassegments": false, "id": "http://lccn.loc.gov/mm79032243", "image_url": [], "index": 8, "language": ["english"], "location": ["italy", "washington d.c.", "new york", "pennsylvania", "rome", "rhode island", "united states", "the mall", "illinois", "boston", "massachusetts", "chicago", "gettysburg"], "number": ["mm79032243", "2026-05-26t17:44:12.600000"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["catalog", "manuscript division"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/mm79032243", "site": ["catalog"], "subject": ["architectural firms", "garrison, francis jackson", "mckim, mead, & white", "clubs", "architecture", "pennsylvania", "rhode island", "washington (d.c.)", "united states", "correspondence", "boston", "reconstruction (u.s. history,)", "french, daniel chester", "commission for the improvement of the district of columbia", "mowbray, h. siddons", "public buildings", "james miller)", "universities and colleges", "study and teaching", "american academy in rome", "rhode island state house (providence, r.i.)", "italy", "libraries", "parks", "congress", "white house (washington, d.c.)", "moore, charles", "saint-gaudens, augustus", "19th century", "exhibitions", "mall, the (washington, d.c.)", "chicago, ill.)", "university club (new york, n.y.)", "conservation and restoration", "civil war", "garrison, wendell phillips", "symphony hall (boston, mass.)", "new york", "olmsted, frederick law", "world's columbian exposition", "la farge, john", "african americans", "history", "garrison, william lloyd", "columbia university", "millet, francis davis", "illinois", "description and travel", "chicago", "senate", "m'kim, j. miller", "century club (new york, n.y.)", "music-halls", "american institute of architects", "gettysburg (pa.)", "capital and capitol", "mckim family", "new york (state)", "rome", "societies, etc", "grant memorial commission", "freed persons", "massachusetts", "boston public library", "mckim, margaret", "harry siddons)"], "timestamp": "2026-05-27T11:48:52.327Z", "title": "Charles Follen McKim papers, 1838-1929", "type": ["manuscript"], "url": "//lccn.loc.gov/mm79032243"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2023655343", "http://www.loc.gov/item/2023655343/", "https://search.catalog.loc.gov/instances/9cefb0b0-347c-5c42-8c28-443ae250a473", "https://hdl.loc.gov/loc.afc/collafc.afc2022012"], "campaigns": [], "contributor": ["harris, jamal m.", "scott k.", "yarbrough, decimus", "ishida, h. k.", "gilliam, gbari", "reyes, rose", "randolph, chris chosen", "ferreira, cody coflo", "melendez, miley", "valenzuela, lorena", "bobb, merlin", "sloan, ronnie", "parisi, dolores ninja", "parks, charles lee", "mendoza, juliet e.", "dj nativesun", "urban artistry", "kg superstar", "forman, kelli", "de clive-lowe, mark", "kumta, prem", "becquette, wyatt", "basa, ray", "chambers, marlon", "blondet, thomas", "stewart, wesley", "burns, rita jean kelly", "caballero, dan", "smith, jesse", "boyd, jaron", "creation global (dance group)", "dj paul howard", "kell-abrams, maya", "williams, wayne", "james, bradford", "dj underdog", "mendoza, rhonda", "lomelin, andrea", "gar\u00e7on, jeffery miyake-mugler", "ferreira, ami tsunami", "cummings, maren", "guerrero, jake", "dj gargamel", "lazee, ken", "daniels, tre", "joyner, michael", "huggins, kimyon", "joyner, sherri", "kenlo key", "pause eddie", "blancaflor, cynthia", "dunnington, geno", "neff, ad\u00e9 e.", "d.j. slugo", "morris, oji", "guerrero, noah", "grant, arnez", "benedetti, cristina", "george-wheeler, hannah", "creative netwerk (organization)", "prosper, d. (derick)", "twan-twan", "riddick, will (william keith)", "liao, leslie", "ultra nat\u00e9", "johnson, sire dhone", "huff, ricki", "andrew w. mellon foundation", "brickhouse, junious", "american folklife center", "hall, rama mahesh", "sarakul, ryan", "nouri, farid", "pel\u00e1ez sordo, claudio", "torrence, kim", "dozier, brandon marcelas", "kirk, wayne weezy", "carter chu, eric", "eddy, john f.", "feliciano, frankie", "croshaw, ren (lauren lucia)", "simon, morgan", "harris, isaac crossfire", "paulos, angelo jiwa", "hlinkov\u00e1, michaela", "vaca, jos\u00e9", "kosmik", "tate, jay jay", "rp boo", "haynes, jeremiah supaman", "belle, jonathan", "garcia, leyda", "foaad, leigh", "battle, shadawn", "malapit, michael", "verdoodt, vanessa neva", "woods, tyrone", "lopez, jackie", "sugiyama, emiko"], "date": "1994", "dates": ["1994"], "description": ["\"Follow the Music: Exploring Multi-Linear Legacies of House Culture\" aims to expand upon the common narratives documenting a wider range of community voices that define the multi-linear legacies of House Music and Dance Cultures (HMDC). This collection documents the culture of Black and Brown urban communities through dance forms including Breakin', House, Hip Hop, Popping/Boogaloo, and locking. This includes oral histories documenting community voices in Washington, D.C.; Baltimore, Maryland; Chicago, Illinois; New York, New York; Los Angeles, California; and Oakland, California."], "digitized": true, "extract_timestamp": "2026-06-16T06:37:55.629Z", "group": ["catalog-split-01", "catalog", "main-catalog-split-01"], "hassegments": false, "id": "http://lccn.loc.gov/2023655343", "image_url": [], "index": 9, "language": ["english"], "location": ["washington d.c.", "new york", "los angeles", "california", "united states", "illinois", "maryland", "chicago", "oakland", "baltimore"], "number": ["2026-06-15t13:44:13.100000", "2023655343"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["american folklife center", "catalog"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/2023655343", "site": ["catalog"], "subject": ["interviews", "washington (d.c.)", "united states", "gay community", "oakland", "social aspects", "music and dance", "hip-hop", "ghetto house (music)", "electronic dance music", "new york", "oral histories", "los angeles", "gay culture", "illinois", "maryland", "chicago", "hip-hop dance", "baltimore", "color", "nightclubs", "video recordings", "california", "new york (state)", "voguing (dance)", "digital photographs", "house music"], "timestamp": "2026-06-16T07:09:11.517Z", "title": "Follow the Music : Exploring Multi-Linear Legacies of House Culture : Community Collections Grant Project, 1994-2023,", "type": ["manuscript"], "url": "//lccn.loc.gov/2023655343"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930120201/0588.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897664:1930120201:0585/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930120201/0588.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn84020097/1930-12-02/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930120201/0588.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897664:1930120201:0585/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930120201/0588.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn84020097/1930-12-02/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930120201/0588.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020097/1930-12-02/ed-1/?sp=4"], "batch": ["iune_fluorite_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/new york/", "2/united states/new york/new york/", "3/united states/new york/new york/new york/", "1/united states/illinois/", "2/united states/illinois/cook/", "3/united states/illinois/cook/chicago/"], "contributor": ["university of illinois at urbana-champaign library, urbana, il"], "date": "1930-12-02", "dates": ["1930-12-02"], "description": ["Page Four ST LOUIS CONVENTION ANSWERS SLANDER OF THE NEGRO MISLEADERS Further emphasis of the militancy of the Negro and white workers at the St Louis Convention of the League of Struggle for Ne gro Rights is contained in the two following speeches from the floor The Negro worker delegates to the convention utterly repudiated the slander of the Negro pettybourgeois mis leaders that the masses were apathetic are not ready for struggle etc Such slander is used merely for the purpose of excusing the treach By ARTHCR HALLBuffalo COMRADE Chairman and Fellow Delegates I think when we chose the new name The League of Struggle for Negro Rights we have chosen well and it should serve to give us the first chance of going on the offensive We have been fighting on the defensive and it is now time to go out on the offensive We not only came here to talk but to organize to fight This is the spirit in this convention I am sorry that condi tions made it impossible for me to get here earlier but I see that now we will be able to carry forward and build a fighting organization I have heard"], "digitized": true, "extract_timestamp": "2025-05-21T10:20:26.864Z", "group": ["ndnp/iune", "university-of-illinois-at-urbana-champaign-library-urbana-il-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020097/1930-12-02/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897664:1930120201:0588/full/pct:3.125/0/default.jpg#h=273&w=213", "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897664:1930120201:0588/full/pct:6.25/0/default.jpg#h=546&w=426", "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897664:1930120201:0588/full/pct:12.5/0/default.jpg#h=1093&w=852", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930120201/0588.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["new york", "united states", "new york city", "illinois", "cook", "chicago"], "location_city": ["new york", "chicago"], "location_country": ["united states"], "location_county": ["new york", "cook"], "location_state": ["new york", "illinois"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "8", "3", "0000000004", "4", "7", "6", "2", "1", "sn84020097"], "number_edition": ["1"], "number_lccn": ["sn84020097"], "number_page": ["0000000004"], "number_reel": ["0", "0", "3", "3", "2", "8", "9", "7", "6", "6", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the daily worker (chicago, ill.;new york, n.y.) 1924-1958", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the daily worker (chicago, ill.;new york, n.y.) 1924-1958"], "publication_frequency": ["daily"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn84020097/1930-12-02/ed-1/?sp=4"}], "segmentof": ["http://www.loc.gov/resource/sn84