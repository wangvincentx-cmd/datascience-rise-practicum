", "meeting of frontiers"], "score": 22.568964, "shelf_id": "LOT 11453-1, no. 734", "site": ["catalog", "pictures"], "subject": ["fishing industry", "petersburg", "salmon", "photographic prints", "united states", "hoisting machinery", "alaska"], "timestamp": "2022-11-29T20:00:33.583Z", "title": "[Loading boxes of salmon] Petersburg", "type": ["still image"], "url": "https://www.loc.gov/item/99615014/"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2007664630/", "http://www.loc.gov/item/2007664630/", "http://www.loc.gov/pictures/item/2007664630/", "https://www.loc.gov/pictures/collection/pan/item/2007664630/", "http://www.loc.gov/pictures/collection/pan/item/2007664630/", "https://hdl.loc.gov/loc.pnp/cph.3c15240", "https://hdl.loc.gov/loc.pnp/cph.3c15240", "https://hdl.loc.gov/loc.pnp/cph.3c15241", "https://hdl.loc.gov/loc.pnp/cph.3c15241", "https://hdl.loc.gov/loc.pnp/cph.3c15242", "https://hdl.loc.gov/loc.pnp/cph.3c15242", "http://www.loc.gov/resource/cph.3c15240/", "http://www.loc.gov/resource/cph.3c15241/", "http://www.loc.gov/resource/cph.3c15242/", "http://lccn.loc.gov/2007664630", "https://search.catalog.loc.gov/instances/a3de1641-66f9-5b15-8936-8d43217e19fd"], "campaigns": [], "contributor": ["sheelor, f. w."], "date": "1915", "dates": ["1915"], "description": ["1 photographic print : gelatin silver ; 9.5 x 48 in."], "digitized": true, "extract_timestamp": "2026-02-21T13:35:01.839Z", "group": ["pan", "catalog-split-02", "catalog", "panoramic-photographs", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/2007664630/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/cph/3c10000/3c15000/3c15200/3c15240_150px.jpg#h=118&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3c10000/3c15000/3c15200/3c15240t.gif#h=118&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3c10000/3c15000/3c15200/3c15240r.jpg#h=502&w=640", "https://tile.loc.gov/storage-services/service/pnp/cph/3c10000/3c15000/3c15200/3c15240v.jpg#h=804&w=1024"], "index": 5, "language": ["english"], "location": ["petersburg", "alaska", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["sheet", "2026-02-09t15:29:01.400000", "http://www.loc.gov/item/2007664630", "2007664630", "http://www.loc.gov/item/pan1994000021/pp", "online resource"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["panoramic photographs", "taking the long view: panoramic photographs, 1851-1991", "catalog", "prints and photographs division", "american memory"], "score": 22.568964, "shelf_id": "PAN US GEOG - Alaska no. 40 (F size) [P&P]", "site": ["pictures", "catalog"], "subject": ["petersburg", "panoramic photographs", "united states", "gelatin silver prints", "boats", "alaska", "piers & wharves"], "timestamp": "2026-02-21T13:35:41.295Z", "title": "[Petersburg, Alaska]", "type": ["still image"], "url": "https://www.loc.gov/item/2007664630/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021671113/", "https://hdl.loc.gov/loc.wdl/wdl.20913", "http://www.loc.gov/resource/wdl.20913/", "http://lccn.loc.gov/2021671113", "http://www.loc.gov/resource/gdcwdl.wdl_20913/"], "campaigns": [], "contributor": ["alaska engineering commission", "cohn, august"], "description": ["This image is from an album of 298 black-and-white photographs taken by August Cohn during his work with the Alaska Engineering Commission in 1915-17. Cohn was a civil engineer and surveyor who worked on the survey of the original site on which the town (and later city) of Anchorage was built. He also was involved in surveying and engineering work for many of the bridges that were constructed along the Alaska Railroad from Seward to Nenana. The photographs in the album focus on the Anchorage town site area, including images of construction, railroad buildings and equipment, Anchorage residents and their families, houses, cabins, and local businesses. Other locations that Cohn photographed and that are included in the album are Seldovia, Ketchikan, Petersburg, Juneau, Yakutat, and Seward in Alaska and Seattle, Washington. Cohn generally recorded the date, location, and subject of each photograph. The album was donated to the Anchorage Museum by Cohn's daughter, Helen Copeland, in 1997. It was digitized for the Meeting of Frontiers digital library project in the early 2000s."], "digitized": true, "extract_timestamp": "2021-10-12T16:32:07.781Z", "group": ["wdlpartner/batch/2", "catalog-split-08", "catalog", "world-digital-library-batch-2", "main-catalog-split-08", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2021671113/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:20:91:3:wdl_20913:amrc-cohn-page004-2/full/pct:6.25/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:20:91:3:wdl_20913:amrc-cohn-page004-2/full/pct:6.25/0/default.jpg#h=178&w=267", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:20:91:3:wdl_20913:amrc-cohn-page004-2/full/pct:12.5/0/default.jpg#h=356&w=534", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:20:91:3:wdl_20913:amrc-cohn-page004-2/full/pct:25/0/default.jpg#h=712&w=1069", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:20:91:3:wdl_20913:amrc-cohn-page004-2/full/pct:50/0/default.jpg#h=1425&w=2139", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:20:91:3:wdl_20913:amrc-cohn-page004-2/full/pct:100/0/default.jpg#h=2850&w=4279"], "index": 6, "language": ["english"], "location": ["petersburg", "alaska", "united states of america"], "mime_type": ["application/zip", "image/jpeg", "image/jp2"], "number": ["2021-10-05t17:00:29", "2021671113"], "online_format": ["compressed data", "image"], "original_format": ["photo, print, drawing"], "other_title": ["Petersburg, Alaska"], "partof": ["world digital library", "catalog", "anchorage museum", "world digital library - partner items", "meeting of frontiers"], "score": 21.352648, "shelf_id": "http://lccn.loc.gov/2021671113", "site": ["catalog"], "subject": ["petersburg", "expeditions and surveys", "united states of america", "settlements", "alaska", "construction"], "timestamp": "2022-03-30T12:28:20.767Z", "title": "Petersburg, Alaska, from the Water.", "url": "https://www.loc.gov/item/2021671113/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/gvhs01.vhs00038/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00038", "http://www.loc.gov/item/001-CABIB20002938/", "http://www.loc.gov/resource/gvhs01.vhs00038/"], "campaigns": [], "contributor": ["sneden, robert knox"], "description": ["The purpose of this map is uncertain; it may have been to identify the rail lines within the corridor between Fredericksburg and Petersburg.  Included (as phrased by Sneden) are the Richmond and Danville Railroad, Lynchburg Railroad, Norfolk and Petersburg Railroad, Virginia Central Railroad, and the Richmond Fredericksburg (Railroad).  A few key events in the entire war are indicated such as the surrender of Lee at Appomattox."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:09.205Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00038/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00038.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00038.gif#h=224&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00038/full/pct:12.5/0/default.jpg#h=686&w=460", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00038/full/pct:25/0/default.jpg#h=1372&w=921"], "index": 7, "language": ["english"], "location": ["petersburg", "confederate states of america", "richmond", "virginia", "appomattox", "united states", "fredericksburg"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2002-01-31t16:27:51"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "civil war maps", "geography and map division", "american memory"], "score": 14.534108, "shelf_id": "http://www.loc.gov/item/001-CABIB20002938/", "site": ["ammem"], "subject": ["railroads", "confederate states of america", "petersburg", "richmond", "richmond (va.)", "history", "virginia", "appomattox", "united states", "fredericksburg (va.)", "petersburg (va.)", "fredericksburg", "maps", "civil war", "appomattox (va.)"], "timestamp": "2022-03-30T06:52:22.796Z", "title": "Fredericksburg to Petersburg, Va.", "url": "https://www.loc.gov/item/gvhs01.vhs00038/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/001-CABIB20007938/", "http://www.loc.gov/item/gvhs01.vhs00289/", "http://www.loc.gov/resource/gvhs01.vhs00289/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00289"], "campaigns": [], "contributor": ["sneden, robert knox"], "description": ["Shows the area surrounding Petersburg on the Appomattox River with all major transportation lines noted. Union forces under Grant are opposed by Lee's Confederates. Five Forks is to the left of the image; Port Walthall to the upper right: Ream's Station is in the lower right; and Dinwiddie Court House is at the bottom center."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:39.301Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00289/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00289.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00289.gif#h=179&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00289/full/pct:12.5/0/default.jpg#h=450&w=376", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00289/full/pct:25/0/default.jpg#h=900&w=752"], "index": 8, "language": ["english"], "location": ["petersburg", "virginia", "united states"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-05-30t15:41:02"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "civil war maps", "geography and map division", "american memory"], "score": 14.534108, "shelf_id": "http://www.loc.gov/item/001-CABIB20007938/", "site": ["ammem"], "subject": ["petersburg", "history", "virginia", "united states", "petersburg (va.)", "siege", "siege warfare", "maps", "civil war"], "timestamp": "2022-03-30T06:52:52.845Z", "title": "The Investment of Petersburg, Va. Shewing [sic] battlefield of 5 Forks and Hatcher's Run, Friday March 31st, Saturday April 1st & Sunday April 2nd 1865.", "url": "https://www.loc.gov/item/gvhs01.vhs00289/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/001-CABIB20011402/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00186", "http://www.loc.gov/resource/gvhs01.vhs00186/", "http://www.loc.gov/item/gvhs01.vhs00186/"], "campaigns": [], "contributor": ["sneden, robert knox"], "date": "1865-01-01", "dates": ["1865"], "description": ["Map shows area surrounding Petersburg, Va., on the Appomattox River including all of the Union and Confederate fortifications during the siege of 1864-65 by Genl. Grant.  Details include locations of roads, railroads, significant buildings, and creeks.  Map extends to north as far as Fort Walthall, to west as far as Wells Church, to south as far as Reams Station, and to east as far as Fort. Pat Kelly."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:55.241Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00186/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00186.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00186.gif#h=180&w=150",