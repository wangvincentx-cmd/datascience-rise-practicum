tricted": false, "aka": ["http://lccn.loc.gov/2024642196", "http://www.loc.gov/item/2024642196/", "https://hdl.loc.gov/loc.pnp/highsm.72652", "http://www.loc.gov/resource/highsm.72652/"], "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2023", "dates": ["2023"], "description": ["No known restrictions on publication. Title, date, and keywords based on information provided by the photographer. It opened in 1965 and was built for $2,000,000.00. A key feature of the courthouse is the Great Seal Mottoes signifying strength, duration, and the eye of providence. Photographed as part of an assignment for the General Services Administration. Purchase; Carol M. Highsmith Photography, Inc.; 2023; (DLC/PP-2023:107). Forms part of Carol M. Highsmith's America Project in the Carol M. Highsmith Archive. Credit Line: Photographs in Carol M. Highsmith's America Project in the Carol M. Highsmith Archive, Library of Congress, Prints and Photographs Division."], "digitized": true, "extract_timestamp": "2025-01-01T06:47:07.610Z", "group": ["catalog-split-04", "catalog", "main-catalog-split-04"], "hassegments": false, "id": "http://lccn.loc.gov/2024642196", "image_url": [], "index": 2, "language": ["english"], "location": ["gainesville", "florida", "alachua county", "united states"], "number": ["2024642196", "online resource", "2024-12-30t14:11:19"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "prints and photographs division"], "score": 37.35985, "shelf_id": "LC-DIG-highsm- 72652", "site": ["catalog"], "subject": ["post offices", "america", "courthouses", "florida", "alachua county", "united states", "gainesville", "federal buildings", "digital photographs", "color", "gsa"], "timestamp": "2025-01-01T06:48:28.770Z", "title": "The Federal Courthouse in Gainesville serves as both a courthouse and a post office", "type": ["still image"], "url": "//lccn.loc.gov/2024642196"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/20246