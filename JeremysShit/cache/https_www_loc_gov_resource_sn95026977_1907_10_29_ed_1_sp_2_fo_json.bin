{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn95026977/?st=calendar", "cite_this": {"apa": "(1907, October 29)  <cite>Gainesville Daily Sun</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn95026977/1907-10-29/ed-1/.", "chicago": "<cite>Gainesville Daily Sun</cite>. (Gainesville, FL), Oct. 29 1907. https://www.loc.gov/item/sn95026977/1907-10-29/ed-1/.", "mla": "<cite>Gainesville Daily Sun</cite>. (Gainesville, FL) 29 Oct. 1907, p. 2. Retrieved from the Library of Congress, www.loc.gov/item/sn95026977/1907-10-29/ed-1/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_six_ver01/data/sn95026977/00175040419/1907102901/0227.xml&format=alto_xml&full_text=1", "item": {"_version_": 1855560849753636864, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn95026977/1907-10-29/ed-1/", "http://www.loc.gov/resource/sn95026977/1907-10-29/ed-1/"], "batch": ["fu_six_ver01"], "call_number": ["Newspaper"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/florida/", "2/united states/florida/alachua/", "3/united states/florida/alachua/gainesville/"], "contributor_names": ["University of Florida"], "contributors": [{"university of florida": "https://www.loc.gov/search/?fa=contributor:university+of+florida&fo=json"}], "created_published": ["Gainesville, Fla., October 29, 1907"], "date": "1907-10-29", "date_issued": "1907-10-29", "dates": [{"1907-10-29": "https://www.loc.gov/search/?dates=1907-10-29/1907-10-29&fo=json"}], "dates_of_publication": "190?-1938", "description": ["Gainesville, Fla."], "digital_id": ["https://www.loc.gov/chroniclingamerica/lccn/sn95026977/issues", "http://ufdc.ufl.edu/UF00028298"], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2026-01-27T17:03:13.580Z", "extract_urls": ["file:/service/ndnp//fu/batch_fu_six_ver01/data/sn95026977/00175040419/1907102901/1907102901_1.xml#ndnp/fu"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn95026977/1907-10-29/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_six_ver01:data:sn95026977:00175040419:1907102901:0225/full/pct:6.25/0/default.jpg#h=469&w=285", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_six_ver01:data:sn95026977:00175040419:1907102901:0225/full/pct:12.5/0/default.jpg#h=939&w=571"], "index": 2, "item": {"batch": ["fu_six_ver01"], "call_number": ["Newspaper"], "contributor_names": ["University of Florida"], "created_published": ["Gainesville, Fla., October 29, 1907"], "date": "190u", "date_issued": "1907-10-29", "dates": ["1907-10-29"], "digital_id": ["https://www.loc.gov/chroniclingamerica/lccn/sn95026977/issues", "http://ufdc.ufl.edu/UF00028298"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn95026977", "location": ["Gainesville (Fla.)", "Alachua County (Fla.)", "Florida--Alachua County", "Florida--Gainesville"], "medium": "8 pages", "newspaper_title": ["Gainesville daily sun"], "notes": ["Daily (except Saturday), -1938", "-58th year (July 24, 1938).", "Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection.", "Semiweekly ed.: Gainesville sun (Gainesville, Fla. : 1903), <1903-1918>.", "Description based on: Vol. 20, no. 48 (Apr. 5, 1903).", "Alachua County news (Gainesville, Fla. : 1934)", "Gainesville daily sun and the Alachua County news (DLC)sn 95026980 (OCoLC)1446270"], "other_formats": ["https://tile.loc.gov/storage-services/service/ndnp//fu/batch_fu_six_ver01/data/sn95026977/00175040419/1907102901/1907102901_1.xml", "http://lccn.loc.gov/sn95026977/marcxml"], "other_title": ["Daily sun", "Sun"], "place_of_publication": "Gainesville, Fla.", "raw_lccn": "sn 95026977 ", "reel_numbers": ["00175040419"], "source_group": "ndnp/fu", "subjects": ["Gainesville (Fla.)--Newspapers", "Alachua County (Fla.)--Newspapers", "Florida--Alachua County", "Florida--Gainesville", "United States--Florida--Alachua--Gainesville"], "summary": ["The Gainesville (FL) Daily Sun [LCCN: sn95026977] continued the Daily Sun [LCCN: sn95026976] beginning sometime in 1903. Exact dates are uncertain; mast-heads and catalog data suggest that for a brief time between 1903 and 1908 or 1918, the newspaper bore the title, the Gainesville (FL) Sun [LCCN: sn95026969]. It continued to be published in Gainesville, Florida. In 1938, the Gainesville Daily Sun merged with the Alachua County (FL) News [LCCN: sn96027436] to form the Gainesville Daily Sun and the Alachua County News [LCCN: sn95026980]. The Daily Sun and the Gainesville Daily Sun both were self-described as \"democratic\" papers. Gainesville Daily Sun, like its predecessor, was published daily, except Mondays, by Henry Hamilton McCreary. H.H. McCreary is one of the best researched of Florida's newspaper publishers; documentation is maintained by the Florida Historical Society. In brief, McCreary came from a well established southern family, with prominent relatives throughout his contemporary American South. Following the completion of a degree from the University of Kentucky, McCreary established himself as a newspaper editor at the age of twenty. Throughout his publishing career, he also rose to prominence as a politician in the Democratic Party, first as a City Councilman and later as a member of the State Assembly, re-elected several times. McCreary considered himself a staunch patriot. He fervently supported industrialization as a means of strengthening Florida and the Nation. McCreary's wife, born Irene Richardson, was well connected in Gainesville and northeast Florida's civic networks as well. She served, for a time, both as Vice President of the Florida Federation of Women's Clubs and president of the United Daughters of the Confederacy. Between 1903 and 1938, Gainesville's moderate phosphate, turpentine and tung oil industries made room for the industry that, today (ca. 2008) drives the Gainesville economy. In 1905, when the Florida Legislature sited the University of Florida, the State's college for men, in Gainesville, the city was known for its good drinking water and lack of other drink or activities that might get young men into trouble. The University offered its first classes in Gainesville in 1906, having relocated from its previous home in Ocala (FL). Along with its move, its mission had also changed, broadened from that of the East Florida Seminary that it had been. University population and offerings grew steadily over time. Women were admitted, albeit under limiting circumstances, for the first time in 1925. The University of Florida would not see its next growth spurt until after World War II. Gainesville, since 1854, has been the seat of Alachua County (FL) government.--E. Kesse, University of Florida Digital Library Center."], "title": "Gainesville daily sun (Gainesville, Fla.), October 29, 1907"}, "language": ["english"], "languages": [{"english": "https://www.loc.gov/search/?fa=language:english&fo=json"}], "library_of_congress_control_number": "sn95026977", "location": ["florida", "alachua county", "united states", "gainesville", "alachua"], "location_city": ["gainesville"], "location_country": ["united states"], "location_county": ["alachua"], "location_state": ["florida"], "locations": [{"alachua": "https://www.loc.gov/search/?fa=location:alachua&fo=json"}, {"alachua county": "https://www.loc.gov/search/?fa=location:alachua+county&fo=json"}, {"florida": "https://www.loc.gov/search/?fa=location:florida&fo=json"}, {"gainesville": "https://www.loc.gov/search/?fa=location:gainesville&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=location:united+states&fo=json"}], "locations_city": [{"gainesville": "https://www.loc.gov/search/?fa=location_city:gainesville&fo=json"}], "locations_country": [{"united states": "https://www.loc.gov/search/?fa=location_country:united+states&fo=json"}], "locations_county": [{"alachua": "https://www.loc.gov/search/?fa=location_county:alachua&fo=json"}], "locations_state": [{"florida": "https://www.loc.gov/search/?fa=location_state:florida&fo=json"}], "medium": "8 pages", "method": "mets_filesec", "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "newspaper_title": ["Gainesville daily sun"], "notes": ["Daily (except Saturday), -1938", "-58th year (July 24, 1938).", "Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection.", "Semiweekly ed.: Gainesville sun (Gainesville, Fla. : 1903), <1903-1918>.", "Description based on: Vol. 20, no. 48 (Apr. 5, 1903).", "Alachua County news (Gainesville, Fla. : 1934)", "Gainesville daily sun and the Alachua County news (DLC)sn 95026980 (OCoLC)1446270"], "number": ["00175040419", "sn95026977", "1"], "number_edition": ["1"], "number_lccn": ["sn95026977"], "number_reel": ["00175040419"], "numeric_shelf_id": 190710291, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//fu/batch_fu_six_ver01/data/sn95026977/00175040419/1907102901/1907102901_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn95026977/marcxml"}], "other_title": ["Daily sun", "Sun"], "partof": [{"count": 1585, "title": "gainesville daily sun (gainesville, fla.) 190?-1938", "url": "https://www.loc.gov/search/?fa=partof:gainesville+daily+sun+%28gainesville,+fla.%29+190%3F-1938&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["gainesville daily sun (gainesville, fla.) 190?-1938"], "place_of_publication": "Gainesville, Fla.", "publication_frequency": ["daily"], "raw_lccn": "sn 95026977 ", "reel_numbers": ["00175040419"], "resources": [{"files": 8, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_six_ver01:data:sn95026977:00175040419:1907102901:0225/full/pct:6.25/0/default.jpg", "url": "https://www.loc.gov/resource/sn95026977/1907-10-29/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.96732, "shard": "04", "shelf_id": "sn95026977, 1907-10-29, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/fu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "florida", "gainesville (fla.)", "alachua county", "united states", "gainesville", "alachua county (fla.)", "alachua"], "subject_headings": ["Gainesville (Fla.)--Newspapers", "Alachua County (Fla.)--Newspapers", "Florida--Alachua County", "Florida--Gainesville", "United States--Florida--Alachua--Gainesville"], "subjects": [{"alachua": "https://www.loc.gov/search/?fa=subject:alachua&fo=json"}, {"alachua county": "https://www.loc.gov/search/?fa=subject:alachua+county&fo=json"}, {"alachua county (fla.)": "https://www.loc.gov/search/?fa=subject:alachua+county+%28fla.%29&fo=json"}, {"florida": "https://www.loc.gov/search/?fa=subject:florida&fo=json"}, {"gainesville": "https://www.loc.gov/search/?fa=subject:gainesville&fo=json"}, {"gainesville (fla.)": "https://www.loc.gov/search/?fa=subject:gainesville+%28fla.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "summary": ["The Gainesville (FL) Daily Sun [LCCN: sn95026977] continued the Daily Sun [LCCN: sn95026976] beginning sometime in 1903. Exact dates are uncertain; mast-heads and catalog data suggest that for a brief time between 1903 and 1908 or 1918, the newspaper bore the title, the Gainesville (FL) Sun [LCCN: sn95026969]. It continued to be published in Gainesville, Florida. In 1938, the Gainesville Daily Sun merged with the Alachua County (FL) News [LCCN: sn96027436] to form the Gainesville Daily Sun and the Alachua County News [LCCN: sn95026980]. The Daily Sun and the Gainesville Daily Sun both were self-described as \"democratic\" papers. Gainesville Daily Sun, like its predecessor, was published daily, except Mondays, by Henry Hamilton McCreary. H.H. McCreary is one of the best researched of Florida's newspaper publishers; documentation is maintained by the Florida Historical Society. In brief, McCreary came from a well established southern family, with prominent relatives throughout his contemporary American South. Following the completion of a degree from the University of Kentucky, McCreary established himself as a newspaper editor at the age of twenty. Throughout his publishing career, he also rose to prominence as a politician in the Democratic Party, first as a City Councilman and later as a member of the State Assembly, re-elected several times. McCreary considered himself a staunch patriot. He fervently supported industrialization as a means of strengthening Florida and the Nation. McCreary's wife, born Irene Richardson, was well connected in Gainesville and northeast Florida's civic networks as well. She served, for a time, both as Vice President of the Florida Federation of Women's Clubs and president of the United Daughters of the Confederacy. Between 1903 and 1938, Gainesville's moderate phosphate, turpentine and tung oil industries made room for the industry that, today (ca. 2008) drives the Gainesville economy. In 1905, when the Florida Legislature sited the University of Florida, the State's college for men, in Gainesville, the city was known for its good drinking water and lack of other drink or activities that might get young men into trouble. The University offered its first classes in Gainesville in 1906, having relocated from its previous home in Ocala (FL). Along with its move, its mission had also changed, broadened from that of the East Florida Seminary that it had been. University population and offerings grew steadily over time. Women were admitted, albeit under limiting circumstances, for the first time in 1925. The University of Florida would not see its next growth spurt until after World War II. Gainesville, since 1854, has been the seat of Alachua County (FL) government.--E. Kesse, University of Florida Digital Library Center."], "timestamp": "2026-01-28T11:45:21.094Z", "title": "Gainesville daily sun (Gainesville, Fla.), October 29, 1907", "type": ["issue"], "url": "https://www.loc.gov/item/sn95026977/1907-10-29/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95026977/", "http://lccn.loc.gov/sn95026977", "https://search.catalog.loc.gov/instances/6b1c4de6-292e-5480-a4c0-9800b983f8c6"], "batch": ["fu_eight_ver01"], "campaigns": [], "date": "190?", "description": ["The Gainesville (FL) Daily Sun [LCCN: sn95026977] continued the Daily Sun [LCCN: sn95026976] beginning sometime in 1903. Exact dates are uncertain; mast-heads and catalog data suggest that for a brief time between 1903 and 1908 or 1918, the newspaper bore the title, the Gainesville (FL) Sun [LCCN: sn95026969]. It continued to be published in Gainesville, Florida. In 1938, the Gainesville Daily Sun merged with the Alachua County (FL) News [LCCN: sn96027436] to form the Gainesville Daily Sun and the Alachua County News [LCCN: sn95026980]. The Daily Sun and the Gainesville Daily Sun both were self-described as \"democratic\" papers. Gainesville Daily Sun, like its predecessor, was published daily, except Mondays, by Henry Hamilton McCreary. H.H. McCreary is one of the best researched of Florida's newspaper publishers; documentation is maintained by the Florida Historical Society. In brief, McCreary came from a well established southern family, with prominent relatives throughout his contemporary American South. Following the completion of a degree from the University of Kentucky, McCreary established himself as a newspaper editor at the age of twenty. Throughout his publishing career, he also rose to prominence as a politician in the Democratic Party, first as a City Councilman and later as a member of the State Assembly, re-elected several times. McCreary considered himself a staunch patriot. He fervently supported industrialization as a means of strengthening Florida and the Nation. McCreary's wife, born Irene Richardson, was well connected in Gainesville and northeast Florida's civic networks as well. She served, for a time, both as Vice President of the Florida Federation of Women's Clubs and president of the United Daughters of the Confederacy. Between 1903 and 1938, Gainesville's moderate phosphate, turpentine and tung oil industries made room for the industry that, today (ca. 2008) drives the Gainesville economy. In 1905, when the Florida Legislature sited the University of Florida, the State's college for men, in Gainesville, the city was known for its good drinking water and lack of other drink or activities that might get young men into trouble. The University offered its first classes in Gainesville in 1906, having relocated from its previous home in Ocala (FL). Along with its move, its mission had also changed, broadened from that of the East Florida Seminary that it had been. University population and offerings grew steadily over time. Women were admitted, albeit under limiting circumstances, for the first time in 1925. The University of Florida would not see its next growth spurt until after World War II. Gainesville, since 1854, has been the seat of Alachua County (FL) government.--E. Kesse, University of Florida Digital Library Center."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.596Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-14", "catalog", "united-states-newspaper-directory", "main-catalog-split-14"], "hassegments": false, "id": "http://www.loc.gov/item/sn95026977/", "image_url": [], "index": 2, "language": ["english"], "latlong": [29.6519756, -82.3250209], "location": ["florida", "alachua county", "united states", "gainesville", "alachua"], "location_str": "", "lonlat": [-82.3250209, 29.6519756], "number": ["http://www.loc.gov/item/sn95026977/1905-01-01/ed-1/", "2025-11-07t15:13:27.500000", "sn95026980", "sn95026977", "sn95026969", "1584", "2026-04-13t21:30:13", "1941-0778", "http://www.loc.gov/item/sn95026977/1909-12-31/ed-1/", "2025-05-23t21:30:26", "online resource", "1", "sn95026976", "32994415"], "original_format": ["newspaper"], "other_title": ["Daily sun", "Sun"], "partof": ["serial and government publications division", "chronicling america", "gainesville daily sun (gainesville, fla.) 190?-1938", "catalog", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 82.176994, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "florida", "gainesville (fla.)", "alachua county", "united states", "gainesville", "alachua county (fla.)", "alachua"], "timestamp": "2026-07-18T09:36:43.276Z", "title": "Gainesville daily sun", "type": ["title"], "url": "https://www.loc.gov/item/sn95026977/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95026969/"], "campaigns": [], "date": "190?", "dates": ["[1900 TO 1999]"], "description": ["Having begun as the Alachua (County, FL) advocate [LCCN: sn95026964] in the 1880s, the newspaper went through several title changes; and, as it was known in late 1800s, the Twice-a-week Sun [LCCN: sn95026968] finally became the Gainesville (FL) Sun [LCCN: sn95026969] which was published briefly during the early 1900s. Exact dates are uncertain; mast-heads and catalog data suggest that for only a brief time between 1903 and 1908 or 1918, the newspaper bore the title, the Gainesville (FL) Sun [LCCN: sn95026969]. The Gainesville Sun, like its predecessors, was published in Gainesville, Florida, and continued to describe itself as a \"democratic\" paper. It was published daily, except Mondays, by Henry Hamilton McCreary. H.H. McCreary is one of the best researched of Florida's newspaper publishers; documentation is maintained by the Florida Historical Society. In brief, McCreary came from a well established southern family, with prominent relatives throughout his contemporary American South. Following the completion of a degree from the University of Kentucky, McCreary established himself as a newspaper editor at the age of twenty. Throughout his publishing career, he also rose to prominence as a politician in the Democratic Party, first as a City Councilman and later as a member of the State Assembly, re-elected several times. McCreary considered himself a staunch patriot. He fervently supported industrialization as a means of strengthening Florida and the Nation. McCreary's wife, born Irene Richardson, was well connected in Gainesville and northeast Florida's civic networks as well. She served, for a time, both as Vice President of the Florida Federation of Women's Clubs and president of the United Daughters of the Confederacy. The newspaper was continued by the Gainesville (FL) Daily Sun [LCCN: sn95026977]. Between 1903 and 1918, Gainesville's moderate phosphate, turpentine and tung oil industries made room for the industry that, today (ca. 2008) drives the Gainesville economy. In 1905, when the Florida Legislature sited the University of Florida, the State's college for men, in Gainesville, the city was known for its good drinking water and lack of other drink or activities that might get young men into trouble. The University offered its first classes in Gainesville in 1906, having relocated from its previous home in Ocala (FL). Along with its move, its mission had also changed, broadened from that of the East Florida Seminary that it had been. University population and offerings grew steadily over time. The University of Florida would not see its next growth spurt until 1925 when women were admitted, albeit under limiting circumstances, for the first time. Gainesville, since 1854, has been the seat of Alachua County (FL) government. --E. Kesse, University of Florida Digital Library Center."], "digitized": true, "extract_timestamp": "2026-05-19T21:34:03.124Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn95026969/", "image_url": [], "index": 3, "language": ["english"], "location": ["florida", "alachua county", "united states", "gainesville", "alachua"], "number": ["sn95026968", "online resource", "32993937", "sn95026977", "sn95026969", "2026-04-13t21:30:13", "1"], "original_format": ["newspaper"], "other_title": ["Twice-a-week sun", "Sun"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the gainesville sun (gainesville, fla.) 190?-19??"], "publication_frequency": ["semiweekly"], "score": 73.002365, "shelf_id": "https://s3.amazonaws.com/chronam-bib-derivatives/sn95026969.xml", "site": ["usnd"], "subject": ["newspapers", "florida", "gainesville (fla.)", "alachua county", "united states", "gainesville", "alachua county (fla.)", "alachua"], "timestamp": "2026-05-27T08:36:39.230Z", "title": "The Gainesville sun", "type": ["title"], "url": "https://www.loc.gov/item/sn95026969/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2007264064/"], "campaigns": [], "date": "190?", "dates": ["[1900 TO 1938]"], "description": ["Print ceased with 58th year (July 24, 1938). The Monday issue of the semiweekly ed.: Gainesville sun (Gainesville, Fla. : 1903), has been reproduced within this collection for the years <1905-1909> when the daily was not published on Mondays. Description based on: Vol. 21, no. 276 (Jan. 3, 1905); title from PDF caption (Library of Congress Chronicling America online collection, viewed Dec. 5, 2007). Latest issue consulted: Vol. 26, no. 281 (Dec. 31, 1909)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:02.671Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2007264064/", "image_url": [], "index": 4, "language": ["english"], "location": ["florida", "alachua county", "united states", "gainesville", "alachua"], "number": ["online resource", "2007264065", "182779383", "2026-04-13t21:30:13", "2007264064"], "original_format": ["newspaper"], "other_title": ["Daily sun", "Masthead title: Sun"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "gainesville daily sun (gainesville, fla.) 190?-1938 [online resource]"], "score": 73.002365, "shelf_id": "https://s3.amazonaws.com/chronam-bib-derivatives/2007264064.xml", "site": ["usnd"], "subject": ["newspapers", "florida", "gainesville (fla.)", "alachua county", "united states", "gainesville", "alachua county (fla.)", "alachua"], "timestamp": "2026-05-26T20:43:14.516Z", "title": "Gainesville daily sun", "type": ["title"], "url": "https://www.loc.gov/item/2007264064/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2007264065/"], "campaigns": [], "date": "190?", "dates": ["[1900 TO 1999]"], "description": ["Semiweekly The Monday issue of this paper has been reproduced within the run of the daily ed.: Gainesville daily sun (Gainesville, Fla. : 1903) for the years <1905-1909> when the daily was not published on Mondays; the Thursday issue has been omitted. Description based on: Vol. 24, no. 45 (Jan. 2, 1905); title from PDF caption (Library of Congress Chronicling America online collection, viewed Dec. 5, 2007). Latest issue consulted: Vol. 29, no. 50 (Dec. 27, 1909)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:02.671Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2007264065/", "image_url": [], "index": 5, "language": ["english"], "location": ["florida", "alachua county", "united states", "gainesville", "alachua"], "number": ["online resource", "2007264065", "182782317", "2026-04-13t21:30:13", "2007264064"], "original_format": ["newspaper"], "other_title": ["Title in masthead: Twice-a-week sun", "Sun"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the gainesville sun (gainesville, fla.) 190?-19?? [online resource]"], "publication_frequency": ["semiweekly"], "score": 73.002365, "shelf_id": "https://s3.amazonaws.com/chronam-bib-derivatives/2007264065.xml", "site": ["usnd"], "subject": ["newspapers", "florida", "gainesville (fla.)", "alachua county", "united states", "gainesville", "alachua county (fla.)", "alachua"], "timestamp": "2026-05-26T20:43:14.516Z", "title": "The Gainesville sun", "type": ["title"], "url": "https://www.loc.gov/item/2007264065/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95047242/", "http://lccn.loc.gov/sn95047242", "https://search.catalog.loc.gov/instances/091afa63-1ea5-59f2-954c-b9e7d81feb66"], "batch": ["fu_six_ver01"], "campaigns": [], "date": "1903", "description": ["The Gainesville (FL) Star [LCCN: sn95047242] began with the issue for May 1, 1903 and was published by D.E. Godwin in Gainesville (FL). The newspaper subsequently published semiweekly at least through October 4, 1904 when W.L. Hill was serving as its publisher. Some issues bear the heading \"Twice a Week\" and publisher's information within some issues refers to the \"Gainesville (FL) Twice a Week Star\". The newspaper appears to have been affiliated with the Democratic Party. Between 1903 and 1906, Gainesville's moderate phosphate, turpentine and tung oil industries made room for the industry that, today (ca. 2008) drives the Gainesville economy. In 1905, when the Florida Legislature sited the University of Florida, the State's college for men, in Gainesville, the city was known for its good drinking water and lack of other drink or activities that might get young men into trouble. The University offered its first classes in Gainesville in 1906, having relocated from its previous home in Ocala (FL). Along with its move, its mission had also changed, broadened from that of the East Florida Seminary that it had been. Gainesville, since 1854, has been the seat of Alachua County (FL) government. The Gainesville Star carried the reprinted news of the world together with local news. Among the issues discussed regularly if not prominently was Gainesville's 1904 adoption of a \"dry ticket\" and the closure of saloons. The adoption of this ticket would later help Gainesville acquire the University from its completion in Live Oak (FL).--E. Kesse, University of Florida Digital Library Center."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.596Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-02", "catalog", "united-states-newspaper-directory", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/sn95047242/", "image_url": [], "index": 6, "language": ["english"], "latlong": [29.6519756, -82.3250209], "location": ["florida", "alachua county", "united states", "gainesville", "alachua"], "location_str": "", "lonlat": [-82.3250209, 29.6519756], "number": ["http://www.loc.gov/item/sn95047242/1904-10-04/ed-1/", "2025-11-07t14:59:46.400000", "sn95047242", "2026-04-13t21:30:13", "1446361", "1941-0794", "2025-05-23t21:30:26", "147", "online resource", "1", "http://www.loc.gov/item/sn95047242/1903-05-01/ed-1/"], "original_format": ["newspaper"], "other_title": ["Gainesville twice-a-week star"], "partof": ["serial and government publications division", "chronicling america", "catalog", "the gainesville star (gainesville, fla.) 1903-19??", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["semiweekly"], "score": 73.002365, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "florida", "gainesville (fla.)", "alachua county", "united states", "gainesville", "alachua county (fla.)", "alachua"], "timestamp": "2026-07-18T09:36:43.276Z", "title": "The Gainesville star", "type": ["title"], "url": "https://www.loc.gov/item/sn95047242/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn96027438/", "http://lccn.loc.gov/sn96027438", "https://search.catalog.loc.gov/instances/6e9b34d6-2fab-5ebc-a72c-ccc1a9a347d7"], "batch": ["fu_eight_ver01"], "campaigns": [], "date": "1906", "description": ["The University News [LCCN: sn96027438] was published for the target audience of the newly formed University of Florida and it student body in Gainesville, Florida. The University of Florida moved to Gainesville in 1906 from Ocala, Florida. While in Ocala, the University had been a theological seminary, the University formed in Gainesville as a school for men with, in part, a military focus. Though the University News lasted just two years and published only semimonthly, it was the one of the first student newspapers in Florida. Its editors were A. Clyde Evans in 1906 and Sam A. Sanborn in 1907. Nothing is definitively known about either editor. Both were likely students of the University. Military records maintained by the Florida State Archives and Library suggest that Evans became an officer in the U.S. Army serving in World War I in France near the Marne River. The University News was eventually succeeded by the Florida Alligator [LCCN: sn96027439], a student- produced newspaper, which lasted from 1912 to 1973, when it became the Independent Florida Alligator [LCCN: sn86010448], which is still published (ca. 2008). By the time of the Florida Alligator's founding, the University of Florida had moved to a new location, then on the edge of Gainesville, and had broadened its educational mission. --E. Kesse, University of Florida Digital Library Center."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:17.596Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-08", "catalog", "united-states-newspaper-directory", "main-catalog-split-08"], "hassegments": false, "id": "http://www.loc.gov/item/sn96027438/", "image_url": [], "index": 7, "language": ["english"], "latlong": [29.6519756, -82.3250209], "location": ["florida", "alachua county", "united states", "gainesville", "alachua"], "location_str": "", "lonlat": [-82.3250209, 29.6519756], "number": ["sn96027438", "http://www.loc.gov/item/sn96027438/1907-04-27/ed-1/", "5", "2025-11-07t12:29:14.800000", "1390155", "2026-04-13t21:30:13", "2151-5492", "2025-05-23t21:30:26", "http://www.loc.gov/item/sn96027438/1906-10-19/ed-1/", "online resource", "1"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "the university news (gainesville, fla.) 1906-190?", "catalog", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["semimonthly"], "score": 73.002365, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["students", "university of florida", "newspapers", "florida", "gainesville (fla.)", "alachua county", "united states", "gainesville", "alachua county (fla.)", "alachua"], "timestamp": "2026-07-18T09:37:35.627Z", "title": "The university news", "type": ["title"], "url": "https://www.loc.gov/item/sn96027438/"}], "next_resource": {"label": "Next Issue", "url": "https://www.loc.gov/resource/sn95026977/1907-10-30/ed-1/?fo=json&sp=1"}, "options": {"access_group": [""], "access_group_raw": "", "all": null, "api_version": "1", "app_context": null, "application_version": "$Revision$", "attribute": null, "attribute!": null, "attribute_map": null, "cache_tags": ["ndnp/fu", "university-of-florida-awardee", "newspaper-titles", "ndnp/newspapers", "catalog-split-14", "catalog", "united-states-newspaper-directory", "main-catalog-split-14", "catalog-split-02", "main-catalog-split-02", "catalog-split-08", "main-catalog-split-08", "catalog-split-04", "main-catalog-split-04", "highsm", "catalog-split-01", "carol-m-highsmith", "main-catalog-split-01", "catalog-split-03", "main-catalog-split-03", "c