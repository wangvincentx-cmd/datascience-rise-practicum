pct:12.5/0/default.jpg#h=1026&w=1385", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd429:g4294:g4294s:pm007260/full/pct:25/0/default.jpg#h=2052&w=2770"], "index": 12, "language": ["english"], "location": ["oregon", "salem", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2026-03-12t19:55:38.800000", "75694941"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "cities and towns", "catalog", "panoramic maps"], "score": 29.87147, "shelf_id": "G4294.S3A3 1905 .K6", "site": ["catalog"], "subject": ["salem (or.)", "oregon", "maps", "salem", "aerial views", "united states"], "timestamp": "2026-04-29T16:16:47.158Z", "title": "Capital city of Oregon, Salem", "type": ["cartographic"], "url": "https://www.loc.gov/item/75694941/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017655482", "http://www.loc.gov/item/2017655482/", "https://hdl.loc.gov/loc.afc/afc2014021.afc2014021_01620_mv01", "http://www.loc.gov/resource/afc2014021.afc2014021_01620_mv01/", "https://hdl.loc.gov/loc.afc/afc2014021.afc2014021_01620_mv02", "http://www.loc.gov/resource/afc2014021.afc2014021_01620_mv02/", "https://hdl.loc.gov/loc.afc/afc2014021.afc2014021_01620_mv03", "http://www.loc.gov/resource/afc2014021.afc2014021_01620_mv03/", "https://hdl.loc.gov/loc.afc/afc2014021.afc2014021_01620_sr01", "http://www.loc.gov/resource/afc2014021.afc2014021_01620_sr01/", "http://www.loc.gov/resource/afc2014021.afc2014021_01620_ms02/"], "campaigns": [], "contributor": ["smith, edward", "occupational folklife project", "bussel, robert"], "date": "2015", "dates": ["2015"], "description": ["Interview with Edward Smith about his job as home care worker. Smith, who trained as a phlebotomist in college, has been a forensic nurse and served in the military. He tends to work closely with a single, high-maintenance client at a time. He speaks about challenges of being a man in a heavily female profession, how much he enjoys his work, and the positive impact the union has had on the quality of life for its members as well as the progressive legislation it has supported in Oregon for caregivers and their clients."], "digitized": true, "extract_timestamp": "2025-08-11T18:09:19.205Z", "group": ["afc/2014021", "catalog-split-08", "catalog", "taking-care", "main-catalog-split-08"], "hassegments": false, "id": "http://www.loc.gov/item/2017655482/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2014021/afc2014021_01620/afc2014021_01620_mv01.gif", "https://tile.loc.gov/storage-services/service/afc/afc2014021/afc2014021_01620/afc2014021_01620_ms02.gif#h=150&w=116"], "index": 13, "language": ["english"], "location": ["oregon", "salem"], "mime_type": ["audio/mp3", "image/gif", "audio/wav", "application/pdf", "video/quicktime", "application/x-video", "application/x-audio"], "number": ["online resource", "2017655482", "2021-02-01t14:10:53"], "online_format": ["audio", "image", "pdf", "video"], "original_format": ["film, video"], "partof": ["taking care--documenting the occupational culture of home care workers", "american folklife center", "occupational folklife project", "catalog"], "score": 22.046555, "shelf_id": "http://lccn.loc.gov/2017655482", "site": ["catalog"], "subject": ["smith, edward", "job satisfaction", "interviews", "sound recordings", "people with disabilities", "home care services", "employment", "industrial relations", "wages", "caregivers", "job stress", "labor contract", "event place", "collective bargaining", "folklore", "humor in the workplace", "health insurance", "oral histories", "veterans", "united states", "oregon", "salem (or.)", "filmed interviews", "labor unions", "employees", "joking"], "timestamp": "2025-08-11T18:10:00.591Z", "title": "Edward Smith interview conducted by Michael Robert Bussel, 2014-12-19", "type": ["moving image"], "url": "https://www.loc.gov/item/2017655482/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017655476", "http://www.loc.gov/item/2017655476/", "https://hdl.loc.gov/loc.afc/afc2014021.afc2014021_01360_mv01", "http://www.loc.gov/resource/afc2014021.afc2014021_01360_mv01/", "https://hdl.loc.gov/loc.afc/afc2014021.afc2014021_01360_sr01", "http://www.loc.gov/resource/afc2014021.afc2014021_01360_sr01/", "http://www.loc.gov/resource/afc2014021.afc2014021_01360_ms02/"], "campaigns": [], "contributor": ["occupational folklife project", "adamski, rita", "bussel, robert"], "date": "2015", "dates": ["2015"], "description": ["Interview with Rita Adamski about her career as a home care worker. She talks about how she got into the profession, her training, what a \"typical day\" is like, how she balances being friends with her clients while retaining a \"respectful\" and professional distance, caring for dying patients, the challenging to taking on new clients after the death of a long-time client, and \"the many different ways\" to be a caregiver."], "digitized": true, "extract_timestamp": "2025-08-11T18:09:19.205Z", "group": ["afc/2014021", "catalog-split-11", "catalog", "taking-care", "main-catalog-split-11"], "hassegments": false, "id": "http://www.loc.gov/item/2017655476/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2014021/afc2014021_01360/afc2014021_01360_mv01.gif", "https://tile.loc.gov/storage-services/service/afc/afc2014021/afc2014021_01360/afc2014021_01360_ms02.gif#h=150&w=116"], "index": 14, "language": ["english"], "location": ["oregon", "salem"], "mime_type": ["audio/mp3", "image/gif", "audio/wav", "application/pdf", "video/quicktime", "application/x-video", "application/x-audio"], "number": ["2017655476", "online resource", "2018-10-23t12:15:40"], "online_format": ["audio", "image", "pdf", "video"], "original_format": ["film, video"], "partof": ["taking care--documenting the occupational culture of home care workers", "american folklife center", "occupational folklife project", "catalog"], "score": 21.570234, "shelf_id": "http://lccn.loc.gov/2017655476", "site": ["catalog"], "subject": ["job satisfaction", "interviews", "home care services", "industrial relations", "jargon (terminology)", "caregivers", "job stress", "labor contract", "event place", "collective bargaining", "humor in the workplace", "health insurance", "oral histories", "interviews (sound recordings)", "oregon", "salem (or.)", "filmed interviews", "medical care", "adamski, rita", "violence in the workplace", "labor unions"], "timestamp": "2025-08-11T18:10:00.591Z", "title": "Rita Adamski interview conducted by Michael Robert Bussel, 2014-12-05", "type": ["moving image"], "url": "https://www.loc.gov/item/2017655476/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017655496", "http://www.loc.gov/item/2017655496/", "https://hdl.loc.gov/loc.afc/afc2014021.afc2014021_02026_mv01", "http://www.loc.gov/resource/afc2014021.afc2014021_02026_mv01/", "https://hdl.loc.gov/loc.afc/afc2014021.afc2014021_02026_sr01", "http://www.loc.gov/resource/afc2014021.afc2014021_02026_sr01/", "http://www.loc.gov/resource/afc2014021.afc2014021_02026_ms02/"], "campaigns": [], "contributor": ["stacy, donald eugene", "estrada, rhonda", "occupational folklife project", "moore, nathan j."], "date": "2015", "dates": ["2015"], "description": ["Rhonda discusses her work as a home care provider, including her typical activities and her relationships with her \"consumers,\" some of which span decades. She also discusses her active involvement in the Service Employees International Union (SEIU) and the benefits, such as sick days and better pay, that have been negotiated by the union."], "digitized": true, "extract_timestamp": "2025-08-11T18:09:19.205Z", "group": ["afc/2014021", "catalog-split-13", "catalog", "taking-care", "main-catalog-split-13"], "hassegments": false, "id": "http://www.loc.gov/item/2017655496/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2014021/afc2014021_02026/afc2014021_02026_mv01.gif", "https