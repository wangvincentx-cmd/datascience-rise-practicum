ord-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mohi/batch_mohi_dagwood_ver01/data/sn90061308/00294555845/1920121001/0847.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_dagwood_ver01:data:sn90061308:00294555845:1920121001:0838/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mohi/batch_mohi_dagwood_ver01/data/sn90061308/00294555845/1920121001/0847.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn90061308/1920-12-10/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mohi/batch_mohi_dagwood_ver01/data/sn90061308/00294555845/1920121001/0847.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn90061308/1920-12-10/ed-1/?sp=8"], "batch": ["mohi_dagwood_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/missouri/", "2/united states/missouri/barry/", "3/united states/missouri/barry/monett/"], "contributor": ["state historical society of missouri; columbia, mo"], "date": "1920-12-10", "dates": ["1920-12-10"], "description": ["PRESIDENT SENDS MESSAGE TO CONGRESS Urges Industrial Relief and Enact ment of Workable Budget System Washington Dec 7Congres was in brief session today to hear Presi dent Wilsons annual message It was read by the clerk Mr Wilson having heeded advice of his physician not to appear in person Galleries in both houes were crowded but those drawn by the chance that the president might appear in person or by the possibility Jiis message might touch on the league of nations question or his own approaching retirement were disap pointed Mr Wilson confined himself almost whollv to domestic questions Aside from hearing the message congress made definite progress on at least one problem The house revived a rule under which an effort will be made Thursday to take up the immigration bill for prompt action It would limit general debate to four hours The twoday interval was al lowed to permit Representative Sieged of New York member of the immi gration committee to frame a mi nority report No other matter had passed to day beyond the committee stage At both ends of the capitol however members were deep in jdans to deal with business depression unemploy ment and farmers"], "digitized": true, "extract_timestamp": "2020-09-15T11:52:52.843Z", "group": ["ndnp/mohi", "state-historical-society-of-missouri-columbia-mo-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn90061308/1920-12-10/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_dagwood_ver01:data:sn90061308:00294555845:1920121001:0847/full/pct:6.25/0/default.jpg#h=421&w=284", "https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_dagwood_ver01:data:sn90061308:00294555845:1920121001:0847/full/pct:12.5/0/default.jpg#h=842&w=569", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mohi/batch_mohi_dagwood_ver01/data/sn90061308/00294555845/1920121001/0847.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["monett", "missouri", "united states", "barry"], "location_city": ["monett"], "location_country": ["united states"], "location_county": ["barry"], "location_state": ["missouri"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000008", "4", "8", "0", "sn90061308", "5", "2", "1", "9"], "number_edition": ["1"], "number_lccn": ["sn90061308"], "number_page": ["0000000008"], "number_reel": ["0", "0", "2", "9", "4", "5", "5", "5", "8", "4", "5"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the monett times (monett, mo.) 1899-1939", "chronicling america", "serial an