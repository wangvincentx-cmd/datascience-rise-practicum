n write HARRIS REAL STATE COMPANY E Las Vegas New Mexico IN COEUR DALENESix acres fully modern ten room house Beautiful shade trees Can take teachers to room Price 650000 Fine cli mate P P Johnson Coeur dAlene Idaho FOR BALEPART OF MY FARM Sickness forced"], "digitized": true, "extract_timestamp": "2023-07-03T13:50:11.300Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075284/1927-06-03/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_froid_ver01:data:sn86075284:0051717869A:1927060301:0593/full/pct:6.25/0/default.jpg#h=350&w=285", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_froid_ver01:data:sn86075284:0051717869A:1927060301:0593/full/pct:12.5/0/default.jpg#h=701&w=571", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_froid_ver01/data/sn86075284/0051717869A/1927060301/0593.xml&format=alto_xml"], "index": 7, "language": ["english"], "location": ["poplar", "united states", "roosevelt", "montana"], "location_city": ["poplar"], "location_country": ["united states"], "location_county": ["roosevelt"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "5", "0000000007", "7", "sn86075284", "a", "6", "8", "1"], "number_edition": ["1"], "number_lccn": ["sn86075284"], "number_page": ["0000000007"], "number_reel": ["0", "0", "5", "1", "7", "1", "7", "8", "6", "9", "a"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the poplar standard (poplar, mont.) 1910-1976", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the poplar standard (poplar, mont.) 1