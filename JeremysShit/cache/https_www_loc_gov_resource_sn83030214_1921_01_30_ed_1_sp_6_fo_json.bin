ented Monday W G Lee president of the Brother hood of Railroad Trainmen W S Carter president of the Brotherhood of Locomotive Firemen and Enginenien and L E Sheppard president of the Order of Railway Conductors made this declaration in formal statements A similar declaration was made Thurs day by Warren S Stone grand chief of the Brotherhood of Locomotive En gineers All the Brotherhood executives dc j clare that reports of decreases In the l cost of living are not borne out by j actual conditions but are the result of j propoganda that the wages of railway j employees did not increase as much is did the"], "digitized": true, "extract_timestamp": "2026-07-14T20:56:34.764Z", "group": ["ndnp/dlc-2009_2010", "library-of-congress-washington-dc-awardee-3"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83030214/1921-01-30/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_fogler_ver01:data:sn83030214:00206532592:1921013001:0828/full/pct:3.125/0/default.jpg#h=259&w=204", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_fogler_ver01:data:sn83030214:00206532592:1921013001:0828/full/pct:6.25/0/default.jpg#h=519&w=409", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_fogler_ver01:data:sn83030214:00206532592:1921013001:0828/full/pct:12.5/0/default.jpg#h=1038&w=818", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_fogler_ver01/data/sn83030214/00206532592/1921013001/0828.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["new york city", "united states", "new york county", "new york"], "location_city": ["new york"], "location_country": ["united states"], "location_county": ["new york"], "location_state": ["new york"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "2", "1", "0000000006", "9", "6", "sn