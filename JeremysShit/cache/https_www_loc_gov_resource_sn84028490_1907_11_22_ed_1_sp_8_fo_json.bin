ve that candldato endors ed by Mr Bryan If Mr"], "digitized": true, "extract_timestamp": "2023-09-04T23:20:26.300Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84028490/1907-11-22/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_hotel_ver01:data:sn84028490:00237289298:1907112201:0559/full/pct:6.25/0/default.jpg#h=413&w=274", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_hotel_ver01:data:sn84028490:00237289298:1907112201:0559/full/pct:12.5/0/default.jpg#h=826&w=549", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_hotel_ver01/data/sn84028490/00237289298/1907112201/0559.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["stark", "ohio", "canton", "united states"], "location_city": ["canton"], "location_country": ["united states"], "location_county": ["stark"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "8", "3", "sn84028490", "0000000008", "7", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn84028490"], "number_page": ["0000000008"], "number_reel": ["0", "0", "2", "3", "7", "2", "8", "9", "2", "9", "8"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Stark Democrat"], "partof": ["the stark county democrat (canton, ohio) 1833-1912", "chronicling america", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the stark county democrat (canton, ohio) 1833-1912"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn84028490/1907-11-22/ed-1/?sp=8"}], "segmentof": ["http://www.loc.gov/resource/sn84028490/