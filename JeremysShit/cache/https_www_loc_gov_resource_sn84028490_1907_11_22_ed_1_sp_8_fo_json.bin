v/pictures/item/2013647520/", "http://www.loc.gov/item/2013647520/", "http://www.loc.gov/pictures/item/2013647520/", "https://www.loc.gov/pictures/collection/stereo/item/2013647520/", "http://www.loc.gov/pictures/collection/stereo/item/2013647520/", "https://hdl.loc.gov/loc.pnp/stereo.1s03691", "http://www.loc.gov/resource/stereo.1s03691/", "http://lccn.loc.gov/2013647520"], "campaigns": [], "contributor": ["kilburn, b. w. (benjamin west)"], "date": "1901-01-01", "dates": ["1901"], "description": ["1 photograph : print on card mount ; mount 9 x 18 cm (stereograph format)"], "digitized": true, "extract_timestamp": "2021-09-01T20:20:12.503Z", "group": ["stereo", "catalog-split-14", "catalog", "stereograph-cards", "main-catalog-split-14", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2013647520/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/stereo/1s00000/1s03000/1s03600/1s03691_150px.jpg#h=78&w=150", "https://tile.loc.gov/storage-services/service/pnp/stereo/1s00000/1s03000/1s03600/1s03691t.gif#h=78&w=150", "https://tile.loc.gov/storage-services/service/pnp/stereo/1s00000/1s03000/1s03600/1s03691r.jpg#h=334&w=640", "https://tile.loc.gov/storage-services/service/pnp/stereo/1s00000/1s03000/1s03600/1s03691v.jpg#h=534&w=1024"], "index": 9, "language": ["english"], "location": ["ohio", "canton"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/17710215", "2013647520", "2019-09-16t14:26:10", "sheet"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "catalog", "prints and photographs division", "lot 13664", "stereograph cards"], "score": 27.10229, "shelf_id": "LOT 13664, no. 24 [P&P]", "site": ["pictures", "catalog"], "subject": ["canton (ohio)", "public appearances", "presidents", "ohio", "roosevelt, theodore", "photographic prints", "stereographs", "canton"], "timestamp": "2022-05-20T17:05:46.152Z", "title": "President Roosevelt and escort arriving at Canton, O.", "url": "https://www.loc.gov/item/2013647520/"}, {"access_restricted": false, "aka": ["http://parkplanning.nps.gov/document.cfm?projectId=11019&documentID=12661", "http://lccn.loc.gov/2005452090", "http://www.loc.gov/item/2005452090/"], "campaigns": [], "contributor": ["united states. national park service"], "date": "2005", "dates": ["2005"], "description": ["Also available via Internet. Cover title."], "digitized": true, "extract_timestamp": "2023-06-02T20:40:33.284Z", "group": ["catalog-split-11", "catalog", "main-catalog-split-11", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2005452090", "image_url": [], "index": 10, "language": ["english"], "location": ["first ladies national historic site", "ohio", "canton"], "number": ["61858167", "2011-05-11t13:42:24", "2005452090"], "original_format": ["book"], "partof": ["catalog"], "score": 27.10229, "shelf_id": "F499.C2 F57 2005", "site": ["catalog"], "subject": ["monuments", "canton (ohio)", "first ladies national historic site (canton, ohio)", "management", "environmental impact statements", "mckinley, ida saxton", "ohio", "homes and haunts", "historic sites", "mckinley, william", "buildings, structures, etc", "canton", "presidents' spouses"], "timestamp": "2023-07-08T16:10:38.136Z", "title": "First Ladies National Historic Site : draft general management plan, environmental impact statement", "type": ["text"], "url": "//lccn.loc.gov/2005452090"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/mp76000323", "http://www.loc.gov/item/mp76000323/", "https://search.catalog.loc.gov/instances/016d0023-a230-57cd-87cd-d89282217706", "https://hdl.loc.gov/loc.mbrsmi/ntscrm.00013542", "http://www.loc.gov/resource/ntscrm.00013542/"], "campaigns": [], "contributor": ["theodore roosevelt association collection (library of congress)", "biograph company", "roosevelt memorial association"], "date": "1901", "dates": ["1901"], "description": ["Three sequences of the funeral ceremonies held for President William McKinley: Sequence 1: McKinley's body lay in state in the Rotunda of the Capitol, Washington, D.C. on Sept. 17, 1901; views of officers on horseback, the Artillery Band (wearing dark headdresses), a squadron of cavalry, a battalion of artillery and coast artillery, Marine Band (wearing white helmets), battalion of Marines, civilians carrying umbrellas (may be the diplomatic corps), other civilians, guard of honor, pallbearers, and the horsedrawn hearse all turning the corner off what may be Pennsylvania Avenue on their way to the Capitol; camera pans the hearse, as a procession of carriages turns the corner. Sequence 2: McKinley's body first lay in state for public viewing in Buffalo, N.Y. on Sept. 15-16; views of carriages, the horsedrawn hearse, and marchers stopping in front of the Buffalo City Hall; medium close shots of the casket being unloaded from hearse and carried up stairs of City Hall; crowds of mourners lining up to view the body as group of soldiers enters City Hall; camera pans crowd gathered outside as mourners enter and leave City Hall. Unrelated sequence of Washington ceremonies follows; camera pans from different angles of crowds gathered at the east front of the Capitol. Sequence 3: McKinley's body was conveyed to its final resting place at Canton, Ohio on Sept. 18-19; views of mounted military units, marching civilians, carriages, and the horsedrawn hearse turning and entering what is probably Westlawn Cemetery where McKinley is buried; military units marching down a street as gathered crowds watch; final pans of mourners, crowds, and soldiers outside the McKinley home in Canton."], "digitized": true, "extract_timestamp": "2026-02-10T14:37:43.855Z", "group": ["nsr", "catalog-split-02", "catalog", "national-screening-room", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/mp76000323/", "image_url": ["https://tile.loc.gov/storage-services/service/mbrs/ntscrm/00013542/00013542.gif"], "index": 11, "language": ["english"], "location": ["washington d.c.", "new york", "ohio", "united states", "buffalo", "canton"], "mime_type": ["image/gif", "video/mp4", "image/jpeg", "video/quicktime", "application/x-video"], "number": ["film reel", "2025-06-06t17:36:21.200000", "http://www.loc.gov/item/mp76000323", "2024-01-31t16:07:38", "http://www.loc.gov/item/mp 76000323", "mp76000323"], "online_format": ["image", "video"], "original_format": ["film, video"], "other_title": ["Title in Theodore Roosevelt Association film collection catalog: President McKinley's funeral, 1901 [1]"], "partof": ["motion picture, broadcasting and recorded sound division", "national screening room", "catalog", "theodore roosevelt: his life and times on film"], "score": 20.449514, "shelf_id": "FAB 0756 (viewing print) FRA 5811 (non-viewing print)", "site": ["catalog"], "subject": ["city and county hall (buffalo, n.y.)", "west lawn cemetery (canton, ohio)", "presidents", "new york (state)", "ohio", "short films", "washington (d.c.)", "mckinley, william", "united states", "funeral rites and ceremonies", "silent films", "united states capitol (washington, d.c.)", "buffalo", "death and burial", "nonfiction films", "canton"], "timestamp": "2026-02-10T14:42:53.214Z", "title": "President McKinley's funeral, 1901. [No. 1]", "type": ["moving image"], "url": "https://www.loc.gov/item/mp76000323/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/00694354", "http://www.loc.gov/item/00694354/", "https://search.catalog.loc.gov/instances/4567049a-8e17-516f-8082-462a80315ea6", "https://hdl.loc.gov/loc.mbrsmi/ntscrm.00045705", "http://www.loc.gov/resource/ntscrm.00045705/"], "campaigns": [], "contributor": ["paper print collection (library of congress)", "thomas a. edison, inc"], "date": "1901", "dates": ["1901"], "description": ["\"It is apparent that the camera was placed on a platform of a train station. A steam locomotive pulling several passenger cars can be seen nearing the camera position and coming to a stop. The remainder of the film is concerned with the people who get off the train and walk off the platform\"--Early motion pictures. \"In recording this scene the position of our camera was an excellent one, and we present to the public a most perfect picture of the train's arrival. The engine is decorated with crepe to mark the solemnity of this great historical event. As the train stops at the platform great respect for the dead President is shown by the waiting diplomats and reception committee baring their heads and standing respectfully on one side as the mourners leave the train\"--Edison films catalog."], "digitized": true, "extract_timestamp": "2026-02-10T14:37:42.365Z", "group": ["nsr", "catalog-split-15", "catalog", "national-screening-room", "main-catalog-split-15"], "hassegments": false, "id": "http://www.loc.gov/item/00694354/", "image_url": ["https://tile.loc.gov/storage-services/service/mbrs/ntscrm/00045705/00045705.gif"], "index": 12, "language": ["english"], "location": ["ohio", "canton", "united states"], "mime_type": ["image/gif", "video/mp4", "image/jpeg", "video/quicktime", "application/x-video"], "number": ["00694354", "film reel", "2026-01-06t18:05:26.400000"], "online_format": ["image", "video"], "original_format": ["film, video"], "other_title": ["Title in Edison films catalog: Funeral train arriving at Canton Station"], "partof": ["national screening room", "catalog", "inventing entertainment: the early motion pictures and sound recordings of the edison companies", "motion picture, broadcasting and recorded sound division", "last days of a president: films of mckinley and the pan-american exposition, 1901"], "score": 20.449514, "shelf_id": "FLA 3997 (viewing print) FEB 9625 (viewing print) FRA 0095 (dupe neg pic) FPE 5350 (dupe neg pic) FRB 1254 (master pos pic) FPE 5521 (master pos pic) Box 0286 (paper pos) Box 5024B (paper pos, copy 2)", "site": ["catalog"], "subject": ["presidents", "actualities (motion pictures)", "ohio", "funeral trains", "railroad stations", "mckinley, william", "united states", "funeral rites and ceremonies", "silent films", "short films", "death and burial", "nonfiction films", "canton", "death"], "timestamp": "2026-02-10T14:40:10.031Z", "title": "Arrival of McKinley's funeral train at Canton, Ohio", "type": ["moving image"], "url": "https://www.loc.gov/item/00694354/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/00694355", "http://www.loc.gov/item/00694355/", "https://search.catalog.loc.gov/instances/09422cc9-99d9-5753-bd80-702db3020284", "https://hdl.loc.gov/loc.mbrsmi/ntscrm.00045722", "http://www.loc.gov/resource/ntscrm.00045722/"], "campaigns": [], "contributor": ["paper print collection (library of congress)", "thomas a. edison, inc"], "date": "1901", "dates": ["1901"], "description": ["\"Here, as in the other pictures, we secured a most advantageous location, and we present a life-size view of the casket containing the body of President McKinley as it is slowly and carefully taken from the window of the car which bore it from the Capitol to Canton. The casket is placed upon the shoulders of ten stalwart sailors and soldiers and borne to the waiting hearse. 60 ft.\"--Edison films catalog, no. 135."], "digitized": true, "extract_timestamp": "2026-02-10T14:37:42.765Z", "group": ["nsr", "catalog-split-00", "catalog", "national-screening-room", "main-catalog-split-00"], "hassegments": false, "id": "http://www.loc.gov/item/00694355/", "image_url": ["https://tile.loc.gov/storage-services/service/mbrs/ntscrm/00045722/00045722.gif"], "index": 13, "language": ["english"], "location": ["ohio", "canton", "united states"], "mime_type": ["image/gif", "video/mp4", "image/jpeg", "video/quicktime", "application/x-video"], "number": ["2024-01-31t16:06:53", "2025-06-06t18:21:46.300000", "film reel", "00694355"], "online_format": ["image", "video"], "original_format": ["film, video"], "other_title": ["Title from Edison films catalog, no. 135: Body leaving the train at Canton, Ohio", "Title from Edison films catalog, no. 225: Body leaving the train, Canton, Ohio"], "partof": ["national screening room", "catalog", "inventing entertainment: the early motion pictures and sound recordings of the edison companies", "motion picture, broadcasting and recorded sound division", "last days of a president: films of mckinley and the pan-american exposition, 1901"], "score": 20.449514, "shelf_id": "FLA 3033 (viewing print) FEC 1637 (viewing print) FRA 2132 (dupe neg pic) FPE 7101 (dupe neg pic) Box 0746F (paper pos) Box 5283E (paper pos, copy 2)", "site": ["catalog"], "subject": ["presidents", "actualities (motion pictures)", "ohio", "short films", "railroad stations", "mckinley, william", "united states", "funeral rites and ceremonies", "silent films", "death and burial", "nonfiction films", "canton", "death"], "timestamp": "2026-02-10T14:40:10.031Z", "title": "Taking President McKinley's body from train at Canton, Ohio", "type": ["moving image"], "url": "https://www.loc.gov/item/00694355/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_hotel_ver01/data/sn84028490/00237289298/1907112201/0559.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_hotel_ver01:data:sn84028490:00237289298:1907112201:0552/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ohi/batch_ohi_hotel_ver01/data/sn84028490/00237289298/1907112201/0559.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn84028490/1907-11-22/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_hotel_ver01/data/sn84028490/00237289298/1907112201/0559.xml&format=alto_xml&full_text=1", "