nt=/service/ndnp/kyu/batch_kyu_charo_ver01/data/sn86069496/00175044279/1907121101/0360.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:kyu:batch_kyu_charo_ver01:data:sn86069496:00175044279:1907121101:0359/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/kyu/batch_kyu_charo_ver01/data/sn86069496/00175044279/1907121101/0360.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86069496/1907-12-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/kyu/batch_kyu_charo_ver01/data/sn86069496/00175044279/1907121101/0360.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86069496/1907-12-11/ed-1/?sp=2"], "batch": ["kyu_charo_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/kentucky/", "2/united states/kentucky/adair/", "3/united states/kentucky/adair/columbia/"], "contributor": ["university of kentucky, lexington, ky"], "date": "1907-12-11", "dates": ["1907-12-11"], "description": ["I I I z I 1r J 2 THE ADAIR COUNTY NEWS COLUMBIA vKY DECEMBER 11 1907 I I DO SOMETHING ffOR KENTUCKY j I 0A A man is not estimated by what he thinks of himself but by the impression he creates o n mothers r No matter how highly r we may esteem ourselves our fellows will not share our opin ion unless there is an evidence of good works It does not mat ter how well we Kentuckians think of our State the question is what do the other States think of Kentucky Our opinion of Kentucky has nothing to do with the standing of Kentucky among her sister States If Kentucky would stand tha e column among the other Com monwealths we must do some thing for Kentucky The State has the reputation abroad that our Courts do not administer even Handed justice but is too often preverted by sympathy You Judges can do something for Kentucky by pay ing more attention to justice and the rights of society and less to the technicalites of the law You Lawyers can do something for Kentucky by fully realizing that your clients have no claim upon you to"], "digitized": true, "extract_timestamp": "2025-07-21T10:35:47.003Z", "group": ["ndnp/kyu", "university-of-kentucky-lexington-ky-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86069496/1907-12-11/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:kyu:batch_kyu_charo_ver01:data:sn86069496:00175044279:1907121101:0360/full/pct:3.125/0/default.jpg#h=283&w=188", "https://tile.loc.gov/image-services/iiif/service:ndnp:kyu:batch_kyu_charo_ver01:data:sn86069496:00175044279:1907121101:0360/full/pct:6.25/0/default.jpg#h=566&w=376", "https://tile.loc.gov/image-services/iiif/service:ndnp:kyu:batch_kyu_charo_ver01:data:sn86069496:00175044279:1907121101:0360/full/pct:12.5/0/default.jpg#h=1132&w=752", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/kyu/batch_kyu_charo_ver01/data/sn86069496/00175044279/1907121101/0360.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["adair", "kentucky", "adair county", "columbia", "united states"], "location_city": ["columbia"], "location_country": ["united states"], "location_county": ["adair"], "location_state": ["kentucky"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "sn86069496", "9", "7", "0000000002", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn86069496"], "number_page": ["0000000002"], "number_reel": ["0", "0", "1", "7", "5", "0", "4", "4", "2", "7", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the adair county news (columbia, ky.) 1897-1987", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["ser