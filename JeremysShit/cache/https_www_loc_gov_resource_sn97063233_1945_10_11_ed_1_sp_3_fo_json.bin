paper"], "partof": ["serial and government publications division", "chronicling america", "catalog", "the wyandotte herald (wyandotte, mich.) 1879-1943", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 66.41492, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["wayne county", "wyandotte", "newspapers", "united states", "wayne", "wyandotte (mich.)", "wayne county (mich.)", "michigan"], "timestamp": "2026-07-18T09:38:22.884Z", "title": "The Wyandotte herald", "type": ["title"], "url": "https://www.loc.gov/item/sn97063232/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95070373/", "http://lccn.loc.gov/sn95070373", "https://search.catalog.loc.gov/instances/c46679b9-b94a-5fd9-b779-c272ac89c04e"], "campaigns": [], "date": "1995", "dates": ["[1995 TO 9999]"], "description": ["Daily Began July 13, 1995. Back issues available online. Print ed.: Detroit news (Detroit, Mich. : 1905). Mode of access: World Wide Web. Description based on: Aug. 18, 1995; title from title screen. Latest issue consulted: 145th year, No. 238 (April 17, 2019) (surrogate)."], "digitized": true, "extract_timestamp": "2026-05-19T21:34:05.793Z", "group": ["ndnp/newspapers", "catalog-split-03", "catalog", "united-states-newspaper-directory", "main-catalog-split-03"], "hassegments": false, "id": "http://www.loc.gov/item/sn95070373/", "image_url": [], "index": 7, "language": ["english"], "location": ["wayne county", "detroit", "united states", "wayne", "michigan"], "number": ["33115544", "online resource", "sn95070373", "2690-7186", "2026-04-13t21:30:13", "2025-11-07t15:14:20.700000"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "catalog", "the detroit news ([detroit, mich.]) 1995-current [online resource]"], "publication_frequency": ["daily"], "score": 42.566914, "shelf_id": "Newspaper", "site": ["usnd", "catalog"], "subject": ["wayne county", "electronic journals", "periodicals", "detroit", "newspapers", "united states", "detroit (mich.)", "wayne", "michigan", "wayne county (mich.)"], "timestamp": "2026-05-27T08:50:05.467Z", "title": "The Detroit news", "type": ["title"], "url": "https://www.loc.gov/item/sn95070373/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019201736/", "http://lccn.loc.gov/2019201736", "https://search.catalog.loc.gov/instances/a75bc0b9-b4b9-51ec-92f4-ab1f43e513f5"], "campaigns": [], "date": "1858", "dates": ["[1858 TO 9999]"], "description": ["Daily Print began with 1858. Issue for May 10, 1931 called: One hundredth anniversary edition. Editors: Wilbur F. Storey, Aug. 18, 1858-June 4, 1861; Henry N. Walker, June 5-Aug. 27, 1861. Due to strike on Apr. 15, 1962, combined with: Detroit news (Detroit, Mich. : 1905) and called: Detroit news-the Detroit free press. Due to a strike from July 15, 1995-Jan. 1, 1996, combined with: Detroit news (Detroit, Mich. : 1905) and called: Detroit news and free press. Saturday and Sunday issues combined with: Detroit news (Detroit, Mich. : 1905) and called: Detroit news and free press, Dec. 2, 1989-Apr. 30, 2006. Sunday issues include editorial page from Detroit news (Detroit, Mich. : 1905) and called: Sunday free press, May 7, 2006- Issue numbers v. 94, no. 120-v. 94, no. 265 skipped. Suspended Dec. 2, 1955-Jan. 16, 1956; Apr. 12-May 10, 1962; July 14-Nov. 24, 1964; Nov. 18, 1967-Aug. 9, 1968. Saturday and Sunday issues also have numbering for Detroit news. Other daily ed.: Detroit free press (Detroit, Mich. : State ed.). Weekly eds.: Detroit free press (Detroit, Mich. : Weekly), and; Detroit weekly free press; and: Weekly Detroit free press. Regional eds.: Weekly Detroit free press (Detroit, Mich. : Mich. ed.); Semiweekly ed.: Twice-a-week Detroit free press. Description based on: Volume 189, No. 64 (July 7, 2019); title from digital edition caption (freep.com, surrogate provided by publisher, viewed September 24, 2019). Latest issue consulted: Volume 189, No. 64 (July 7, 2019) (viewed September 24, 2019)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:01.189Z", "group": ["ndnp/newspapers", "catalog-split-15", "catalog", "united-states-newspaper-directory", "main-catalog-split-15"], "hassegments": false, "id": "http://www.loc.gov/item/2019201736/", "image_url": [], "index": 8, "language": ["english"], "location": ["wayne county", "detroit", "united states", "wayne", "michigan"], "number": ["2025-11-07t12:37:05.400000", "137343179", "2019201736", "online resource", "2689-0410", "sn97063368", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Detroit news-the Detroit free press", "Detroit news and free press", "Sunday free press"], "partof": ["serial and government publications division", "catalog", "directory of u.s. newspapers in american libraries", "detroit free press (detroit, mich.;detroit, michigan) 1858-current [online resource]"], "publication_frequency": ["daily"], "score": 42.566914, "shelf_id": "Newspapers", "site": ["usnd", "catalog"], "subject": ["wayne county", "electronic journals", "periodicals", "detroit", "newspapers", "united states", "detroit (mich.)", "wayne", "michigan", "wayne county (mich.)"], "timestamp": "2026-05-26T20:57:39.303Z", "title": "Detroit free press", "type": ["title"], "url": "https://www.loc.gov/item/2019201736/"}], "next_resource": {"label": "Next Issue", "url": "https://www.loc.gov/resource/sn97063233/1945-10-15/ed-1/?fo=json&sp=1"}, "options": {"access_group": [""], "access_group_raw": "", "all": null, "api_version": "1", "app_context": null, "application_version": "$Revision$", "attribute": null, "attribute!": null, "attribute_map": null, "cache_tags": ["ndnp/mimtptc", "central-michigan-university-clark-historical-library-awardee", "newspaper-titles", "ndnp/newspapers", "catalog-split-02", "catalog", "united-states-newspaper-directory", "main-catalog-split-02", "ca