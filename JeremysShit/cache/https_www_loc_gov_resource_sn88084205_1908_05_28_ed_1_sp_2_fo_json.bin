ditor TermsOne Year 100 Six Months 50c Hates for advertising on application Entered as secondclass matter May 30th 1907 at the post otllcc at Panama City Florida under the Act of Congress of March 3 1879 u PANAMA CITY FLA MAY 28 1908 A Yearling With its last issue the PILOT com pleted an existence of one full year 1he management takes this occasion to heartily thank those who have made possible its steady and rapid increase in circulation which for a small marooned sheet has been almost unprecedented Scarcely a day has passed but accessions have been made to its readers and as yet no one has stopped his paper In the Salutatory in Number 1 it was stated that the aim of the PILOT is to further the interests of this portion of West Florida bringing immigrants homoseekers to Wash ington county advancing the up building of Panama City hastening the opening of our magnificent Deep I Water Harbor to the commerce of the"], "digitized": true, "extract_timestamp": "2026-01-27T17:03:28.232Z", "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88084205/1908-05-28/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_sixteen_ver01:data:sn88084205:00100478973:1908052801:0274/full/pct:3.125/0/default.jpg#h=320&w=207", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_sixteen_ver01:data:sn88084205:00100478973:1908052801:0274/full/pct:6.25/0/default.jpg#h=641&w=415", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_sixteen_ver01/data/sn88084205/00100478973/1908052801/0274.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["panama city", "united states", "washington county", "bay county", "florida"], "location_city": ["panama city"], "location_country": ["united states"], "location_county": ["bay county", "washington county"], "location_state": ["florida"], "mime_type": ["image/jp2", "application/pd