ates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/lu/batch_lu_duffy_ver02/data/sn86079068/00200299024/1913121601/0412.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:lu:batch_lu_duffy_ver02:data:sn86079068:00200299024:1913121601:0411/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/lu/batch_lu_duffy_ver02/data/sn86079068/00200299024/1913121601/0412.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn86079068/1913-12-16/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/lu/batch_lu_duffy_ver02/data/sn86079068/00200299024/1913121601/0412.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86079068/1913-12-16/ed-1/?sp=2"], "batch": ["lu_duffy_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/louisiana/", "2/united states/louisiana/lafayette/", "3/united states/louisiana/lafayette/vermilionville/", "3/united states/louisiana/lafayette/lafayette/"], "contributor": ["louisiana state university; baton rouge, la"], "date": "1913-12-16", "dates": ["1913-12-16"], "description": ["bshed SemiWeekly Tuesday and Friday by F OSEN ALPHA Proprietors sicription 100 a Year Payable in Advance entered as second class matter Sept I 1907 at the Postofce at Lafayette IA under the Act of Congress of March 8 1897 TUESDAY DECEMBER 16 1913 A Carefully Manipulated Business Depression Country Review 11e is blind indeed who cannot see that the existing business depression is being persistently manufactured by the big Wall Street interests for the purpose of influencing the action of Congress in the currency legislation now pending in the Senate The tar iff law has already gone into effect and its operation save in a few iso lated sections has caused no jar to the business of the people The steady withdrawal of money from the channels of business to be hoarded in the coffers of the banks and in the money centers of the East is utterly indefensible it was planned deliber ately for the purpose of creating a stringency in the money markets and distress among the people with the hope of deceiving them into believ ing that the pending legislation is re sponsible for the condition noted and inciting them to opposition to the bill The"], "digitized": true, "extract_timestamp": "2020-10-12T13:30:06.701Z", "group": ["ndnp/lu", "louisiana-state-university-baton-rouge-la-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86079068/1913-12-16/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:lu:batch_lu_duffy_ver02:data:sn86079068:00200299024:1913121601:0412/full/pct:6.25/0/default.jpg#h=481&w=324", "https://tile.loc.gov/image-services/iiif/service:ndnp:lu:batch_lu_duffy_ver02:data:sn86079068:00200299024:1913121601:0412/full/pct:12.5/0/default.jpg#h=963&w=649", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/lu/batch_lu_duffy_ver02/data/sn86079068/00200299024/1913121601/0412.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["vermilionville", "united states", "louisiana", "lafayette"], "location_city": ["vermilionville", "lafayette"], "location_country": ["united states"], "location_county": ["lafayette"], "location_state": ["louisiana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "1", "sn86079068", "2", "4", "0", "0000000002"], "number_edition": ["1"], "number_lccn": ["sn86079068"], "number_page": ["0000000002"], "number_reel": ["0", "0", "2", "0", "0", "2", "9", "9", "0", "2", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and governmen