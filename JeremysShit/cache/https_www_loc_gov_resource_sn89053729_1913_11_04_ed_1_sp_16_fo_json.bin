{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn89053729/?st=calendar", "cite_this": {"apa": "(1913, November 4)  <cite>Atlanta Georgian</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn89053729/1913-11-04/ed-1/.", "chicago": "<cite>Atlanta Georgian</cite>. (Atlanta, GA), Nov. 4 1913. https://www.loc.gov/item/sn89053729/1913-11-04/ed-1/.", "mla": "<cite>Atlanta Georgian</cite>. (Atlanta, GA) 4 Nov. 1913, p. 16. Retrieved from the Library of Congress, www.loc.gov/item/sn89053729/1913-11-04/ed-1/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_kesil_ver01/data/sn89053729/00393344581/1913110401/0116.xml&format=alto_xml&full_text=1", "item": {"_version_": 1799816573603545088, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn89053729/1913-11-04/ed-1/", "http://www.loc.gov/resource/sn89053729/1913-11-04/ed-1/"], "batch": ["gu_kesil_ver01"], "call_number": ["Newspaper"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/georgia/", "2/united states/georgia/fulton/", "3/united states/georgia/fulton/atlanta/"], "contributor_names": ["Digital Library of Georgia, a project of GALILEO located at the University of Georgia Libraries"], "contributors": [{"digital library of georgia, a project of galileo located at the university of georgia libraries": "https://www.loc.gov/search/?fa=contributor:digital+library+of+georgia,+a+project+of+galileo+located+at+the+university+of+georgia+libraries&fo=json"}], "created_published": ["Atlanta, Ga., November 4, 1913"], "date": "1913-11-04", "date_issued": "1913-11-04", "dates": [{"1913-11-04": "https://www.loc.gov/search/?dates=1913-11-04/1913-11-04&fo=json"}], "dates_of_publication": "1912-1939", "description": ["Atlanta, Ga."], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2024-05-22T12:58:29.408Z", "extract_urls": ["file:/service/n