r Hours Vapo\u00dfubs special action keeps on working Invites restful sleep Often by morning most of the misery of the cold is gone Only Vapo\u00dfub gives you this special penetratingstimulating action So be sure you get the one and only VICKS VAPORUB People Make Fun of Mrs Beulah Hankins INDIANAPOLIS INDIANA Mrs Beulah Hankins who lives at 634 S Collier wrote an amusing letter to Faultless Starch Com pany recently She said I want to tell you about your wonderful starch I sure think its grand Several people make fun of me for not boiling my starch They say this starch is for lazy people I have a boy four years old and I iron ten to fifteen suits of clothes a week for him I love to iron them as Faultless Starch makes easy ironing"], "digitized": true, "extract_timestamp": "2023-07-03T13:49:39.715Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075229/1945-12-13/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_belt_ver01:data:sn86075229:00517178263:1945121301:0814/full/pct:6.25/0/default.jpg#h=365&w=282", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_belt_ver01:data:sn86075229:00517178263:1945121301:0814/full/pct:12.5/0/default.jpg#h=730&w=565", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_belt_ver01/data/sn86075229/00517178263/1945121301/0814.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["hardin", "big horn", "united states", "montana"], "location_city": ["hardin"], "location_country": ["united states"], "location_county": ["big horn"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "8", "3", "0000000006", "7", "sn86075229", "6", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn86075229"], "number_