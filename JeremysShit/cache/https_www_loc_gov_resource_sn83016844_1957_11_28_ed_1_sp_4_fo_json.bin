ontributor": ["koh, harold hongju", "blackmun, harry a. (harry andrew)"], "date": "1997", "dates": ["1997"], "description": ["Correspondence, appointment books, memoranda, case files, legal papers, subject files, speeches, and writings chiefly documenting Blackmun's career as associate justice of the U.S. Supreme Court (1970-1994) and as judge of the U.S. Court of Appeals (8th Circuit). Also includes material relating to his boyhood in Saint Paul, Minn., his undergraduate and law school studies at Harvard University, his private law practice in Minneapolis, Minn., his work as counsel for the Mayo Clinic and Mayo Association, and his association with the Advisory Committee on Judicial Activities for the Judicial Conference of the United States, Aspen Institute, and the United Methodist Church. U.S. Court of Appeals case topics include taxation, civil rights, and labor, administrative, constitutional, and criminal law. Documents Blackmun's decision to declare the use of corporal punishment in prisons unconstitutional. Subjects in the Supreme Court files include abortion rights, adoption, research use of fetal tissues, reverse discrimination, and legal issues stemming from the Watergate affair. Correspondents include Robert A. Bezoier, Myron H. Bright, Warren E. Burger, Daniel C. Connolly, James Russell Eckman, Felix Frankfurter, Erwin N. Griswold, Henry Earnest Halladay, Russell C. Jewell, A. M. Keith, Robert E. Merry, Roy M. Mersky, Norval Morris, John Bell Sanborn, James F. Simon, Scott Turow, and Charles Alan Wright."], "digitized": true, "extract_timestamp": "2026-06-29T12:08:51.204Z", "group": ["mssadhoc", "catalog-split-15", "catalog", "mss-nonmarc-adhoc", "main-catalog-split-15"], "hassegments": true, "id": "http://www.loc.gov/item/mm99084430/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:mss:mss84430dig:mss84430dig:1429:02:0001/full/pct:25/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:mss:mss84430dig:mss84430dig:1429:02:0001/full/pct:25/0/default.jpg#h=320&w=250", "https://tile.loc.gov/image-services/iiif/service:mss:mss84430dig:mss84430dig:1429:02:0001/full/pct:50/0/default.jpg#h=640&w=500", "https://tile.loc.gov/image-services/iiif/service:mss:mss84430dig:mss84430dig:1429:02:0001/full/pct:100/0/default.jpg#h=1280&w=1000"], "index": 9, "language": ["english"], "location": ["united states", "minneapolis", "saint paul", "minnesota"], "mime_type": ["image/jpeg", "image/jp2", "application/pdf", "application/xml", "image/tiff", "text/plain"], "number": ["2025-09-12t17:25:55.100000", "mm99084430"], "online_format": ["image", "pdf", "online text"], "original_format": ["book", "manuscript/mixed material", "collection"], "partof": ["harry a. blackmun papers", "manuscript division", "catalog", "harry a. blackmun papers: supreme court file, 1918-1999"], "score": 24.996233, "shelf_id": "series: Supreme Court File, 1918-1999 Box: Box 1429", "site": ["catalog"], "subject": ["harvard law school", "bright, myron h.", "eckman, james russell", "sanborn, john bell", "law", "simon, james f.", "labor laws and legislation", "robert ellsworth)", "united states", "harvard university", "supreme court", "court of appeals (8th circuit)", "united states. supreme court", "blackmun, harry a. (harry andrew)", "morris, norval", "turow, scott", "adoption", "mayo association", "united methodist church (u.s.)", "abortion", "keith, a. m.", "correspondence", "wright, charles alan", "aspen institute", "law and legislation", "griswold, erwin n.", "transcriptions", "bezoier, robert a.", "practice of law", "reverse discrimination", "frankfurter, felix", "advisory committee on judicial activities", "constitutional law", "judicial conference of the united states", "taxation", "interviews", "mayo clinic", "saint paul (minn.)", "connolly, daniel c.", "watergate affair", "halladay, henry earnest", "criminal law", "judges", "corporal punishment", "administrative law", "fetal tissues", "personal correspondence", "minnesota", "p