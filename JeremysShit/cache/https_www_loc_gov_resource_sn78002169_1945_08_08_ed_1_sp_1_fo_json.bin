claimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.331948, "shard": "06", "shelf_id": "sn78002169, 1945-08-08, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ncu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["wilmington", "new hanover county", "new hanover", "united states", "new hanover county (n.c.)", "north carolina", "newspapers", "wilmington (n.c.)"], "subject_headings": ["Wilmington (N.C.)--Newspapers", "New Hanover County (N.C.)--Newspapers", "North Carolina--New Hanover County", "North Carolina--Wilmington", "United States--North Carolina--New Hanover--Wilmington"], "subjects": [{"new hanover": "https://www.loc.gov/search/?fa=subject:new+hanover&fo=json"}, {"new hanover county": "https://www.loc.gov/search/?fa=subject:new+hanover+county&fo=json"}, {"new hanover county (n.c.)": "https://www.loc.gov/search/?fa=subject:new+hanover+county+%28n.c.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"north carolina": "https://www.loc.gov/search/?fa=subject:north+carolina&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"wilmington": "https://www.loc.gov/search/?fa=subject:wilmington&fo=json"}, {"wilmington (n.c.)": "https://www.loc.gov/search/?fa=subject:wilmington+%28n.c.%29&fo=json"}], "timestamp": "2023-08-13T12:55:00.149Z", "title": "The Wilmington morning star (Wilmington, N.C.), August 8, 1945", "type": ["issue"], "url": "https://www.loc.gov/item/sn78002169/1945-08-08/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn84025826/1899-12-21/ed-1/", "http://www.loc.gov/resource/sn84025826/1899-12-21/ed-1/"], "batch": ["dlc_bigstone_ver02"], "campaigns": [], "contributor": ["library of congress, washington, dc"], "date": "1899-12-21", "dates": ["1899-12-