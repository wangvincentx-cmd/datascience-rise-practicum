08-08/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_lily_ver01/data/sn78002169/00279558856/1945080801/0441.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_lily_ver01:data:sn78002169:00279558856:1945080801:0441/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ncu/batch_ncu_lily_ver01/data/sn78002169/00279558856/1945080801/0441.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn78002169/1945-08-08/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ncu/batch_ncu_lily_ver01/data/sn78002169/00279558856/1945080801/0441.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn78002169/1945-08-08/ed-1/?sp=1"], "batch": ["ncu_lily_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/north carolina/", "2/united states/north carolina/new hanover/", "3/united states/north carolina/new hanover/wilmington/"], "contributor": ["university of north carolina at chapel hill library, chapel hill, nc"], "date": "1945-08-08", "dates": ["1945-08-08"], "description": ["Jfl 1 X I W 1 VTTilrl associAted press uiiumumiui zwuiinuin yiur __ 4r State and National Newt VoTtNQ 231 WILMINGTON N C WEDNESDAY AUGUST 8 1945 ESTABLISHED 1861 Directors Of Atomic Bomb Project Maj Gen Leslie R Groves seated Army officer in charge the governments atomic bomb project at Oak Ridge Tenn works in his office with his assistant Brig Gen Thomas F Farrell right several days before the first use of the bomb against Japan was announced by President Truman Aug 6 AP Wirephoto Em Barbers At Clinton Kept Mum On New Bomb OAK RIDGE Term Aug 7 UR Tens of thousands of workers at the governments Clinton En gineering Works and their fami lies struggled to act like normal persons today and it wasnt at all easy For months some for years they had been living in an atmos phere of strain and secrecy The knew they were working with com ponent parts or the raw materials of a mighty war weapon Very few of them had even an idea it was an atomic bomb but they knew whatever it was it was their coun trys most valued secret Workers were asked not to tell their wives"], "digitized": true, "extract_timestamp": "2023-08-12T17:38:24.992Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn78002169/1945-08-08/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_lily_ver01:data:sn78002169:00279558856:1945080801:0441/full/pct:6.25/0/default.jpg#h=428&w=324", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_lily_ver01:data:sn78002169:00279558856:1945080801:0441/full/pct:12.5/0/default.jpg#h=856&w=648", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_lily_ver01/data/sn78002169/00279558856/1945080801/0441.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["new hanover county", "united states", "new hanover", "north carolina", "wilmington"], "location_city": ["wilmington"], "location_country": ["united states"], "location_county": ["new hanover"], "location_state": ["north carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "2", "1", "8", "6", "sn78002169", "7", "9", "0000000001"], "number_edition": ["1"], "number_lccn": ["sn78002169"], "number_page": ["0000000001"], "number_reel": ["0", "0", "2", "7", "9", "5", "5", "8", "8", "5", "6"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Sunday star-news", "Morning star"