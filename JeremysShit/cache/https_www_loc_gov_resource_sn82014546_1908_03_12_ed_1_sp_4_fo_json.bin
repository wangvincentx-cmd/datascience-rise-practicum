 "macon", "atlanta (ga.)", "maps", "transportation", "andersonville prison", "civil war", "military prisons"], "timestamp": "2022-03-30T06:52:22.796Z", "title": "Georgia.", "url": "https://www.loc.gov/item/gvhs01.vhs00031/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/gvhs01.vhs00311/", "http://www.loc.gov/item/001-CABIB20008824/", "http://www.loc.gov/resource/gvhs01.vhs00311/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00311"], "campaigns": [], "contributor": ["sneden, robert knox"], "date": "1864-09-01", "dates": ["1864-09-01"], "description": ["Map shows a detailed layout of the city of Atlanta, Ga., including the batteries and earthworks in the surrounding area.  The Western Atlanta and the Macon & Western Railroad are also indicated. The map depicts the situation in the city as of 1 September 1864; the city fell to Sherman's army on the 8th."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:42.832Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00311/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00311.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00311.gif#h=193&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00311/full/pct:12.5/0/default.jpg#h=690&w=535", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00311/full/pct:25/0/default.jpg#h=1380&w=1071"], "index": 6, "language": ["english"], "location": ["atlanta", "georgia", "united states"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-08-04t12:58:24"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "civil war maps", "geography and map division", "american memory"], "score": 27.004824, "shelf_id": "http://www.loc.gov/item/001-CABIB20008824/", "site": ["ammem"], "subject": ["georgia", "