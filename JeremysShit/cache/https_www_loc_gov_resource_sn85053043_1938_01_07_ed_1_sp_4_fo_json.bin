r01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/glacier/", "3/united states/montana/glacier/browning/"], "contributor": ["montana historical society; helena, mt"], "date": "1938-01-07", "dates": ["1938-01-07"], "description": ["The Glacier County Chief Entered as 2nd daM matter July 15 1931 at the poatoffice at Browning Mont under the act of March 3 1879 Subscription 8200 year to advance JACK DUNCAN Editor and Publisher A weekly newspaper published every Friday at Browning Glaeier County The Low Down From Hickory Grove 1 just been readin iiiwut what it is costinto keep I nele Sambo in business and my word it woke me out of my sno z The feller who made the figures he says it is cost ing eaeh family in the I S 160 dollar a year just for Sambos normal stuffnot includin relief and 1 got out my own pencil and it is 14 dollars a month out of my own Jeansthree and a half a week Wow thats money I guess I sure been a sucker hs tenin to all this sweet stuff 1 been swallowing whole and not pryin into details or lookin under the blankets and find who is there and gettin the money But a neighbor he says Jo you are just the kind of a duck who is to blame He says also nobody is ever goin to slow down Sambo till"], "digitized": true, "extract_timestamp": "2023-07-03T13:49:43.957Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85053043/1938-01-07/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_circle_ver01:data:sn85053043:0051717841A:1938010701:0643/full/pct:6.25/0/default.jpg#h=327&w=216", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_circle_ver01:data:sn85053043:0051717841A:1938010701:0643/full/pct:12.5/0/default.jpg#h=655&w=432", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_circle_ver01/data/sn8505