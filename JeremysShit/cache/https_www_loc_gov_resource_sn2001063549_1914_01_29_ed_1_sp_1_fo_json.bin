rviewed yesterday Since Jan 1 several thousand men who had been laid off late in 19X3 have been put back to work in different in dustries Reports are that working forces will be still further increased Points for Encouragement Among the points advanced as in the go ahead spirit coupled with a general feeling of optimism"], "digitized": true, "extract_timestamp": "2023-06-25T23:49:58.520Z", "group": ["ndnp/sdhi", "south-dakota-state-historical-society-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn2001063549/1914-01-29/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_mustang_ver01:data:sn2001063549:00415625030:1914012901:0367/full/pct:6.25/0/default.jpg#h=504&w=415", "https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_mustang_ver01:data:sn2001063549:00415625030:1914012901:0367/full/pct:12.5/0/default.jpg#h=1008&w=831", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/sdhi/batch_sdhi_mustang_ver01/data/sn2001063549/00415625030/1914012901/0367.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["codington", "united states", "south dakota", "watertown", "codington county"], "location_city": ["watertown"], "location_country": ["united states"], "location_county": ["codington"], "location_state": ["south dakota"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0", "2", "4", "1", "6", "0000000001", "sn2001063549", "5"], "number_edition": ["1"], "number_lccn": ["sn2001063549"], "number_page": ["0000000001"], "number_reel": ["0", "0", "4", "1", "5", "6", "2", "5", "0", "3", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "saturday news (watertown, s.d.) 19??-19??"], "partof_collection": ["chronicling americ