torage-services/service/ndnp/gu/batch_gu_cookie_ver02/data/sn89053307/00517177167/1907113001/0537.jp2", "use": "", "width": 6505}, {"mimetype": "application/pdf", "url": "https://tile.loc.gov/storage-services/service/ndnp/gu/batch_gu_cookie_ver02/data/sn89053307/00517177167/1907113001/0537.pdf", "use": ""}, {"mimetype": "text/xml", "url": "https://tile.loc.gov/storage-services/service/ndnp/gu/batch_gu_cookie_ver02/data/sn89053307/00517177167/1907113001/0537.xml", "use": ""}, {"height": 300, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_cookie_ver02:data:sn89053307:00517177167:1907113001:0537/full/pct:3.125/0/default.jpg", "width": 203}, {"height": 600, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_cookie_ver02:data:sn89053307:00517177167:1907113001:0537/full/pct:6.25/0/default.jpg", "width": 406}, {"height": 9609, "info": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_cookie_ver02:data:sn89053307:00517177167:1907113001:0537/info.json", "language": ["english"], "mimetype": "application/json", "reel_number": "00517177167", "section_label": null, "size": 4694318, "title": "Image 2 of Fitzgerald enterprise (Fitzgerald, Ga.;Fitzgerald, Georgia), November 30, 1907", "width": 6505}, {"fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_cookie_ver02/data/sn89053307/00517177167/1907113001/0537.xml&format=alto_xml&full_text=1", "mimetype": "text/plain", "use": "text"}], "pagination": {"current": 2, "first": "https://www.loc.gov/resource/sn89053307/1907-11-30/ed-1/?fo=json&sp=1", "from": 2, "last": "https://www.loc.gov/resource/sn89053307/1907-11-30/ed-1/?fo=json&sp=4", "next": "https://www.loc.gov/resource/sn89053307/1907-11-30/ed-1/?fo=json&sp=3", "of": 6, "page_list": [{"number": 1, "url": "https://www.loc.gov/resource/sn89053307/1907-11-30/ed-1/?fo=json&sp=1"}, {"number": 2, "url": null}, {"number": 3, "url": "https://www.loc.gov/resource/sn89053307/1907-11-30/ed-1/?fo=json&sp=3"}, {"number": 4, "url": "https://www.loc.gov/resource/sn89053307/1907-11-30/ed-1/?fo=json&sp=4"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": "https://www.loc.gov/resource/sn89053307/1907-11-30/ed-1/?fo=json&sp=1", "results": "2 - 2", "to": 2, "total": 6}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn89053307/1907-11-28/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/2010655308", "http://www.loc.gov/item/2010655308/", "https://hdl.loc.gov/loc.afc/collafc.afc1982010", "http://www.loc.gov/resource/collafc.afc1982010/"], "campaigns": [], "contributor": ["mcgraw, hugh", "coelho, dennis", "jabbour, alan", "hamrick, raymond c.", "blackmarr, syd", "marshall, howard w.", "robinson, beverly j.", "adler, thomas a.", "fleischhauer, carl", "stanley, david", "american folklife center", "abraham baldwin agricultural college", "archive of folk culture (library of congress)", "lightfoot, william e. (william edwin)"], "date": "1977", "dates": ["1977"], "description": ["Collection of documentary materials resulting from an ethnographic field research project conducted by the American Folklife Center in eight counties of south central Georgia, and at Mt. Zion, Georgia, in July and August 1977 in cooperation with the Arts Experiment Station of Abraham Baldwin Agricultural College. Topics of research were hymn singing conventions, gospel singing of white and African American residents, fiddling and old-time music, vernacular architecture, quilts and quilting, occupations, foodways, jokes and stories from the region, which were documented through approximately 300 hours of audio interviews and in recordings made at local events. The collection also includes photographs and sound recordings of the following people and activities: Hugh McGraw, Raymond Hamrick, J. C. Cooper, and others leading sacred harp singing; other congregational and gospel singing groups; African American children's games, singing games, handclapping, and hambone; and old-time and bluegrass music featuring local fiddle, guitar, piano, and banjo players. Subjects of documentary photography include: people interviewed for the project; copies of their family photographs; vernacular houses, barns, and outbuildings, including log buildings; tools, furniture, birdhouses, and yard art; wells; tobacco culture, including curing, harvesting, warehouses, auctions, and farms, as well as tobacco workers; peanut, cotton, soybean, corn, and wheat fields; crop dusting; churches; religious services, including baptisms; prayers, sermons, hymn singing, and tent revivals; church suppers; barbecue cooking; breakfasts; quilts, crochet, and basket work; woodcarving; vernacular boats, boat repair, and boat building; fishing; graveyards, gravesites and grave markers; grocery stores, restaurants, dry goods stores, and a barber shop; business and roadside signs; a piano repair shop; aerial photographs; gathering wild herbs; trees, landscapes; swamps and rivers; and turtles, catfish, cattle, and dogs.  The collection includes photographs of sculpture, paintings, and gardens at Pope's Museum, near Pelham, Georgia, featuring the sculpture and artwork of Laura Pope Forester who died in 1953, and artwork and sculpture of St. EOM (Eddie Owens Martin) and his creation, Pasaquan.  Includes photographs of President Nyerere of Tanzania visiting Abraham Baldwin Agricultural College, August 9, 1977. Also includes photographs of the reception held for the exhibition \"Folk Art and Folk Life,\" at the Library of Congress in Washington, D.C. with Dr. and Mrs. Daniel Boorstin; First Lady Rosalynn Carter, Amy Carter, Mrs. Mary Beth Busbee, J. Michael Carrigan, Jr., Don Yoder, and Reverend Howard Finster, January 26, 1978, and photographs of the exhibition, February, 1978.  Includes additional photographs of a seminar held in the Whittall Pavilion, Library of Congress, March 17, 1978, titled \"Southern Folk Pottery: The Meaders Family Tradition,\" with Lanier Meaders, Mrs. Cheever Meaders, John Burrison, and Ralph Rinzler.  More  photographs of south Georgia cemeteries were taken by Dennis Coelho, Georgia state folklorist, in the summer of 1979.  Thirty-one pen-and-ink drawings of vernacular buildings and floor plans were made by Howard Marshall.  The collection includes documentation of the exhibition, and proposed publication projects to 1982."], "digitized": true, "extract_timestamp": "2023-07-22T07:41:56.144Z", "group": ["catalog-split-14", "catalog", "main-catalog-split-14", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2010655308", "image_url": [], "index": 2, "language": ["english"], "location": ["georgia", "cook county", "ben hill county", "colquitt county", "worth county", "grady county", "washington d.c.", "turner county", "irwin county", "berrien county", "tift county"], "number": ["2023-07-20t10:58:01", "2010655308"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["american folklife center", "catalog"], "score": 41.10274, "shelf_id": "http://lccn.loc.gov/2010655308", "site": ["catalog"], "subject": ["ethnography", "pictorial works", "cook county (ga.)", "oral histories", "folk music", "vernacular architecture", "field notes", "shape-note singing", "methodist church buildings", "essays", "south georgia sacred harp singing convention", "forester, laura pope", "worship programs", "social life and customs", "baptist church buildings", "gospel music", "georgia", "old-time music", "outsider art", "clippings", "berrien county (ga.)", "songs", "food habits", "tales", "nyerere, julius k.", "st. eom", "music", "worth county (ga.)", "sermons", "correspondence", "boats", "agriculture", "bluegrass music", "folklore", "cemeteries", "turner county (ga.)", "programs", "singing games", "hymns", "choral societies", "washington (d.c.)", "hymns, english", "interviews", "sound recordings", "sculpture", "gopher tortoise", "tobacco farms", "quilts", "african american quiltmakers", "ben hill county (ga.)", "drawings", "finster, howard", "grady county (ga.)", "event place", "african american children's games", "african americans", "colquitt county (ga.)", "irwin county (ga.)", "tift county (ga.)", "videocassettes", "aerial photographs", "photographs", "fishing", "fiddle tunes", "documentary photography", "hymn festivals"], "timestamp": "2023-07-22T07:44:32.027Z", "title": "South-Central Georgia Folklife Project collection,", "type": ["manuscript"], "url": "//lccn.loc.gov/2010655308"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/75693192", "http://www.loc.gov/item/75693192/", "https://search.catalog.loc.gov/instances/732afa30-4ecd-5b2d-9a9e-dd381fc407f6", "https://hdl.loc.gov/loc.gmd/g3924f.pm001260", "http://www.loc.gov/resource/g3924f.pm001260/"], "campaigns": [], "contributor": ["fowler, t. m. (thaddeus mortimer)"], "date": "1908", "dates": ["1908"], "description": ["Includes illus. Perspective map not drawn to scale. LC Panoramic maps (2nd ed.), 126 Available also through the Library of Congress Web site as a raster image. AACR2"], "digitized": true, "extract_timestamp": "2026-04-29T15:39:47.046Z", "group": ["gmd.mar", "catalog-split-10", "catalog", "general-maps", "main-catalog-split-10"], "hassegments": false, "id": "http://www.loc.gov/item/75693192/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd392/g3924/g3924f/pm001260.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd392/g3924/g3924f/pm001260.gif#h=150&w=195", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd392:g3924:g3924f:pm001260/full/pct:12.5/0/default.jpg#h=894&w=1164", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd392:g3924:g3924f:pm001260/full/pct:25/0/default.jpg#h=1788&w=2328"], "index": 3, "language": ["english"], "location": ["united states", 