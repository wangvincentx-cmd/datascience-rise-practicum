: ["Shows the names of some residents. Relief shown by spot heights. Copy imperfect: Sheet 1 torn along vertical fold, minor losses. Sheets 1 and 2 sectioned in 9 pieces, separated along fold lines, encapsulated in mylar, and mounted on cloth backing. Title on verso obscured by mounting. LC Land ownership maps, 231 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:12.572Z", "group": ["gmd.mar", "catalog-split-00", "catalog", "general-maps", "main-catalog-split-00"], "hassegments": false, "id": "http://www.loc.gov/item/2012593091/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd395/g3953/g3953h/la000231a.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd395/g3953/g3953h/la000231a.gif#h=150&w=199", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd395:g3953:g3953h:la000231a/full/pct:12.5/0/default.jpg#h=1005&w=1331", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd395:g3953:g3953h:la000231a/full/pct:25/0/default.jpg#h=2011&w=2662"], "index": 5, "language": ["english"], "location": ["grayson county", "kentucky", "breckinridge county", "hancock county", "united states", "ohio county"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t05:20:54.100000", "sheet", "2012593091", "2013-01-07t12:17:30"], "online_format": ["image"], "original_format": ["map"], "partof": ["cultural landscapes", "county landownership maps", "catalog", "geography and map division"], "score": 34.065193, "shelf_id": "G3953.H2G46 1887 .M6", "site": ["catalog"], "subject": ["real property", "grayson county", "cadastral maps", "kentucky", "hancock county (ky.)", "landowners", "breckinridge county", "grayson county (ky.)", "hancock county", "united states", "breckinridge county (ky.)", "ohio county (ky.)", "ohio county", "maps"], "timestamp": "2026-04-29T16:06:30.250Z", "title": "Map of Hancock County and parts of Ohio, Grayson and Breckinridge : showing eastern outline of the western coal field", "type": ["cartographic"], "url": "https://www.loc.gov/item/2012593091/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2004629233", "http://www.loc.gov/item/2004629233/", "https://search.catalog.loc.gov/instances/66c16d6d-7120-5712-ac32-f03c6726a887", "https://hdl.loc.gov/loc.gmd/g4084c.ct001308", "http://www.loc.gov/resource/g4084c.ct001308/"], "campaigns": [], "contributor": ["gest, joseph", "haviland, w. (william)"], "date": "1838", "dates": ["1838"], "description": ["Map has profile of the bottom of the Ohio River ; scale recording height of reservoirs and extent of the river's overflow ; landmarks ; ward boundaries. Map includes environs of Cincinnati including parts of Covington, Ky. and Newport, Ky. \"Latitude 39\u20705\u02b954\u02ba North. Longitude 7\u207025\u02b912\u02ba West of Washington City.\" \"Entered according to Act of Congress by Joseph Gest in the clerk's office of the District Court of Ohio.\" Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:56.333Z", "group": ["gmd.mar", "catalog-split-15", "catalog", "general-maps", "main-catalog-split-15"], "hassegments": false, "id": "http://www.loc.gov/item/2004629233/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd408/g4084/g4084c/ct001308.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd408/g4084/g4084c/ct001308.gif#h=150&w=209", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4084:g4084c:ct001308/full/pct:12.5/0/default.jpg#h=1124&w=1563", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4084:g4084c:ct001308/full/pct:25/0/default.jpg#h=2249&w=3127"], "index": 6, "language": ["english"], "location": ["covington", "cincinnati", "newport", "kentucky", "ohio", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2004629233", "2016-07-15t08:18:03", "sheet", "2025-06-06t21:19:28.900000"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "panoramic maps", "geography and map division", "cities and towns"], "score": 16.340193, "shelf_id": "G4084.C4 1838 .G4", "site": ["catalog"], "subject": ["covington", "cincinnati", "newport", "kentucky", "ohio", "united states", "covington (ky.)", "cincinnati (ohio)", "newport (ky.)", "maps"], "timestamp": "2026-04-29T15:47:23.273Z", "title": "Map of the city of Cincinnati", "type": ["cartographic"], "url": "https://www.loc.gov/item/2004629233/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2019588076", "http://www.loc.gov/item/2019588076/", "https://search.catalog.loc.gov/instances/5e7ba814-4437-562a-8af0-2b72978c7813", "https://hdl.loc.gov/loc.gmd/g4081p.ct011835", "http://www.loc.gov/resource/g4081p.ct011835/"], "campaigns": [], "contributor": ["russell & struthers"], "date": "1877", "dates": ["1877"], "description": ["Accompany by text \"Geography of Indiana\" on page 4-6. From Special geography of Indiana to accompany Monteith's school geographies, New York, A.S. Barnes & Company, 1877. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:38:58.277Z", "group": ["gmd.mar", "catalog-split-14", "catalog", "general-maps", "main-catalog-split-14"], "hassegments": false, "id": "http://www.loc.gov/item/2019588076/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd408/g4081/g4081p/ct011835.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd408/g4081/g4081p/ct011835.gif#h=98&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4081:g4081p:ct011835/full/pct:12.5/0/default.jpg#h=493&w=756", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4081:g4081p:ct011835/full/pct:25/0/default.jpg#h=986&w=1512"], "index": 7, "language": ["english"], "location": ["kentucky", "indiana", "ohio", "united states", "illinois"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2020-02-20t13:47:26", "sheet", "2019588076", "2025-06-07t09:24:11.700000"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "transportation and communication", "geography and map division"], "score": 16.340193, "shelf_id": "G4081.P2 1877 .R8", "site": ["catalog"], "subject": ["roads", "road maps", "kentucky", "indiana", "ohio", "united states", "illinois", "maps"], "timestamp": "2026-04-29T16:10:47.702Z", "title": "Ohio, Indiana, Illinois & Kentucky", "type": ["cartographic"], "url": "https://www.loc.gov/item/2019588076/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2024593567", "http://www.loc.gov/item/2024593567/", "https://search.catalog.loc.gov/instances/0e83748c-0c37-5cdd-87e3-84658d18a999", "https://hdl.loc.gov/loc.gmd/g4081p.ct007585", "http://www.loc.gov/resource/g4081p.ct007585/"], "campaigns": [], "contributor": ["wagner, john"], "date": "1835", "dates": ["1835"], "description": ["vcFY24 Pen-and-ink and watercolor on paper. Mounted on cloth. Title supplied by cataloger. Shows a canal, roads, turnpikes (complete, under construction, and proposed), railroad, seats of government, and seats of justice in Southwest Ohio and Northern Kentucky. Date presumed to be between 1832-1835 based on the inclusion of a railroad between Frankfort and Lexington, Kentucky. Beneath legend: This plat, believed to be correctly extracted from the last edition of Hough & Bourne's map of the state of Ohio, and Munsel's map of the state of Kentucky, is respectfully forwarded to the Senators in Congress from Kentucky & Ohio by their obt. hble. sevt. John Wagner. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:38:56.354Z", "group": ["gmd.mar", "catalog-split-11", "catalog", "general-maps", "main-catalog-split-11"], "hassegments": false, "id": "http://www.loc.gov/item/2024593567/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd408/g4081/g4081p/ct007585.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd408/g4081/g4081p/ct007585.gif#h=120&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4081:g4081p:ct007585/full/pct:12.5/0/default.jpg#h=697&w=874", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4081:g4081p:ct007585/full/pct:25/0/default.jpg#h=1394&w=1749"], "index": 8, "language": ["english"], "location": ["ohio", "kentucky", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2024593567", "2025-09-16t13:23:06.600000"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "transportation and communication", "geography and map division"], "score": 16.340193, "shelf_id": "G4081.P2 1835 .W3", "site": ["catalog"], "subject": ["roads", "railroads", "road maps", "kentucky", "canals", "manuscript maps", "ohio", "united states", "maps"], "timestamp": "2026-04-29T16:11:23.546Z", "title": "[Manuscript map of Ohio and Kentucky showing planned turnpikes and existing roads, canals, and railroads]", "type": ["cartographic"], "url": "https://www.loc.gov/item/2024593567/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2005625137", "http://www.loc.gov/item/2005625137/", "https://search.catalog.loc.gov/instances/20e613b5-cd86-5e83-923c-7f57ddef5ce2", "https://hdl.loc.gov/loc.gmd/g3953p.cwh00230", "http://www.loc.gov/resource/g3953p.cwh00230/"], "campaigns": [], "contributor": ["hotchkiss, jedediah"], "date": "1884", "dates": ["1884"], "description": ["General maps not showing coal mines or timber lands. Pen-and-ink on brown paper, mounted on cloth. Includes inset of \"Geological section across Elkhorn lands, from Ky. Geol. Survey, 1884.\" LC Civil War maps (2nd ed.), H230 Available also through the Library of Congress web site as raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:53.822Z", "group": ["gmd.mar", "catalog-split-15", "catalog", "general-maps", "main-catalog-split-15"], "hassegments": false, "id": "http://www.loc.gov/item/2005625137/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd395/g3953/g3953p/cwh00230.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd395/g3953/g3953p/cwh00230.gif#h=150&w=201", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd395:g3953:g3953p:cwh00230/full/pct:12.5/0/default.jpg#h=425&w=569", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd395:g3953:g3953p:cwh00230/full/pct:25/0/default.jpg#h=850&w=1139"], "index": 9, "language": ["english"], "location": ["west virginia", "pike county", "kentucky", "virginia", "ohio", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2025-06-06t21:44:05.600000", "2005-12-07t08:56:35", "2005625137"], "online_format": ["image"], "original_format": ["map"], "partof": ["hotchkiss map collection", "military battles and campaigns", "geography and map division", "catalog"], "score": 16.340193, "shelf_id": "G3953.P5 1884 .H6", "site": ["catalog"], "subject": ["pike county (ky.)", "west virginia", "pike county", "kentucky", "virginia", "ohio", "maps, manuscript", "united states"], "timestamp": "2026-04-29T15:48:49.324Z", "title": "Map of the N.C. Morse patent of eighty-six thousand acres of coal, timber, iron, etc. lands in Pike County, Kentucky ; Map of part of Kentucky and Virginia, W. Va., and Ohio showing location of coal and timber lands", "type": ["cartographic"], "url": "https://www.loc.gov/item/2005625137/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/99447487", "http://www.loc.gov/item/99447487/", "https://search.catalog.loc.gov/instances/dbb73a93-5c41-5071-bfd0-f6bf7ef19511", "https://hdl.loc.gov/loc.gmd/g4084c.cw0319000", "http://www.loc.gov/resource/g4084c.cw0319000/"], "campaigns": [], "contributor": ["united states. army. corps of engineers"], "date": "1877", "dates": ["1877"], "description": ["Detailed map showing batteries and rifle pits, common and military roads, turnpikes, city streets and names, bridges, ferries, rural houses and names of some residents, drainage, vegetation, towns, and relief by hachures. Description derived from published bibliography. Scale ca. 1:16,000. LC Civil War Maps (2nd ed.), 319 Available also through the Library of Congress web site as raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:40.720Z", "group": ["gmd.mar", "catalog-split-04", "catalog", "general-maps", "main-catalog-split-04"], "hassegments": false, "id": "http://www.loc.gov/item/99447487/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd408/g4084/g4084c/cw0319000.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd408/g4084/g4084c/cw0319000.gif#h=150&w=211", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4084:g4084c:cw0319000/full/pct:12.5/0/default.jpg#h=1021&w=1439", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4084:g4084c:cw0319000/full/pct:25/0/default.jpg#h=2042&w=2879"], "index": 10, "language": ["english"], "location": ["covington", "cincinnati", "kentucky", "ohio", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["99447487", "2015-04-24t11:35:07", "2025-06-06t18:55:25", "http://www.loc.gov/item/99447487"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "military battles and campaigns", "civil war maps", "geography and map division"], "score": 16.340193, "shelf_id": "G4084.C4 1877 .U5", "site": ["catalog"], "subject": ["covington", "cincinnati", "kentucky", "ohio", "covington (ky.)", "cincinnati (ohio)", "united states", "maps"], "timestamp": "2026-04-29T16:34:35.304Z", "title": "Map showing the military defences of Cincinnati, Covington and Newport", "type": ["cartographic"], "url": "https://www.loc.gov/item/99447487/"}], "res