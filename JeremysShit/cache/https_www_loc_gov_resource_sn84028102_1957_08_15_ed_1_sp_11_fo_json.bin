er needs So if you want plenty of hot waterfast get a fast recovery electric water heater now"], "digitized": true, "extract_timestamp": "2023-09-04T23:19:14.730Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84028102/1957-08-15/ed-1/?sp=11", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_geranium_ver02:data:sn84028102:00340580813:1957081501:0506/full/pct:3.125/0/default.jpg#h=294&w=224", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_geranium_ver02:data:sn84028102:00340580813:1957081501:0506/full/pct:6.25/0/default.jpg#h=588&w=449", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_geranium_ver02:data:sn84028102:00340580813:1957081501:0506/full/pct:12.5/0/default.jpg#h=1176&w=899", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_geranium_ver02/data/sn84028102/00340580813/1957081501/0506.xml&format=alto_xml"], "index": 11, "language": ["english"], "location": ["chardon", "united states", "geauga", "geauga county", "ohio"], "location_city": ["chardon"], "location_country": ["united states"], "location_county": ["geauga"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "1", "4", "8", "0000000011", "sn84028102"], "number_edition": ["1"], "number_lccn": ["sn84028102"], "number_page": ["0000000011"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "0", "8", "1", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "geauga record (chardon, geauga county, ohio) 1952-1962"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["geauga record (c