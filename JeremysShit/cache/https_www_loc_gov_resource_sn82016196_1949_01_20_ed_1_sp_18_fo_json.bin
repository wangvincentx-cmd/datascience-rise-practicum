iv", "source_modified": "2000-01-01T12:00:00Z", "subject": ["los angeles county (calif.)", "african american", "african americans", "los angeles county", "los angeles", "california", "newspapers", "united states"], "subject_ethnicity": ["african american"], "subject_headings": ["African Americans--California--Newspapers", "Los Angeles County (Calif.)--Newspapers", "African Americans", "California", "California--Los Angeles County", "United States--California--Los Angeles--Los Angeles"], "subjects": [{"african american": "https://www.loc.gov/search/?fa=subject:african+american&fo=json"}, {"african americans": "https://www.loc.gov/search/?fa=subject:african+americans&fo=json"}, {"california": "https://www.loc.gov/search/?fa=subject:california&fo=json"}, {"los angeles": "https://www.loc.gov/search/?fa=subject:los+angeles&fo=json"}, {"los angeles county": "https://www.loc.gov/search/?fa=subject:los+angeles+county&fo=json"}, {"los angeles county (calif.)": "https://www.loc.gov/search/?fa=subject:los+angeles+county+%28calif.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "subjects_ethnicity": [{"african american": "https://www.loc.gov/search/?fa=subject_ethnicity:african+american&fo=json"}], "timestamp": "2026-03-01T09:55:10.639Z", "title": "California eagle (Los Angeles, Calif.), January 20, 1949", "type": ["issue"], "url": "https://www.loc.gov/item/sn82016196/1949-01-20/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn82016196/", "http://lccn.loc.gov/sn82016196"], "batch": ["curiv_archylee_ver01"], "campaigns": [], "contributor": ["bass, charlotta a."], "date": "1879", "description": ["Weekly Began Mar. 8, 1879; ceased in 1966. Available online and on microfilm from the Library of Congress, Photoduplication Service, and University of California, Los Angeles,