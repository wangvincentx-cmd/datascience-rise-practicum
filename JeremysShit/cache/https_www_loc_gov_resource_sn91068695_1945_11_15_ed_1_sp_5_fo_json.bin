s said that in addition to the maintenance of tiie price level for two years that non farm families already have and are ac cumulating weekly savings through the Payroll Savings Plan of the War Finance Division of the Treasury This they claim Is proof the nonfarm front will be much better able to support itself than after the last"], "digitized": true, "extract_timestamp": "2023-08-12T17:33:29.921Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn91068695/1945-11-15/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_dill_ver02:data:sn91068695:00279559447:1945111501:0377/full/pct:6.25/0/default.jpg#h=489&w=333", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_dill_ver02:data:sn91068695:00279559447:1945111501:0377/full/pct:12.5/0/default.jpg#h=978&w=666", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_dill_ver02/data/sn91068695/00279559447/1945111501/0377.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["marion", "north carolina", "mcdowell", "mcdowell county", "united states"], "location_city": ["marion"], "location_country": ["united states"], "location_county": ["mcdowell"], "location_state": ["north carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "0", "5", "2", "0000000005", "7", "1", "9", "sn91068695"], "number_edition": ["1"], "number_lccn": ["sn91068695"], "number_page": ["0000000005"], "number_reel": ["0", "0", "2", "7", "9", "5", "5", "9", "4", "4", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["marion progress (marion, n.c.) 1909-19??", "chronicling america", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["se