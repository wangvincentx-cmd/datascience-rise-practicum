c.gov/item/2020271141/"], "campaigns": [], "date": "1922", "dates": ["[1922 TO 1965]"], "description": ["Daily Began with volume 35, number 39 (June 26, 1922); ceased October 11, 1965. Description based on: Volume 35, Number 39 (June 26, 1922); title from masthead (Chroniclingamerica.loc.gov, viewed September 28, 2020). Latest issue consulted: Volume 48, Number 66 (May 27, 1936) (Chroniclingamerica.loc.gov, viewed September 28, 2020)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:56.386Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271141/", "image_url": [], "index": 23, "language": ["english"], "location": ["indianapolis", "indiana", "marion county", "marion", "united states"], "number": ["2020271140", "2694-1880", "2020271141", "online resource", "1197974391", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the indianapolis times (indianapolis [ind.]) 1922-1965 [online resource]", "serial and government publications division"], "publication_frequency": ["daily"], "score": 63.8758, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "marion county (ind.)", "indianapolis", "indianapolis (ind.)", "indiana", "marion county", "marion", "united states"], "timestamp": "2026-05-26T21:00:49.563Z", "title": "The Indianapolis times", "type": ["title"], "url": "https://www.loc.gov/item/2020271141/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2011254382/"], "campaigns": [], "contributor": ["howland, louis,"], "date": "1884", "dates": ["[1884 TO 1927]"], "description": ["Weekly Print began in 1884; ceased in 1927. Editors: Louis Howland, <1886>; Edward E. Cooper, <1888> Numbering starts over again in July 1888. Microfilmed for the Committee on Negro Studies of the American Council of Learned Societies and Bell & Howell, by the Library of Congress, Photoduplication Service. Description based on: Vol. 1, no. 2 (July 21, 1888); title from PDF masthead (Readex America's Historical Newspapers Web site, viewed Nov. 30, 2011). Latest issue consulted: Vol. 29, no. 53 (Dec. 30, 1916) (viewed Nov. 30, 2011). Vol. 1, no. 2 (July 21, 1888); title PDF masthead (Reveal Digital website (viewed November 9, 2025) Vol. 29, no. 53 (December 30 1916) (viewed November 9, 2025)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:16.507Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2011254382/", "image_url": [], "index": 24, "language": ["english"], "location": ["indianapolis", "indiana", "marion county", "marion", "united states"], "number": ["online resource", "2011254382", "764798092", "2997-5816", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["the freeman (indianapolis [ind.];indianapolis) 1884-1927 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 63.8758, "shelf_id": "ISSN RECORD AN", "site": ["usnd"], "subject": ["newspapers", "marion county (ind.)", "journaux noirs am\u00e9ricains", "african american", "indianapolis", "indianapolis (ind.)", "journaux", "indiana", "african american newspapers", "marion county", "marion", "united states", "noirs am\u00e9ricains", "african americans"], "timestamp": "2026-05-26T20:46:43.712Z", "title": "The freeman", "type": ["title"], "url": "https://www.loc.gov/item/2011254382/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218278/"], "campaigns": [], "date": "1833", "dates": ["[1833 TO 1861]"], "description": ["Semiweekly, Jan. 1861- Began July 19, 1833; ceased in early 1861. Imprint varies: Published in Brookville, July 19, 1833-Apr. 10, 1857 and in Indianapolis, Apr. 17, 1857-1861. Publisher varies: C.F. Clarkson, <1833-1853>; Thomas A. Goodwin, <1853-1858>; J.F. Bunner, <1858>-Feb. 18, 1859; Thomas A. Goodwin, Feb. 25, 1859-Nov. 1859; Jas. H. Smith, Dec. 1859-Jan. 4, 1860; J.P. Trimble, Jan. 11, 1860-1861. \"Whig,\" <1833>; \"Abolitionist, \" <1853>. Cf. Miller, J.W. Ind. newspaper bibliography. Also issued on microfilm by Bell & Howell. Description based on: Vol. XXI, no. 42 (October 7, 1853); title from masthead (Chroniclingamerica.loc.gov, viewed April 23, 2014). Latest issue consulted: Vol. XXVI, no. 2 (December 25, 1857) (Chroniclingamerica.loc.gov, viewed April 23, 2014). Indianapolis daily American"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:25.703Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218278/", "image_url": [], "index": 25, "language": ["english"], "location": ["franklin", "franklin county", "indianapolis", "indiana", "brookville", "marion county", "marion", "united states"], "number": ["online resource", "2372-5249", "877951684", "2014218278", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Weekly Indiana American"], "partof": ["indiana american (brookville, franklin county, indiana) 1833-1861 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["semiweekly"], "score": 63.8758, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "franklin", "marion county (ind.)", "franklin county", "indianapolis", "indianapolis (ind.)", "indiana", "brookville", "marion county", "marion", "brookville (ind.)", "united states", "franklin county (ind.)"], "timestamp": "2026-05-26T20:50:11.310Z", "title": "Indiana American", "type": ["title"], "url": "https://www.loc.gov/item/2014218278/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2012254026/"], "campaigns": [], "date": "188?", "dates": ["[1880 TO 1999]"], "description": ["Weekly Description based on: Vol. 18, no. 30 (Jan. 27