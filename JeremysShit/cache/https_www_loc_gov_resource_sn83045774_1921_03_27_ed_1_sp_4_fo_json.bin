 today At conferences be tween representatives of the road and or the employees recently no agree ment was reached on a wage cut and the dispute was referred under the transportation act to the board Two othfr hearings involving nineteen small roads will be held on April 4 antl 6 It was also announced Tlies roads al ready Have reduced wages and the dis putes were brought to the board by the employees The defendant roads for the April 4 hearing include Alabama Ten nessee and Northern Cornwall Dp Queen and Eastern Northampton and Bath Northwestern of South Carolina Patapsco and Back River South Geor git and Texas Oklahoma and Eastern The roads involved in the April 6 hearing are Atlanta and St Andrews Bay Boyne City Gaylord and Alpena Brooklyn"], "digitized": true, "extract_timestamp": "2020-09-15T06:50:41.658Z", "group": ["ndnp/dlc-2014_2016", "library-of-congress-washington-dc-awardee-5"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045774/1921-03-27/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_bindweed_ver02:data:sn83045774:00271744146:1921032701:0783/full/pct:6.25/0/default.jpg#h=506&w=409", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_bindweed_ver02:data:sn83045774:00271744146:1921032701:0783/full/pct:12.5/0/default.jpg#h=1012&w=819", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_bindweed_ver02/data/sn83045774/00271744146/1921032701/0783.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["new york", "united states", "new york city", "new york county"], "location_city": ["new york"], "location_country": ["united states"], "location_county": ["new york"], "location_state": ["new york"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "0000000004", "0", "2", "7", "1", "6", "sn83045774"], "number_edition": ["1"], "num