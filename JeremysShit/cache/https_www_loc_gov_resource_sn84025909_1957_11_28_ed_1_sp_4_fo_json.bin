esented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.017402, "shard": "02", "shelf_id": "sn84025909, 1957-11-28, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/mnhi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "african americans", "ramsey", "united states", "saint paul", "african american", "minnesota"], "subject_ethnicity": ["african american"], "subject_headings": ["African Americans--Minnesota--Saint Paul--Newspapers", "African Americans", "Minnesota--Saint Paul", "United States--Minnesota--Ramsey--Saint Paul"], "subjects": [{"african american": "https://www.loc.gov/search/?fa=subject:african+american&fo=json"}, {"african americans": "https://www.loc.gov/search/?fa=subject:african+americans&fo=json"}, {"minnesota": "https://www.loc.gov/search/?fa=subject:minnesota&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"ramsey": "https://www.loc.gov/search/?fa=subject:ramsey&fo=json"}, {"saint paul": "https://www.loc.gov/search/?fa=subject:saint+paul&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "subjects_ethnicity": [{"african american": "https://www.loc.gov/search/?fa=subject_ethnicity:african+american&fo=json"}], "timestamp": "2025-07-11T03:08:55.787Z", "title": "The Saint Paul sun (St. Paul, Minn.), November 28, 1957", "type": ["issue"], "url": "https://www.loc.gov/item/sn84025909/1957-11-28/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted":