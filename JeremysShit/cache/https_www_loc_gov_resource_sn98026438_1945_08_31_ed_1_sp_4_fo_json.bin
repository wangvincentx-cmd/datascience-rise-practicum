urces": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_lantana_ver01/data/sn98026438/00541310113/1945083101/0264.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_lantana_ver01:data:sn98026438:00541310113:1945083101:0261/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/fu/batch_fu_lantana_ver01/data/sn98026438/00541310113/1945083101/0264.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn98026438/1945-08-31/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/fu/batch_fu_lantana_ver01/data/sn98026438/00541310113/1945083101/0264.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn98026438/1945-08-31/ed-1/?sp=4"], "batch": ["fu_lantana_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/florida/", "2/united states/florida/hernando/", "3/united states/florida/hernando/brooksville/"], "contributor": ["university of florida"], "date": "1945-08-31", "dates": ["1945-08-31"], "description": ["The Brooksville Sun published March 4 1932 fared as secondclass matter at the hsUffice at Brooksville Fla under Act of March 3 1879 Published Every Friday D LOVETT Publisheil 200 Year Subscription Rates Advertising Rates Upon Request T late T CLASSIFY By Bussell Kay Secretary of Fla Press Assn HM RUSSELL KAY Temptation blew into my office last week in the form of one Vernon Ramsey an extremely likeable chap who hails from Suffolk Va and ekes out a more or less honest living by selling crates baskets twine and other packinghouse supplies to fruit and vegetable folks With the gas ban lifted Vernon was making his first Florida trip since Pearl Harbor and when he offered me half of the front seat of his gas buggy for a swing through South Florida areas in return for my socalled com panionship I took him up even though I knew I was getting the best Of the deal Starting from Tampa we journeyed south stopping for a look at Paul Dickmans Coop development at Rus kin The farms are preparing for a big season packinghouses are being put in readiness to handle a heavy movement and I was surprised at the"], "digitized": true, "extract_timestamp": "2026-01-27T17:02:36.193Z", "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn98026438/1945-08-31/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_lantana_ver01:data:sn98026438:00541310113:1945083101:0264/full/pct:6.25/0/default.jpg#h=400&w=286", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_lantana_ver01:data:sn98026438:00541310113:1945083101:0264/full/pct:12.5/0/default.jpg#h=801&w=573", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_lantana_ver01/data/sn98026438/00541310113/1945083101/0264.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["hernando county", "brooksville", "hernando", "united states", "florida"], "location_city": ["brooksville"], "location_country": ["united states"], "location_county": ["hernando"], "location_state": ["florida"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "4", "0000000004", "0", "sn98026438", "5", "1"], "number_edition": ["1"], "number_lccn": ["sn98026438"], "number_page": ["0000000004"], "number_reel": ["0", "0", "5", "4", "1", "3", "1", "0", "1", "1", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "the brooksville sun (brooksville, fla.) 1932-1959", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications divis