], "score": 77.46361, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["winslow", "arizona", "newspapers", "navajo county", "winslow (ariz.)", "united states", "navajo county (ariz.)", "navajo"], "timestamp": "2026-07-22T08:02:32.462Z", "title": "Winslow daily mail", "type": ["title"], "url": "https://www.loc.gov/item/sn95060744/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271991/"], "campaigns": [], "date": "1913", "dates": ["[1913 TO 1969]"], "description": ["Weekly Began with volumne 1, number 1 (June 27, 1913); ceased April 24, 1969. Suspended publication, June 1942-<Jan. 1964>. Merged with: Holbrook tribune-news, to form: Holbrook tribune-news and Snowflake herald (Holbrook, Ariz.: 1969). Description based on: Volumne 1, Number 1 (June 27, 1913); title from masthead (Chroniclingamerica.loc.gov, viewed July 6, 2020). Latest issue consulted: Volume Eight, Number 11 (August 26, 1921) (Chroniclingamerica.loc.gov, viewed July 6, 2020). Holbrook tribune-news Holbrook tribune-news and Snowflake herald"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:53.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271991/", "image_url": [], "index": 25, "language": ["english"], "location": ["snowflake", "arizona", "navajo county", "united states", "navajo"], "number": ["2026-04-13t21:30:13", "online resource", "2692-8140", "1163616429", "2020271991"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the snowflake herald (snowflake, arizona) 1913-1969 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 52.496403, "shelf_id": "ISSN RECORD AN2.A6 S66", "site": ["usnd"], "subject": ["snowflake", "arizona", "newspapers", "navajo county", "united states", "navajo county (ariz.)", "navajo", "snowflake (ariz.)"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The Snowflake herald", "type": ["title"], "url": "https://www.loc.gov/item/2020271991/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218608/"], "campaigns": [], "date": "1895", "dates": ["[1895 TO 1900]"], "description": ["Weekly Began with volume I, no. 1 (December 12, 1895); ceased with vol. V, no. 21 (May 5, 1900). Spanish language supplement, El Argos, appears Dec. 12, 1895; it becomes a column Dec. 26, 1895, Jan. 9, 1896 and Jan. 16, 1896. Publishers: C. O. Anderson, <January 6>-April 28, 1900; H. A. Pease, May 5, 1900. Description based on: Volume I, no. 1 (December 12, 1895); title from masthead (Chroniclingamerica.loc.gov, viewed October 1, 2014). Latest issue consulted: Vol. V, no. 21 (May 5, 1900) (Chroniclingamerica.loc.gov, viewed October 1, 2014). Holbrook argus (Online) 2375-1738 (DLC) 2014218609 (OCoLC)887952309"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:27.286Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218608/", "image_url": [], "index": 26, "language": ["english", "spanish"], "location": ["arizona", "navajo county", "holbrook", "united states", "navajo"], "number": ["887898484", "online resource", "2026-04-13t21:30:13", "2014218609", "2014218608", "2375-1703"], "original_format": ["newspaper"], "partof": ["the argus (holbrook, arizona) 1895-1900 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 52.496403, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["arizona", "newspapers", "holbrook (ariz.)", "navajo county", "holbrook", "united states", "navajo county (ariz.)", "navajo"], "timestamp": "2026-05-26T20:50:29.180Z", "title": "The argus", "type": ["title"], "url": "https://www.loc.gov/item/2014218608/"}], "next_resource": {"label": "Next Issue", "url": "https://