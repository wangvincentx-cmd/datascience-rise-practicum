ce/ndnp/az/batch_az_arguingmatch_ver02/data/sn96060765/00383341917/1923092101/0489.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/sn96060765/1923-09-21/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_arguingmatch_ver02/data/sn96060765/00383341917/1923092101/0489.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_arguingmatch_ver02:data:sn96060765:00383341917:1923092101:0469/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_arguingmatch_ver02/data/sn96060765/00383341917/1923092101/0489.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/sn96060765/1923-09-21/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/az/batch_az_arguingmatch_ver02/data/sn96060765/00383341917/1923092101/0489.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn96060765/1923-09-21/ed-1/?sp=21"], "batch": ["az_arguingmatch_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arizona/", "2/united states/arizona/navajo/", "3/united states/arizona/navajo/winslow/"], "contributor": ["arizona state library, archives and public records; phoenix, az"], "date": "1923-09-21", "dates": ["1923-09-21"], "description": ["I CHURCH OF LATTER HAY SAINTS HOLBROOK COOLEY LUMBER COMPANY C P Cooley Prop With the purchase by the Cooley Lumber Company of the interests of the Hall Lumber Company of Hol brook in August of this year this City may now boast of the largest retail lumber organization in North ern Arizona The establishment of the Cooley Lumber Company dates back to 1916 when at that time the new organization bought out the Car bon City Lumber Company here The business has been under the same administration since establishment Mr C P Cooley under whose sole ownership and management the busi ness is conducted is a native of Ari zona and was born and raised in Navajo County Mr Cooley was for merly engaged in the livestock busi ness of this section and his family is one of the most prominent in this part of the State The town of Cool ey Arizona was named after his fath er Mr Cooley devotes all of his time to the business is a member of the local Chamber of Commerce and is a fraternal man He is also a member and a Director in the local Rotary Club Summed up tersely"], "digitized": true, "extract_timestamp": "2024-01-09T14:46:47.794Z", "group": ["ndnp/az", "arizona-state-university-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn96060765/1923-09-21/ed-1/?sp=21", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_arguingmatch_ver02:data:sn96060765:00383341917:1923092101:0489/full/pct:6.25/0/default.jpg#h=510&w=352", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_arguingmatch_ver02:data:sn96060765:00383341917:1923092101:0489/full/pct:12.5/0/default.jpg#h=1021&w=704", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_arguingmatch_ver02/data/sn96060765/00383341917/1923092101/0489.xml&format=alto_xml"], "index": 21, "language": ["english"], "location": ["winslow", "arizona", "navajo county", "united states", "navajo"], "location_city": ["winslow"], "location_country": ["united states"], "location_county": ["navajo"], "location_state": ["arizona"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "1", "0", "9", "0000000021", "7", "8", "sn96060765", "4"], "number_edition": ["1"], "number_lccn": ["sn96060765"], "number_page": ["0000000021"], "number_reel": ["0", "0", "3", "8", "3", "3", "4", "1", "9", "1", "7"], "online_format": ["image", "