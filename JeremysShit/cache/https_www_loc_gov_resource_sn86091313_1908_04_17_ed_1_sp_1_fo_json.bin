ed-1/?sp=1"], "batch": ["nvln_jackpot_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/nevada/", "2/united states/nevada/humboldt/", "3/united states/nevada/humboldt/lovelock/", "2/united states/nevada/pershing/", "3/united states/nevada/pershing/lovelock/"], "contributor": ["university of nevada las vegas university libraries"], "date": "1908-04-17", "dates": ["1908-04-17"], "description": ["LO _ TRIBUNE VOL XI NO 14 LOVELOCK HUMBOLDT COUNTY NEVADA FRIDAY APRIL 17 1908 FIVE CENTS PER COPY ANOTHER DEAL MADE AT JESSUP San Francisco Capitalists Buy Bandy Claim Price Said to Be 3500 and a large Stock ConsiderationBig Force of Miners Will Thoroughly Devel op the Property The fourth big deal for the Jessup district was consummated tho fore part of this week when Adolph Kunze and San Francisco associates secured an option on the Dandy claim located about two miles west of the town of Jessup The option runs for a period of 25 days and the price is 3500 with a stock consideration The Dandy claim belongs to William Opper man Eomie Cunningham J J Wilson Dr DeGruyter and T Cruse all well known Lovelockers Mr Opperman who has been in the district for the past three weeks looking after the development of bis property was in Lovelock the fore part of this week closing tne deal for bis crowd lie stated that very little work had been done on the Dandy claim as yet but that in running trenches on the surface a 20 foot ledge had been cut about three feet of the main"], "digitized": true, "extract_timestamp": "2023-06-30T14:58:00.281Z", "group": ["ndnp/nvln", "university-of-nevada-las-vegas-university-libraries-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86091313/1908-04-17/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nvln:batch_nvln_jackpot_ver01:data:sn86091313:00332891315:1908041701:0064/full/pct:6.25/0/default.jpg#h=379&w=259", "https://tile.loc.gov/image-services/iiif/service:ndnp: