ts across all sections and all jf roups Franks message of acceptance made public by Chairman John D M Hamilton of the Republican national committee sai he was accepting the new post without any prior obligation since no one had communicated with him j at the time the committee was formed recently in St Louis Mo He acknowledged that the bus iness of the program group is not to promote the interests of I any candidate nor is it to write platforms which he said is a task for state and national party con ventions Since officeholders of the party are not in its membership 1 Franks telegram said this com j mission is a body of laymen isk ed to devote themselves behind j"], "digitized": true, "extract_timestamp": "2023-08-12T17:34:20.438Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86063811/1938-01-07/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_endive_ver02:data:sn86063811:0027955839A:1938010701:0040/full/pct:3.125/0/default.jpg#h=289&w=211", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_endive_ver02:data:sn86063811:0027955839A:1938010701:0040/full/pct:6.25/0/default.jpg#h=579&w=422", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_endive_ver02:data:sn86063811:0027955839A:1938010701:0040/full/pct:12.5/0/default.jpg#h=1158&w=844", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_endive_ver02/data/sn86063811/0027955839A/1938010701/0040.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["hendersonville", "henderson", "united states", "north carolina"], "location_city": ["hendersonville"], "location_country": ["united states"], "location_county": ["henderson"], "location_state": ["north carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json",