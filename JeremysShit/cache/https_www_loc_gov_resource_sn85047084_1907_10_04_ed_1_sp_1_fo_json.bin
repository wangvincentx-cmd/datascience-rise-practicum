vice/gmd/gmd438/g4384/g4384h/ct003209.gif#h=150&w=186", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd438:g4384:g4384h:ct003209/full/pct:12.5/0/default.jpg#h=1217&w=1509", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd438:g4384:g4384h:ct003209/full/pct:25/0/default.jpg#h=2434&w=3018"], "index": 1, "language": ["english"], "location": ["honolulu", "united states", "hawaii", "honolulu harbor"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2012586639", "2025-06-07t04:55:38.200000", "2012-03-06t11:56:55"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "cities and towns", "geography and map division"], "score": 28.993853, "shelf_id": "G4384.H6 1893 .L6", "site": ["catalog"], "subject": ["honolulu harbor", "hawaii", "honolulu harbor (hawaii)", "honolulu (hawaii)", "honolulu", "united states", "maps"], "timestamp": "2026-04-29T16:04:18.784Z", "title": "Map of the lower part of the city of Honolulu and the harbor front", "type": ["cartographic"], "url": "https://www.loc.gov/item/2012586639/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2022589358", "http://www.loc.gov/item/2022589358/", "https://search.catalog.loc.gov/instances/6f097c8f-0a7c-5053-be62-bc2b887f221b", "https://hdl.loc.gov/loc.gmd/gmdtitlecolmaps.hi-020", "http://www.loc.gov/resource/gmdtitlecolmaps.hi-020/", "https://hdl.loc.gov/loc.gmd/gmdtitlecolfold.hi-020", "http://www.loc.gov/resource/gmdtitlecolfold.hi-020/"], "campaigns": [], "date": "1926", "dates": ["1926"], "description": ["This record covers single maps covering maps of Honolulu, which are not represented in the LC database by separate catalog records. This collection includes single printed maps and blueline prints and photocopies of printed or manuscript single maps as well as multi-sheet single maps, pages from periodicals, and printed facsimiles. These maps may also show various subjects, such as landowners and recreation and tourism. To request a specific map or for more information, contact a reference librarian in the Geography & Map Division (202) 707-6277 or through the \"Ask a librarian\" link through the Geography & Map Division website https://ask.loc.gov/map-geography/. Title supplied by cataloger. Maps in this collection that may be in copyright are not available online. Available also through the Library of Congress Web site as a raster image. HI-20-01 through HI-20-28."], "digitized": true, "extract_timestamp": "2026-04-29T15:17:49.207Z", "group": ["gmd/multimap", "catalog-split-12", "catalog", "multimaps", "main-catalog-split-12"], "hassegments": true, "id": "http://www.loc.gov/item/2022589358/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:hi:-0:20:hi-020:hi-020-01-01/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:hi:-0:20:hi-020:hi-020-01-01/full/pct:12.5/0/default.jpg#h=699&w=700", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:hi:-0:20:hi-020:hi-020-01-01/full/pct:25/0/default.jpg#h=1399&w=1400"], "index": 2, "language": ["english"], "location": ["honolulu", "united states", "hawaii"], "mime_type": ["image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2025-06-07t11:32:23.300000", "2024-01-31t15:32:03", "2022589358"], "online_format": ["image"], "original_format": ["map", "collection"], "other_title": ["Alternate supplied title: Hawaii title collection--drawer 20", "Alternate supplied title: Hawaii title collection--cities and towns Honolulu 1926-1958"], "partof": ["cultural landscapes", "catalog", "cities and towns", "single sheet maps, title collection", "geography and map division"], "score": 28.993853, "shelf_id": "G4384.H6 coll .M3 drawer 20", "site": ["catalog"], "subject": ["real property", "landowners", "tourist maps", "hawaii", "honolulu (hawaii)", "honolulu", "united states", "maps"], "timestamp": "2026-04-29T15:25:27.891Z", "title": "[Maps of Hawaii--cities and towns Honolulu 1926-1958]", "type": ["cartographic"], "url": "https://www.loc.gov/item/2022589358/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2022589359", "http://www.loc.gov/item/2022589359/", "https://search.catalog.loc.gov/instances/b4331200-d0fe-5e9c-aa23-eff8cedd73eb", "https://hdl.loc.gov/loc.gmd/gmdtitlecolmaps.hi-021", "http://www.loc.gov/resource/gmdtitlecolmaps.hi-021/", "https://hdl.loc.gov/loc.gmd/gmdtitlecolfold.hi-021", "http://www.loc.gov/resource/gmdtitlecolfold.hi-021/"], "campaigns": [], "date": "1960", "dates": ["1960"], "description": ["This record covers single maps covering maps of Honolulu, which are not represented in the LC database by separate catalog records. This collection includes single printed maps and blueline prints and photocopies of printed or manuscript single maps as well as multi-sheet single maps, pages from periodicals, and printed facsimiles. These maps may also show various subjects, such as landowners and recreation and tourism. To request a specific map or for more information, contact a reference librarian in the Geography & Map Division (202) 707-6277 or through the \"Ask a librarian\" link through the Geography & Map Division website https://ask.loc.gov/map-geography/. Title supplied by cataloger. Maps in this collection that may be in copyright are not available online. Available also through the Library of Congress Web site as a raster image. HI-21-11 through HI-21-28."], "digitized": true, "extract_timestamp": "2026-04-29T15:17:43.053Z", "group": ["gmd/multimap", "catalog-split-13", "catalog", "multimaps", "main-catalog-split-13"], "hassegments": true, "id": "http://www.loc.gov/item/2022589359/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:hi:-0:21:hi-021:hi-021-05-01/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:hi:-0:21:hi-021:hi-021-05-01/full/pct:12.5/0/default.jpg#h=930&w=1579", "htt