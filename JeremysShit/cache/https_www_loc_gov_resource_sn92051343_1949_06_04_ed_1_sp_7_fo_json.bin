parate catalog records. This collection includes single printed maps and photocopies of printed or manuscript single maps and may also include some multi-sheet single maps, plates from atlases, books or periodicals, and printed facsimiles. These maps may also show various subjects, such as land owners and recreation and tourism. To request a specific map or for more information, contact a reference librarian in the Geography & Map Division (202) 707-6277 or through the \"Ask a librarian\" link through the Geography & Map Division website https://ask.loc.gov/map-geography/. Title supplied by cataloger."], "digitized": true, "extract_timestamp": "2026-04-29T15:17:37.005Z", "group": ["gmd/multimap", "catalog-split-08", "catalog", "multimaps", "main-catalog-split-08"], "hassegments": true, "id": "http://www.loc.gov/item/2022594781/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:44:ct-044:ct-044-00001/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:44:ct-044:ct-044-00001/full/pct:12.5/0/default.jpg#h=687&w=497", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:44:ct-044:ct-044-00001/full/pct:25/0/default.jpg#h=1375&w=995"], "index": 11, "language": ["english"], "location": ["connecticut", "united states", "hartford"], "mime_type": ["image/tiff", "image/jpeg", "image/jp2"], "number": ["2024-05-11t20:56:50", "sheet", "2025-06-07t11:51:26", "2022594781"], "online_format": ["image"], "original_format": ["map", "collection"], "other_title": ["Alternate supplied title: Connecticut title collection--drawer 44", "Alternate supplied title: Connecticut title collection--cities and towns Hartford 1931-1949"], "partof": ["geography and map division", "catalog", "single sheet maps, title collection"], "score": 27.65541, "shelf_id": "G3784.H3 coll .M3 drawer 44", "site": ["catalog"], "subject": ["hartford", "hartford (conn.)", "tourist maps", "united states", "cities and towns", "connecticut", "maps"], "timestamp": "2026-04-29T15:32:48.014Z", "title": "[Maps of Connecticut--cities and towns Hartford 1931-1949]", "type": ["cartographic"], "url": "https://www.loc.gov/item/2022594781/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2022594782", "http://www.loc.gov/item/2022594782/", "https://search.catalog.loc.gov/instances/8488daa1-d137-59e4-a82c-2fc85b6ffa8b", "https://hdl.loc.gov/loc.gmd/gmdtitlecolfold.ct-045", "http://www.loc.gov/resource/gmdtitlecolfold.ct-045/"], "campaigns": [], "date": "1950", "dates": ["1950"], "description": ["This record covers single maps of Connecticut cities and towns, which are not represented in the LC database by separate catalog records. This collection includes single printed maps and photocopies of printed or manuscript single maps and may also include some multi-sheet single maps, plates from atlases, books or periodicals, and printed facsimiles. These maps may also show various subjects, such as land owners and recreation and tourism. To request a specific map or for more information, contact a reference librarian in the Geography & Map Division (202) 707-6277 or through the \"Ask a librarian\" link through the Geography & Map Division website https://ask.loc.gov/map-geography/. Title supplied by cataloger."], "digitized": true, "extract_timestamp": "2026-04-29T15:17:37.005Z", "group": ["gmd/multimap", "catalog-split-09", "catalog", "multimaps", "main-catalog-split-09"], "hassegments": true, "id": "http://www.loc.gov/item/2022594782/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:45:ct-045:ct-045-00001/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:45:ct-045:ct-045-00001/full/pct:12.5/0/default.jpg#h=685&w=500", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolfold:ct:-0:45:ct-045:ct-045-00001/full/pct:25/0/default.jpg#h=1370&w=1000"], "index": 12, "language": ["english"], "location": ["connecticut", "united states", "hartford"], "mime_type": ["image/tiff", "image/jpeg", "image/jp2"], "number": ["2024-05-11t20:56:55", "sheet", "2025-06-07t11:51:26", "2022594782"], "online_format": ["image"], "original_format": ["map", "collection"], "other_title": ["Alternate supplied title: Connecticut title collection--drawer 45", "Alternate supplied title: Connecticut title collection--cities and towns Hartford 1950-1960"], "partof": ["geography and map division", "catalog", "single sheet maps, title collection"], "score": 27.65541, "shelf_id": "G3784.H3 coll .M3 drawer 45", "site": ["catalog"], "subject": ["hartford", "hartford (conn.)", "tourist maps", "united states", "cities and towns", "connecticut", "maps"], "timestamp": "2026-04-29T15:32:48.014Z", "title": "[Maps of Connecticut--cities and towns Hartford 1950-1960]", "type": ["cartographic"], "url": "https://www.loc.gov/item/2022594782/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_clash_ver01/data/sn92051343/00414219597/1949060401/0137.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn92051343:00414219597:1949060401:0131/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_clash_ver01/data/sn92051343/00414219597/1949060401/0137.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn92051343/1949-06-04/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_clash_ver01/data/sn92051343/00414219597/1949060401/0137.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn92051343:00414219597:1949060401:0131/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_clash_ver01/data/sn92051343/00414219597/1949060401/0137.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn92051343/1949-06-04/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ct/batch_ct_clash_ver01/data/sn92051343/00414219597/1949060401/0137.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn92051343/1949-06-04/ed-1/?sp=7"], "batch": ["ct_clash_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/hartford/", "3/united states/connecticut/hartford/hartford/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1949-06-04", "dates": ["1949-06-04"], "description": ["iKnn irnAT Peonie who are not SAT JUNE 4 1949 THE NEW ENGLAND BULLETIN Page Seven LE TS WAKE UP POLITIC ALL Y BURKE WA TERBUR Y SCRIBE CALLS ON CITIZENS TO USE VOTE POWER By J Edward Burke Bulletin Waterbury Correspondent Yes this is election year city elections Do you realize hoyr much Ne groes have been crying how weve been oppressed discriminated against segregated etc Weve been crying for opportunities Our banner has been raised very high Give us a chance give us a chance But when the chance hit us right in the face there were very few of us who grasped it From the time of slaverys end to this present day there have been quite a few changes brought about and a great many of them by the Negroes who have tried to pro gress These things did not come by a whole lot of gift of gab gab etc blah blah etc The trouble has been that we make a great many comments but too little effort There are too few Negroes who realize just how important their vote is They consider their vote \u00e0s a bothersome task a tax or just something that"], "digitized": true, "extract_timestamp": "2023-06-01T13:35:08.785Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92051343/1949-06-04/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn92051343:00414219597:1949060401:0137/full/pct:3.125/0/default.jpg#h=289&w=213", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn92051343:00414219597:1949060401:0137/full/pct:6.25/0/default.jpg#h=578&w=426", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn92051343:00414219597:1949060401:0137/full/pct:12.5/0/default.jpg#h=1157&w=853", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_clash_ver01/data/sn92051343/00414219597/1949060401/0137.xml&format=alto_xml"], "index": 7, "language": ["italian", "english"], "location": ["united states", "hartford", "new england", "connecticut"], "location_city": ["hartford"], "location_country": ["united states"], "location_county": ["hartford"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "sn92051343", "2", "1", "4", "0000000007", "7", "9"], "number_edition": ["1"], "number_lccn": ["sn92051343"], "number_page": ["0000000007"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "9", "5", "9", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["new england bulletin (hartford, conn.) 1949-19??", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["new england bulletin (hartford, conn.) 1949-19??"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn92051343/1949-06-04/ed-1/?sp=7