 or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.141635, "shard": "05", "shelf_id": "sn86063730, 1930-07-19, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/txdn", "source_modified": "2000-01-01T12:00:00Z", "subject": ["mcallen (tex.)", "cameron county", "cameron county (tex.)", "hidalgo county", "hidalgo county (tex.)", "united states", "cameron", "harlingen", "brownsville", "mcallen", "newspapers", "harlingen (tex.)", "brownsville (tex.)", "texas"], "subject_headings": ["Brownsville (Tex.)--Newspapers", "McAllen (Tex.)--Newspapers", "Harlingen (Tex.)--Newspapers", "Cameron County (Tex.)--Newspapers", "Hidalgo County (Tex.)--Newspapers", "Texas--McAllen", "Texas--Hidalgo County", "Texas--Harlingen", "Texas--Brownsville", "Texas--Cameron County", "United States--Texas--Cameron--Brownsville"], "subjects": [{"brownsville": "https://www.loc.gov/search/?fa=subject:brownsville&fo=json"}, {"brownsville (tex.)": "https://www.loc.gov/search/?fa=subject:brownsville+%28tex.%29&fo=json"}, {"cameron": "https://www.loc.gov/search/?fa=subject:cameron&fo=json"}, {"cameron county": "https://www.loc.gov/search/?fa=subject:cameron+county&fo=json"}, {"cameron county (tex.)": "https://www.loc.gov/search/?fa=subject:cameron+county+%28tex.%29&fo=json"}, {"harlingen": "https://www.loc.gov/search/?fa=subject:harlingen&fo=json"}, {"harlingen (tex.)": "https://www.loc.gov/search/?fa=subject:harlingen+%28tex.%29&fo=json"}, {"hidalgo county": "https://www.loc.gov/search/?fa=subject:hidalgo+county&fo=json"}, {"hidalgo county (tex.)": "https://www.loc.gov/search/?fa=subject:hidalgo+county+%28tex.%29&fo=json"}, {"mcallen": "https://www.loc.gov/search/?fa=subject:mcallen&fo=json"}, {"mcallen (tex.)": "https://www.loc.gov/search/?fa=subject:mcallen+%28tex.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"texas": "https://www.loc.gov/search/?fa=subject:texas&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2025-06-10T10:45:28.952Z", "title": "Brownsville herald (Brownsville, Tex.), July 19, 1930", "type": ["issue"], "url": "https://www.loc.gov/item/sn86063730/1930-07-19/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn86063730/", "http://lccn.loc.gov/sn86063730"], "batch": ["txdn_ash_ver01"], "campaigns": [], "date": "1910", "description": ["Daily (except Sat.), <Apr. 14, 1987>- Vol. 18, no. 279 (Oct. 10, 1910)- Sunday issue for July 11, 1937 combines with Valley morning star and McAllen daily monitor and is called: Valley Sunday star; Combined issues for Sunday, July 18, 1937-July 26, 1942 called: Valley Sunday star-monitor-herald Published by Freedom Newspapers, <Apr. 14, 1987>- Issue for May 10, 1936 also called \"International seaport and airport number.\" Later editions issued with Spanish supplement called: El Heraldo de Brownsville. Sometimes called: Brownsville evening herald <Aug. 1, 1924-May 18, 1925>. Available on microfilm: New York : Recordak Corp. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. In English; also included a section in Spanish from April 20, 1914 to June 15, 1914. Description based on: Vol. 18, no. 279 (Oct. 10, 1910) Latest issue consulted: Vol. 95, no. 285 (Apr. 14, 1987)"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:13.718Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-02", "catalog", "united-states-newspaper-directory", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/sn86063730/", "image_url": [], "index": 3, "language": ["english", "spanish"], "latlong": [25.903046, -97.498884], "location": ["texas", "hidalgo county", "united states", "cameron", "brownsville", "harlingen", "cameron county", "mcallen"], "location_str": "", "lonlat": [-97.498884, 25.903046], "number": ["original", "baylor univ", "texas a&m univ, kingsville", "daughters of the republic of texas libr", "univ of texas at austin", "http://www.loc.gov/item/sn86063730/1912-01-01/ed-1/", "2026-04-13t21:30:13", "sn86099906", "10241", "2022-03-09t15:39:29", "boston pub libr", "0894-2064", "texas state libr", "kansas state hist soc, newsp proj", "12903289", "univ of texas, pan am", "microfilm master", "online resource", "center for research libraries", "http://www.loc.gov/item/sn86063730/1937-01-31/ed-1/", "2025-05-09t12:48:08.015499", "microfilm service copy", "sn86063730"], "original_format": ["newspaper"], "other_title": ["Valley Sunday star", "Valley Sunday star-monitor-herald", "Brownsville evening herald", "Brownsville daily herald"], "partof": ["chronicling america", "directo