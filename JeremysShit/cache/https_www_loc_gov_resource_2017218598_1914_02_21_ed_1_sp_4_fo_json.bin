 post 2692-675X (DLC) 2020271965 (OCoLC)1160004125"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:52.256Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271964/", "image_url": [], "index": 7, "language": ["english"], "location": ["alaska", "united states", "seward"], "number": ["2692-6733", "1160004269", "2020271965", "online resource", "2026-04-13t21:30:13", "2020271963", "2020271964"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the seward gateway (seward, alaska) 1914-1917 [online resource]"], "publication_frequency": ["daily"], "score": 35.12464, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["united states", "alaska", "seward (alaska)", "seward", "newspapers"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The Seward gateway", "type": ["title"], "url": "https://www.loc.gov/item/2020271964/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271965/"], "campaigns": [], "date": "1917", "dates": ["[1917 TO 1918]"], "description": ["Daily (except Sunday) Began with vol. 11, no. 65 (February 1, 1917); ceased with volume XI, number 226 (January 17, 1918). \"Independent.\" Cf. Ayer, 1918. Vol. 11, No. 65 (February 1, 1917); title from masthead (Chroniclingamerica.loc.gov, viewed June 27, 2020). Volume XI, Number 226 (January 17, 1918) (Chroniclingamerica.loc.gov, viewed June 27, 2020). Seward gateway daily edition, and the Alaska weekly post 2641-9696 (DLC) 2019218590 (OCoLC)1088563576"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:52.256Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271965/", "image_url": [], "index": 8, "language": ["english"], "location": ["alaska", "united states", "seward"], "number": ["2019218590", "1160004125", "2020271965", "o