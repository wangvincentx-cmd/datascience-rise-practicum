"related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/mm2022086540", "http://www.loc.gov/item/mm2022086540/", "https://openn.library.upenn.edu/Data/0007/html/SCMS0142.html"], "campaigns": [], "contributor": ["mcalpine, william j. (william jarvis)"], "description": ["Letterbooks containing correspondence, memoranda, interim and final project reports, construction diagrams, measurements and data sets, and cost and expense tabulations and reports.  Documents McAlpine's work as chief or consulting civil engineer on aqueduct, bridge, canal, and dry dock projects, primarily in New York State and Chicago, Illinois.  Projects include the Albany Water Works, Albany, New York; dry docks, Brooklyn Navy Yard (New York Naval Shipyard) Brooklyn, New York; Brooklyn Water Works, Brooklyn, New York; Chicago Water Works, Chicago, Illinois; Croton Aqueduct, New York; Erie Canal, New York; and the Harlem Bridge (Washington Bridge), New York, New York."], "digitized": true, "extract_timestamp": "2025-05-24T06:01:48.494Z", "group": ["catalog-split-07", "catalog", "main-catalog-split-07"], "hassegments": false, "id": "http://lccn.loc.gov/mm2022086540", "image_url": [], "index": 1, "language": ["english"], "location": ["croton aqueduct", "new york", "washington bridge", "erie canal", "albany", "chicago", "illinois"], "number": ["mm2022086540", "2025-05-22t15:10:13"], "original_format": ["manuscript/mixed material", "collection"], "other_title": ["William J. McAlpine papers"], "partof": ["catalog", "manuscript division"], "score": 27.3759, "shelf_id": "http://lccn.loc.gov/mm2022086540", "site": ["catalog"], "subject": ["erie canal (n.y.)", "design and construction", "canals", "albany", "chicago", "croton aqueduct (n.y.)", "brooklyn (new york, n.y.)", "albany (n.y.)", "new york", "water works", "illinois", "new york naval shipyard", "new york (state)", "water-supply", "waterworks", "chicago (ill.)", "bridges", "civil engineering", "aqueducts", "dry docks", "washington bridge (new york, n.y.)"], "timestamp": "2025-05-24T06:03:50.170Z", "title": "William J. McAlpine letterbooks, 1837-1861", "type": ["manuscript"], "url": "//lccn.loc.gov/mm2022086540"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2010651409/", "http://www.loc.gov/item/2010651409/", "http://www.loc.gov/pictures/item/2010651409/", "https://www.loc.gov/pictures/collection/cph/item/2010651409/", "http://www.loc.gov/pictures/collection/cph/item/2010651409/", "http://www.loc.gov/resource/ppmsca.25528/", "https://hdl.loc.gov/loc.pnp/ppmsca.25528", "http://lccn.loc.gov/2010651409"], "campaigns": [], "contributor": ["dalrymple, louis"], "date": "1901-05-15", "dates": ["1901-05-15", "1901"], "description": ["1 print : chromolithograph. | Illustration shows a large elderly colonial man labeled \"N.Y.\" sitting atop buildings on New York City's waterfront, strings attached to his fingers extend to ships at dock and beyond, presumably to overseas connections. In the background is a small figure labeled \"Neptune\" holding a trident and standing on Chicago's waterfront area, with a sign stating \"Chicago 1000 miles to the sea\" and with factories spewing thick black smoke."], "digitized": true, "extract_timestamp": "2021-08-24T23:50:47.902Z", "group": ["cph", "catalog-split-12", "catalog", "miscellaneous-items-high-demand", "main-catalog-split-12", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2010651409/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528_150px.jpg#h=150&w=116", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528t.gif#h=150&w=116", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528r.jpg#h=640&w=494", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528v.jpg#h=1024&w=790"], "index": 2, "language": ["english"], "location": ["new york", "chicago", "illinois", "new york city"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/16506129", "2010-10-18t08:12:10", "2010651409"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "prints & photographs online catalog (library of congress)", "prints and photographs division", "miscellaneous items in high demand"], "score": 25.966146, "shelf_id": "Illus. in AP101.P7 1901 (Case X) [P&P]", "site": ["pictures", "catalog"], "subject": ["shipping", "color", "new york (state)", "chromolithographs", "magazine covers", "periodical illustrations", "new york (n.y.)", "chicago (ill.)", "new york", "symbolic representation", "cartoons (commentary)", "tridents"], "timestamp": "2022-05-02T05:35:51.632Z", "title": "The Chicago Neptune", "url": "https://www.loc.gov/item/2010651409/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/afc2011062.afc2011062_00387_ms01/", "http://www.loc.gov/item/2017655527/", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr01", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_ph/", "http://lccn.loc.gov/2017655527", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr02", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr03", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr01/", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr02/", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr03/"], "campaigns": [], "contributor": ["halker, bucky", "keane, jimmy", "occupational folklife project"], "date": "2013-01-01", "dates": ["2013"], "description": ["James \"Jimmy\" Keane, a prominent figure on the Irish music scene in Chicago and Ireland, discusses his career as an iron worker and member of Local 1 of the Iron Workers International Union. Keane, who was injured after ten years in the trade, then turned to music and selling real estate as a career. Keane's father, Jimmy \"Horse\" Keane, was a Local 1 member killed on the job in Chicago. Jimmy's three brothers also work in the iron trade. Jimmy Keane also discusses the music scene and the role of unions in America."], "digitized": true, "extract_timestamp": "2020-09-20T12:15:20.851Z", "group": ["afc/2011062", "catalog-split-08", "catalog", "iron-workers", "main-catalog-split-08", "main-catalog"], "hassegments": true, "id": "http://www.loc.gov/item/2017655527/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2011062/afc2011062_00387/afc2011062_00387_ph/afc2011062_00387_ph01.gif", "https://tile.loc.gov/storage-services/service/afc/afc2011062/afc2011062_00387/afc2011062_00387_ph/afc2011062_00387_ph01.gif#h=150&w=227", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:12.5/0/default.jpg#h=249&w=378", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:25/0/default.jpg#h=499&w=756", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:50/0/default.jpg#h=999&w=1512", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:100/0/default.jpg#h=1998&w=3024"], "index": 3, "language": ["english"], "location": ["chicago", "illinois", "middle west"], "mime_type": ["image/jpeg", "image/jp2", "audio/mp3", "image/gif", "audio/wav", "application/pdf", "application/x-audio"], "number": ["online resource", "2018-10-24t17:32:53", "2017655527"], "online_format": ["image", "audio", "pdf"], "original_format": ["sound recording"], "partof": ["american folklife center", "cultural traditions of ironworkers in america's upper midwest", "occupational folklife project", "catalog"], "score": 25.196415, "shelf_id": "http://lccn.loc.gov/2017655527", "site": ["catalog"], "subject": ["humor in the workplace", "self-employed", "industrial relations", "wages", "oral histories", "social life and customs", "chicago", "employees", "professional associations", "apprenticeship programs", "training of", "manners and customs", "labor unions", "corporations", "middle west", "songs", "industrial safety", "irish american labor union members", "illinois", "interviews", "color", "blue collar workers", "ironwork", "keane, jimmy", "personal narratives", "irish americans", "chicago (ill.)", "employee rights", "music", "work environment", "labor contract", "digital photographs", "work and family", "iron and steel workers", "event place", "hazardous occupations", "interviews (sound recordings)"], "timestamp": "2022-04-27T11:35:06.573Z", "title": "James Robert Keane interview conducted by Clark Douglas Halker, 2013-01-13.", "url": "https://www.loc.gov/item/2017655527/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/mm77035121", "http://www.loc.gov/item/mm77035121/", "https://hdl.loc.gov/loc.mss/collmss.ms000067"], "campaigns": [], "contributor": ["olmsted, john", "olmsted, gideon", "olmsted, frederick law"], "description": ["Correspondence, letterbooks, journals, drafts of articles and books, speeches and lectures, biographical and genealogical data, business papers, legal and financial papers, scrapbooks, printed material, maps, drawings, and other papers encompassing Olmsted's career and private life. The papers focus on Olmsted's career as a landscape architect, specifically as a designer of parks and the grounds of private estates and public buildings and as a city and regional planner.  Includes material pertaining to his designs chiefly of Central Park in New York, N.Y., of the area surrounding Niagara Falls, N.Y., of the U.S. Capitol grounds, Washington, D.C., and of the grounds of the World's Columbian Exposition, Chicago, Ill., 1893.  Material pertains, in part, to work undertaken by Olmsted and the firms of Olmsted and Vaux (1858), Frederick Law Olmsted (1858-1884), F.L. and J.C. Olmsted (1884-1889), F.L. Olmsted and Company (1889-1893), Olmsted, Olmsted, and Eliot (1893-1897), F.L. and J.C. Olmsted (1897-1898), and Olmsted Brothers (1898-1961).  Also documents Olmsted's writings, his investigation of slavery in the South (1850s), his role as general secretary of the U.S. Sanitary Commission during the Civil War, and his work as superintendent of John C. Fre\u0301mont's gold mining estates in Mariposa, Calif. Olmsted family papers include a journal and other papers of Gideon Olmsted documenting his adventures as a privateer during the Revolutionary war; journals kept by Frederick Law Olmsted's father, John, recording activities of the Olmsted family as well as local and national events; and correspondence of John Olmsted (father), John Hull Olmsted (brother), Frederick Law Olmsted, Jr. (son), and John Charles Olmsted (nephew). Correspondents include Henry W. Bellows, Samuel Bowles, Charles Loring Brace, Daniel Hudson Burnham, H.W.S. Cleveland, George William Curtis, Charles A. Dana, Edwin Lawrence Godkin, A.H. Green, Edward Everett Hale, William James, Clarence King, Frederick John Kingsbury, Frederick Newman Knapp, Charles Follen McKim, Charles Eliot Norton, Whitelaw Reid, H.H. Richardson, Charles N. Riotte, Carl Schurz, George Templeton Strong, George Washington Vanderbilt, Calvert Vaux, Henry Villard, George E. Waring, Jr., and Katherine Prescott Wormeley."], "digitized": true, "extract_timestamp": "2025-05-25T06:00:47.553Z", "group": ["catalog-split-04", "catalog", "main-catalog-split-04"], "hassegments": false, "id": "http://lccn.loc.gov/mm77035121", "image_url": [], "index": 4, "language": ["english"], "location": ["mariposa", "ontario", "california", "new york", "united states", "niagara falls", "central park", "washington d.c.", "chicago", "illinois", "southern states"], "number": ["2025-05-23t09:59:54", "mm77035121"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["catalog", "manuscript division"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/mm77035121", "site": ["catalog"], "subject": ["cleveland, h. w. s.", "riotte, carl nicolaus", "washington (d.c.)", "18th century", "wormeley, katherine prescott", "henry hobson)", "mckim, charles follen", "fr\u00e9mont, john charles", "design and construction", "california", "kingsbury, frederick john", "privateering", "frederick law olmsted (firm)", "chicago, ill.)", "andrew haswell)", "curtis, george william", "godkin, edwin lawrence", "united states capitol (washington, d.c.)", "richardson, h. h.", "f.l. and j.c. olmsted (firm)", "revolution", "hale, edward everett", "chicago", "central park (new york, n.y.)", "city planning", "bellows, henry w.", "vaux, calvert", "gold discoveries", "schurz, carl", "mariposa (calif.)", "health aspects", "naval operations", "burnham, daniel hudson", "waring, george e.", "f.l. olmsted and company", "olmsted, frederick law", "exhibitions", "new york", "bowles, samuel", "world's columbian exposition", "parks", "knapp, frederick newman", "green, a. h.", "olmsted brothers", "illinois", "regional planning", "new york (state)", "slavery", "olmsted, john charles", "mariposa", "landscape architecture", "george edwin)", "reid, whitelaw", "norton, charles eliot", "james, william", "correspondence", "united states", "gold mines and mining", "dana, charles a.", "horace william shaler)", "charles anderson)", "strong, george templeton", "olmsted family", "olmsted and vaux (firm)", "king, clarence", "villard, henry", "niagara falls (n.y. and ont.)", "history", "vanderbilt, george washington", "united states sanitary commission", "olmsted, john hull", "civil war", "henry whitney)", "olmsted, olmsted, and eliot", "southern states", "brace, charles loring"], "timestamp": "2025-05-25T06:04:13.927Z", "title": "Frederick Law Olmsted papers, 1777-1952", "type": ["manuscript"], "url": "//lccn.loc.gov/mm77035121"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/mm79032243", "http://www.loc.gov/item/mm79032243/", "https://search.catalog.loc.gov/instances/738e29de-abad-5d65-9aa6-686dafcb6951", "https://link.gale.com/apps/collection/6DDT/SAS?u=loc_main&sid=SAS"], "campaigns": [], "contributor": ["mckim, charles follen"], "description": ["Correspondence, letterbooks, memoranda, diary transcript, notes, legal and financial records, sketches, drawings, photographs, and other papers relating chiefly to the firm of McKim, Mead, & White, New York, New York. Documents McKim's designs for the Boston Public Library and Symphony Hall, Boston, Mass.; Columbia University's Morningside Heights campus and the University Club, New York, New York; Rhode Island State House, Providence, Rhode Island; restoration of the White House, Washington, D.C.; and the World's Columbian Exposition, Chicago, Illinois, 1893. Also documents McKim's work on the U.S. Senate Commission for the Improvement of the District of Columbia concerned with the location and treatment of public buildings and grounds along the Mall and his membership on the Grant Memorial Commission. Includes material pertaining to McKim's membership in societies and clubs including the American Institute of Architects, the Century Club, and the University Club. Subjects include the development of American architecture, establishment of the American Academy in Rome, and efforts of abolitionists to provide aid for newly freed slaves in the years following the Civil War. Diary includes McKim's account of an 1863 walking tour with Francis Jackson Garrison and Wendell Phillips Garrison to the Gettysburg battlefield and other areas in eastern Pennsylvania. Family correspondents include McKim's daughter, Margaret McKim; his father, J. Miller M'Kim; and other family members. Other correspondents include Daniel Chester French, John La Farge, Francis Jackson Garrison, Wendell Phillips Garrison, William Lloyd Garrison, Francis Davis Millet, Charles Moore, H. Siddons Mowbray, Frederick Law Olmsted, and Augustus Saint-Gaudens."], "digitized": true, "extract_timestamp": "2026-05-27T11:39:20.039Z", "group": ["catalog-split-08", "catalog", "main-catalog-split-08"], "hassegments": false, "id": "http://lccn.loc.gov/mm79032243", "image_url": [], "index": 5, "language": ["english"], "location": ["massachusetts", "pennsylvania", "rhode island", "boston", "new york", "united states", "the mall", "rome", "washington d.c.", "gettysburg", "italy", "chicago", "illinois"], "number": ["2026-05-26t17:44:12.600000", "mm79032243"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["catalog", "manuscript division"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/mm79032243", "site": ["catalog"], "subject": ["rhode island state house (providence, r.i.)", "public buildings", "washington (d.c.)", "pennsylvania", "american academy in rome", "mckim, mead, & white", "mowbray, h. siddons", "libraries", "boston", "music-halls", "mckim family", "chicago, ill.)", "italy", "chicago", "french, daniel chester", "millet, francis davis", "mckim, margaret", "senate", "capital and capitol", "universities and colleges", "white house (washington, d.c.)", "saint-gaudens, augustus", "olmsted, frederick law", "garrison, wendell phillips", "new york", "columbia university", "american institute of architects", "exhibitions", "mall, the (washington, d.c.)", "study and teaching", "m'kim, j. miller", "garrison, william lloyd", "world's columbian exposition", "massachusetts", "parks", "reconstruction (u.s. history,)", "illinois", "garrison, francis jackson", "new york (state)", "grant memorial commission", "congress", "architecture", "conservation and restoration", "james miller)", "moore, charles", "freed persons", "architectural firms", "societies, etc", "correspondence", "united states", "gettysburg (pa.)", "african americans", "history", "century club (new york, n.y.)", "harry siddons)", "civil war", "symphony hall (boston, mass.)", "university club (new york, n.y.)", "rhode island", "description and travel", "rome", "clubs", "boston public library", "commission for the improvement of the district of columbia", "19th century", "la farge, john"], "timestamp": "2026-05-27T11:48:52.327Z", "title": "Charles Follen McKim papers, 1838-1929", "type": ["manuscript"], "url": "//lccn.loc.gov/mm79032243"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2023655343", "http://www.loc.gov/item/2023655343/", "https://search.catalog.loc.gov/instances/9cefb0b0-347c-5c42-8c28-443ae250a473", "https://hdl.loc.gov/loc.afc/collafc.afc2022012"], "campaigns": [], "contributor": ["battle, shadawn", "joyner, sherri", "gilliam, gbari", "scott k.", "sloan, ronnie", "bobb, merlin", "malapit, michael", "hall, rama mahesh", "foaad, leigh", "carter chu, eric", "lazee, ken", "melendez, miley", "tate, jay jay", "ferreira, ami tsunami", "verdoodt, vanessa neva", "vaca, jos\u00e9", "chambers, marlon", "ultra nat\u00e9", "dunnington, geno", "benedetti, cristina", "smith, jesse", "stewart, wesley", "paulos, angelo jiwa", "blancaflor, cynthia", "reyes, rose", "d.j. slugo", "de clive-lowe, mark", "parisi, dolores ninja", "blondet, thomas", "joyner, michael", "lomelin, andrea", "grant, arnez", "american folklife center", "feliciano, frankie", "parks, charles lee", "riddick, will (william keith)", "woods, tyrone", "guerrero, jake", "daniels, tre", "johnson, sire dhone", "mendoza, rhonda", "gar\u00e7on, jeffery miyake-mugler", "mendoza, juliet e.", "valenzuela, lorena", "forman, kelli", "george-wheeler, hannah", "lopez, jackie", "dj underdog", "pel\u00e1ez sordo, claudio", "ishida, h. k.", "neff, ad\u00e9 e.", "kell-abrams, maya", "huff, ricki", "randolph, chris chosen", "nouri, farid", "rp boo", "twan-twan", "creation global (dance group)", "sarakul, ryan", "andrew w. mellon foundation", "creative netwerk (organization)", "dozier, brandon marcelas", "yarbrough, decimus", "kenlo key", "dj paul howard", "harris, jamal m.", "belle, jonathan", "ferreira, cody coflo", "kg superstar", "kirk, wayne weezy", "dj gargamel", "huggins, kimyon", "basa, ray", "prosper, d. (derick)", "brickhouse, junious", "harris, isaac crossfire", "urban artistry", "kumta, prem", "becquette, wyatt", "james, bradford", "croshaw, ren (lauren lucia)", "hlinkov\u00e1, michaela", "pause eddie", "sugiyama, emiko", "williams, wayne", "garcia, leyda", "haynes, jeremiah supaman", "guerrero, noah", "eddy, john f.", "morris, oji", "kosmik", "torrence, kim", "simon, morgan", "cummings, maren", "boyd, jaron", "dj nativesun", "liao, leslie", "caballero, dan", "burns, rita jean kelly"], "date": "1994", "dates": ["1994"], "description": ["\"Follow the Music: Exploring Multi-Linear Legacies of House Culture\" aims to expand upon the common narratives documenting a wider range of community voices that define the multi-linear legacies of House Music and Dance Cultures (HMDC). This collection documents the culture of Black and Brown urban communities through dance forms including Breakin', House, Hip Hop, Popping/Boogaloo, and locking. This includes oral histories documenting community voices in Washington, D.C.; Baltimore, Maryland; Chicago, Illinois; New York, New York; Los Angeles, California; and Oakland, California."], "digitized": true, "extract_timestamp": "2026-06-16T06:37:55.629Z", "group": ["catalog-split-01", "catalog", "main-catalog-split-01"], "hassegments": false, "id": "http://lccn.loc.gov/2023655343", "image_url": [], "index": 6, "language": ["english"], "location": ["baltimore", "los angeles", "california", "new york", "chicago", "maryland", "washington d.c.", "oakland", "united states", "illinois"], "number": ["2026-06-15t13:44:13.100000", "2023655343"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["american folklife center", "catalog"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/2023655343", "site": ["catalog"], "subject": ["ghetto house (music)", "washington (d.c.)", "hip-hop", "california", "social aspects", "oral histories", "oakland", "chicago", "video recordings", "gay culture", "new york", "maryland", "voguing (dance)", "illinois", "hip-hop dance", "interviews", "color", "new york (state)", "electronic dance music", "nightclubs", "united states", "baltimore", "gay community", "los angeles", "digital photographs", "music and dance", "house music"], "timestamp": "2026-06-16T07:09:11.517Z", "title": "Follow the Music : Exploring Multi-Linear Legacies of House Culture : Community Collections Grant Project, 1994-2023,", "type": ["manuscript"], "url": "//lccn.loc.gov/2023655343"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930101401/0403.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897664:1930101401:0403/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930101401/0403.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn84020097/1930-10-14/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930101401/0403.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897664:1930101401:0403/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930101401/0403.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn84020097/1930-10-14/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897664/1930101401/0403.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020097/1930-10-14/ed-1/?sp=1"], "batch": ["iune_fluorite_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/new york/", "2/united states/new york/new york/", "3/united states/new york/new york/new york/", "1/united states/illinois/", "2/united states/illinois/cook/", "3/united states/illinois/cook/chicago/"], "contributor": ["university of illinois at urbana-champaign library, urbana, il"], "date": "1930-10-14", "dates": ["1930-10-14"], "description": ["DEMONSTRATE THURS 2PM WZF SSi iffll01INlllllfll3iX For a Fight Against Starva tion for the Workers Un employment Insurance Bill Vol VII No 247 Into the Factories DOLITICAL fakers of the three capitalist partiesrepublican demo cratic and socialistare resorting to every conceivable method of winning votes Graft exposures and prohibition still hold first place in their joint efforts to fool the workers and poor farmers But as the campaign develops and the workers begin to see through these fake issues these political demagogues will deal more and more with the real issues of unemployment wage cuts etc but in such a manner as to confuse the workers and to prevent if possible a real struggle of the masses for immediate relief In their campaign however it is not only the lying character of their promises that constitutes a danger but especially their facilities for reaching the masses of the voters They have unlimited financial resources They have a large staff of publicity agents They control the capitalist press which daily reaches millions of voters The radio stations with state and national hookups are at their command The movie theatres fed by the talking newsreels are the means of reach ing many"], "digitized": true, "extract_timestamp": "2025-05-21T10:20:26.285Z", "group": ["ndnp/iune", "university-of-illinois-at-urbana-champaign-library-urbana-il-awardee"], "hassegments": false, "id": "http://www.loc.gov/r