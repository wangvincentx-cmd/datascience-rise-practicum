mber": 1, "url": "https://www.loc.gov/resource/sn87065702/1921-03-24/ed-1/?fo=json&sp=1"}, {"number": "...", "url": "https://www.loc.gov/resource/sn87065702/1921-03-24/ed-1/?fo=json&sp=4"}, {"number": 5, "url": "https://www.loc.gov/resource/sn87065702/1921-03-24/ed-1/?fo=json&sp=5"}, {"number": 6, "url": "https://www.loc.gov/resource/sn87065702/1921-03-24/ed-1/?fo=json&sp=6"}, {"number": 7, "url": null}, {"number": 8, "url": "https://www.loc.gov/resource/sn87065702/1921-03-24/ed-1/?fo=json&sp=8"}, {"number": 9, "url": "https://www.loc.gov/resource/sn87065702/1921-03-24/ed-1/?fo=json&sp=9"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": "https://www.loc.gov/resource/sn87065702/1921-03-24/ed-1/?fo=json&sp=6", "results": "7 - 7", "to": 7, "total": 16}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn87065702/1921-03-17/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/2015669142", "http://www.loc.gov/item/2015669142/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0043", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0043_mv10/", "http://www.loc.gov/resource/afc2010039text.afc2010039_crhp0043_gaither_transcript/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0043/"], "campaigns": [], "contributor": ["mosnier, joseph", "civil rights history project (u.s.)", "gaither, thomas walter"], "date": "2011", "dates": ["2011"], "description": ["Thomas Gaither recalls growing up in Great Falls, South Carolina, attending Claflin College, and leading the college's National Association for the Advancement of Colored People (NAACP) chapter. He remembers the student sit-ins in Orangeburg, South Carolina, joining the Congress of Racial Equality (CORE), and being arrested for protesting in Hollywood, Florida. He discusses organizing the Freedom Rides, his belief in nonviolence, and earning his PhD in biology at the University of Iowa."], "digitized": true, "extract_timestamp": "2025-06-25T06:00:33.482Z", "group": ["catalog-split-04", "catalog", "afc2010039", "main-catalog-split-04", "civil-rights-history-project"], "hassegments": true, "id": "http://www.loc.gov/item/2015669142/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0043/afc2010039_crhp0043_mv10.gif", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0043_gaither_transcript:0001/full/pct:25/0/default.jpg#h=443&w=339", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0043_gaither_transcript:0001/full/pct:50/0/default.jpg#h=887&w=678", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0043_gaither_transcript:0001/full/pct:100/0/default.jpg#h=1774&w=1356"], "index": 7, "language": ["english"], "location": ["south carolina", "pennsylvania", "hollywood", "pittsburgh", "orangeburg", "united states", "florida", "southern states"], "mime_type": ["image/gif", "image/jpeg", "image/jp2", "application/x-video"], "number": ["2015669142", "online resource", "2025-06-23t18:46:16", "http://www.loc.gov/item/afc2010039_crhp0043", "2020-02-20t10:11:16", "http://www.loc.gov/item/2015669142"], "online_format": ["image", "video"], "original_format": ["film, video"], "partof": ["american folklife center", "catalog", "civil rights history project"], "score": 33.212837, "shelf_id": "http://lccn.loc.gov/2015669142", "site": ["catalog"], "subject": ["hollywood", "20th century", "filmed interviews", "oral histories", "claflin college (orangeburg, s.c.)", "video recordings", "nonviolence", "civil rights movements", "congress of racial equality", "orangeburg", "gaither, thomas walter", "florida", "civil rights demonstrations", "south carolina", "interviews", "national association for the advancement of colored people", "freedom rides", "united states", "history", "african american civil rights workers", "african american college students", "southern states"], "timestamp": "2025-06-25T06:01:54.502Z", "title": "Thomas Walter Gaither oral history interview conducted by Joseph Mosnier in Pittsburgh, Pennsylvania, 2011 September 12", "type": ["moving image"], "url": "https://www.loc.gov/item/2015669142/"}, {"access_restricted": true, "aka": ["https://www.loc.gov/pictures/item/86706877/", "http://www.loc.gov/item/86706877/", "http://www.loc.gov/pictures/item/86706877/", "https://www.loc.gov/pictures/collection/coll/item/86706877/", "http://www.loc.gov/pictures/collection/coll/item/86706877/", "http://lccn.loc.gov/86706877"], "campaigns": [], "contributor": ["frances benjamin johnston photograph collection (library of congress)", "johnston, frances benjamin"], "date": "1927", "dates": ["1927"], "description": ["698 photoprints : gelatin silver ; 26 x 36 cm. or smaller. | Johnston's photos hanging on walls of exhibit hall. Includes exhibits held at Virginia Museum of Fine Arts; Baltimore Museum; Gibbs Gallery in Charleston, S.C.; \"Great Houses\" of New York exhibit at the Library of Congress; AAA-Garden Club of Virginia."], "digitized": true, "extract_timestamp": "2026-03-07T13:36:08.632Z", "group": ["coll", "catalog-split-01", "catalog", "groups-of-images", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/86706877/", "image_url": ["https://www.loc.gov/static/images/original-format/group-of-images.svg"], "index": 8, "language": ["english"], "location": ["south carolina", "baltimore", "charleston", "richmond", "new york", "virginia", "maryland", "united states"], "mime_type": ["image/jpg"], "number": ["86706877", "2021-10-20t14:14:37", "http://www.loc.gov/item/86706877", "http://www.loc.gov/item/11510913"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "prints and photographs division", "groups of images (lots)", "lot 11749"], "score": 29.714962, "shelf_id": "LOT 11749 (G) [P&P]", "site": ["pictures", "catalog"], "subject": ["baltimore", "sout