; Columbia, SC"], "contributors": [{"university of south carolina; columbia, sc": "https://www.loc.gov/search/?fa=contributor:university+of+south+carolina%3B+columbia,+sc&fo=json"}], "created_published": ["Charleston, S.C., March 24, 1921"], "date": "1921-03-24", "date_issued": "1921-03-24", "dates": [{"1921-03-24": "https://www.loc.gov/search/?dates=1921-03-24/1921-03-24&fo=json"}], "dates_of_publication": "1837-1948", "description": ["Charleston, S.C."], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2024-05-12T00:30:24.684Z", "extract_urls": ["file:/service/ndnp//scu/batch_scu_dragonfruit_ver01/data/sn87065702/00516991148/1921032401/1921032401_1.xml#ndnp/scu"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers", "Periodicals"], "group": ["ndnp/scu", "university-of-south-carolina-columbia-sc-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn87065702/1921-03-24/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_dragonfruit_ver01:data:sn87065702:00516991148:1921032401:0180/full/pct:6.25/0/default.jpg#h=267&w=206", "https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_dragonfruit_ver01:data:sn87065702:00516991148:1921032401:0180/full/pct:12.5/0/default.jpg#h=534&w=412", "https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_dragonfruit_ver01:data:sn87065702:00516991148:1921032401:0180/full/pct:25/0/default.jpg#h=1068&w=824"], "index": 7, "item": {"batch": ["scu_dragonfruit_ver01"], "call_number": ["BX8201 .S6"], "contributor_names": ["University of South Carolina; Columbia, SC"], "contributors": ["Methodist Episcopal Church, South"], "created_published": ["Charleston, S.C., March 24, 1921"], "date": "1837", "date_issued": "1921-03-24", "dates": ["1921-03-24"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers", "Periodicals"], "language": ["eng"], "library_of_congress_control_number": "sn87065702", "location": ["Southern States", "Georgia--Augusta", "Georgia--Macon"], "medium": "16 pages", "newspaper_title": ["Southern Christian advocate"], "notes": ["Weekly", "Began with: Vol. I, number 1 (June 24, 1837); ceased with: Volume 112, number 46 (November 18, 1948).", "\"Began as a newspaper but gradually developed a periodical format\"--Moore, South Carolina newspapers, page 210.", "Published: Charleston, South Carolina, 1837-1862 and 1878-1886; Augusta, Georgia, 1862-1865; Macon, Georgia, 1866-1878; Columbia, South Carolina, 1887-1894, 1899-1900 and 1919-1948; Greenville, South Carolina, 1895-1898 and 1912-1914; Orangeburg, South Carolina, 1901-1902; Spartanburg, South Carolina, 1903-1912; and Anderson, South Carolina, 1915-1918.", "Volumes for 1866- numbered continuously as whole no. 1465- .", "Issue of <Dec. 18, 1862> called also: <New ser., v. 1, no. 30>", "Issues for <Mar. 23, 1865> lack volume numbering.", "Publication suspended Apr. 20-June 22, 1865 and July 6-Aug. 24, 1865.", "Published for: Methodist Episcopal Church, 1837-<June 6, 1845>; for the Methodist Episcopal Church, South, <June 12, 1846>-1899; for the South Carolina Conference of the Methodist Episcopal Church, South, 1900.", "Mirror of the times (Macon, Ga.) may have been intended to appear also as a separately titled section of this publication.", "Description based on: Vol. I, number 1 (June 24, 1837); title from masthead.", "Latest issue consulted: Volume 112, number 46 (November 18, 1948).", "South Carolina Methodist advocate (OCoLC)21062437"], "other_formats": ["https://tile.loc.gov/storage-services/service/ndnp//scu/batch_scu_dragonfruit_ver01/data/sn87065702/00516991148/1921032401/1921032401_1.xml", "http://lccn.loc.gov/sn87065702/marcxml"], "other_title": ["May sometimes be called: Southern advocate"], "place_of_publication": "Charleston, S.C.", "raw_lccn": "sn 87065702 ", "reel_numbers": ["00516991148"], "source_group": "ndnp/scu",