8101/", "https://hdl.loc.gov/loc.gmd/g3860.ar138102", "http://www.loc.gov/resource/g3860.ar138102/", "https://hdl.loc.gov/loc.gmd/g3860.ar138103", "http://www.loc.gov/resource/g3860.ar138103/", "https://hdl.loc.gov/loc.gmd/g3860.ar138104", "http://www.loc.gov/resource/g3860.ar138104/"], "campaigns": [], "contributor": ["baldwin, r. (robert)"], "date": "1755", "dates": ["1755"], "description": ["Shows provinces, coastal towns and a few frontier settlements, Indian villages and tribal territory, English \"Factories\" among the Indians, mines, rivers, numerous place-names. Covers also part of Pennsylvania, Delaware, Louisiana, and Arkansas. Relief shown by contours. From the Gentleman's Magazine and Historical Chronicle (July, 1755), vol. 24. Prime meridian: London. Appears to be based on the work of John Mitchell. Mounted on cloth. Library of Congress. Maps and charts of North America and the West Indies, 1750-1789, 1381 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:03.430Z", "group": ["gmd.mar", "catalog-split-02", "catalog", "general-maps", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/2013593290/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd386/g3860/g3860/ar138100.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd386/g3860/g3860/ar138100.gif#h=150&w=179", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd386:g3860:g3860:ar138100/full/pct:12.5/0/default.jpg#h=365&w=435", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd386:g3860:g3860:ar138100/full/pct:25/0/default.jpg#h=731&w=870"], "index": 11, "language": ["english"], "location": ["south carolina", "georgia", "north carolina", "virginia", "maryland", "united states", "southern states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2025-12-12t13:02:33.400000", "2013593290"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "american revolution and its era: maps and charts of north america and the west indies, 1750-1789", "geography and map division", "military battles and campaigns"], "score": 25.213917, "shelf_id": "G3860 1755 .M2 G3860 1755 .M2 G3860 1755 .M2 G3803 1755 .M2 G3803 1755 .M2", "site": ["catalog"], "subject": ["south carolina", "rivers", "early works to 1800", "early maps", "georgia", "north carolina", "virginia", "maryland", "united states", "southern states", "maps"], "timestamp": "2026-04-29T16:08:35.525Z", "title": "A map of Virginia, North and South Carolina, Georgia, Maryland with part of New Jersey &c", "type": ["cartographic"], "url": "https://www.loc.gov/item/2013593290/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2013593291", "http://www.loc.gov/item/2013593291/", "https://search.catalog.loc.gov/instances/d660a132-2ee9-59ac-a90e-a3b59c9bb4f4", "https://hdl.loc.gov/loc.gmd/g3900.ar139000", "http://www.loc.gov/resource/g3900.ar139000/"], "campaigns": [], "contributor": ["kitchin, thomas"], "date": "1765", "dates": ["1765"], "description": ["Shows the boundaries of each of the above provinces extend from the Atlantic coast to the Mississippi River. Also shows towns along the coast, Indian villages and tribal territory, forts principal rivers, and relief. Relief shown by hachures. From The London magazine or Gentleman's monthly intelligencer. (April, 1765), vol. 34. Prime meridian: London. LC copy imperfect: Torn and detached in upper right corner. Library of Congress. Maps and charts of North America and the West Indies, 1750-1789, 1390 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:40.108Z", "group": ["gmd.mar", "catalog-split-03", "catalog", "general-maps", "main-catalog-split-03"], "hassegments": false, "id": "http://www.loc.gov/item/2013593291/", "image_url": ["https://tile.loc.gov/storage-services/ser