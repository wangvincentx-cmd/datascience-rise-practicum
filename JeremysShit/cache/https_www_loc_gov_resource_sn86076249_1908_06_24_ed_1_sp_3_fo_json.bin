ay edition", "White Pine weekly news"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the white pine news (ely, white pine county, nevada) 1906-1910 [online resource]"], "publication_frequency": ["daily"], "score": 55.93541, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "white pine", "nevada", "ely", "united states", "ely (nev.)"], "timestamp": "2026-05-26T21:06:08.233Z", "title": "The White Pine news", "type": ["title"], "url": "https://www.loc.gov/item/2022270519/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2022270542/"], "campaigns": [], "date": "1910", "dates": ["[1910 TO 1920]"], "description": ["Weekly Began with vol. XLI, no. 14 (July 3, 1910); ceased with vol. XLIX, no. 27 (October 17, 1920). Vol. XLI, No. 14 (July 3, 1910); title from indicia (Chroniclingamerica.loc.gov, viewed February 17, 2022). Vol. XLIX, No. 27 (October 17, 1920) (Chroniclingamerica.loc.gov, viewed February 17, 2022). White Pine news (East Ely, Nev. : 1920) 2771-8174 (DLC) 2022270543 (OCoLC)1297841822"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:02.758Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2022270542/", "image_url": [], "index": 5, "language": ["english"], "location": ["white pine", "nevada", "ely", "united states", "east ely"], "number": ["2022270542", "online resource", "2022270543", "sn86076249", "1297840229", "2771-8131", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["white pine news weekly mining review (east ely, nevada) 1910-1920 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 45.859924, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "white pine", "nevada", "ely", "united states", "east ely (nev.)", "east ely"], "timestamp": "2026-05-26T21:06:08.233Z", "title": "White Pine news weekly mining review", "type": ["title"], "url": "https://www.loc.gov/item/2022270542/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn84022047/", "http://lccn.loc.gov/sn84022047", "https://search.catalog.loc.gov/instances/a00694a6-2fb5-563a-ab0b-4d2fb7eaf721"], "batch": ["nvln_hiko_ver01"], "campaigns": [], "date": "1868", "description": ["Semiweekly, Feb. 13, 1906-Dec. 21, 1906 Vol. 1, no. 1 (Dec. 26, 1868)-v. 40, no. 50 (Dec. 21, 1906). Sometimes published as: Daily White Pine news, Apr. 19-May 29, 1869; White Pine daily news, May 31-Sept. 2, 1869, <Feb. 7, 1870>. Published subsequently at Hamilton, 1870-1880; Cherry Creek, 1881-1884; Taylor, 1885-1888; Ely, 1888-1906. Publishers: W.J. Forbes, 1868-1873; Skillman & Elliot, 1873-1875; F. Elliot, 1875-<1876>. \"The official paper of White Pine County.\" Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Published in political opposition to: Daily inland empire. White Pine news (Ely, Nev. : 1906) 2771-5515 (DLC)sn 86076249 (OCoLC)13790203"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:05.071Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-12", "catalog", "united-states-newspaper-directory", "main-catalog-split-12"], "hassegments": false, "id": "http://www.loc.gov/item/sn84022047/", "image_url": [], "index": 6, "language": ["english"], "latlong": [39.253136, -114.875111], "location": ["white pine", "taylor", "treasure city", "nevada", "united states", "ely", "east ely"], "location_str": "", "lonlat": [-114.875111, 39.253136], "number": ["sn86076249", "10267661", "pennsylvania newsp proj, lycoming cnty", "northern arizona univ", "sn84022047", "1", "new york hist soc, newsp proj", "american antiquarian soc, newsp proj", "1620", "2771-540x", "2025-07-01t13:27:27.300000", "http://www.loc.gov/item/sn84022047/1906-12-25/ed-1/", "online