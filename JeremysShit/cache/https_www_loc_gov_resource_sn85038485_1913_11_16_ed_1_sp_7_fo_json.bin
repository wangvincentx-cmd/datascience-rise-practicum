#h=476&w=716"], "index": 8, "language": ["english"], "location": ["united states", "birmingham", "alabama"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["75693075", "2026-02-23t17:24:42.400000"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "geography and map division", "cities and towns", "panoramic maps"], "score": 29.11546, "shelf_id": "G3974.B5A3 1903 .D7", "site": ["catalog"], "subject": ["maps", "birmingham", "birmingham (ala.)", "alabama", "central business districts", "aerial views", "united states"], "timestamp": "2026-04-29T16:15:42.364Z", "title": "Business section of the city of Birmingham, Alabama", "type": ["cartographic"], "url": "https://www.loc.gov/item/75693075/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2016655400", "http://www.loc.gov/item/2016655400/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0109", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0109/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0109_mv08/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0109_ms01/"], "campaigns": [], "contributor": ["walker, wyatt tee", "bishop, john melville", "cline, david p.", "walker, theresa ann", "civil rights history project (u.s.)"], "date": "2014-01-01", "dates": ["2014"], "description": ["Dr. Walker reflects on his involvement in the freedom movement, especially his work as Martin Luther King's chief of staff and as the Executive Director of the Southern Christian Leadership Conference (SCLC) from 1960-1964. He recalls helping to organize the Children's Crusade in Birmingham, Alabama, and supporting Dr. King in transcribing and publishing \"Letter from a Birmingham Jail.\" He also remembers preaching in Petersburg, Virginia, and Harlem, New York, and becoming involved in several later movements, including anti-apartheid and pro-charter schools activism. Towards the end of the interview, his wife, Theresa Ann Walker, joins him on camera to talk briefly about her experiences in the movement."], "digitized": true, "extract_timestamp": "2022-10-04T17:35:53.116Z", "group": ["afc2010039", "catalog-split-13", "catalog", "civil-rights-history-project", "main-catalog-split-13", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2016655400/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0109/afc2010039_crhp0109_mv08.gif", "https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0109/afc2010039_crhp0109_ms01.gif#h=150&w=116"], "index": 9, "language": ["english"], "location": ["virginia", "georgia", "birmingham", "tennessee", "richmond", "alabama", "petersburg", "new york", "united states"], "mime_type": ["image/gif", "application/pdf", "image/jpeg", "application/x-video"], "number": ["online resource", "2020-01-23t09:44:32", "2016655400"], "online_format": ["image", "pdf", "video"], "original_format": ["film, video"], "partof": ["catalog", "civil rights history project", "american folklife center"], "score": 29.11546, "shelf_id": "http://lccn.loc.gov/2016655400", "site": ["catalog"], "subject": ["virginia", "filmed interviews", "race relations", "birmingham (ala.)", "oral histories", "african american women civil rights workers", "religious aspects", "sanitation workers strike, memphis, tenn", "nonviolence", "video recordings", "georgia", "social justice", "washington, d.c.)", "congress of racial equality", "african american clergy", "jr", "christianity", "national association for the advancement of colored people", "civil rights movements", "birmingham", "petersburg (va.)", "march on washington for jobs and freedom", "tennessee", "personal narratives", "king, martin luther", "student nonviolent coordinating committee (u.s.)", "walker, theresa ann", "civil rights demonstrations", "new york", "african american civil rights workers", "walker, wyatt tee", "segregation", "alabama", "african americans", "petersburg", 