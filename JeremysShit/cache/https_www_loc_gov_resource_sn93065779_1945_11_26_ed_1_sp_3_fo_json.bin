http://www.loc.gov/item/20685141", "2018674580", "2018-11-02t16:38:30"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints and photographs division", "lot 7479", "catalog", "national child labor committee collection", "prints & photographs online catalog (library of congress)"], "score": 25.662016, "shelf_id": "LOT 7479, v. 1, no. 0290 [P&P]", "site": ["pictures", "catalog"], "subject": ["photographic prints", "united states", "lincolnton", "streets", "north carolina", "textile mill workers", "boys"], "timestamp": "2022-04-30T18:32:28.882Z", "title": "On streets near Daniel Mill. Lincolnton, N.C. Right hand boy--Dan Biggerstaff. 10 years old. Has worked 3 years. Goes to school now (he says). Left hand, John Erwin. Said 11 years old. Has worked nights.  Location: Lincolnton, North Carolina.", "url": "https://www.loc.gov/item/2018674580/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_broadwick_ver01/data/sn93065779/00279558236/1945112601/0507.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_broadwick_ver01:data:sn93065779:00279558236:1945112601:0505/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ncu/batch_ncu_broadwick_ver01/data/sn93065779/00279558236/1945112601/0507.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn93065779/1945-11-26/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_broadwick_ver01/data/sn93065779/00279558236/1945112601/0507.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_broadwick_ver01:data:sn93065779:00279558236:1945112601:0505/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ncu/batch_ncu_broadwick_ver01/data/sn93065779/00279558236/1945112601/0507.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn93065779/1945-11-26/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ncu/batch_ncu_broadwick_ver01/data/sn93065779/00279558236/1945112601/0507.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn93065779/1945-11-26/ed-1/?sp=3"], "batch": ["ncu_broadwick_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/north carolina/", "2/united states/north carolina/lincoln/", "3/united states/north carolina/lincoln/lincolnton/"], "contributor": ["university of north carolina at chapel hill library, chapel hill, nc"], "date": "1945-11-26", "dates": ["1945-11-26"], "description": ["UNCOLN COUNTYS FAVORITE FAMILY NEWSPAPER This Week in WASHINGTON Washington D C NWNS Although many people may be dis appointed in the accomplishments of the labormanagement conference to date it is th e general consensus of opinion here that it cannot end in complete failure For even though few agreements may be reached which will help solve labormanage ment problems the conference al ready has done a great deal toward defining the differences which exist between labor and management That accomplishment in itself will make it easier for Congress for the ad ministration and for business and labor to seek practical solutions One congressman commented Members of Congress most of whom are closely following the pro cedure of the conference are going to have a clearer picture than they ever did before of what this epi demic of strikes is all about It is going to help us a lot in determin ing whether new labor legislation is necessary and if so what kinds of legislation will do ttye most good This whole problem is now getting p good airingand that is what has been needed Little action on labor legislation is expected until the conference is overuntil both labor"], "digitized": true, "extract_timestamp": "2023-08-12T17:31:54.927Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn93065779/1945-11-26/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_broadwick_ver01:data:sn93065779:00279558236:1945112601:0507/full/pct:6.25/0/default.jpg#h=430&w=313", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_broadwick_ver01:data:sn93065779:00279558236:1945112601:0507/full/pct:12.5/0/default.jpg#h=860&w=627", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_broadwick_ver01/data/sn93065779/00279558236/1945112601/0507.xml&format=alto_xml"], "index": 3, "language": ["english"], "location": ["lincoln county", "lincolnton", "united states", "lincoln", "north carolina"], "location_city": ["lincolnton"], "location_country": ["united states"], "location_county": ["lincoln"], "location_state": ["north carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["sn93065779", "5", "3", "0000000003", "0", "2", "1", "8", "6", "7", "9"], "number_edition": ["1"], "number_lccn": ["sn93065779"], "number_page": ["0000000003"], "number_reel": ["0", "0", "2", "7", "9", "5", "5", "8", "2", "3", "6"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the lincoln times (lincolnton, n.c.) 190?-1965"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the lincoln times (lincolnton, n.c.) 190?-1965"], "publication_frequency": ["semiweekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn9306