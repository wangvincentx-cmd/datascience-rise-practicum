ments": false, "id": "http://www.loc.gov/item/2021270605/", "image_url": [], "index": 3, "language": ["english"], "location": ["humboldt", "winnemucca", "nevada", "united states"], "number": ["1230242976", "online resource", "2021270605", "2021270606", "2021270604", "2766-4929", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["the daily silver state (winnemucca, nevada) 1903-1907 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["daily"], "score": 40.829296, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["winnemucca", "newspapers", "winnemucca (nev.)", "nevada", "united states", "humboldt"], "timestamp": "2026-05-26T21:02:54.346Z", "title": "The daily silver state", "type": ["title"], "url": "https://www.loc.gov/item/2021270605/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021270606/"], "campaigns": [], "date": "1907", "dates": ["[1907 TO 1909]"], "description": ["Semiweekly Began with vol. 1, no. 1 (June 20, 1907); ceased with volume 3, no. 43 (September 7, 1909). Frequent misnumberings. Vol. 1, No. 1 (June 20, 1907); title from masthead (Chroniclingamerica.loc.gov, viewed January 11, 2020). Volume 3, No. 43 (September 7, 1909) (Chroniclingamerica.loc.gov, viewed January 11, 2020). Silver state (Winnemucca, Nev. : 1909) (DLC) 2021270608"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:58.293Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021270606/", "image_url": [], "index": 4, "language": ["english"], "location": ["humboldt", "winnemucca", "nevada", "united states"], "number": ["2021270605", "online resource", "1230247666", "2021270606", "2766-4945", "2021270608", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries