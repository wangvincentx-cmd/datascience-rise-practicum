lish"], "location": ["suffolk", "richmond", "south carolina", "virginia", "charleston", "france", "boston", "massachusetts", "great britain", "savannah", "georgia", "chatham", "united states"], "mime_type": ["text/xml", "image/jpeg", "image/gif", "application/xml", "image/tiff", "application/pdf"], "online_format": ["online text", "image", "pdf"], "original_format": ["notated music"], "partof": ["rare book and special collections division", "american memory", "sheet music from the alfred whital stern collection of lincolniana", "the alfred whital stern collection of lincolniana"], "score": 20.313036, "shelf_id": "Stern catalog 4981", "subject": ["davis, jefferson", "slavery", "african american", "sheet music", "lincoln, abraham", "international relations", "emancipation proclamation"], "timestamp": "2022-08-02T17:10:39.592Z", "title": "Away goes Cuffee, or, Hooray for '63 words & music by L.B. Starkweather.", "type": ["notated music"], "url": "https://www.loc.gov/item/scsm000166/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010674/1948111801/0150.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010674:1948111801:0148/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010674/1948111801/0150.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn89077295/1948-11-18/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010674/1948111801/0150.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data