 properly girls here is"], "digitized": true, "extract_timestamp": "2025-04-20T03:13:51.814Z", "group": ["ndnp/gu", "digital-library-of-georgia-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89077295/1948-11-18/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010674:1948111801:0150/full/pct:6.25/0/default.jpg#h=394&w=276", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010674:1948111801:0150/full/pct:12.5/0/default.jpg#h=788&w=552", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010674/1948111801/0150.xml&format=alto_xml"], "index": 3, "language": ["english"], "location": ["georgia", "chatham", "savannah", "united states"], "location_city": ["savannah"], "location_country": ["united states"], "location_county": ["chatham"], "location_state": ["georgia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "6", "sn89077295", "7", "0000000003", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn89077295"], "number_page": ["0000000003"], "number_reel": ["0", "0", "5", "1", "7", "0", "1", "0", "6", "7", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the herald (savannah, georgia) 1945-1997"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the herald (savannah, georgia) 1945-1997"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn89077295/1948-11-18/ed-1/?sp=3"}], "segmentof": ["http://www.loc.gov/resource/sn89077295/1948-11-18/ed-1/"], "shelf_id": "03", "site": ["chroniclingamerica