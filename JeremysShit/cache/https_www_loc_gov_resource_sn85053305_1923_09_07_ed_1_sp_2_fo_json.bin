Plentywood, Montana", "url": "https://www.loc.gov/item/2017780901/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_juniper_ver01/data/sn85053305/00340581932/1923090701/0274.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_juniper_ver01:data:sn85053305:00340581932:1923090701:0273/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_juniper_ver01/data/sn85053305/00340581932/1923090701/0274.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn85053305/1923-09-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_juniper_ver01/data/sn85053305/00340581932/1923090701/0274.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_juniper_ver01:data:sn85053305:00340581932:1923090701:0273/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_juniper_ver01/data/sn85053305/00340581932/1923090701/0274.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn85053305/1923-09-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_juniper_ver01/data/sn85053305/00340581932/1923090701/0274.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85053305/1923-09-07/ed-1/?sp=2"], "batch": ["mthi_juniper_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/sheridan/", "3/united states/montana/sheridan/plentywood/"], "contributor": ["montana historical society; helena, mt"], "date": "1923-09-07", "dates": ["1923-09-07"], "description": ["A m s I y 9 X m Prize Winning Meats You can come here shopping with the utmost confidence that the Meat you get will be the best to be obtained anywhere And no matter what cut you want you will find us always willing to do our best to give it to you PRICES ALWAYS CONSISTENT WITH QUALITY PHONE 17 The New Market FRED FORMAN Prop A Lucky Escape ONE SATURDAY EVENING a man made a purchase of 4000 worth of goods to be paid for in three monthly payments When he went to make the last payment he was surprised to learn that the store wanted 2700 rather than 1330 which he expected to pay They claimed only one payment had been made This man came to the bank to ask our advice He said he was sure he had paid the billthat he remembered writing a check for the pay ment It took but a minute or two to find that can celled check Of course the store gladly corrected their mis take when they saw this cancelled check Mis takes occur once in a while no matter how care ful you are But you will"], "digitized": true, "extract_timestamp": "2023-07-03T13:49:13.984Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85053305/1923-09-07/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_juniper_ver01:data:sn85053305:00340581932:1923090701:0274/full/pct:3.125/0/default.jpg#h=281&w=213", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_juniper_ver01:data:sn85053305:00340581932:1923090701:0274/full/pct:6.25/0/default.jpg#h=562&w=427", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_juniper_ver01:data:sn85053305:00340581932:1923090701:0274/full/pct:12.5/0/default.jpg#h=1124&w=855", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_juniper_ver01/data/sn85053305/00340581932/1923090701/0274.xml&format=alto_xml"], "index": 2, "language": ["english"], "locat