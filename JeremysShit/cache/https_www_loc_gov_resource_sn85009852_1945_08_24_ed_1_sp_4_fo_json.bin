["https://tile.loc.gov/storage-services/service/rbc/rbpe/rbpe00/rbpe008/00801700/001dq.gif", "https://tile.loc.gov/storage-services/service/rbc/rbpe/rbpe00/rbpe008/00801700/001dt.gif#h=139&w=100", "https://tile.loc.gov/storage-services/service/rbc/rbpe/rbpe00/rbpe008/00801700/001dq.gif#h=832&w=600", "https://tile.loc.gov/storage-services/service/rbc/rbpe/rbpe00/rbpe008/00801700/001dr.jpg#h=3800&w=2739"], "index": 9, "language": ["english"], "location": ["connecticut", "united states", "east windsor"], "mime_type": ["text/xml", "image/jpeg", "image/gif", "application/xml", "image/tiff", "application/pdf"], "number": ["rbpe00801700", "2021768170", "2021-10-21t11:37:19"], "online_format": ["online text", "image", "pdf"], "original_format": ["book"], "partof": ["rare book and special collections division", "american memory", "catalog", "printed ephemera: three centuries of broadsides and other printed ephemera"], "score": 26.225807, "shelf_id": "Portfolio 8, Folder 17", "site": ["ammem", "catalog"], "subject": ["east windsor", "connecticut", "united states", "broadsides"], "timestamp": "2023-06-08T14:17:33.429Z", "title": "Auction on Wednesday, the 8th day of April, inst. Will be sold at public auction, at the dwelling house of Hannibal A. Ellsworth, in the town of East Windsor, a large amount of personal property ... Sam'l W. Thompson. Deputy Sheriff. East Windso", "type": ["text"], "url": "https://www.loc.gov/item/2021768170/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945082401/0382.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945082401:0379/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945082401/0382.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn85009852/1945-08-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945082401/0382.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945082401:0379/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945082401/0382.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn85009852/1945-08-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945082401/0382.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85009852/1945-08-24/ed-1/?sp=4"], "batch": ["ct_carpsurprise_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/hartford/", "3/united states/connecticut/hartford/new britain/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1945-08-24", "dates": ["1945-08-24"], "description": ["FOUR East Hartforb ftazettr Established 1885 PUBLISHED EVERY FRIDAY AT EAST HARTFORD CONN By The Gazette Publishing Company EDWARD B STEVENS Publisher DANIEL F SHEA Editor si HENRI TUSSENBROEK Associate Editor Entered at the Post Office in East Hartford as Second Class Matter SUBSCRIPTION RATES Full Year 200 Six Months sl25 Three Months 75c Single Copy 4c NATIONAL DITORI AL_ w associaton RECONVERSION AND LABOR When the first announcements of the Japa nese surrender came the complicated picture of American war activities swung momentarily into a sudden halt It seemed but a matter of hours before we knew that attempts at the reorganization of indus try were already in full swing A first analysis of the dramatic steps along the production front revealed the colossal scope of the war effort up to the very minute of surrender by the enemy It appeared like a signal to all industry to stop at once take inventory turn about face and head back on the road to reconversion The program which lies ahead is of neces sity based on many new factors and ideas Revolu tionary discoveries in science a quick and compre hensive picture of the most immediate needs for the country"], "digitized": true, "extract_timestamp": "2024-12-15T22:26:55.485Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85009852/1945-08-24/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945082401:0382/full/pct:3.125/0/default.jpg#h=283&w=206", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945082401:0382/full/pct:6.25/0/default.jpg#h=567&w=413", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_carpsurprise_ver01:data:sn85009852:00517174774:1945082401:0382/full/pct:12.5/0/default.jpg#h=1134&w=827", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_carpsurprise_ver01/data/sn85009852/00517174774/1945082401/0382.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["new britain", "connecticut", "united states", "east hartford", "glastonbury", "hartford", "east windsor", "south windsor"], "location_city": ["new britain"], "location_country": ["united states"], "location_county": ["hartford"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/