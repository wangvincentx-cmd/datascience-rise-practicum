tures", "catalog"], "subject": ["agricultural laborers", "connecticut", "tobacco industry", "boys", "photographic prints", "united states", "south windsor"], "timestamp": "2022-04-30T19:11:34.072Z", "title": "Field-workers, Amer[ican] Sumatra Tobacco Co. The Supt. called the boys out to the end of the rows and we found 47 boys from 9 to 15 yrs. old, all working but could not get hold of them all. The Supt. said, \"We have to hire boys because we can't get men to do the work.\" Many of them live in Hartord, Conn., and go back and forth on the trolley.  Location: S[outh] Windsor, Connecticut", "url": "https://www.loc.gov/item/2018678626/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/nclc/item/2018678627/", "https://hdl.loc.gov/loc.pnp/nclc.00705", "http://www.loc.gov/item/2018678627/", "http://www.loc.gov/pictures/item/2018678627/", "http://www.loc.gov/resource/nclc.00705/", "http://lccn.loc.gov/2018678627"], "campaigns": [], "contributor": ["hine, lewis wickes"], "date": "1917-01-01", "dates": ["1917"], "description": ["1 photographic print."], "digitized": true, "extract_timestamp": "2021-09-01T22:53:56.861Z", "group": ["nclc", "catalog-split-15", "catalog", "national-child-labor-committee", "main-catalog-split-15", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2018678627/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/nclc/00700/00705_150px.jpg#h=108&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/00700/00705t.gif#h=108&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/00700/00705r.jpg#h=461&w=640", "https://tile.loc.gov/storage-services/service/pnp/nclc/00700/00705v.jpg#h=737&w=1024"], "index": 8, "language": ["english"], "location": ["connecticut", "united states", "south windsor"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/ncl2004005020/pp", "http://www.loc.gov/item/2018678627", "2018-11-02t15:47:03", "201867