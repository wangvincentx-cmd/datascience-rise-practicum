vice/ndnp/arhi/batch_arhi_biotite_ver01/data/sn89051220/00513688556/1921032401/0466.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_biotite_ver01:data:sn89051220:00513688556:1921032401:0466/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/arhi/batch_arhi_biotite_ver01/data/sn89051220/00513688556/1921032401/0466.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn89051220/1921-03-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_biotite_ver01/data/sn89051220/00513688556/1921032401/0466.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_biotite_ver01:data:sn89051220:00513688556:1921032401:0466/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/arhi/batch_arhi_biotite_ver01/data/sn89051220/00513688556/1921032401/0466.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn89051220/1921-03-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/arhi/batch_arhi_biotite_ver01/data/sn89051220/00513688556/1921032401/0466.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89051220/1921-03-24/ed-1/?sp=1"], "batch": ["arhi_biotite_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arkansas/", "2/united states/arkansas/logan/", "3/united states/arkansas/logan/paris/"], "contributor": ["arkansas state archives"], "date": "1921-03-24", "dates": ["1921-03-24"], "description": ["PARIS FORTYSECOND YEAR PARIS ARKANSAS THURSDAY MARCH 24 1921 NUMBER 4 GOVERNOR MRAE DEFERS THE PENALTY ON TAXES The following proclamation deferr ing the penalty on taxes has been issued by Governor McRae I Thomas C McRae governor of the state of Arkansas believing that it will be helpful to many tax payers and not hurtful to the state counties municipal and school dis tricts by virtue of the authority in me vested do hereby proclaim re quest and direct 1 that the tax collectors of the several counties in this state shall not collect from the persons firms and corporations who owe county municipal state and school taxes the 10 per centum pen alty authorized by Section 10066 of Crawford Moses Digest 2 nor shall they collect from such persons firms and corporations who may owe such taxes the 25 per centum pen alty that shall be assessed by the county clerks against lands and lots returned as delinquent for the non payment of taxes thereon under Section 10083 of Crawford Moses Digest of the Statutes of Arkansas if the taxes and costs are paid on or before the day provided by law for the delinquent tax sale The"], "digitized": true, "extract_timestamp": "2024-12-02T17:48:35.319Z", "group": ["ndnp/arhi", "arkansas-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89051220/1921-03-24/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_biotite_ver01:data:sn89051220:00513688556:1921032401:0466/full/pct:6.25/0/default.jpg#h=408&w=292", "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_biotite_ver01:data:sn89051220:00513688556:1921032401:0466/full/pct:12.5/0/default.jpg#h=816&w=584", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_biotite_ver01/data/sn89051220/00513688556/1921032401/0466.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["paris", "arkansas", "logan", "logan county", "united states"], "location_city": ["paris"], "location_country": ["united states"], "location_county": ["logan"], "location_state": ["arkansas"], "mime_type": ["image/jp2", "application/pdf",