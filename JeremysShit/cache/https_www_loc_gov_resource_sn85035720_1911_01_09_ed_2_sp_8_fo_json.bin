, "aka": ["http://lccn.loc.gov/74692880", "http://www.loc.gov/item/74692880/", "https://search.catalog.loc.gov/instances/af8d1edf-4b84-58b7-a566-9964a5fd0fe1", "https://hdl.loc.gov/loc.gmd/g3800.ct000082", "http://www.loc.gov/resource/g3800.ct000082/"], "campaigns": [], "contributor": ["robert sayer and john bennett (firm)", "pownall, thomas", "holland, samuel"], "date": "1776", "dates": ["1776"], "description": ["Hand colored. Relief shown pictorially. Shows administrative divisions. Insets: A chart of the mouth of Hudson's River, from Sandy Hook to New York.--A plan of the city of New York.--Plan of Amboy, with its environs, from an actual survey. Scale ca. 1:650,000. LC Maps of North America, 1750-1789, 1045 Available also through the Library of Congress Web site as a raster image. Vault AACR2: 100; 651/1; 651/2; 651/3; 651/4; 651/5; 651/6; 651/7; 651/8; 700/1; 710/2"], "digitized": true, "extract_timestamp": "2026-04-29T15:40:09.708Z", "group": ["gmd.mar", "catalog-split-12", "catalog", "general-maps", "main-catalog-split-12"], "hassegments": false, "id": "http://www.loc.gov/item/74692880/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd380/g3800/g3800/ct000082.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd380/g3800/g3800/ct000082.gif#h=381&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd380:g3800:g3800:ct000082/full/pct:12.5/0/default.jpg#h=2017&w=794", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd380:g3800:g3800:ct000082/full/pct:25/0/default.jpg#h=4035&w=1589"], "index": 11, "language": ["english"], "location": ["united states", "new york (state)", "new jersey", "qu\u00e9bec", "new york city", "qu\u00e9bec (province)", "canada", "new york", "northeastern states", "perth amboy"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t18:30:16.200000", "2005-01-04t16:52:50", "74692880"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "american revolution and its era: maps and charts of north america and the west indies, 1750-1789", "catalog", "geography and map division"], "score": 34.21692, "shelf_id": "G3800 1776 .P6", "site": ["catalog"], "subject": ["perth amboy (n.j.)", "united states", "new york (state)", "administrative and political divisions", "new jersey", "qu\u00e9bec (province)", "canada", "new york (n.y.)", "new york", "northeastern states", "early works to 1800", "perth amboy", "maps"], "timestamp": "2026-04-29T16:14:20.380Z", "title": "The provinces of New York and New Jersey; with part of Pensilvania, and the province of Quebec", "type": ["cartographic"], "url": "https://www.loc.gov/item/74692880/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2006625921", "http://www.loc.gov/item/2006625921/", "https://search.catalog.loc.gov/instances/13f8e8ec-e3f5-51b7-b1a1-5c0d6c9331e8", "https://hdl.loc.gov/loc.gmd/g3814p.ct006952", "http://www.loc.gov/resource/g3814p.ct006952/"], "campaigns": [], "contributor": ["brinley, francis w.", "baker (lithographer : new york, n.y.)"], "date": "1836", "dates": ["1836"], "description": ["General street map showing buildings and lot lines. Relief shown by hachures. Depths shown by soundings. Also covers part of Raritan Bay. LC copy imperfect: Upper left corner torn away, laminated, mounted on cloth backing to form single sheet, fold-lined, small sections missing at fold lines, sheet trimmed, annotated in ink to show additional buildings and names. Includes inset \"Map shewing the situation of Perth Amboy with New York, the Atlantic Ocean &c., scale 3 miles to an inch\". Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:12.234Z", "group": ["gmd.mar", "catalog-split-01", "catalog", "general-maps", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/2006625921/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd381/g3814/g3814p/ct006952.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd381/g3814/g3814p/ct006952.gif#h=150&w=100", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3814:g3814p:ct006952/full/pct:12.5/0/default.jpg#h=1337&w=894", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3814:g3814p:ct006952/full/pct:25/0/default.jpg#h=2675&w=1788"], "index": 12, "language": ["english"], "location": ["united states", "new jersey", "new york", "raritan bay", "perth amboy", "perth amboy region"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t01:46:57.300000", "2006625921", "2016-10-03t09:58:45", "sheet"], "online_format": ["image"], "original_format": ["map"], "partof": ["cities and towns", "catalog", "geography and map division"], "score": 34.21692, "shelf_id": "G3814.P4 1836 .B7", "site": ["catalog"], "subject": ["perth amboy (n.j.)", "united states", "real property", "new jersey", "raritan bay (n.j. and n.y.)", "new york", "perth amboy region (n.j.)", "bathymetric maps", "raritan bay", "perth amboy", "maps", "perth amboy region"], "timestamp": "2026-04-29T15:51:03.749Z", "title": "Map of the city of Perth Amboy, N.J. : February 1836", "type": ["cartographic"], "url": "https://www.loc.gov/item/2006625921/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/gm71000984", "http://www.loc.gov/item/gm71000984/", "https://search.catalog.loc.gov/instances/e3e24845-78ac-5814-bd0b-74b6c33051a6", "https://hdl.loc.gov/loc.gmd/g3814p.ar125000", "http://www.loc.gov/resource/g3814p.ar125000/"], "campaigns": [], "date": "1780", "dates": ["1780"], "description": ["\"The map presented here shows the city and harbor of Charleston, South Carolina, at the time of the first British siege of Charleston and attack on Fort Sullivan in June 1776. This was the earliest British attempt to capture Charleston during the Revolutionary War, by which General Henry Clinton and Admiral Sir Peter Parker sought to put down the rebellion in the southern colonies. Above the map of Charleston is a view of Fort Sullivan, where William Moultrie, a colonel in the state militia of South Carolina, repulsed a British attack. The fort was later renamed Fort Moultrie in his honor. After failing to secure Charleston, the British fleet sailed to New York City. British forces would not return to Charleston until 1780. The map also includes an inset view of Amboy (present-day Perth Amboy) on the Raritan River, in New Jersey. It shows a layout of the town with houses, streets, fields, vegetation, connecting roads, nearby parts of Raritan Bay and Staten Island, and the ferry to South Amboy. This map has a watermark. Relief is shown by hachures. The map is from the Rochambeau Collection at the Library of Congress, which consists of 40 manuscript maps, 26 printed maps, and a manuscript atlas that belonged to Jean-Baptiste-Donatien de Vimeur, comte de Rochambeau (1725-1807), commander in chief of the French expeditionary army (1780-82) during the American Revolution. Some of the maps were used by Rochambeau during the war. Dating from 1717 to 1795, the maps cover much of eastern North America, from Newfoundland and Labrador in the north to Haiti in the south. The collection includes maps of cities, maps showing Revolutionary War battles and military campaigns, and early state maps from the 1790s.\" World Digital Library."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:45.215Z", "group": ["gmd.mar", "catalog-split-01", "catalog", "general-maps", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/gm71000984/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd381/g3814/g3814p/ar125000.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd381/g3814/g3814p/ar125000.gif#h=150&w=220", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3814:g3814p:ar125000/full/pct:12.5/0/default.jpg#h=464&w=681", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3814:g3814p:ar125000/full/pct:25/0/default.jpg#h=929&w=1363"], "index": 13, "language": ["french"], "location": ["united states", "charleston harbor", "new jersey", "charleston", "south carolina", "fort moultrie", "perth amboy"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-09-24t13:14:18.100000", "gm71000984"], "online_format": ["image"], "original_format": ["map"], "partof": ["rochambeau map collection", "catalog", "france in america", "world digital library", "military battles and campaigns", "american revolution and its era: maps and charts of north america and the west indies, 1750-1789", "geography and map division"], "score": 34.21692, "shelf_id": "G3814.P4 1780 .P5", "site": ["catalog"], "subject": ["perth amboy (n.j.)", "united states", "perth amboy", "charleston harbor (s.c.)", "charleston harbor", "new jersey", "charleston", "charleston (s.c.)", "south carolina", "fort moultrie", "history", "siege", "early works to 1800", "fort moultrie (s.c.)", "maps", "aerial views", "early maps"], "timestamp": "2026-04-29T16:36:27.580Z", "title": "[Plan d'Amboy]. [Vues de la rade de Charles-Town et de Fort Sulivan, mai 1780]", "type": ["cartographic"], "url": "https://www.loc.gov/item/gm71000984/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/njr/batch_njr_cinnamon_ver03/data/sn85035720/00279529558/1911010902/0073.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_cinnamon_ver03:data:sn85035720:00279529558:1911010902:0066/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/njr/batch_njr_cinnamon_ver03/data/sn85035720/00279529558/1911010902/0073.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn85035720/1911-01-09/ed-2/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/njr/batch_njr_cinnamon_ver03/data/sn85035720/00279529558/1911010902/0073.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_cinnamon_ver03:data:sn85035720:00279529558:1911010902:0066/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/njr/batch_njr_cinnamon_ver03/data/sn85035720/00279529558/1911010902/0073.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn85035720/1911-01-09/ed-2/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/njr/batch_njr_cinnamon_ver03/data/sn85035720/00279529558/1911010902/0073.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85035720/1911-01-09/ed-2/?sp=8"], "batch": ["njr_cinnamon_ver03"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/new jersey/", "2/united states/new jersey/middlesex/", "3/united states/new jersey/middlesex/perth amboy/"], "contributor": ["rutgers university libraries"], "date": "1911-01-09", "dates": ["1911-01-09"], "description": ["jg 1 CLASSIFIED ADS w BJJ WT v nini uni i put imttmimam Ten Words yygTen Cents STATEN ISLAND NEWS OFFICIALS ON VISIT HERE Railroad Men Make an In spection of System George H Campbell formerly vicepresident of the Staten Island Rapid Transit Railway now assist ant to President Williard of the B O railroad together with Vice President C C F Bent Superinten dent P H Cassidy General Traffic Agent George J Brown and Train master Frederick C Syze of the Rapid Transit went over the entire system on the island Saturday The party who came down in Su perintendent Cassidys private car were at the local depot in Totten ville about 11 oclock in the morn ing A geenral inspection of the entire rolling stock and tracks were made during this trip over the three divisions of the road It is said that gome improvements are contem plated by the officials at this end of the line some time in the spring What they are could not be learned This was Mr Campbells first visit over the system since he was made assistant to the president several months ago ELIZABETH DECKER DIES Miss Elizabeth Decker thirtytwo years old"], "digitized": true, "extract_timestamp": "2025-12-01T12:39:29.491Z", "group": ["ndnp/njr", "rutgers-university-libraries-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85035720/1911-01-09/ed-2/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_cinnamon_ver03:data:sn85035720:00279529558:1911010902:0073/full/pct:6.25/0/default.jpg#h=435&w=324", "https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_cinnamon_ver03:data:sn85035720:00279529558:1911010902:0073/full/pct:12.5/0/default.jpg#h=871&w=649", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/njr/batch_njr_cinnamon_ver03/data/sn85035720/00279529558/1911010902/0073.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["middlesex county", "united states", "new jersey", "middlesex", "perth amboy"], "location_city": ["perth amboy"], "location_country": ["united states"], "location_county": ["middlesex"], "location_state": ["new jersey"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "sn85035720", "2", "7", "8", "0000000008", "5"], "number_edition": ["2"], "number_lccn": ["sn85035720"], "number_page": ["0000000008"], "number_reel": ["0", "0", "2", "7", "9", "5", "2", "9", "5", "5", "8"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "perth amboy evening news (perth amboy, n.j.) 1903-1959", "chronicling america"], "partof_collection": ["ch