g people What would you do with 1000 Twothirds of the boys said they would put it into sports and twothirds of the girls would spend it for clothes Parents and teachers should show the young people of Pocc moke City that money can be used in one of two ways Tt can be employed for some slight present satisfaction Or it can be used as the foundation on which can be built some great benefit later on If a boy blew out nis money on a trip to some city and spent it on shows anj feeds all benefits therefrom would have disap peared the next day But if he would put in his money to help buy a musical instrument and would go to work taking lessons on the same he would eventually acquire"], "digitized": true, "extract_timestamp": "2023-03-01T18:24:28.471Z", "group": ["ndnp/mdu", "university-of-maryland-college-park-college-park-md-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89060127/1921-03-19/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_easton_ver02:data:sn89060127:00279521948:1921031901:0097/full/pct:3.125/0/default.jpg#h=260&w=181", "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_easton_ver02:data:sn89060127:00279521948:1921031901:0097/full/pct:6.25/0/default.jpg#h=520&w=362", "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_easton_ver02:data:sn89060127:00279521948:1921031901:0097/full/pct:12.5/0/default.jpg#h=1041&w=725", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_easton_ver02/data/sn89060127/00279521948/1921031901/0097.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["worcester", "maryland", "worcester county", "pocomoke city", "united states"], "location_city": ["pocomoke city"], "location_country": ["united states"], "location_county": ["worcester"], "location_state": ["maryland"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg"