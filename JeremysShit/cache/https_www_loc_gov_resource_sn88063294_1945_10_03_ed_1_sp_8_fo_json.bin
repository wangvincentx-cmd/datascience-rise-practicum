"], "other_title": ["Tribune independent"], "partof": ["the tribune independent of michigan (detroit, michigan) 1933-1935 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 61.323586, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "wayne", "michigan", "wayne county (mich.)", "african american", "detroit (mich.)", "wayne county", "detroit", "united states", "african americans"], "timestamp": "2026-05-26T20:56:09.337Z", "title": "The tribune independent of Michigan", "type": ["title"], "url": "https://www.loc.gov/item/2018218643/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218653/"], "campaigns": [], "date": "1935", "dates": ["[1935 TO 1966]"], "description": ["Weekly Began with volume XIII, no. 26 (September 14, 1935); ceased in 1966. Publisher: Detroit Tribune Publishing Co., Inc., <January 5-December 28, 1963>. Description based on: Description based on: Volume XIII, no. 26 (September 14, 1935); title from masthead (Chroniclingamerica.loc.gov, viewed March 21, 2018). Latest issue consulted: Volume 42, number 4 (December 28, 1963) (Chroniclingamerica.loc.gov, viewed March 21, 2018)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:42.357Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218653/", "image_url": [], "index": 13, "language": ["english"], "location": ["wayne", "michigan", "wayne county", "detroit", "united states"], "number": ["online resource", "2018218653", "2577-3518", "2018218643", "1029203520", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["the detroit tribune (detroit, michigas[n]) 1935-1966 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 61.323586, "shelf_i