9T21:37:49.584Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019271249/", "image_url": [], "index": 12, "language": ["english"], "location": ["birmingham", "mississippi", "shelby county", "shelby", "southern states", "memphis", "alabama", "tennessee", "united states", "oktibbeha", "jefferson county", "starkville", "jefferson"], "number": ["2026-04-13t21:30:13", "2019271249", "2019271168", "1119724206", "online resource", "2688-9927"], "original_format": ["newspaper"], "other_title": ["Progressive farmer", "Southern farm gazette"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the progressive farmer and southern farm gazette (starkville, miss.) 1910-1920 [online resource]"], "publication_frequency": ["weekly"], "score": 43.896782, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["birmingham", "tennessee", "shelby county (tenn.)", "united states", "oktibbeha", "jefferson county", "birmingham (ala.)", "jefferson", "mississippi", "shelby county", "shelby", "memphis", "agriculture", "starkville", "memphis (tenn.)", "starkville (miss.)", "jefferson county (ala.)", "southern states", "alabama", "newspapers"], "timestamp": "2026-05-26T20:58:47.437Z", "title": "The progressive farmer and southern farm gazette", "type": ["title"], "url": "https://www.loc.gov/item/2019271249/"}], "next_resource": {"label": "Next Issue", "url": "https://www.loc.gov/resource/sn85038485/1921-03-05/ed-1/?fo=json&sp=1"}, "options": {"access_group": [""], "access_group_raw": "", "all": null, "api_version": "1", "app_context": null, "application_version": "$Revision$", "attribute": null, "attribute!": null, "attribute_map": null, "cache_tags": ["ndnp/au", "university-of-alabama-tuscaloosa-al-awardee", "ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8", "newspaper-titles", "ndnp/newspapers", "catalog-split-10", "catalog", "united-state