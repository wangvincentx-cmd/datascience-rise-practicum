 false, "aka": ["http://www.loc.gov/item/2018218525/"], "campaigns": [], "date": "1899", "dates": ["[1899 TO 1969]"], "description": ["Weekly Began in Nov. 1899; ceased Sepetember 4, 1969. Published as: Bowbells bulletin=tribune, Nov. 22, 1907-June 25, 1908 (due to fire at Tribune plant). \"Official paper of the Village.\" Publisher: Burke County Farmers Press, <January 13-December 29, 1922>. Available on microfilm from the State Historical Society of North Dakota. Description based on: Vol. 1, no. 3 (December 1, 1899); title from masthead (Chroniclingamerica.loc.gov, viewed January 31, 2018). Latest issue consulted: Vol. 24, no. 31 (December 29, 1922) (Chroniclingamerica.loc.gov, viewed January 31, 2018). Burke County tribune"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:41.529Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218525/", "image_url": [], "index": 8, "language": ["english"], "location": ["burke", "ward", "bowbells", "north dakota", "united states"], "number": ["2018218525", "online resource", "1021046286", "2576-6864", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Bowbells bulletin=tribune"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the bowbells tribune (bowbells, ward co., north dakota) 1899-1969 [online resource]"], "publication_frequency": ["weekly"], "score": 29.232153, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "burke", "ward", "bowbells (n.d.)", "bowbells", "north dakota", "united states"], "timestamp": "2026-05-26T20:55:54.213Z", "title": "The Bowbells tribune", "type": ["title"], "url": "https://www.loc.gov/item/2018218525/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn88076095/", "http://lccn.loc.gov/sn88076095"], "batch": ["ndhi_jodium_ver01"], "campaigns": [], "date": "1899", "description": ["Weekly Began in Nov. 1899. -v. 71, no. 11 (Sept. 4, 1969). Published as: Bowbells bulletin=tribune, Nov. 22, 1907-June 25, 1908 (due to fire at Tribune plant). \"Official paper of the Village.\" Available on microfilm from the State Historical Society of North Dakota. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Description based on: Vol. 1, no. 3 (Dec. 1, 1899). Burke County tribune (DLC)sn 88076097 (OCoLC)1537836"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:06.609Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-12", "catalog", "united-states-newspaper-directory", "main-catalog-split-12"], "hassegments": false, "id": "http://www.loc.gov/item/sn88076095/", "image_url": [], "index": 9, "language": ["english"], "latlong": [48.8071718, -102.2399499], "location": ["burke", "ward", "bowbells", "north dakota", "united states"], "location_str": "", "lonlat": [-102.2399499, 48.8071718], "number": ["microfilm master", "state hist soc of n dakota", "online resource", "2025-06-25t14:21:31", "sn88076286", "http://www.loc.gov/item/sn88076095/1922-12-29/ed-1/", "1", "microfilm service copy", "original", "2023-08-22t07:32:24.084270", "967", "sn88076097", "2576-6856", "sn88076095", "http://www.loc.gov/item/sn88076095/1899-12-01/ed-1/", "2252739", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Bowbells bulletin=tribune"], "partof": ["chronicling america", "the bowbells tribune (bowbells, ward co., n.d.) 1899-1969", "catalog", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 29.232153, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "burke", "ward", "bowbells (n.d.)", "bowbells", "north dakota", "united states"], "timestamp": "2026-07-18T09:27:07.296Z", "title": "The Bowbells tribune", "type": ["title"], "url":