ally increased prices and with out impairment of the profit position Unless this is done he continued the contrast be tween"], "digitized": true, "extract_timestamp": "2023-09-04T23:21:49.772Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82007637/1945-11-09/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_kaffirlily_ver01:data:sn82007637:00340580370:1945110901:0016/full/pct:3.125/0/default.jpg#h=281&w=213", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_kaffirlily_ver01:data:sn82007637:00340580370:1945110901:0016/full/pct:6.25/0/default.jpg#h=563&w=426", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_kaffirlily_ver01:data:sn82007637:00340580370:1945110901:0016/full/pct:12.5/0/default.jpg#h=1126&w=852", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_kaffirlily_ver01/data/sn82007637/00340580370/1945110901/0016.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["toledo", "lucas", "united states", "lucas county", "ohio"], "location_city": ["toledo"], "location_country": ["united states"], "location_county": ["lucas"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "1", "4", "8", "0000000002", "7", "sn82007637"], "number_edition": ["1"], "number_lccn": ["sn82007637"], "number_page": ["0000000002"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "0", "3", "7", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "toledo union journal (toledo, ohio) 1942-current"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "par