 "https://www.loc.gov/resource/ca06001655/1920-09-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_antelope_ver01/data/ca06001655/00543171670/1920092401/0728.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_antelope_ver01:data:ca06001655:00543171670:1920092401:0716/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/dlc/batch_dlc_antelope_ver01/data/ca06001655/00543171670/1920092401/0728.pdf", "segment_count": 25, "url": "https://www.loc.gov/resource/ca06001655/1920-09-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/dlc/batch_dlc_antelope_ver01/data/ca06001655/00543171670/1920092401/0728.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/ca06001655/1920-09-24/ed-1/?sp=13"], "batch": ["dlc_antelope_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/kansas/", "2/united states/kansas/douglas/", "3/united states/kansas/douglas/lawrence/"], "contributor": ["library of congress, washington, dc"], "date": "1920-09-24", "dates": ["1920-09-24"], "description": ["to consumers means that this problem is of the greatest importance But it is not for the farmers benefit primarily that such a move ment must quickly culminate in action The consumer feels that somewhere between the farmer and himself too much is taken for a service of comparative insignificance in contrast with that which the producer himself renders 4 6 The farmers apparently are not alone in desiring cooperative action The survey shows opposition to cooperative movements only in the New England and Pacific coast districts Sentiment is divided in Ohio Illionis and the other North Central Western States but favor able in the Middle Altantic the South Central and the Southern States 66 Politically the replies indicate that it is too early to tell what the outcome of the November election will be Three months ago there was a stronger Republican sentiment than there appears to be now The trend has been and is Republican What it will be in November these gentlemen do not prophesy 66 The large outstanding fact developed by the Fidelity and Deposit Company seems to be that the greatest issue in the public mind is being 4 6 Shall and Will Among the"], "digitized": true, "extract_timestamp": "2025-08-24T04:50:07.082Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8"], "hassegments": false, "id": "http://www.loc.gov/resource/ca06001655/1920-09-24/ed-1/?sp=13", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_antelope_ver01:data:ca06001655:00543171670:1920092401:0728/full/pct:6.25/0/default.jpg#h=272&w=198", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_antelope_ver01:data:ca06001655:00543171670:1920092401:0728/full/pct:12.5/0/default.jpg#h=544&w=397", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_antelope_ver01:data:ca06001655:00543171670:1920092401:0728/full/pct:25/0/default.jpg#h=1088&w=795", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_antelope_ver01/data/ca06001655/00543171670/1920092401/0728.xml&format=alto_xml"], "index": 13, "language": ["english"], "location": ["lawrence", "kansas", "douglas county", "douglas", "united states"], "location_city": ["lawrence"], "location_country": ["united states"], "location_county": ["douglas"], "location_state": ["kansas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000013", "3", "0", "6", "ca06001655", "7", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["c