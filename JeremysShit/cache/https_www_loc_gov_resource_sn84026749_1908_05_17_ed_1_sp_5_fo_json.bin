lish"], "location": ["alexandria", "washington d.c.", "district of columbia", "fairfax county", "united states", "virginia", "washington metropolitan area", "washington"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2002-11-21t15:38:47"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "civil war maps", "american memory"], "score": 23.467398, "shelf_id": "http://www.loc.gov/item/001-CABIB20005856/", "site": ["ammem"], "subject": ["alexandria", "fairfax county (va.)", "washington (d.c.)", "district of columbia", "washington metropolitan area", "united states", "alexandria (va.)", "washington", "virginia", "civil war", "history", "fairfax county", "maps"], "timestamp": "2022-03-30T06:52:22.796Z", "title": "Map showing positions of Union and Rebel forces Septr 1861.", "url": "https://www.loc.gov/item/gvhs01.vhs00064/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/gvhs01.vhs00032/", "http://www.loc.gov/item/gvhs01.vhs00032/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00032", "http://www.loc.gov/item/001-CABIB20002753/"], "campaigns": [], "contributor": ["sneden, robert knox"], "date": "1861-01-01", "dates": ["1861"], "description": ["Illustrates Alexandria's central position in the defense of Washington, where at least 12 outlying forts surrounded the city. Military camps of various Union officers such as Samuel Peter Heintzelman are indicated on this map."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:09.205Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00032/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00032.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00032.gif#h=192&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00032/full/pct:12.5/0/default.jpg#h=279&w=218", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00032/full/pct:25/0/default.jpg#h=559&w=437"], "index": 6, "language": ["english"], "location": ["alexandria", "washington d.c.", "district of columbia", "virginia", "united states", "fort lyon", "washington"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2001-12-29t15:29:00"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "civil war maps", "american memory"], "score": 23.467398, "shelf_id": "http://www.loc.gov/item/001-CABIB20002753/", "site": ["ammem"], "subject": ["alexandria", "washington (d.c.)", "fort lyon (va.)", "district of columbia", "virginia", "united states", "alexandria (va.)", "washington", "fort lyon", "civil war", "history", "heintzelman, samuel peter", "maps"], "timestamp": "2022-03-30T06:52:22.796Z", "title": "[Map of Alexandria, Virginia]", "url": "https://www.loc.gov/item/gvhs01.vhs00032/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/gvhs01.vhs00256/", "http://www.loc.gov/item/001-CABIB20007590/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00256", "http://www.loc.gov/item/gvhs01.vhs00256/"], "campaigns": [], "contributor": ["sneden, robert knox"], "description": ["As a diversionary measure to take some of the pressure off of besieged Petersburg, Confederate forces under Jubal Early launched a northern offensive beginning in late June 1864. After stops near Harper's Ferry and Shepherdstown, W. Va., and Frederick and Baltimore, Md., they reached the outskirts of Washington, D.C., by July 11. Reconnaissance showed the Union had begun some intensive reinforcement, so an attack planned for July 12 was postponed and then abandoned. Settling for several skirmishes near Fort Stevens, and burning the house of Montgomery Blair (Lincoln's Postmaster General), the Confederates withdrew the night of July 12th and recrossed the Potomac at Leesburg."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:32.232Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00256/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00256.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00256.gif#h=193&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00256/full/pct:12.5/0/default.jpg#h=681&w=530", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00256/full/pct:25/0/default.jpg#h=1363&w=1061"], "index": 7, "language": ["english"], "location": ["maryland", "washington d.c.", "district of columbia", "united states", "washington"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-04-28t12:18:37"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "civil war maps", "american memory"], "score": 23.467398, "shelf_id": "http://www.loc.gov/item/001-CABIB20007590/", "site": ["ammem"], "subject": ["maryland", "blair, montgomery", "homes and haunts", "washington (d.c.)", "early, jubal anderson", "district of columbia", "united states", "washington", "history", "civil war", "maryland campaign", "maps"], "timestamp": "2022-03-30T06:52:35.344Z", "title": "Plan of the Rebel attack on Washington, D.C., July 11th and 12th, 1864.", "url": "https://www.loc.gov/item/gvhs01.vhs00256/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/glva01.lva00044/", "http://www.loc.gov/item/lva0000044/", "https://hdl.loc.gov/loc.ndlpcoop/glva01.lva00044"], "campaigns": [], "contributor": ["bache, a. d. (alexander dallas)", "united states coast survey"], "date": "1862-01-01", "dates": ["1862"], "description": ["Chart of the Potomac River from Washington, D.C. to its entrance into the Chesapeake Bay. Chart indicates soundings, tides, lighthouses, and the shoreline configuration. Description derived from published bibliography. Maps numbered 20-23 in upper left corners. Seal of U.S. Coast Survey Office printed below the map title. Similar to no. 35.2, LC Civil War maps (2nd ed.) This item is in the Map Collection of the Library of Virginia; please contact the Library's Archives Research Services department for more information. Swem, E.G. Maps relating to Virginia, 989-991, 1151 Available also through the Library of Congress web site as raster image. June 2002; L.S. Straight, June 1970, cd, Map Cataloging Team. Civil War Map Proj. no.: LVA00044. Conservation: Etherington Conservation Center, April 2002. Digital image available: 39 x 24 in. or smaller. Map accession no.: 3017 (1970) Previously filed as: 755.23 H9 1862-1864."], "digitized": true, "extract_timestamp": "2020-09-23T17:20:44.449Z", "group": ["gmd_lva.mar", "library-of-virginia-maps"], "hassegments": false, "id": "http://www.loc.gov/item/lva0000044/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00044.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00044.gif#h=150&w=557", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00044/full/pct:12.5/0/default.jpg#h=944&w=3508", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00044/full/pct:25/0/default.jpg#h=1888&w=7016"], "index": 8, "language": ["english"], "location": ["washington d.c.", "district of columbia", "united states", "washington", "potomac river", "potomac river estuary"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2002-07-10t09:31:44", "lva0000044"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "civil war maps", "american memory"], "score": 23.467398, "shelf_id": "http://www.loc.gov/item/lva0000044/", "site": ["ammem"], "subject": ["washington (d.c.)", "district of columbia", "harbors", "united states", "washington", "potomac river", "nautical charts", "maps", "potomac river estuary"], "timestamp": "2022-04-30T03:06:42.687Z", "title": "Potomac River (in four sheets)", "url": "https://www.loc.gov/item/lva0000044/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/lva0000020/", "http://www.loc.gov/resource/glva01.lva00020/", "https://hdl.loc.gov/loc.ndlpcoop/glva01.lva00020"], "campaigns": [], "contributor": ["schedler, j.", "united states. war dept. corps of topographical engineers", "mcdowell, irvin"], "date": "1862-01-01", "dates": ["1862"], "description": ["Accompanied by sheet: Presented to Brig. Genl. S. Williams, A.A. Genl. Hd. Qrs. Army, by order of Maj. Genl. McClellan, Comd. in Chf. U.S.A. [signed] A.W. Whipple, Maj. T.E. [1] leaf ; 21 x 13 cm. At head of title: Surveys for military defences. Includes \"Data used in compilation,\" table of \"Elevations above tide water,\" and \"Geological profile of Loudoun County.\" Mounted on cloth backing. Relief shown by hachures. Depths shown by soundings. Shows forts and batteries in the District of Columbia and immediate vicinity. Similar to no. 1005, Swem, C.E. Maps relating to Virginia. This item is in the Map Collection of the Library of Virginia; please contact the Library's Archives Research Services department for more information. LC Civil War maps (2nd ed.), 466 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2020-09-23T17:20:44.449Z", "group": ["gmd_lva.mar", "library-of-virginia-maps"], "hassegments": false, "id": "http://www.loc.gov/item/lva0000020/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00020.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00020.gif#h=201&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00020/full/pct:12.5/0/default.jpg#h=2158&w=1612", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00020/full/pct:25/0/default.jpg#h=4317&w=3225"], "index": 9, "language": ["english"], "location": ["washington d.c.", "district of columbia", "washington metropolitan area", "united states", "washington", "virginia"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-03-17t10:25:46", "lva0000020"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "civil war maps", "american memory"], "score": 23.467398, "shelf_id": "G3881.S5 1862 .U5", "site": ["ammem"], "subject": ["washington (d.c.)", "maps, topographic", "district of columbia", "virginia", "washington metropolitan area", "united states", "fortification", "washington", "history", "civil war", "maps"], "timestamp": "2022-04-30T03:06:42.687Z", "title": "Map of n. eastern Virginia and vicinity of Washington", "url": "https://www.loc.gov/item/lva0000020/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/glva01.lva00099/", "http://www.loc.gov/item/lva0000099/", "https://hdl.loc.gov/loc.ndlpcoop/glva01.lva00099"], "campaigns": [], "contributor": ["bache, a. d. (alexander dallas)", "krebs, charles g.", "united states coast survey", "nicholson, w. l.", "w.h. & o.h. morrison (firm)"], "date": "1863-01-01", "dates": ["1863"], "description": ["\"August 1863.\" \"Lith. by Chas. G. Krebs.\" Accompanied by cover: Map of Virginia / compiled in the office of the United States Coast Survey. Washington, D.C. : W.H. & O.H. Morrison : 15 x 10 cm. Also covers Delaware, Maryland, West Virginia and parts of adjacent states. Shows cities and towns, roads, rivers, and relief by hachures. Map has concentric circles centered on Richmond, Virginia and Washington, D.C. Includes table: Distances by railroads. Relief shown by hachures. Similar to no. 465.45 (1862), LC Civil War maps (2d ed.) This item is in the Map Collection of the Library of Virginia; please contact the Library's Archives Research Services department for more information. Available also through the Library of Congress web site as raster image. c.1, Jan. 1952, Argosy Book Store, h; c. 2, 1961 photocopy, LVA; Feb. 2003, Map Cataloging Team. C. 1, map accession no. 1462 (1952); c. 2 (negative photostat, LVA, 1961, approx. 16 x 23 1/2 in.), map accession no. 1844 (1961). Civil War project no.: lva00099. Conservation: copy 1 restored May 1961; Etherington Conservation Center, Dec. 2002. Digital image available: 23 x 34 3/4 in. Previously filed as: 755 R15 1863."], "digitized": true, "extract_timestamp": "2020-09-23T17:20:46.603Z", "group": ["gmd_lva.mar", "library-of-virginia-maps"], "hassegments": false, "id": "http://www.loc.gov/item/lva0000099/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00099.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdlva/glva/glva01/lva00099.gif#h=150&w=226", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00099/full/pct:12.5/0/default.jpg#h=908&w=1368", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdlva:glva:glva01:lva00099/full/pct:25/0/default.jpg#h=1816&w=2736"], "index": 10, "language": ["english"], "location": ["delaware", "maryland", "washington d.c.", "district of columbia", "atlantic states", "virginia", "united states", "washington"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-02-21t09:35:44", "lva0000099"], "online_format": ["image"], "original_format": ["map"], "other_title": ["Map of Virginia"], "partof": ["military battles and campaigns", "geography and map division", "civil war maps", "american memory"], "score": 23.467398, "shelf_id": "http://www.loc.gov/item/lva0000099/", "site": ["ammem"], "subject": ["delaware", "maryland", "washington (d.c.)", "district of columbia", "atlantic states", "virginia", "united states", "washington", "civil war", "history", "maps"], "timestamp": "2022-04-30T03:06:42.687Z", "title": "Map of the state of Virginia", "url": "https://www.loc.gov/item/lva0000099/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_sierra_ver02/data/sn84026749/100492635/1908051701/0095.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_sierra_ver02:data:sn84026749:100492635:1908051701:0091/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/dlc/batch_dlc_sierra_ver02/data/sn84026749/100492635/1908051701/0095.pdf", "segment_count": 51, "url": "https://www.loc.gov/resource/sn84026749/1908-05-17/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_sierra_ver02/data/sn84026749/100492635/1908051701/0095.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_sierra_ver02:data:sn84026749:100492635:1908051701:0091/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/dlc/batch_dlc_sierra_ver02/data/sn84026749/100492635/1908051701/0095.pdf", "segment_count": 51, "url": "https://www.loc.gov/resource/sn84026749/1908-05-17/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/dlc/batch_dlc_sierra_ver02/data/sn84026749/100492635/1908051701/0095.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84026749/1908-05-17/ed-1/?sp=5"], "batch": ["dlc_sierra_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/district of columbia/", "3/united states/district of columbia/washington/"], "contributor": ["library of congress, washington, dc"], "date": "1908-05-17", "dates": ["1908-05-17"], "description": ["HARRIMAN HOPEFUL AT TRADE OUTLOOK RailrcadsAble to Get Money Out of Politics and Avoids Official Calls E H Harriman master of a railroad mileage that would span the globe dropped into Washington to attend a din Tied nd before his departure yesterday declared that prosperty was on its way back and would get here just about in proportion as the people returned to sound sensible understanding of busi ness condition He expressed the con fident conviction that there is a much more comfortable feeling as a result of recent court decisions which have convinced the community that the courts may yet be relied upon to protect the rights of the people and insisted that the financial troubles are at an end so far as concerns the railroads He said Hoy I wo The feeling is easier and all the country needs now is to be let alone less agitation excitement Ii has be come apparent of late that agitation has ceased to have so much effect on the public mind The people are geiling back to a calmer frame confidence that the courts will protect rights and inter ests and persons has been inspired by Some recent decisions There has"], "digitized": true, "extract_timestamp": "2026-06-16T10:00:32.512Z", "group": ["ndnp/dlc-2004_2006", "library-of-congress-washington-dc-awardee-1"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84026749/1908-05-17/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_sierra_ver02:data:sn84026749:100492635:1908051701:0095/full/pct:3.125/0/default.jpg#h=356&w=272", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_sierra_ver02:data:sn84026749:100492635:1908051701:0095/full/pct:6.25/0/default.jpg#h=712&w=544", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_sierra_ver02/data/sn84026749/100492635/1908051701/0095.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["united stat