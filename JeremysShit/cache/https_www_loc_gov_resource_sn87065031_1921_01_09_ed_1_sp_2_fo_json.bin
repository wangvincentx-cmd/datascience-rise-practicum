s/service/pnp/mrg/04100/04107v.jpg#h=1024&w=727"], "index": 6, "language": ["english"], "location": ["columbus", "mississippi", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/mrg2017004098", "2023-06-14t11:43:35", "http://www.loc.gov/item/2017706213", "2017706213", "sheet", "http://www.loc.gov/item/19676418"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints and photographs division", "john margolies roadside america photograph archive", "prints & photographs online catalog (library of congress)", "catalog"], "score": 21.628496, "shelf_id": "LC-MA05- 4107 [P&P]", "site": ["pictures", "catalog"], "subject": ["mississippi", "slides", "columbus", "color", "banks", "united states"], "timestamp": "2023-08-17T16:53:02.751Z", "title": "National Bank of Commerce, Columbus, Mississippi", "type": ["still image"], "url": "https://www.loc.gov/item/2017706213/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/nclc/item/2018676472/", "https://hdl.loc.gov/loc.pnp/nclc.02128", "http://www.loc.gov/item/2018676472/", "http://www.loc.gov/pictures/item/2018676472/", "http://www.loc.gov/resource/nclc.02128/", "http://lccn.loc.gov/2018676472"], "campaigns": [], "contributor": ["hine, lewis wickes"], "date": "1911-01-01", "dates": ["1911"], "description": ["1 photographic print."], "digitized": true, "extract_timestamp": "2021-09-01T22:53:44.911Z", "group": ["nclc", "catalog-split-11", "catalog", "national-child-labor-committee", "main-catalog-split-11", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2018676472/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/nclc/02100/02128_150px.jpg#h=108&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02100/02128t.gif#h=108&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02100/02128r.jpg#h=462&w=640", "https://tile.loc.gov/storage-services/service/pnp/nclc/02100/02128v.jpg#h=739&w=1024"], "index": 7, "language": ["english"], "location": ["columbus", "mississippi", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2018-11-02t16:00:09", "http://www.loc.gov/item/20687194", "2018676472", "http://www.loc.gov/item/ncl2004002862/pp", "http://www.loc.gov/item/2018676472"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 7479", "prints and photographs division", "prints & photographs online catalog (library of congress)", "national child labor committee collection", "catalog"], "score": 21.628496, "shelf_id": "LOT 7479, v. 3, no. 2137 [P&P]", "site": ["pictures", "catalog"], "subject": ["mississippi", "children", "textile mill workers", "columbus", "families", "photographic prints", "adults", "united states"], "timestamp": "2022-04-30T18:51:00.077Z", "title": "Family of B. F. Clark, 219 N. 4th Street. This family has worked in 8 different mill villages in the past five years. Clark was a prosperous farmer, before that, but his farm ran down. He says mill families get the habit of moving from place to place. \"And mills are writing all the time, giving great inducements and trying to fool you too.\" Some of the families around here have moved much more than we have. Moving eats up a heap of money.\" The father and all in group except mother and baby are in the mill. Home bare and ill-kept.  Location: Columbus, Mississippi.", "url": "https://www.loc.gov/item/2018676472/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/msar/batch_msar_kingsombra_ver01/data/sn87065031/00415662117/1921010901/0021.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:msar:batch_msar_kingsombra_ver01:data:sn87065031:00415662117:1921010901:0020/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/msar/batch_msar_kingsombra_ver01/data/sn87065031/00415662117/1921010901/0021.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87065031/1921-01-09/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/msar/batch_msar_kingsombra_ver01/data/sn87065031/00415662117/1921010901/0021.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:msar:batch_msar_kingsombra_ver01:data:sn87065031:00415662117:1921010901:0020/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/msar/batch_msar_kingsombra_ver01/data/sn87065031/00415662117/1921010901/0021.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87065031/1921-01-09/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/msar/batch_msar_kingsombra_ver01/data/sn87065031/00415662117/1921010901/0021.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn87065031/1921-01-09/ed-1/?sp=2"], "batch": ["msar_kingsombra_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/mississippi/", "2/united states/mississippi/lowndes/", "3/united states/mississippi/lowndes/columbus/"], "contributor": ["mississippi department of archives and history"], "date": "1921-01-09", "dates": ["1921-01-09"], "description": ["S 4 1 J v lv JS View of the Salvation Armys Christmas Party at Army Headquarters A PEEP INTO THE FUTURE Continued from Faie One has faith in the pood old UNITED STATES OF AMERICA will do well to purchase the January 8th issue of The Literary Digest and read Pages 789 an article entitled WHEN WILL HOOD TIMES RETURN 7 v In thin article the leaders of the country both in finance and industry point out that the country will enter a period of SOUND prosperity early in 1921 Lowndes County Mississippi is a part of the U S A It is rich in natural resources Its people are 100 per cent Americans and producers of wealth By hard work and cooperation the people of Lowndes County will pet their shnre of tjie coming prosperity As The Literary Biprst says As day follows night and floodtide follows ibb o jlnfVitcfy nwt h existing business depression sometime come to an end and the irJIooding tides of prosperity begin to rise MR IRA L GAslON Cashier of the First State Hank v Responding to your request for an expression of opinion on the outlook and conditions generally I submit the"], "digitized": true, "extract_timestamp": "2023-07-03T13:44:49.520Z", "group": ["ndnp/msar", "mississippi-department-of-archives-and-history"], "hassegments": false, "id": "http://www.loc.gov/resource/sn87065031/1921-01-09/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:msar:batch_msar_kingsombra_ver01:data:sn87065031:00415662117:1921010901:0021/full/pct:6.25/0/default.jpg#h=459&w=336", "https://tile.loc.gov/image-services/iiif/service:ndnp:msar:batch_msar_kingsombra_ver01:data:sn87065031:00415662117:1921010901:0021/full/pct:12.5/0/default.jpg#h=919&w=672", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/msar/batch_msar_kingsombra_ver01/data/sn87065031/00415662117/1921010901/0021.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["columbus", "mississippi", "united states", "lowndes"], "location_city": ["columbus"], "location_country": ["united states"], "location_county": ["lowndes"], "location_state": ["mississippi"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "6", "sn87065031", "7", "0000000002", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn87065031"], "number_page": ["0000000002"], "number_reel": ["0", "0", "4", "1", "5", "6", "6", "2", "1", "1", "7"], "online_format": ["ima