rvices/word-coordinates-service?segment=/service/ndnp/khi/batch_khi_lawrence_ver01/data/sn82015485/00416150576/1920123001/0326.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:khi:batch_khi_lawrence_ver01:data:sn82015485:00416150576:1920123001:0326/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/khi/batch_khi_lawrence_ver01/data/sn82015485/00416150576/1920123001/0326.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn82015485/1920-12-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/khi/batch_khi_lawrence_ver01/data/sn82015485/00416150576/1920123001/0326.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82015485/1920-12-30/ed-1/?sp=1"], "batch": ["khi_lawrence_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/kansas/", "2/united states/kansas/trego/", "3/united states/kansas/trego/wakeeney/"], "contributor": ["kansas state historical society; topeka, ks"], "date": "1920-12-30", "dates": ["1920-12-30"], "description": ["Prints All Official County News WAKEENEY KANSAS DECEMBER 30 1920 Forty Second Year Number 44 v T THE FARMERS ARE WATCHING NORTH DAKOTA While banks all over the country r nire have been prospering as never before j an exception is noted in North Da kota where many of these institu r tions recently have closed their doors j rri K ViTirl P government existing there and its itimate connection with the business of the people will experience no sur prise It has been freely predicted from the time the Nonpartisan League came into control of the North Dakota state government that disas ter for about everybody except the league leaders would follow It seems to have arrived Money may be ac quired by a few through sharp prac tices but the masses must work for what they get Prosperity cannot be snatched from the air If there be farmers who still think that the league is a good thing let them keep their eyes on North Dakota for the next two years Industrial News Letter HELP FEED THE STARVING Bare feet and tattered clothes and nothing to eat Such is the fate of millions of children in central and"], "digitized": true, "extract_timestamp": "2021-06-18T07:42:42.505Z", "group": ["ndnp/khi", "kansas-state-historical-society-topeka-ks-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82015485/1920-12-30/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:khi:batch_khi_lawrence_ver01:data:sn82015485:00416150576:1920123001:0326/full/pct:6.25/0/default.jpg#h=375&w=355", "https://tile.loc.gov/image-services/iiif/service:ndnp:khi:batch_khi_lawrence_ver01:data:sn82015485:00416150576:1920123001:0326/full/pct:12.5/0/default.jpg#h=751&w=710", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/khi/batch_khi_lawrence_ver01/data/sn82015485/00416150576/1920123001/0326.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["wakeeney", "trego county", "trego", "united states", "kansas"], "location_city": ["wakeeney"], "location_country": ["united states"], "location_county": ["trego"], "location_state": ["kansas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "1", "4", "sn82015485", "7", "6", "0000000001"], "number_edition": ["1"], "number_lccn": ["sn82015485"], "number_page": ["0000000001"], "number_reel": ["0", "0", "4", "1", "6", "1", "5", "0", "5", "7", "6"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["western kansas world (wakeeney, kan.) 1885-current", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title"