/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/001-CABIB20008140/", "http://www.loc.gov/item/gvhs01.vhs00303/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00303", "http://www.loc.gov/resource/gvhs01.vhs00303/"], "campaigns": [], "contributor": ["sneden, robert knox"], "date": "1861-01-01", "dates": ["1861"], "description": ["Detailed plan of Andersonville Prison Camp, showing Sweetwater Lick to the north, and the Southwestern & Enfaula Railroad to the east. Shows the main forts, stockade and cemetery."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:41.065Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00303/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00303.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00303.gif#h=235&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00303/full/pct:12.5/0/default.jpg#h=367&w=234", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00303/full/pct:25/0/default.jpg#h=734&w=468"], "index": 4, "language": ["english"], "location": ["andersonville", "andersonville prison", "sumter county", "georgia", "united states"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-06-13t15:34:21"], "online_format": ["image"], "original_format": ["map"], "partof": ["civil war maps", "geography and map division", "american memory", "military battles and campaigns"], "score": 32.598984, "shelf_id": "http://www.loc.gov/item/001-CABIB20008140/", "site": ["ammem"], "subject": ["andersonville (ga.)", "sumter county (ga.)", "maps", "andersonville prison", "sumter county", "history", "georgia", "civil war", "united states", "prisoners and prisons"], "timestamp": "2022-03-30T06:52:52.845Z", "title": "Andersonville Prison", "url": "https://www.loc.gov/item/gvhs01.vhs00303/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2015669162", "http://www.loc.gov/item/2015669162/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0063", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0063/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0063_mv02/", "http://www.loc.gov/resource/afc2010039text.afc2010039_crhp0063_Mahone_transcript/"], "campaigns": [], "contributor": ["mahone, sam", "civil rights history project (u.s.)", "jeffries, hasan kwame"], "date": "2013-01-01", "dates": ["2013"], "description": ["Sam Mahone discusses his experiences of racial segregation and discrimination in Americus, Georgia, and how he came to be involved in the Student Nonviolent Coordinating Committee (SNCC). After he joined SNCC, he participated in an array of activism: picketing a segregated movie theater, registering voters, and organizing in the black community. He also discusses the arrests that he and other activists experienced due to their activism, including the Americus Four case and the Leesburg Stockade. He concludes the interview by discussing his current involvement in showcasing African American art."], "digitized": true, "extract_timestamp": "2022-10-04T17:33:11.652Z", "group": ["afc2010039", "catalog-split-06", "catalog", "civil-rights-history-project", "main-catalog-split-06", "main-catalog"], "hassegments": true, "id": "http://www.loc.gov/item/2015669162/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0063/afc2010039_crhp0063_mv02.gif", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:25/0/default.jpg#h=443&w=339", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:50/0/default.jpg#h=887&w=678", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:100/0/default.jpg#h=1774&w=1356"], "index": 5, "lan