l</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn89051168, 1908-04-05, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/arhi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["pine bluff (ark.)", "https://id.oclc.org/worldcat/entity/e39pbjxgtmbhxdmvvyyqkycrkd", "arkansas", "newspapers", "https://id.oclc.org/worldcat/entity/e39pbjjt34ykpvxydcwh3wkmt3", "jefferson", "united states", "pine bluff", "jefferson county (ark.)", "jefferson county"], "subject_headings": ["Pine Bluff (Ark.)--Newspapers", "Jefferson County (Ark.)--Newspapers", "Arkansas--Jefferson County.--https://id.oclc.org/worldcat/entity/E39PBJjT34ykpVxyDCwH3wkMT3", "Arkansas--Pine Bluff.--https://id.oclc.org/worldcat/entity/E39PBJxGTMbhxDmvVyyQKYCRKd", "United States--Arkansas--Jefferson--Pine Bluff"], "subjects": [{"arkansas": "https://www.loc.gov/search/?fa=subject:arkansas&fo=json"}, {"https://id.oclc.org/worldcat/entity/e39pbjjt34ykpvxydcwh3wkmt3": "https://www.loc.gov/search/?fa=subject:https://id.oclc.org/worldcat/entity/e39pbjjt34ykpvxydcwh3wkmt3&fo=json"}, {"https://id.oclc.org/worldcat/entity/e39pbjxgtmbhxdmvvyyqkycrkd": "https://www.loc.gov/search/?fa=subject:https://id.oclc.org/worldcat/entity/e39pbjxgtmbhxdmvvyyqkycrkd&fo=json"}, {"jefferson": "https://www.loc.gov/search/?fa=subject:jefferson&fo=json"}, {"jefferson county": "https://www.loc.gov/search/?fa=subject:jefferson+county&fo=json"}, {"jefferson county (ark.)": "https://www.loc.gov/search/?fa=subject:jefferson+county+%28ark.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"pine bluff": "https://www.loc.gov/search/?fa=subject:pine+bluff&fo=json"}, {"pine bluff (ark.)": "https://www.loc.gov/search/?fa=subject:pine+bluff+%28ark.%29&fo=json"}, {"unit