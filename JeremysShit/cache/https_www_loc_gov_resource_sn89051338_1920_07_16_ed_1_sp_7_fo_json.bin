torage-services/service/ndnp/arhi/batch_arhi_kangaskhan_ver02/data/sn89051338/00414213133/1920071601/0703.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn89051338/1920-07-16/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_kangaskhan_ver02/data/sn89051338/00414213133/1920071601/0703.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_kangaskhan_ver02:data:sn89051338:00414213133:1920071601:0697/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/arhi/batch_arhi_kangaskhan_ver02/data/sn89051338/00414213133/1920071601/0703.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn89051338/1920-07-16/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/arhi/batch_arhi_kangaskhan_ver02/data/sn89051338/00414213133/1920071601/0703.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89051338/1920-07-16/ed-1/?sp=7"], "batch": ["arhi_kangaskhan_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arkansas/", "2/united states/arkansas/lee/", "3/united states/arkansas/lee/marianna/"], "contributor": ["arkansas state archives"], "date": "1920-07-16", "dates": ["1920-07-16"], "description": ["Which Way are Trade Winds Really Blowing I 9 Everit B Terhune Gen Mgr Boot and Shoe Recorder It is high time that a certain type of American business men cease worry ing and take comfort from some plain easilydiscoverable facts I am getting a growing conviction that in some commercial quarters pessimism is masquerading as marvelous schrewdness farsightedness conservatism I sense the tendency on the part of a few business men here and there to construe present unusual commercial conditions as the inevitable forerunner of panic conditions Also I ean put my finger on what I consider a very stupid inclination among certain thoughtless persons to shrug their shoulders at any mild suggestion that the business of this country is not necessarily going to blow up with a loud and resonant crash within the next eighteen months If one has the interest to chase this pessimism to its source then puts the source under the magnifying glass of intelligent unflamed business analysis of what does he find it to consist Just this Commodities are very high the consuming public is crying more nearly in unison every day for lower prices labor is in an aggrevated state of unrest and"], "digitized": true, "extract_timestamp": "2024-12-03T01:46:36.802Z", "group": ["ndnp/arhi", "arkansas-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89051338/1920-07-16/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_kangaskhan_ver02:data:sn89051338:00414213133:1920071601:0703/full/pct:6.25/0/default.jpg#h=464&w=305", "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_kangaskhan_ver02:data:sn89051338:00414213133:1920071601:0703/full/pct:12.5/0/default.jpg#h=928&w=611", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_kangaskhan_ver02/data/sn89051338/00414213133/1920071601/0703.xml&format=alto_xml"], "index": 7, "language": ["english"], "location": ["united states", "lee", "arkansas", "marianna"], "location_city": ["marianna"], "location_country": ["united states"], "location_county": ["lee"], "location_state": ["arkansas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "4", "0", "2", "1", "sn89051338", "0000000007"], "number_edition": ["1"], "number_lccn": ["sn89051338"], "number_page": ["0000000007"], "number_reel": ["0", "