5/1901-05-01/ed-1/", "library of congress", "univ of texas at austin", "baylor univ", "wisconsin hist soc, newsp proj", "original", "sn86050480", "birmingham-jefferson libr", "online resource", "2024-05-25t20:25:50.256555", "sn84020645", "9739", "http://www.loc.gov/item/sn84020645/1927-12-31/ed-1/", "microfilm service copy", "duke univ libr", "kansas state hist soc, newsp proj", "2026-04-13t21:30:13", "alabama newsp proj", "sn82008412", "western rsv hist soc, newsp proj", "center for res libr, newsp proj", "sn84023567", "2025-07-01t13:40:25.700000", "1", "sn84023549", "2993-9143", "virginia historical society library", "brigham young univ libr", "univ of kentucky libr", "panhandle-plains hist mus", "microfilm master", "sn86050479"], "original_format": ["newspaper"], "other_title": ["Saturday morning", "Montgomery advertiser and Alabama journal", "Montgomery advertiser/Alabama journal", "Daily advertiser"], "partof": ["catalog", "chronicling america", "serial and government publications division", "the montgomery advertiser (montgomery, ala.) 1885-1982", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 61.636593, "shelf_id": "Newspaper AN", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["montgomery (ala.)", "montgomery county", "alabama", "montgomery", "montgomery county (ala.)", "newspapers", "united states"], "timestamp": "2026-07-22T07:34:31.418Z", "title": "The Montgomery advertiser", "type": ["title"], "url": "https://www.loc.gov/item/sn84020645/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013254326/"], "campaigns": [], "date": "1898", "dates": ["[1898 TO 1999]"], "description": ["Weekly Print began in 1898. Description based on: Volume 2, no. 20 (January 26, 1900); title from PDF masthead (Readex America's Historical Newspapers Web site, viewed May 22, 2013). Latest issue consulted: Volume 2, no. 20 (January 26, 1900) (viewed May 22, 2013)."], "digitized": true, "extract_ti