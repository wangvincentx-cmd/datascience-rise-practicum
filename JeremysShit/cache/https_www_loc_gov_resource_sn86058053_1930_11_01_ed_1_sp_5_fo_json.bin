ints & photographs online catalog (library of congress)", "catalog"], "score": 33.52678, "shelf_id": "LC-DIG-highsm- 40830 (ONLINE) [P&P]", "site": ["pictures", "catalog"], "subject": ["lake county", "digital photographs", "gary city hall", "indiana", "america", "welcome to gary", "united states steel", "color", "gary", "united states", "city halls"], "timestamp": "2022-04-23T14:24:34.949Z", "title": "The \"Welcome to Gary\" sign at City Hall in Gary, Indiana, one of America's most economically distressed cities", "url": "https://www.loc.gov/item/2016631648/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/in/batch_in_archer_ver01/data/sn86058053/0051701719A/1930110101/0988.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_archer_ver01:data:sn86058053:0051701719A:1930110101:0984/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/in/batch_in_archer_ver01/data/sn86058053/0051701719A/1930110101/0988.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86058053/1930-11-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/in/batch_in_archer_ver01/data/sn86058053/0051701719A/1930110101/0988.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_archer_ver01:data:sn86058053:0051701719A:1930110101:0984/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/in/batch_in_archer_ver01/data/sn86058053/0051701719A/1930110101/0988.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86058053/1930-11-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/in/batch_in_archer_ver01/data/sn86058053/0051701719A/1930110101/0988.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86058053/1930-11-01/ed-1/?sp=5"], "batch": ["in_archer_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/indiana/", "2/united states/indiana/lake/", "3/united states/indiana/lake/gary/"], "contributor": ["indiana state library"], "date": "1930-11-01", "dates": ["1930-11-01"], "description": ["How long will you as taxpayers and voters of Lake county and the State of Indiana perpetuate the dangerous Republican policies existing in the public offices of trust permit existing conditions under the false mask of Republican Party Regularity I n ii This is the most important political issue of the present campaign and no political bosses no political machine no Republican Parly excuse will remedy this condition Only the taxpayers and voters themselves can do this on Tuesday November 4 No place can you find except in the state of Indiana such misrule as is found under the republican administration of Lake county and Indiana politics It is only in this county where yon find county commissioners under indictment township trustee in jail township assessor recommend ed for removal from office mayor convicted county treasurer mysterious ly disappearing for a few weeks and state officials involved in bootleg gasoline scandal Republican Prosperity lias been a joke on the people of this state and county even as in the whole United States The grafters have been able to satisfy their own personal greed and have allowed their thous ands of constituents to plod along in dire need of the many"], "digitized": true, "extract_timestamp": "2024-06-23T00:24:35.958Z", "group": ["ndnp/in", "indiana-state-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86058053/1930-11-01/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_archer_ver01:data:sn86058053:0051701719A:1930110101:0988/full/pct:6.25/0/default.jpg#h=404&w=315", "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_archer_ver01:data:sn86058053:0051701719A:1930110101:0988/full/pct:12.5/0/default.jpg#h=809&w=630", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/in/batch_in_archer_ver01/data/sn86058053/0051701719A/1930110101/0988.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["lake county", "lake", "indiana", "gary", "united states"], "location_city": ["gary"], "location_country": ["united states"], "location_county": ["lake"], "location_state": ["indiana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000005", "sn86058053", "0", "9", "7", "a", "1", "5"], "number_edition": ["1"], "number_lccn": ["sn86058053"], "number_page": ["0000000005"], "number_reel": ["0", "0", "5", "1", "7", "0", "1", "7", "1", "9", "a"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the gary american (gary, ind.) 1928-current", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the gary american (gary, ind.) 1928-current"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn86058053/1930-11-01/ed-1/?sp=5"}], "segmentof": ["http://www.loc.gov/resource/sn86058053/1930-11-01/ed-1/"], "shelf_id": "5", "site": ["chroniclingamerica"], "subject": ["lake county", "african american", "gary (ind.)", "african americans", "lake", "indiana", "lake county (ind.)", "newspapers", "gary", "united states"], "subject_ethnicity": ["african american"], "timestamp": "2024-06-23T00:44:17.508Z", "title": "Image 5 of The Gary American (Gary, Ind.), November 1, 1930, (Final Edition)", "type": ["segment"], "url": 