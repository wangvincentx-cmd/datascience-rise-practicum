v/text-services/word-coordinates-service?segment=/service/ndnp/okhi/batch_okhi_ham_ver01/data/sn86090528/00295864667/1920092401/0169.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:okhi:batch_okhi_ham_ver01:data:sn86090528:00295864667:1920092401:0161/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/okhi/batch_okhi_ham_ver01/data/sn86090528/00295864667/1920092401/0169.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn86090528/1920-09-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/okhi/batch_okhi_ham_ver01/data/sn86090528/00295864667/1920092401/0169.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86090528/1920-09-24/ed-1/?sp=9"], "batch": ["okhi_ham_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/oklahoma/", "2/united states/oklahoma/grady/", "3/united states/oklahoma/grady/chickasha/"], "contributor": ["oklahoma historical society"], "date": "1920-09-24", "dates": ["1920-09-24"], "description": ["SECTION TWO THE CHICKASHA DAILY EXPRESS SEPT K 1920 IF A EDITION IBM VIE fyaal 3 J Jr J r Clviiutv J l Starts at Chickasha Okla Saturday September 25th 1920 GOE FOE YEAR Beginning Saturday September 25th We start our great Fall Drive We have been receiving new Fall and Winter merchandise almost every day by freight and express since July 1st and now our entire stock three big floors 50x120 are filled to the brim with complete stocks of seasonable merchandise s We have set our goal at 50000000 for 1920 and we are determined not to do any less business than that amount this year We realize that in order to get volume we must sell merchandise cheap and when you see our merchandise and com pare our prices you will agree that we are offering lower prices on dependable good merchandise this fall than any other store in Western Oklahoma We have taken advantage of our enormous buying power this year for three big stores by buying great surplus stocks from manufacturers who were stuck with the goods during th business depression this past summer This we were able to do only because of our great"], "digitized": true, "extract_timestamp": "2020-09-15T15:04:15.078Z", "group": ["ndnp/okhi", "oklahoma-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86090528/1920-09-24/ed-1/?sp=9", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:okhi:batch_okhi_ham_ver01:data:sn86090528:00295864667:1920092401:0169/full/pct:6.25/0/default.jpg#h=406&w=316", "https://tile.loc.gov/image-services/iiif/service:ndnp:okhi:batch_okhi_ham_ver01:data:sn86090528:00295864667:1920092401:0169/full/pct:12.5/0/default.jpg#h=813&w=633", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/okhi/batch_okhi_ham_ver01/data/sn86090528/00295864667/1920092401/0169.xml&format=alto_xml"], "index": 9, "language": ["english"], "location": ["oklahoma", "grady county", "grady", "indian territory", "united states", "chickasha"], "location_city": ["chickasha"], "location_country": ["united states"], "location_county": ["grady"], "location_state": ["oklahoma"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "8", "0", "0000000009", "5", "2", "7", "sn86090528", "1", "6", "9"], "number_edition": ["1"], "number_lccn": ["sn86090528"], "number_page": ["0000000009"], "number_reel": ["0", "0", "2", "9", "5", "8", "6", "4", "6", "6", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Daily express", "Chickasha morning express"], "partof": ["the chickasha daily express (chickasha, indian territory [okla.]) 1899-current", "chronicling america", "serial and government publications division"], "partof_collection": ["chronic