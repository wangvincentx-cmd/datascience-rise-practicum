egment_id": "/service/ndnp/mthi/batch_mthi_douglasfir_ver01/data/sn86075189/00414211021/1948101501/0421.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86075189/1948-10-15/ed-1/?sp=4"], "batch": ["mthi_douglasfir_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/lewis and clark/", "3/united states/montana/lewis and clark/helena/"], "contributor": ["montana historical society; helena, mt"], "date": "1948-10-15", "dates": ["1948-10-15"], "description": ["TTTZTJZ T J V Lsmn HiK r r r flirrn UhH WIDe INDEPENDENT NEWSPAPER MONTANAS Published weekly by The Peoples Voice Publishing Co at 1205 Lockey Street Helena Montana Phone 26J P O Box 838 H S BRUCE Managing Editor HARRY L BILLINGS Editor COOP PUBLISHING CO HELENA MONT Entered as Second Class Matter December 7 1939 at the Post Office at Helena Montana under the Act of March 3 1879 Uj Subscription Price 200 Year Trial Subscription Five Months 100 No Commercial Advertising except from Cooperative Business institutions accepted Rates on application M P Discourages Sales C It is generally assumed that when an increase in volume of sales is attained by any well conducted commercial or in dustrial enterprise a reduction in the unit cost to the purchaser or consumer s made possible Ordinarily also the common practice of commercial or industrial enterprises is to make con stant appeal for increased consumption or sale of the articles or services sold And everyone realizes that the most potent appeal to the purchaser lies in reduced prices for larger quantities The recent residential rate increase in the price of electric power approved by the Railroad and Public Service Commis sion"], "digitized": true, "extract_timestamp": "2023-07-03T13:45:49.536Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075189/1948-10-15/ed-1/?sp=4", "image