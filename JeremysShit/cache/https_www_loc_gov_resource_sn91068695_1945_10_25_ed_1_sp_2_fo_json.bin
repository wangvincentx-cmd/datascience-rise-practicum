59447:1945102501:0347/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ncu/batch_ncu_dill_ver02/data/sn91068695/00279559447/1945102501/0348.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn91068695/1945-10-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ncu/batch_ncu_dill_ver02/data/sn91068695/00279559447/1945102501/0348.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn91068695/1945-10-25/ed-1/?sp=2"], "batch": ["ncu_dill_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/north carolina/", "2/united states/north carolina/mcdowell/", "3/united states/north carolina/mcdowell/marion/"], "contributor": ["university of north carolina at chapel hill library, chapel hill, nc"], "date": "1945-10-25", "dates": ["1945-10-25"], "description": ["THE MARION PROGRESS PUBLISHED EVERY THURSDAY BY THE Mcdowell publishing cq MARION N C TELEPHONE 64 S E WHITTEN Editor and Proprietor Entered at the Postoffice at Marion N C as second class matter SUBSCRIPTION RATE One Year 150 Strictly in Advance SHOULD WORK TOGETHER On of the difficulties that concerns the heathen when they consider embracing Chris tianity is the division that separated the var ious churches It is hard for a nonChristian to understand the exclusive claims and specific doctrines of the various branches of Christian ity It is easy to understand the confusion that befuddles the nonChristian thinker and to comprehend the logic of some nonChristians who have expressed a willingness to become Christians but an unwillingness to become a member of any particular branch of the Chris tian faith We do not believe that it is necessary for the various branches of Protestantism or of the Christian faith to become united into one church but there is a great opportunity for combined effort to convert nonbelievers in cluding millions residing in the United States It should also be possible for the various church organizations to cooperate wholeheartedly in the promotion of social and religious objectives in"], "digitized": true, "extract_timestamp": "2023-08-12T17:33:29.921Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn91068695/1945-10-25/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_dill_ver02:data:sn91068695:00279559447:1945102501:0348/full/pct:6.25/0/default.jpg#h=492&w=328", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_dill_ver02:data:sn91068695:00279559447:1945102501:0348/full/pct:12.5/0/default.jpg#h=984&w=657", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_dill_ver02/data/sn91068695/00279559447/1945102501/0348.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["mcdowell", "marion", "mcdowell county", "north carolina", "united states"], "location_city": ["marion"], "location_country": ["united states"], "location_county": ["mcdowell"], "location_state": ["north carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "9", "7", "0000000002", "sn91068695", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn91068695"], "number_page": ["0000000002"], "number_reel": ["0", "0", "2", "7", "9", "5", "5", "9", "4", "4", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["marion progress (marion, n.c.) 1909-19??", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["marion progress (marion, n.c.) 1909-19??"], "publication_frequency": ["weekly"], "resources"