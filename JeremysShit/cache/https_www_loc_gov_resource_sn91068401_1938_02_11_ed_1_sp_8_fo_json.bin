ivileges sl2 Membership Embraces All But Golf Seeking more Members At the annual meeting of stockhold ers and members of West End Coun try Club held at the chib house last night with T P Gholon president presiding a new pen of operation was suggested and adopted by the body that promises to make the club even more active in years here tofore The new plans call for two member ships one embracing all privileges of the club including golf at 36 per year and the other embracing all pri vileges of the club with the exception of golf at sl2 per year There will he no charge for wives of husbands in good standing Fourteen directors were named and they will meet today to name officers of the club for the ensuing year and to appoint the various committees The directors are J T Cheatham R G S Davis J W Jenkins Rev J A Jones O T Kirkland R G Kittrell M F Legg C O Seifert E F Shaw N"], "digitized": true, "extract_timestamp": "2023-08-12T17:37:21.869Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn91068401/1938-02-11/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_jordan_ver01:data:sn91068401:00332892782:1938021101:0280/full/pct:3.125/0/default.jpg#h=293&w=221", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_jordan_ver01:data:sn91068401:00332892782:1938021101:0280/full/pct:6.25/0/default.jpg#h=587&w=442", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_jordan_ver01:data:sn91068401:00332892782:1938021101:0280/full/pct:12.5/0/default.jpg#h=1174&w=884", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_jordan_ver01/data/sn91068401/00332892782/1938021101/0280.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["vance county", "vance", "united states", "henderson", "north carolina"], "location_city": ["henderson"], "location_country"