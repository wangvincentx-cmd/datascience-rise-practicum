", "united states", "safety film negatives", "akron"], "timestamp": "2022-04-26T10:42:17.637Z", "title": "Broken windmill near Akron", "url": "https://www.loc.gov/item/2017867928/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017693199/", "http://www.loc.gov/item/2017693199/", "http://www.loc.gov/pictures/item/2017693199/", "https://hdl.loc.gov/loc.pnp/fsa.8b03931", "http://www.loc.gov/resource/fsa.8b03931/", "http://lccn.loc.gov/2017693199"], "campaigns": [], "contributor": ["hollem, howard r.", "liberman, howard", "freeman, albert", "united states. office of war information", "roberts, martha mcmillan"], "date": "1942-01-01", "dates": ["1942"], "description": ["1 negative : safety ; 4 x 5 inches or smaller."], "digitized": true, "extract_timestamp": "2021-09-01T20:10:22.732Z", "group": ["fsa", "catalog-split-15", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-15", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017693199/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8b03000/8b03900/8b03931_150px.jpg#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b03000/8b03900/8b03931t.gif#h=120&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b03000/8b03900/8b03931r.jpg#h=513&w=640", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b03000/8b03900/8b03931v.jpg#h=821&w=1024"], "index": 3, "language": ["english"], "location": ["ohio", "united states", "summit county", "akron"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/oem2002004127/pp", "http://www.loc.gov/item/2017693199", "2017693199", "http://www.loc.gov/item/19638447", "2017-05-15t09:30:27"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 1936", "farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "prints and photographs division", "american memory", "catalog"], "score": 32.008778, "shelf_id": "LC-USE6- D-005529 [P&P] LOT 1936  (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["summit county", "ohio", "united states", "safety film negatives", "akron"], "timestamp": "2022-04-25T15:24:37.473Z", "title": "Salvage. Scrap rubber collection. Have you any old rubber lying around? Look at this picture closely and you will find many things that you too can contribute to the national scrap rubber pile. This accumulation in the yards of the Dowenthal Company in Akron, Ohio, contains old bicycle tires, hot water bottles, fruit jar rings, rubber heals and soles, floor mats, tire patches, hose connections, tubing, gaskets, fan belts, washers, in fact, everything but rubber checks", "url": "https://www.loc.gov/item/2017693199/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017699410/", "http://www.loc.gov/item/2017699410/", "http://www.loc.gov/pictures/item/2017699410/", "https://hdl.loc.gov/loc.pnp/fsa.8b01089", "http://www.loc.gov/resource/fsa.8b01089/", "http://lccn.loc.gov/2017699410"], "campaigns": [], "contributor": ["united states. office of war information", "palmer, alfred t."], "date": "1941-01-01", "dates": ["1941"], "description": ["1 negative : safety ; 4 x 5 inches or smaller."], "digitized": true, "extract_timestamp": "2021-09-01T20:10:54.612Z", "group": ["fsa", "catalog-split-07", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-07", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017699410/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8b01000/8b01000/8b01089_150px.jpg#h=118&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b01000/8b01000/8b01089t.gif#h=118&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8b01000/8b01000/8b01089r.jpg#h=503&w=640", "https://tile.loc.gov/storage-service