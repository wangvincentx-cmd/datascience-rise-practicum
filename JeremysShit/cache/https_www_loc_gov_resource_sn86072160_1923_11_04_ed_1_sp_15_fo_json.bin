nal_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "catalog", "prints and photographs division", "highsmith (carol m.) archive"], "score": 40.114937, "shelf_id": "LC-DIG-highsm- 38265 (ONLINE) [P&P]", "site": ["pictures", "catalog"], "subject": ["wyoming", "cowboy statues", "america", "20% chance of flurries", "chris navarro", "digital photographs", "color", "casper", "natrona county", "united states"], "timestamp": "2022-04-23T14:43:23.911Z", "title": "A cowboy statue called \"20% Chance of Flurries,\" in Casper, Wyoming. The work, by artist Chris Navarro, is a tongue-in-cheek reference to Wyoming cowboys' lot in winter: unpredictable, sideways blizzards in which they have to work, saving livestock, sometimes including newborn calves and lambs who would starve and freeze to death in the bitter cold", "url": "https://www.loc.gov/item/2017688157/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wyu/batch_wyu_hartville_ver01/data/sn86072160/00514150461/1923110401/0051.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_hartville_ver01:data:sn86072160:00514150461:1923110401:0037/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/wyu/batch_wyu_hartville_ver01/data/sn86072160/00514150461/1923110401/0051.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/sn86072160/1923-11-04/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wyu/batch_wyu_hartville_ver01/data/sn86072160/00514150461/1923110401/0051.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_hartville_ver01:data:sn86072160:00514150461:1923110401:0037/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/wyu/batch_wyu_hartville_ver01/data/sn86072160/00514150461/1923110401/0051.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/sn86072160/1923-11-04/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/wyu/batch_wyu_hartville_ver01/data/sn86072160/00514150461/1923110401/0051.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86072160/1923-11-04/ed-1/?sp=15"], "batch": ["wyu_hartville_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/wyoming/", "2/united states/wyoming/natrona/", "3/united states/wyoming/natrona/casper/"], "contributor": ["university of wyoming libraries"], "date": "1923-11-04", "dates": ["1923-11-04"], "description": ["SUNDAY NOVEMBER 4 1923 MIMON BRAKE NEAR PERFECT Complications Elimin ated in Making Im provements The Marman Motor Car company believes that In it front wheel brake mechanism it has attained the peak In four wheel brake mechanism and offers th following features of th new Marmon front wheel brakes as evidence J Simple internal mechanism A remarkable degree of simplicity has been attained in Marmon front wheel brake construction They necessitate few parts and few com plications This means greater de pendability lighter weight and longer wearing qualities 2 Quiet simple controls Per haps the most ingenious single fea ture of Marmon brakes lies in the simplicity of the control linkage With th cross shaft lying within Ah channel ot th front axle and with all working parts of the brakes enclosed within dust proof drums th clean cut appearance of the do sign speaki for itself in assurance of dependability and safety 3 All working parts enclosed Automobile brakes are by their na ture placed in a position of maxi mu in exposure to dirt water and mud Working parts must be pro tactsd if long wearing qualities an t efficient operation are expected The mechanism of the"], "digitized": true, "extract_timestamp": "2023-05-31T13:49:23.152Z", "group": ["ndnp/wyu", "university-of-wyoming-libraries"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86072160/1923-11-04/ed-1/?sp=15", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_hartville_ver01:data:sn86072160:00514150461:1923110401:0051/full/pct:6.25/0/default.jpg#h=286&w=237", "https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_hartville_ver01:data:sn86072160:00514150461:1923110401:0051/full/pct:12.5/0/default.jpg#h=573&w=475", "https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_hartville_ver01:data:sn86072160:00514150461:1923110401:0051/full/pct:25/0/default.jpg#h=1147&w=950", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wyu/batch_wyu_hartville_ver01/data/sn86072160/00514150461/1923110401/0051.xml&format=alto_xml"], "index": 15, "language": ["english"], "location": ["wyoming", "natrona", "casper", "natrona county", "united states"], "location_city": ["casper"], "location_country": ["united states"], "location_county": ["natrona"], "location_state": ["wyoming"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "6", "1", "0", "sn86072160", "5", "0000000015"], "number_edition": ["1"], "number_lccn": ["sn86072160"], "number_page": ["0000000015"], "number_reel": ["0", "0", "5", "1", "4", "1", "5", "0", "4", "6", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Casper Sunday morning tribune and Wyoming weekly review", "Casper Sunday tribune and Wyoming weekly review", "Casper Sunday tribune", "Casper tribune-herald"], "partof": ["casper daily tribune (casper, wyo.) 1916-1931", "chronicling america", "serial and government publications division"], "partof_collection": ["chr