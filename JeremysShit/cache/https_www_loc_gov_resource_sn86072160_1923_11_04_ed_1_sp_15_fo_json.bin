np/wyu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["casper (wyo.)", "wyoming", "newspapers", "united states", "natrona", "casper", "natrona county", "natrona county (wyo.)"], "subject_headings": ["Casper (Wyo.)--Newspapers", "Natrona County (Wyo.)--Newspapers", "Wyoming--Casper", "Wyoming--Natrona County", "United States--Wyoming--Natrona--Casper"], "subjects": [{"casper": "https://www.loc.gov/search/?fa=subject:casper&fo=json"}, {"casper (wyo.)": "https://www.loc.gov/search/?fa=subject:casper+%28wyo.%29&fo=json"}, {"natrona": "https://www.loc.gov/search/?fa=subject:natrona&fo=json"}, {"natrona county": "https://www.loc.gov/search/?fa=subject:natrona+county&fo=json"}, {"natrona county (wyo.)": "https://www.loc.gov/search/?fa=subject:natrona+county+%28wyo.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"wyoming": "https://www.loc.gov/search/?fa=subject:wyoming&fo=json"}], "timestamp": "2023-06-28T07:47:59.110Z", "title": "Casper daily tribune (Casper, Wyo.), November 4, 1923", "type": ["issue"], "url": "https://www.loc.gov/item/sn86072160/1923-11-04/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/sn86072160", "http://www.loc.gov/item/sn86072160/", "https://search.catalog.loc.gov/instances/b443fd37-214f-548d-9c3f-4c294ef73f88"], "batch": ["wyu_frannie_ver01"], "campaigns": [], "date": "1916", "description": ["Daily -v. 15, no. 142 (Mar. 31, 1931). Began Oct. 9, 1916. Cf. Gregory, W. Amer. newspapers. On Sunday published as: Casper Sunday morning tribune and Wyoming weekly review, Oct. 1, 1922-Aug. 26, 1923; Casper Sunday tribune and Wyoming weekly review, Sept. 2, 1923-Mar. 2, 1924; Casper Sunday tribune, Mar. 9, 1924-Nov. 29, 1925; Casper tribune-herald, Dec. 6, 1925-Mar. 29, 1931. Also issued on microfilm from Micro Photo Div., Bell & Howell Co. 