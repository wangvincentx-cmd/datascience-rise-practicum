d/gmd433/g4333/g4333p/la000006.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd433/g4333/g4333p/la000006.gif#h=150&w=278", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd433:g4333:g4333p:la000006/full/pct:12.5/0/default.jpg#h=1109&w=2052", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd433:g4333:g4333p:la000006/full/pct:25/0/default.jpg#h=2218&w=4105"], "index": 4, "language": ["english"], "location": ["arizona", "united states", "tucson", "nogales", "pima county"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2011-11-28t13:39:51", "2025-06-07t18:32:05.200000", "77692954"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "catalog", "county landownership maps", "cultural landscapes"], "score": 32.592434, "shelf_id": "G4333.P4 1893 .R6 G4333.P4 1893 .R6 G4333.P4 1893 .R6", "site": ["catalog"], "subject": ["arizona", "nogales (ariz.)", "tucson (ariz.)", "united states", "tucson", "nogales", "pima county (ariz.)", "pima county", "maps"], "timestamp": "2026-04-29T16:18:09.713Z", "title": "Official map of Pima County, Arizona", "type": ["cartographic"], "url": "https://www.loc.gov/item/77692954/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2020655666", "http://www.loc.gov/item/2020655666/", "https://hdl.loc.gov/loc.afc/afc2015028.afc2015028_03002_sr01", "http://www.loc.gov/resource/afc2015028.afc2015028_03002_sr01/", "http://www.loc.gov/resource/afc2015028.afc2015028_03002_ms02/"], "campaigns": [], "contributor": ["hartmann, nic", "thomas, charlie (charles, sr.)", "occupational folklife project"], "date": "2015", "dates": ["2015"], "description": ["Charlie Thomas of Thomas Produce in Tucson, Arizona, talks about his life in the fresh produce industry of both North Carolina and Arizona. He discusses his father's and family's involvement in produce industry; handling different vegetables; determining ripeness; changes in industry; the impact of Wal-Mart; growing areas in Mexico; Greco-Mexican connections in produce industry; winter produce and Florida; cash vs. credit; the local industry in Arizona; competition from elsewhere; and etc."], "digitized": true, "extract_timestamp": "2025-08-14T14:52:29.355Z", "group": ["afc/2015028", "catalog-split-06", "catalog", "produce-workers", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/2020655666/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:afc:afc2015028:afc2015028_03002:afc2015028_03002_ms02/full/pct:25/0/default.jpg"], "index": 5, "language": ["english"], "location": ["arizona", "tucson", "nogales"], "mime_type": ["audio/mp3", "application/pdf"], "number": ["2021-01-11t12:50:47", "2020655666", "online resource"], "online_format": ["audio", "pdf"], "original_format": ["sound recording"], "partof": ["occupational folklife project", "american folklife center", "catalog", "fresh produce workers in arizona: archie green fellows project, 2015-2016"], "score": 31.482742, "shelf_id": "http://lccn.loc.gov/2020655666", "site": ["catalog"], "subject": ["oral histories", "nogales", "social life and customs", "arizona", "personal narratives", "quality", "work ethic", "folklore", "farm produce", "charles, sr.)", "produce trade", "interviews", "sound recordings", "thomas, charlie", "family-owned business enterprises", "occupational training", "nogales (ariz.)", "job satisfaction", "quality of work life", "work environment"], "timestamp": "2025-08-14T14:53:11.604Z", "title": "Charles \"Charlie\" Thomas, Sr. interview conducted by Nic Hartmann, 2015-08-25", "type": ["sound recording-nonmusical"], "url": "https://www.loc.gov/item/2020655666/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2020655667", "http://www.loc.gov/item/2020655667/", "https://hdl.loc.gov/loc.afc/afc2015028.afc2015028_03021_sr01", "http://www.loc.gov/resource/afc2015028.afc2015028_03021_sr01/", "http://www.loc.gov/resource/afc2015028.afc2015028_03021_ms02/"], "campaigns": [], "contributor": ["hartmann, nic", "cathey, jim", "occupational folklife project"], "date": "2015", "dates": ["2015"], "description": ["Interview with Jim Cathey, Sales and Sourcing Manager of Red Sun Farms in Tubac, Arizona. He talks about entering the industry; moving to Arizona; going into the greenhouse industry; McAllen's (TX) rise as a produce center, and Nogales' response; an average work day; the challenges of the industry; labor and labor shortages; the impact of technology on the trade; and etc."], "digitized": true, "extract_timestamp": "2025-08-14T14:52:29.355Z", "group": ["afc/2015028", "catalog-split-07", "catalog", "produce-workers", "main-catalog-split-07"], "hassegments": false, "id": "http://www.loc.gov/item/2020655667/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:afc:afc2015028:afc2015028_03021:afc2015028_03021_ms02/full/pct:25/0/default.jpg"], "index": 6, "language": ["english"], "location": ["arizona", "tubac", "nogales"], "mime_type": ["audio/mp3", "application/pdf"], "number": ["2020655667", "2021-01-11t09:07:35", "online resource"], "online_format": ["audio", "pdf"], "original_format": ["sound recording"], "partof": ["occupational folklife project", "american folklife center", "catalog", "fresh produce workers in arizona: archie green fellows project, 2015-2016"], "score": 31.482742, "shelf_id": "http://lccn.loc.gov/2020655667", "site": ["catalog"], "subject": ["arizona", "farm produce", "work ethic", "nogales (ariz.)", "nogales", "produce trade", "oral histories", "personal narratives", "interviews", "sound recordings", "work environment", "quality", "work-life balance", "cathey, jim", "social life and customs", "folklore"], "timestamp": "2025-08-14T14:53:11.604Z", "title": "Jim Cathey interview conducted by Nic Hartmann, 2015-08-26", "type": ["sound recording-nonmusical"], "url": "https://www.loc.gov/item/2020655667/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414218258/1930110701/0127.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414218258:1930110701:0127/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414218258/1930110701/0127.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn96060774/1930-11-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414218258/1930110701/0127.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414218258:1930110701:0127/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414218258/1930110701/0127.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn96060774/1930-11-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414218258/1930110701/0127.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn96060774/1930-11-07/ed-1/?sp=1"], "batch": ["az_groomcreek_ver04"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arizona/", "2/united states/arizona/santa cruz/", "3/united states/arizona/santa cruz/nogales/"], "contributor": ["arizona state library, archives and public records; phoenix, az"], "date": "1930-11-07", "dates": ["1930-11-07"], "description": ["POPULATION it Am bos NOGALES IS 24701 GREAT FASHION SHOW IN NOGALES TONIGHT MERCHANTS DISPLAY TONIGHT TO BE GALA CARNIVAL EVENT Entire City Will Turn Out To Witness Magnificent Exhibits Prepared In Stores And Shops Jr a stupendous effort to revive business and prove to the public the high purchasing power of the dollar today as compared with a year ago the merchants of Nogales are cooperating 100 per cent in pro viding for this city its first Merch ants Display Night event tonight Prom 7 until 9 oclock the two main thoroughfares of the business district Morley and Grand avenues will take on the appearance of a huge fashion show The carnival spirit will reign and it is expected the entire city will turn out to wit ness the magnificent exhibits and enjoy the program prepared for them by the progressive business men of Nogales Music will be furnished at prom inent places in the business area by the 25th Infantry band and the high school band and by three or chestras Many of the stores also will furnish music while the merch andise is being shown as many have installed radios which will be tuned in on stations"], "digitized": true, "extract_timestamp": "2024-01-09T14:50:03.875Z", "group": ["ndnp/az", "arizona-state-university-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn96060774/1930-11-07/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414218258:1930110701:0127/full/pct:3.125/0/default.jpg#h=264&w=188", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414218258:1930110701:0127/full/pct:6.25/0/default.jpg#h=529&w=376", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414218258:1930110701:0127/full/pct:12.5/0/default.jpg#h=1059&w=753", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414218258/1930110701/0127.xml&format=alto_xml"], "index": 1, "language": ["english"], "lo