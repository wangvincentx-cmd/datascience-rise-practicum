item/2017764958/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8c52000/8c52400/8c52470_150px.jpg#h=121&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8c52000/8c52400/8c52470t.gif#h=121&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8c52000/8c52400/8c52470r.jpg#h=515&w=640", "https://tile.loc.gov/storage-services/service/pnp/fsa/8c52000/8c52400/8c52470v.jpg#h=825&w=1024"], "index": 3, "language": ["english"], "location": ["ripley", "vermont", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/2017764958", "http://www.loc.gov/item/19879428", "2017764958", "http://www.loc.gov/item/fsa1998023609/pp", "2017-10-03t16:40:39"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "farm security administration/office of war information black-and-white negatives", "lot 1251", "prints and photographs division", "american memory", "catalog"], "score": 17.705303, "shelf_id": "LC-USF342- 013213-A [P&P] LOT 1251A (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["united states", "safety film negatives", "ripley", "vermont", "small towns"], "timestamp": "2022-04-25T18:07:48.877Z", "title": "A marble storeyard. Ripley, Vermont", "url": "https://www.loc.gov/item/2017764958/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/mm78039768", "http://www.loc.gov/item/mm78039768/", "https://search.catalog.loc.gov/instances/4352a1e4-d38c-567b-896b-0c595188da9b", "https://hdl.loc.gov/loc.mss/collmss.ms000038"], "campaigns": [], "contributor": ["sheridan, philip henry"], "description": ["Correspondence, letterbooks, telegrams, memoir, speeches, reports, orders, financial records, scrapbooks, and other papers relating primarily to Sheridan's role as U.S. Army officer during the Civil War, Reconstruction, Mexican border disputes, Indian wars, and and his service as commanding general of the U.S. Army. Civil War material relates to cavalry operations, the Appomattox, Shenandoah, and Tullahoma campaigns, the Winchester Raid, and engagements at Boonville, Chickamauga, Missionary Ridge, Perryville, Ripley, and Stone River. Also includes material on George A. Forsyth's Europe-Asia tour (1875-1876), the Piegan Expedition (1869-1870), Gouverneur K. Warren's court of inquiry (1881), Rebecca M. Bonsal's service as Union spy at Winchester, Va., reconnaissance of the Bighorn Mountains and the Bighorn and Yellowstone river valleys (1877), and Henry Page's service as quartermaster of the Army of the Potomac (1863-1865). Correspondents include George A. Forsyth, James W. Forsyth, Ulysses S. Grant, Abraham Lincoln, Michael V. Sheridan, and William T. Sherman."], "digitized": true, "extract_timestamp": "2026-05-12T10:21:50.610Z", "group": ["catalog-split-10", "catalog", "main-catalog-split-10"], "hassegments": false, "id": "http://lccn.loc.gov/mm78039768", "image_url": [], "index": 4, "language": ["english"], "location": ["tullahoma", "yellowstone river", "asia", "united states", "chickamauga", "europe", "winchester", "missionary ridge", "georgia", "murfreesboro", "mississippi", "bighorn mountains", "appomattox", "perryville", "shenandoah river valley", "ripley", "kentucky", "virginia", "missouri", "boonville", "montana", "west virginia", "tennessee", "mexico", "wyoming"], "number": ["mm78039768", "2026-05-11t21:19:51.400000"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["catalog", "manuscript division"], "score": 15.065923, "shelf_id": "http://lccn.loc.gov/mm78039768", "site": ["catalog"], "subject": ["bonsal, rebecca m", "discovery and exploration", "gouverneur kemble)", "courts-martial and courts of inquiry", "asia", "ulysses simpson)", "boundaries", "cavalry operations", "united states", "yellowstone river", "page, henry", "correspondence", "reconstruction (u.s. history,)", "shenandoah valley 