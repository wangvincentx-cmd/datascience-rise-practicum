81", "sheet", "2007-01-06t09:15:48"], "online_format": ["image"], "original_format": ["map"], "other_title": ["Atlanta and vicinity"], "partof": ["catalog", "military battles and campaigns", "civil war maps", "geography and map division"], "score": 27.004824, "shelf_id": "G3924.A8S5 1864 .F5 G3924.A8S5 1864 .F5 Copy 2 Vault : Sher 38", "site": ["catalog"], "subject": ["georgia", "history", "united states", "atlanta", "atlanta (ga.)", "maps", "civil war"], "timestamp": "2026-04-29T15:50:44.690Z", "title": "Atlanta & vicinity : compiled from state map and information", "type": ["cartographic"], "url": "https://www.loc.gov/item/2006458681/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2006459233", "http://www.loc.gov/item/2006459233/", "https://search.catalog.loc.gov/instances/ca924d0c-5f41-5d28-bb23-fa78c3f2f33d", "https://hdl.loc.gov/loc.gmd/g3924a.cws00040", "http://www.loc.gov/resource/g3924a.cws00040/"], "campaigns": [], "contributor": ["molitor, e.", "poe, o. m. (orlando metcalfe)", "united states. war department. engineer bureau"], "date": "1864-07-19", "dates": ["1864-07-19"], "description": ["Relief shown by hachures and spot heights. Main entry from Stephenson's Civil War maps, 1989. Includes note. In pencil in upper-right margin: 52. LC copy imperfect: Margins trimmed, mounted on paper. Library of Congress. Civil War maps (2nd ed.), S40, 138 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:34.100Z", "group": ["gmd.mar", "catalog-split-02", "catalog", "general-maps", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/2006459233/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd392/g3924/g3924a/cws00040.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd392/g3924/g3924a/cws00040.gif#h=150&w=241", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd392:g3924:g3924a:cws00040/full/pct:12.5/0/default.jpg#h=524&w=842", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd392:g3924:g3924a:cws00040/full/pct:25/0/default.jpg#h=1048&w=1684"], "index": 6, "language": ["english"], "location": ["atlanta", "georgia", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2006459233", "2026-01-13t19:16:59", "sheet"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "military battles and campaigns", "civil war maps", "geography and map division"], "score": 27.004824, "shelf_id": "G3924.A8S5 1864 .P62", "site": ["catalog"], "subject": ["sherman, william t.", "georgia", "history", "united states", "atlanta", "atlanta (ga.)", "maps", "william tecumseh)", "civil war", "atlanta campaign"], "timestamp": "2026-04-29T15:50:44.690Z", "title": "Map illustrating the siege of Atlanta, Ga. by the U.S. forces, under command of Maj. Gen. W.T. Sherman : from the passage of Peach Tree Creek, July 19th, 1864 to the commencement of the movement upon the enemy's lines of communication south of Atlanta, August 26, 1864", "type": ["cartographic"], "url": "https://www.loc.gov/item/2006459233/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2006459234", "http://www.loc.gov/item/2006459234/", "https://search.catalog.loc.gov/instances/9a082904-5c46-53d6-a572-bb11959168d3", "https://hdl.loc.gov/loc.gmd/g3924a.cws00044", "http://www.loc.gov/resource/g3924a.cws00044/"], "campaigns": [], "contributor": ["united states. army of the cumberland. topographical engineers office"], "date": "1864", "dates": ["1864"], "description": ["From Vincent's subdivision map of the city of Atlanta, Dekalb County, state of Georgia. Savannah : Edward A. Vincent, 185-. Includes numbered building index. LC copy imperfect: Fold-lined, mounted on paper. LC Civil War maps (2nd ed.), S44 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:01.278Z", "group": 