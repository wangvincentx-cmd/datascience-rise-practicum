vices/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/vi/batch_vi_nipon_ver01/data/10021978/00271764832/1921020901/0107.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:vi:batch_vi_nipon_ver01:data:10021978:00271764832:1921020901:0106/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/vi/batch_vi_nipon_ver01/data/10021978/00271764832/1921020901/0107.pdf", "segment_count": 18, "url": "https://www.loc.gov/resource/10021978/1921-02-09/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/vi/batch_vi_nipon_ver01/data/10021978/00271764832/1921020901/0107.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/10021978/1921-02-09/ed-1/?sp=2"], "batch": ["vi_nipon_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/georgia/", "2/united states/georgia/fulton/", "3/united states/georgia/fulton/atlanta/", "1/united states/virginia/", "2/united states/virginia/henrico/", "3/united states/virginia/henrico/richmond/"], "contributor": ["library of virginia; richmond, va"], "date": "1921-02-09", "dates": ["1921-02-09"], "description": ["THE FOUNDATION OF PROSPERITY A great deal is being said these days about business depression That tbere is such a con dition no one will deny There is difference of opinion as to the reason for this depression and also as to the length of time it will con tinue A question that is uppermost in the minds of many is as to how this depression may be overcome and business be brought back to nor mal conditions Many suggestions have been made and many remedies have been proposed Some say that wages must be reduced so as lo bring down the cost of production Others say wages must be maintained at present levels in order that the wage earner may be able to buy liberally Some say that the Government must regulate business as to prices and n many other ways Others say that the trouble is that the Government has tried to do too much regulating and that it ought to let busi ness take eare of itself Some say that the Government should finance certain lines of business Others say that this is entirely be yond the province of the Government Some say that what is needed"], "digitized": true, "extract_timestamp": "2024-02-06T12:46:02.877Z", "group": ["ndnp/vi", "library-of-virginia-richmond-va-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/10021978/1921-02-09/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:vi:batch_vi_nipon_ver01:data:10021978:00271764832:1921020901:0107/full/pct:6.25/0/default.jpg#h=350&w=242", "https://tile.loc.gov/image-services/iiif/service:ndnp:vi:batch_vi_nipon_ver01:data:10021978:00271764832:1921020901:0107/full/pct:12.5/0/default.jpg#h=700&w=485", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/vi/batch_vi_nipon_ver01/data/10021978/00271764832/1921020901/0107.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["richmond", "georgia", "virginia", "united states", "fulton", "atlanta", "henrico"], "location_city": ["atlanta", "richmond"], "location_country": ["united states"], "location_county": ["fulton", "henrico"], "location_state": ["georgia", "virginia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "8", "3", "4", "7", "10021978", "6", "2", "1", "0000000002"], "number_edition": ["1"], "number_lccn": ["10021978"], "number_page": ["0000000002"], "number_reel": ["0", "0", "2", "7", "1", "7", "6", "4", "8", "3", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "the presbyterian of