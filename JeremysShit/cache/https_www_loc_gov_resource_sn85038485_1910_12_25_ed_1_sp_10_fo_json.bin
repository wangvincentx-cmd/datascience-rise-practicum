ion", "king, martin luther", "segregation", "alabama", "african american children"], "timestamp": "2023-07-08T02:18:22.520Z", "title": "Let the children march", "type": ["sound recording-nonmusical"], "url": "//lccn.loc.gov/2020617872"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/au/batch_au_gaston_ver01/data/sn85038485/00340583978/1910122501/0963.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:au:batch_au_gaston_ver01:data:sn85038485:00340583978:1910122501:0954/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/au/batch_au_gaston_ver01/data/sn85038485/00340583978/1910122501/0963.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/sn85038485/1910-12-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/au/batch_au_gaston_ver01/data/sn85038485/00340583978/1910122501/0963.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:au:batch_au_gaston_ver01:data:sn85038485:00340583978:1910122501:0954/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/au/batch_au_gaston_ver01/data/sn85038485/00340583978/1910122501/0963.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/sn85038485/1910-12-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/au/batch_au_gaston_ver01/data/sn85038485/00340583978/1910122501/0963.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85038485/1910-12-25/ed-1/?sp=10"], "batch": ["au_gaston_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/alabama/", "2/united states/alabama/jefferson/", "3/united states/alabama/jefferson/birmingham/"], "contributor": ["university of alabama libraries, tuscaloosa, al"], "date": "1910-12-25", "dates": ["1910-12-25"], "description": ["He Is 55 Years Old But Young in Vitality 3 f Th vigor of youth can b hut on thingYTtaTTty The man who pos sesses an abundant vitality never grows old be will be younger at 60 than the man of SO whose vitality has been sapped and who has taken no means to restore It The great scientists of today are unanimous on the point that vitality is the true secret of what we call perpetual youth If I can renew your vitality I can make you young and keep yon young forever I have found the true supply of manly strength My Health Belt is a greet natural restorer you wear It nights while asleep and thus during the period of your rest when the vital energy Is the lowest It pours a great stream of electrovitality Into your weakened organs and system It never ceases for a single moment hour after hour the great flow of warm new life and strength passes silently Into your blood nerves and organs you feel better Immediately the pains In your back may be expected to disappear In one night the electrosuspensory attachment is free with each Health Belt for men"], "digitized": true, "extract_timestamp": "2022-09-26T05:40:29.257Z", "group": ["ndnp/au", "university-of-alabama-tuscaloosa-al-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85038485/1910-12-25/ed-1/?sp=10", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:au:batch_au_gaston_ver01:data:sn85038485:00340583978:1910122501:0963/full/pct:6.25/0/default.jpg#h=440&w=308", "https://tile.loc.gov/image-services/iiif/service:ndnp:au:batch_au_gaston_ver01:data:sn85038485:00340583978:1910122501:0963/full/pct:12.5/0/default.jpg#h=881&w=616", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/au/batch_au_gaston_ver01/data/sn85038485/00340583978/1910122501/0963.xml&format=alto_xml"], "index": 10, "language