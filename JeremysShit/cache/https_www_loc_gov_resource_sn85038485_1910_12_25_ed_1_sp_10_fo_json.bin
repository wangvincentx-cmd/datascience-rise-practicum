52, 33.5228587], "number": ["sn85038485", "wisconsin hist soc, newsp proj", "2025-07-01t13:40:39.800000", "library of congress", "8481", "original", "univ of chicago", "1", "2024-05-25t20:25:50.256555", "center for research libraries", "microfilm master", "univ of georgia", "2692-6318", "sn89050031", "http://www.loc.gov/item/sn85038485/1902-05-21/ed-1/", "http://www.loc.gov/item/sn85038485/1925-08-31/ed-1/", "western rsv hist soc, newsp proj", "birmingham-jefferson libr", "microfilm service copy", "alabama dept of arch & hist libr", "center for res libr, newsp proj", "online resource", "2026-04-13t21:30:13", "12607279", "sn82014765", "sn86072192"], "original_format": ["newspaper"], "other_title": ["Sunday issues for <June 5, 1927-May 7, 1950> published as combined issue with Birmingham news, with title: Birmingham news, the Birmingham age-herald", "Age-herald"], "partof": ["chronicling america", "catalog", "the birmingham age-herald (birmingham, ala.) 1902-1950", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 53.016407, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["united states", "birmingham", "newspapers", "alabama", "jefferson", "birmingham (ala.)"], "timestamp": "2026-07-22T07:41:54.616Z", "title": "The Birmingham age-herald", "type": ["title"], "url": "https://www.loc.gov/item/sn85038485/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271955/"], "campaigns": [], "date": "1890", "dates": ["[1890 TO 1895]"], "description": ["Daily Print began with vol. 2, no. 301 (September 6, 1890); ceased with volume 21, number 310 (October 3, 1895). Numbering is irregular. Also issued on microfilm from Bell & Howell, Micro Photo Div.; the Library of Congress, Photoduplication Service. Description based on: Volume 20, Number 198 (July 3, 1894); title from masthead (Chroniclingamerica.loc.gov, viewed June 11, 2020). 