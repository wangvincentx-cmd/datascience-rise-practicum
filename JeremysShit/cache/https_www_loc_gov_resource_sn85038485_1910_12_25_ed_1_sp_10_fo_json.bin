1455&w=1503"], "index": 10, "language": ["english"], "location": ["birmingham", "alabama", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["73696177", "2018-11-05t13:54:56", "2025-06-07t18:29:58.400000"], "online_format": ["image"], "original_format": ["map"], "partof": ["cities and towns", "catalog", "geography and map division"], "score": 29.11546, "shelf_id": "G3974.B5 1903 .K4", "site": ["catalog"], "subject": ["united states", "administrative and political divisions", "birmingham", "alabama", "maps", "birmingham (ala.)"], "timestamp": "2026-04-29T16:13:09.409Z", "title": "Map of Birmingham, Alabama and adjacent suburbs", "type": ["cartographic"], "url": "https://www.loc.gov/item/73696177/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/75693075", "http://www.loc.gov/item/75693075/", "https://search.catalog.loc.gov/instances/b123437d-e20d-5f95-ae81-7487f2f2c186", "https://hdl.loc.gov/loc.gmd/g3974b.pm000050", "http://www.loc.gov/resource/g3974b.pm000050/"], "campaigns": [], "contributor": ["dry, camille n."], "date": "1904", "dates": ["1904"], "description": ["AACR2 Bird's-eye-view. Photocopy. Perspective map not drawn to scale. Library of Congress. Panoramic maps of cities in the United States and Canada (2nd ed.), 5 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:54.578Z", "group": ["gmd.mar", "catalog-split-10", "catalog", "general-maps", "main-catalog-split-10"], "hassegments": false, "id": "http://www.loc.gov/item/75693075/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd397/g3974/g3974b/pm000050.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd397/g3974/g3974b/pm000050.gif#h=150&w=226", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd397:g3974:g3974b:pm000050/full/pct:12.5/0/default.jpg#h=238&w=358", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd397:g3974:g3974b:pm000050/full/pct:25/0/default.jpg#h=476&w=716"], "index": 11, "language": ["english"], "location": ["birmingham", "alabama", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2026-02-23t17:24:42.400000", "75693075"], "online_format": ["image"], "original_format": ["map"], "partof": ["panoramic maps", "cities and towns", "catalog", "geography and map division"], "score": 29.11546, "shelf_id": "G3974.B5A3 1903 .D7", "site": ["catalog"], "subject": ["united states", "birmingham", "central business districts", "alabama", "maps", "aerial views", "birmingham (ala.)"], "timestamp": "2026-04-29T16:15:42.364Z", "title": "Business section of the city of Birmingham, Alabama", "type": ["cartographic"], "url": "https://www.loc.gov/item/75693075/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2016655400", "http://www.loc.gov/item/2016655400/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0109", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0109/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0109_mv08/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0109_ms01/"], "campaigns": [], "contributor": ["bishop, john melville", "walker, wyatt tee", "walker, theresa ann", "civil rights history project (u.s.)", "cline, david p."], "date": "2014-01-01", "dates": ["2014"], "description": ["Dr. Walker reflects on his involvement in the freedom movement, especially his work as Martin Luther King's chief of staff and as the Executive Director of the Southern Christian Leadership Conference (SCLC) from 1960-1964. He recalls helping to organize the Children's Crusade in Birmingham, Alabama, and supporting Dr. King in transcribing and publishing \"Letter from a Birmingham Jail.\" He also remembers preaching in Petersburg, Virginia, and Harlem, New York, and becoming involved in several later movements, including anti-apartheid and pro-charter schools activism. Towards the end of the interview, his wife, Theresa Ann Walker, joins him on camera to talk briefly about her experiences in the movement."], "digitized": true, "extract_timestamp": "2022-10-04T17:35:53.116Z", "group": ["afc2010039", "catalog-split-13", "catalog", "civil-rights-history-project", "main-catalog-split-13", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2016655400/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0109/afc2010039_crhp0109_mv08.gif", "https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0109/afc2010039_crhp0109_ms01.gif#h=150&w=116"], "index": 12, "language": ["english"], "location": ["georgia", "united states", "birmingham", "tennessee", "new york", "richmond", "virginia", "alabama", "petersburg"], "mime_type": ["image/gif", "application/pdf", "image/jpeg", "application/x-video"], "number": ["online resource", "2020-01-23t09:44:32", "2016655400"], "online_format": ["image", "pdf", "video"], "original_format": ["film, video"], "partof": ["civil rights history project", "catalog", "american folklife center"], "score": 29.11546, "shelf_id": "http://lccn.loc.gov/2016655400", "site": ["catalog"], "subject": ["personal narratives", "interviews", "sanitation workers strike, memphis, tenn", "social justice", "civil rights demonstrations", "albany movement (albany, ga.)", "virginia", "jr", "race relations", "african americans", "video recordings", "birmingham", "tennessee", "petersburg (va.)", "christianity", "filmed interviews", "african american clergy", "african american civil rights workers", "united states", "walker, theresa ann", "national association for the advancement of colored people", "nonviolence", "congress of racial equality", "civil rights movements", "march on washington for jobs and freedom", "petersburg", "birmingham (ala.)", "georgia", "walker, wyatt tee", "southern christian leadership conference", "new york", "king, martin luther", "washington, d.c.)", "segregation"