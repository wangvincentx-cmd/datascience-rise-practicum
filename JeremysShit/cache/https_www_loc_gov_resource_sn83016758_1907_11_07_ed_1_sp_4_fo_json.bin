ce/sn83016758/1907-11-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_halma_ver01/data/sn83016758/00280767748/1907110701/0368.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_halma_ver01:data:sn83016758:00280767748:1907110701:0365/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_halma_ver01/data/sn83016758/00280767748/1907110701/0368.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn83016758/1907-11-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mnhi/batch_mnhi_halma_ver01/data/sn83016758/00280767748/1907110701/0368.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83016758/1907-11-07/ed-1/?sp=4"], "batch": ["mnhi_halma_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/minnesota/", "2/united states/minnesota/mille lacs/", "3/united states/minnesota/mille lacs/princeton/"], "contributor": ["minnesota historical society; saint paul, mn"], "date": "1907-11-07", "dates": ["1907-11-07"], "description": ["v THE PRINCETON UNION BY R O DUNN TIRM8S10 0 PER YEAR IN ADVANCE 125 I NOT PAID IN ADVANCE OPPIOBI FIRST ST EAST OF COURTHOUSE Q I STAPLES Business Manager is news THOS H PROWSB Editor The reason why lumber is so high but then there is really no reason why it should be Since the financial disturbance has set in there has been a suspension of trustbusting There is no doubt that those Wall street gamblers ought to be jailed but how are we going to accomplish it It doesnt necessarily follow that because Harry Thaw is studying law he is crazy as declared by the alien ists In flaming headlines the Minneapo lis Tribune announces that Governor Johnson will seek a third term That A daily advises us to hold our copper stocks Just about now we would be mighty thankful could we hold our copper cents One great advantage in aerial teleg raphy is that no possibiliby exists of being killed by coming into contact with the systems live wires Now is a splendid time for the Ameri can Society of Equity to practice what it preachesdo not dump farmers produce on a falling market A"], "digitized": true, "extract_timestamp": "2023-08-04T17:00:52.775Z", "group": ["ndnp/mnhi", "minnesota-historical-society-saint-paul-mn-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83016758/1907-11-07/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_halma_ver01:data:sn83016758:00280767748:1907110701:0368/full/pct:3.125/0/default.jpg#h=272&w=191", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_halma_ver01:data:sn83016758:00280767748:1907110701:0368/full/pct:6.25/0/default.jpg#h=545&w=382", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_halma_ver01:data:sn83016758:00280767748:1907110701:0368/full/pct:12.5/0/default.jpg#h=1091&w=765", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_halma_ver01/data/sn83016758/00280767748/1907110701/0368.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["united states", "princeton", "mille lacs", "minnesota"], "location_city": ["princeton"], "location_country": ["united states"], "location_county": ["mille lacs"], "location_state": ["minnesota"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000004", "0", "2", "1", "8", "4", "7", "sn83016758", "6"], "number_edition": ["1"], "number_lccn": ["sn83016758"], "number_page": ["0000000004"], "number_reel": ["0", "0", "2", "8", "0", "7", "6", "7", "7"