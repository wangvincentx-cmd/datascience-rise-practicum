370/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/74692205", "http://www.loc.gov/item/74692205/", "https://search.catalog.loc.gov/instances/f5afe959-16b6-5784-b388-e359e52354b3", "https://hdl.loc.gov/loc.gmd/g3811s.ar127000", "http://www.loc.gov/resource/g3811s.ar127000/"], "campaigns": [], "contributor": ["faden, william"], "date": "1777", "dates": ["1777"], "description": ["Hand colored. Relief shown by hachures. Shows area from Newtown, Pennsylvania to Kingston, New Jersey, with routes of British and American forces. Includes tables \"Loss in the engagement, on the roads from Prince Town to Maidenhead, January the 3d. 1777\" and \"Loss at Trenton, December 26th. 1776.\" Scale ca. 1:113,000. LC Maps of North America, 1750-1789, 1270 Available also through the Library of Congress Web site as a raster image. LC copy trimmed to border. Vault AACR2: 100; 651/1; 650/2; 650/3"], "digitized": true, "extract_timestamp": "2026-04-29T15:40:01.797Z", "group": ["gmd.mar", "catalog-split-03", "catalog", "general-maps", "main-catalog-split-03"], "hassegments": false, "id": "http://www.loc.gov/item/74692205/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd381/g3811/g3811s/ar127000.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd381/g3811/g3811s/ar127000.gif#h=150&w=202", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3811:g3811s:ar127000/full/pct:12.5/0/default.jpg#h=431&w=580", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3811:g3811s:ar127000/full/pct:25/0/default.jpg#h=862&w=1161"], "index": 5, "language": ["english"], "location": ["trenton", "princeton", "new jersey", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2008-08-22t12:43:21", "74692205", "2025-06-07t18:30:13.500000"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "catalog", "american revolution and it