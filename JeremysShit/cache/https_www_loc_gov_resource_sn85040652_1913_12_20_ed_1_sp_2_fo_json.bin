nal flower of the United States in a bill introduced in the house at Washington by Representa tive Klnkead of New York President Wilson has taken more cold and canceled all his engagements by order of bis physician Chief Jus tice White and Justice Burton also are confined to their homes in Washington suffering with colds The house at Washington waR turned into a fcircus for an"], "digitized": true, "extract_timestamp": "2023-08-22T16:20:23.610Z", "group": ["ndnp/whi", "wisconsin-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85040652/1913-12-20/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_grindylow_ver01:data:sn85040652:00414215579:1913122001:0326/full/pct:6.25/0/default.jpg#h=448&w=317", "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_grindylow_ver01:data:sn85040652:00414215579:1913122001:0326/full/pct:12.5/0/default.jpg#h=897&w=634", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/whi/batch_whi_grindylow_ver01/data/sn85040652/00414215579/1913122001/0326.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["iron county", "hurley", "iron", "wisconsin", "united states"], "location_city": ["hurley"], "location_country": ["united states"], "location_county": ["iron"], "location_state": ["wisconsin"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "1", "0000000002", "0", "9", "7", "sn85040652", "5", "2"], "number_edition": ["1"], "number_lccn": ["sn85040652"], "number_page": ["0000000002"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "5", "5", "7", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "iron county news (hurley, wis.) 1913-1950", "serial and government publications division"], "partof_collection": ["chronicling america"], "p