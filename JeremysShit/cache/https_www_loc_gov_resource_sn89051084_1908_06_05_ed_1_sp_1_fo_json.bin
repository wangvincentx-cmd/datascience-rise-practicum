under the management of Prof Geo B Cook Democratic nominee for state superintendent of public in struction Representative work of the pupils of all classes of schools will be ac ceptable as well as pictures of school buildings groups of scholars etc This work can be sent now to the edu cational department of the Arkansas Fair Hot Springs Ark It is only required that the exhibits lie sent pre paid with full instructions as to their return after the close of the state fair m Liberal awards in books diplomas etc will be given for all"], "digitized": true, "extract_timestamp": "2024-12-02T17:34:57.002Z", "group": ["ndnp/arhi", "arkansas-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89051084/1908-06-05/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_beatles_ver01:data:sn89051084:00393342705:1908060501:0617/full/pct:6.25/0/default.jpg#h=445&w=293", "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_beatles_ver01:data:sn89051084:00393342705:1908060501:0617/full/pct:12.5/0/default.jpg#h=891&w=587", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_beatles_ver01/data/sn89051084/00393342705/1908060501/0617.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["independence", "united states", "arkansas", "newark"], "location_city": ["newark"], "location_country": ["united states"], "location_county": ["independence"], "location_state": ["arkansas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "4", "0", "0000000001", "5", "2", "7", "1", "sn89051084", "9"], "number_edition": ["1"], "number_lccn": ["sn89051084"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "9", "3", "3", "4", "2", "7", "0", "5"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the ne