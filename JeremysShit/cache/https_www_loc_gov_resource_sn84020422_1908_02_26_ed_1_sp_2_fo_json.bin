https://hdl.loc.gov/loc.pnp/highsm.68265"], "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2021-01-01", "dates": ["2021"], "description": ["Title, date, and keywords based on information provided by the photographer. He was U.S. Marine captain and \"Blue Angels\" formation pilot Jeff Kuss, who, at age 32 on June 2, 2016, was killed while demonstrating the capabilities of a similar jet at the Great Tennessee Airshow outside Smryna when it malfunctioned and crashed, but not before Captain Kuss managed to steer the disabled jet away from stands full of spectators. Purchase Carol M. Highsmith Photography, Inc.; 2021  (DLC/PP-2021:107). Forms part of Carol M. Highsmith's America Project in the Carol M. Highsmith Archive. Credit Line: Photographs in Carol M. Highsmith's America Project in the Carol M. Highsmith Archive, Library of Congress, Prints and Photographs Division."], "digitized": true, "extract_timestamp": "2022-08-02T18:21:32.668Z", "group": ["catalog", "highsm", "catalog-split-09", "main-catalog", "carol-m-highsmith", "main-catalog-split-09"], "hassegments": false, "id": "http://www.loc.gov/item/2021756486/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/highsm/68200/68265_150px.jpg#h=100&w=150", "https://tile.loc.gov/storage-services/service/pnp/highsm/68200/68265r.jpg#h=427&w=640", "https://tile.loc.gov/storage-services/service/pnp/highsm/68200/68265v.jpg#h=683&w=1024"], "index": 7, "language": ["english"], "location": ["tennessee", "rutherford county", "united states", "smyrna"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/22636008", "online resource", "2021756486", "2022-06-09t14:46:33"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["highsmith (carol m.) archive", "catalog", "prints & photographs online catalog (library of congress)", "prints and photographs division"], "score": 17.699469, "shelf_id": "LC-DIG-highsm- 68265", "site": ["catalog", "pictures"], "subject": ["tennessee", "rutherford county", "color", "digital photographs", "america", "jeff kuss memorial", "jeff kuss", "great tennessee airshow", "u.s. navy blue angels", "smyrna", "united states"], "timestamp": "2022-08-02T18:32:32.872Z", "title": "A U.S. Navy fighter jet at the Lee Victory Recreational Park in Smyrna, an exurban town near Nashville in Rutherford County, Tennessee, salutes a decorated pilot", "type": ["still image"], "url": "https://www.loc.gov/item/2021756486/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/deu/batch_deu_batman_ver01/data/sn84020422/00514156220/1908022601/0356.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:deu:batch_deu_batman_ver01:data:sn84020422:00514156220:1908022601:0355/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/deu/batch_deu_batman_ver01/data/sn84020422/00514156220/1908022601/0356.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn84020422/1908-02-26/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/deu/batch_deu_batman_ver01/data/sn84020422/00514156220/1908022601/0356.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:deu:batch_deu_batman_ver01:data:sn84020422:00514156220:1908022601:0355/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/deu/batch_deu_batman_ver01/data/sn84020422/00514156220/1908022601/0356.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn84020422/1908-02-26/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/deu/batch_deu_batman_ver01/data/sn84020422/00514156220/1908022601/0356.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020422/1908-02-26/ed-1/?sp=2"], "batch": ["deu_batman_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/delaware/", "2/united states/delaware/kent/", "3/united states/delaware/kent/smyrna/"], "contributor": ["university of delaware library, newark, de"], "date": "1908-02-26", "dates": ["1908-02-26"], "description": ["SHORT AND SN\u00c2PP\u00cf ITEMS OF INTEREST GLEANED BY OUR WASH INGTON CORRESPONDENT Clever Hits on Big Men and Great Questions Which are Uppermost in the Public E ye of theWeek Criticism of the Navy has become so much the fashion recently that the president some time ago deputed Rear Admiral Converse now on the retired list to go into the question from the standpoint of an expert and tell the truth for the benefit of the public It will be remembered by those who have followed the naval discussion that a lot of socalled ex perts have made all sorts of charges against the navy from defective con struction and material Ito lack of speed and gun practice The two latter charges are as almost every one knows unfounded The Ameri can navy now holds the record for target practice with almost all guns at almost all distances Ship for ship the shooting average is better than in any nation of the world and the speed of the later ships has proved in each class to be the high est that could be expected there are only two warship where the American navy has not kept in the first flight"], "digitized": true, "extract_timestamp": "2023-08-12T17:53:54.086Z", "group": ["ndnp/deu", "university-of-delaware-library-newark-de-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020422/1908-02-26/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:deu:batch_deu_batman_ver01:data:sn84020422:00514156220:1908022601:0356/full/pct:6.25/0/default.jpg#h=439&w=308", "https://tile.loc.gov/image-services/iiif/servi