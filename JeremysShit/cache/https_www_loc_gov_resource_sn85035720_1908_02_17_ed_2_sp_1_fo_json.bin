s of prominent buildings. LC Land ownership maps, 457 Available also through the Library of Congress Web site as a raster image. 2 copies"], "digitized": true, "extract_timestamp": "2026-04-29T15:39:18.487Z", "group": ["gmd.mar", "catalog-split-10", "catalog", "general-maps", "main-catalog-split-10"], "hassegments": false, "id": "http://www.loc.gov/item/2012593677/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd381/g3813/g3813m/la000457.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd381/g3813/g3813m/la000457.gif#h=155&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3813:g3813m:la000457/full/pct:12.5/0/default.jpg#h=2303&w=2233", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd381:g3813:g3813m:la000457/full/pct:25/0/default.jpg#h=4607&w=4466"], "index": 1, "language": ["english"], "location": ["middlesex county", "new brunswick", "perth amboy", "south amboy", "united states", "new jersey"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t06:10:59.800000", "2014-07-09t12:24:15", "sheet", "2012593677"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "catalog", "county landownership maps", "cultural landscapes"], "score": 57.048836, "shelf_id": "G3813.M5 1861 .W3 G3813.M5 1861 .W3 Copy 2", "site": ["catalog"], "subject": ["middlesex county", "villages", "landowners", "new brunswick", "perth amboy", "south amboy", "real property", "united states", "cities and towns", "new jersey", "south amboy (n.j.)", "perth amboy (n.j.)", "maps", "middlesex county (n.j.)", "new brunswick (n.j.)"], "timestamp": "2026-04-29T16:07:16.015Z", "title": "Map of the county of Middlesex, New Jersey : from actual surveys", "type": ["cartographic"], "url": "https://www.loc.gov/item/2012593677/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/74692227", "http://www.loc.gov/item/74692227/", "https://search.catalog.loc.gov/instan