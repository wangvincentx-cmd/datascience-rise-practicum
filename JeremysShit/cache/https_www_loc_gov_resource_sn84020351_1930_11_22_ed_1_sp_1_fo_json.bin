df": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_clash_ver01/data/sn84020351/00414219494/1930112201/0379.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn84020351/1930-11-22/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ct/batch_ct_clash_ver01/data/sn84020351/00414219494/1930112201/0379.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020351/1930-11-22/ed-1/?sp=1"], "batch": ["ct_clash_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/fairfield/", "3/united states/connecticut/fairfield/bridgeport/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1930-11-22", "dates": ["1930-11-22"], "description": ["Thanksgiving Il quarto Gioved\u00ec di Novembre tutta lAme rica festeggia il Thanksgiving Day Giorno che Il Pericolo Russo zioni sentimentali vanta Il Thanksgiving Day di questanno trova il popolo Americano travagliato dalla crisi economi ca che infierisce da per tutta la Nazione La popo lazione non ha gran che da ringraziare purtutta via bisogna essere grati che le cose non sono state peggiori Il primo Thanksgiving Day Giorno di Ringraziamento fu celebrato negli Stati Uniti religiose cne miierivano m quei tempi neiia \u00ecuiu terra natia attraversarono loceano in cerca di una Non \u00e8 certamente un sollazzo essere oggi confinati con la Russia La Polonia e la Rumenia o i i j pei essexe pi\u00f9 precisi 1 usueiu accanto alle leccornie dei crapuloni tante trad\u00ec vi goVerni naturalmente debbo lno essere a disagio Non si pu\u00f2 vivere tranquilli Ic\u00f2n una nazione vicina come la Repubblica Sovietica munista potrebbe essere conta gioso ed allora cose straordinarie avverrebbero Di qui la necessit\u00e0 per i paesi confinanti di prepararsi alla resistenza contro la Russia e contro possibili moti interni A questi ultimi si \u00e8 creduto di re con le museruole ceppi ed altri ammenni coli autocratici Al pericolo di fuori Polonia e Rumenia molto"], "digitized": true, "extract_timestamp": "2023-06-01T13:35:04.522Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020351/1930-11-22/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn84020351:00414219494:1930112201:0379/full/pct:3.125/0/default.jpg#h=280&w=227", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn84020351:00414219494:1930112201:0379/full/pct:6.25/0/default.jpg#h=561&w=454", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_clash_ver01:data:sn84020351:00414219494:1930112201:0379/full/pct:12.5/0/default.jpg#h=1123&w=909", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_clash_ver01/data/sn84020351/00414219494/1930112201/0379.xml&format=alto_xml"], "index": 1, "language": ["english", "italian"], "location": ["fairfield", "bridgeport", "connecticut", "fairfield county", "united states"], "location_city": ["bridgeport"], "location_country": ["united states"], "location_county": ["fairfield"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "0", "0000000001", "2", "1", "sn84020351", "9"], "number_edition": ["1"], "number_lccn": ["sn84020351"], "number_page": ["0000000001"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "9", "4", "9", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Sentinel"], "partof": ["la sentinella = the sentinel (bridgeport, conn.) 191?-1948", "chronicling america", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof