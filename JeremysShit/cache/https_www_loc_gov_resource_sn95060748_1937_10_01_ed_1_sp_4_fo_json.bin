igh-demand", "main-catalog-split-04", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2012649417/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/cph/3a30000/3a30000/3a30100/3a30166_150px.jpg#h=105&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3a30000/3a30000/3a30100/3a30166t.gif#h=105&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3a30000/3a30000/3a30100/3a30166r.jpg#h=448&w=640"], "index": 6, "language": ["english"], "location": ["arizona", "maricopa"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2012649417", "http://www.loc.gov/item/17483091", "2012-10-03t14:16:11"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "prints and photographs division", "catalog", "miscellaneous items in high demand"], "score": 26.036812, "shelf_id": "SSF - Pumping Stations [item] [P&P]", "site": ["pictures", "catalog"], "subject": ["arizona", "photographic prints", "maricopa", "railroad stations", "southern pacific railroad company", "pumping stations", "water towers"], "timestamp": "2022-05-02T06:11:29.410Z", "title": "Arizona. Maricopa pumping station and water tower", "url": "https://www.loc.gov/item/2012649417/"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2006679484/", "http://www.loc.gov/item/2006679484/", "http://www.loc.gov/pictures/item/2006679484/", "https://www.loc.gov/pictures/collection/cph/item/2006679484/", "http://www.loc.gov/pictures/collection/cph/item/2006679484/", "http://www.loc.gov/resource/cph.3c36283/", "http://lccn.loc.gov/2006679484", "https://hdl.loc.gov/loc.pnp/cph.3c36283"], "campaigns": [], "date": "1900-01-01", "dates": ["1900"], "description": ["1 photographic print. | Photograph shows the Maricopa, Arizona, train depot. Men and baggage carts wait for the train."], "digitized": true, "extract_timestamp": "2021-08-25T10:12:16.268Z", "group": ["cph", "catalog-split-14", "catalog", "miscellaneous-items-high-demand", "main-catalog-split-14", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2006679484/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/cph/3c30000/3c36000/3c36200/3c36283_150px.jpg#h=121&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3c30000/3c36000/3c36200/3c36283t.gif#h=121&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3c30000/3c36000/3c36200/3c36283r.jpg#h=515&w=640", "https://tile.loc.gov/storage-services/service/pnp/cph/3c30000/3c36000/3c36200/3c36283v.jpg#h=825&w=1024"], "index": 7, "language": ["english"], "location": ["arizona", "maricopa"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2006-04-20t13:58:20", "2006679484", "http://www.loc.gov/item/14298724"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "prints and photographs division", "catalog", "miscellaneous items in high demand"], "score": 26.036812, "shelf_id": "SSF - Railroads--Stations [item] [P&P]", "site": ["pictures", "catalog"], "subject": ["arizona", "photographic prints", "maricopa", "railroad stations", "southern pacific railroad company", "facilities"], "timestamp": "2022-05-02T03:03:43.430Z", "title": "Arizona, Maricopa. Southern Pacific Railroad station", "url": "https://www.loc.gov/item/2006679484/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2021669750", "http://www.loc.gov/resource/wdl.2729/", "https://hdl.loc.gov/loc.wdl/wdl.2729", "http://www.loc.gov/item/2021669750/", "http://www.loc.gov/resource/gdcwdl.wdl_02729/"], "campaigns": [], "contributor": ["lange, dorothea"], "date": "1940-01-01", "dates": ["1940"], "description": ["This photograph, taken by Dorothea Lange (1895-1965) in late 1940, depicts a migrant from the South and her baby on an Arizona cotton farm. Lange was one of the most important American photographers of the 20th century. After apprenticing in New York City, she moved to San Francisco and in 1919 established her own studio. During the 1920s and early 1930s, she worked as a portrait photographer. In 1932, wanting to see a world different from the society families she had been photographing, she began shooting San Francisco's labor unrest and urban unemployed. In 1935, she accepted a position as a staff photographer with the Federal Resettlement Administration, later renamed the Farm Security Administration. Her new job took her to the South, where she documented small towns, the lives of tenant farmers, and experimental agricultural communities. Returning to the West, she focused on the lives of migrant workers. In 1940, Lange was hired by the Bureau of Agricultural Economics to produce photographs for a series of community studies in California and Arizona."], "digitized": true, "extract_timestamp": "2021-07-24T06:17:01.397Z", "group": ["wdlpartner", "catalog-split-06", "catalog", "world-digital-library-partners", "main-catalog-split-06", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2021669750/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:02:72:9:wdl_02729:19-1675m/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:02:72:9:wdl_02729:19-1675m/full/pct:12.5/0/default.jpg#h=313&w=375", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:02:72:9:wdl_02729:19-1675m/full/pct:25/0/default.jpg#h=626&w=750", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:02:72:9:wdl_02729:19-1675m/full/pct:50/0/default.jpg#h=1252&w=1500", "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:02:72:9:wdl_02729:19-1675m/full/pct:100/0/default.jpg#h=2504&w=3000"], "index": 8, "language": ["not applicable", "no linguistic content"], "location": ["arizona", "buckeye", "united states of america"], "mime_type": ["appli