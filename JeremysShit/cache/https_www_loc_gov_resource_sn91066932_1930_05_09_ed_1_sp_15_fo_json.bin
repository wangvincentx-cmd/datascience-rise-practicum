ANCE 125 TRUMBULL STREET SUITE 400 Tel 61403 HARTFFORD ARTESIAN WELLS We Make A Specialty Of Drilling for Farms and Country Residents F A BECKER Tel 170 9 Maple Street EAST HAMPTON ANNOUNCEMENT f Wish to Inform my Friends and The Public that I Have Opened a REPAIR SHOP for all kinds of work on Any Make of Automobile J L MARINER Rear of Whitney Block"], "digitized": true, "extract_timestamp": "2024-11-03T01:53:28.129Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn91066932/1930-05-09/ed-1/?sp=15", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_bugmeat_ver01:data:sn91066932:0051717466A:1930050901:0303/full/pct:3.125/0/default.jpg#h=296&w=203", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_bugmeat_ver01:data:sn91066932:0051717466A:1930050901:0303/full/pct:6.25/0/default.jpg#h=592&w=407", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_bugmeat_ver01:data:sn91066932:0051717466A:1930050901:0303/full/pct:12.5/0/default.jpg#h=1185&w=815", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_bugmeat_ver01/data/sn91066932/0051717466A/1930050901/0303.xml&format=alto_xml"], "index": 15, "language": ["english"], "location": ["hebron", "connecticut", "east hartford", "hartford county", "hartford", "united states"], "location_city": ["east hartford"], "location_country": ["united states"], "location_county": ["hartford"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["sn91066932", "0", "6", "0000000015", "7", "a", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn91066932"], "number_page": ["0000000015"], "number_reel": ["0", "0", "5", "1", "7", "1", "7", "4", "6", "6", "a"], "online_format": ["image", "pdf", "online text"], "original_format