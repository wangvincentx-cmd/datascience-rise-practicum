blication_frequency": ["daily"], "score": 70.7167, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["periodicals", "united states", "bernalillo", "albuquerque", "new mexico", "newspapers", "albuquerque (n.m.)", "bernalillo county", "bernalillo county (n.m.)", "electronic journals"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The evening herald", "type": ["title"], "url": "https://www.loc.gov/item/2021201433/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218649/"], "campaigns": [], "date": "1903", "dates": ["[1903 TO 1926]"], "description": ["Daily Began October 7, 1903; ceased June 19, 1926. Publisher: Journal Publishing Co., <July 2-Spetember 30, 1908>. Carries designation of Morning journal and Morning Democrat, Oct. 7, 1903- Numeric designation includes several changes in the numbering system and numerous inconsistencies. Available on microfilm from the Library of Congress, Photoduplication Service, and Southwest Micropublishing, Inc. Evening ed.: Albuquerque herald, 1922-1926. Description based on: Twenty-seventh year (October 1, 1905); title from masthead (Chroniclingamerica.loc.gov, viewed October 22, 2014). Latest issue consulted: Thirtieth year (September 30, 1908) (Chroniclingamerica.loc.gov, viewed October 22, 2014). Albuquerque journal (Albuquerque, N.M. : 1926 : Online) (OCoLC)137344748"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:28.190Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218649/", "image_url": [], "index": 5, "language": ["english"], "location": ["bernalillo", "united states", "albuquerque", "new mexico", "bernalillo county"], "number": ["2014218649", "2375-5911", "online resource", "2026-04-13t21:30:13", "893557619"], "original_format": ["newspaper"], "other_title": ["Morning journal", "Issues for Sunday Jan. 10, 1926-June 13, 1926 published as: Albuquerque journal-herald"], "partof": ["serial and government publications division", "albuquerque morning journal (albuquerque, new mexico) 1903-1926 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 70.7167, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["united states", "bernalillo", "albuquerque", "new mexico", "newspapers", "albuquerque (n.m.)", "bernalillo county", "bernalillo county (n.m.)"], "timestamp": "2026-05-26T20:50:45.370Z", "title": "Albuquerque morning journal", "type": ["title"], "url": "https://www.loc.gov/item/2014218649/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218700/"], "campaigns": [], "date": "1882", "dates": ["[1882 TO 1884]"], "description": ["Daily Began February 4, 1882); ceased October 5, 1884. Sunday issues called: Albuquerque Sunday journal. Description based on: Volume II, number 261 (September 1, 1882); title from masthead (Chroniclingamerica.loc.gov, viewed October 22, 2014). Latest issue consulted: Vol. IV, no. 254 (August 31, 1884) (Chroniclingamerica.loc.gov, viewed October 22, 2014). Morning journal (Albuquerque, N.M.) 2375-7191 (DLC) 2014218713 (OCoLC)733795160"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:28.190Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218700/", "image_url": [], "index": 6, "language": ["english"], "location": ["bernalillo", "united states", "albuquerque", "new mexico", "bernalillo county"], "number": ["2375-5946", "2014218713", "2014218700", "online resource", "2026-04-13t21:30:13", "893559515"], "original_format": ["newspaper"], "other_title": ["Albuquerque Sunday journal"], "partof": ["serial and government publications division", "the albuquerque morning journal (new albuquerque, new mexico) 1882-1884 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 70.7167, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["united states", "bernalillo", "albuquerque", "new mexico", "newspapers", "albuquerque (n.m.)", "bernalillo county", "bernalillo county (n.m.)"], "timestamp": "2026-05-26T20:50:45.370Z", "title": "The Albuquerque morning journal", "type": ["title"], "url": "https://www.loc.gov/item/2014218700/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218713/"], "campaigns": [], "date": "1884", "dates": ["[1884 TO 1886]"], "description": ["Daily (except Monday) Began with vol. 4, no. 285 (Oct. 7, 1884); ceased with v. 7, no. 45 (Jan. 14, 1886). Available on microfilm published by BMI Imaging Systems; issued in series: Chicano serials collection. Weekly ed.: Albuquerque weekly journal, 1883-1886. Description based on: Volume IV, number 314 (November 9, 1884); title from masthead (Readex, viewed August 18, 2015). Latest issue consulted: Volume VI, number 94 (February 28, 1885) (Chroniclingamerica.loc.gov, viewed October 29, 2014). Albuquerque morning journal (Albuquerque, N.M. : 1886)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:15.066Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218713/", "image_url": [], "index": 7, "language": ["english"], "location": ["bernalillo", "united states", "albuquerque", "new mexico", "bernalillo county"], "number": ["2375-7191", "2014218713", "2014218700", "online resource", "2026-04-13t21:30:13", "733795160"], "original_format": ["newspaper"], "other_title": ["Sunday Albuquerque journal", "Albuquerque Sunday journal", "Journal"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the morning journal (albuquerque, new mexico) 1884-1886 [online resource]"], "publication_frequency": ["daily"], "score": 70.7167, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["united states", "bernalillo", "albuquerque", "new mexico", "newspapers", "albuque