/tif"], "number": ["http://www.loc.gov/item/owi2001003928/pp", "http://www.loc.gov/item/19997166", "2021-06-02t16:07:44", "2017830199", "http://www.loc.gov/item/2017830199"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 205", "prints and photographs division", "farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "american memory", "catalog"], "score": 28.670176, "shelf_id": "LC-USW3- 001670-D [P&P] LOT 205 (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["indianapolis", "marion county", "indiana", "safety film negatives", "united states"], "timestamp": "2022-04-26T03:58:08.705Z", "title": "Negro schoolchildren of the Military Officers' Training Corps marching in formation for Chaplain George W. Williams, a graduate of the U.S. Army chaplain school at Fort Benjamin Harrison, Indiana. The MOTC was organized at the school by the teachers for those youngsters who wanted some preparation for future military service", "url": "https://www.loc.gov/item/2017830199/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/in/batch_in_goldman_ver01/data/sn82015313/00383349217/1929111301/0392.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_goldman_ver01:data:sn82015313:00383349217:1929111301:0377/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/in/batch_in_goldman_ver01/data/sn82015313/00383349217/1929111301/0392.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn82015313/1929-11-13/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/in/batch_in_goldman_ver01/data/sn82015313/00383349217/1929111301/0392.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_goldman_ver01:data:sn82015313:00383349217:1929111301:0377/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/in/batch_in_goldman_ver01/data/sn82015313/00383349217/1929111301/0392.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn82015313/1929-11-13/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/in/batch_in_goldman_ver01/data/sn82015313/00383349217/1929111301/0392.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82015313/1929-11-13/ed-1/?sp=16"], "batch": ["in_goldman_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/indiana/", "2/united states/indiana/marion/", "3/united states/indiana/marion/indianapolis/"], "contributor": ["indiana state library"], "date": "1929-11-13", "dates": ["1929-11-13"], "description": ["PAGE 16 PAPER SUED BY FORMER KAISER LIBELCHARGED Wilhelm Seeks to Have Berlin Editor Fined or Jailed Ru United Pert BERLIN Nov 13For the first time since the revolution former Kaiser Wilhelm has struck back at the critics In Germany who have attacked him throughout his years of exile in Holland He has instituted a libel suit gainst the Berlin paper Morgen Post which accused him of unduly favoring the Krupp factory in granting munitions contracts during the war The suit does not ask monetary damages but seeks to have the editor responsible for the charges imprisoned or fined heavily The Morgen Post declared the alleged libelous article appeared Oct 24 It asserted that the former kaiser always considered himself a partner in the Krupp concern and because of his influence the com pany enjoyed a virtual monopoly in providing guns and munitions for the imperial army The Morgen Post article described the kaisers alleged pool in the Krupp concern as the greatest scandal in world history and charged that because of the un satisfactory armaments produced by Krupp works the German army en tered the World war poorly equipped and that the kaiser en riched himself at the expense"], "digitized": true, "extract_timestamp": "2023-08-22T13:12:28.438Z", "group": ["ndnp/in", "indiana-state-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82015313/1929-11-13/ed-1/?sp=16", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_goldman_ver01:data:sn82015313:00383349217:1929111301:0392/full/pct:3.125/0/default.jpg#h=264&w=199", "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_goldman_ver01:data:sn82015313:00383349217:1929111301:0392/full/pct:6.25/0/default.jpg#h=529&w=399", "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_goldman_ver01:data:sn82015313:00383349217:1929111301:0392/full/pct:12.5/0/default.jpg#h=1059&w=799", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/in/batch_in_goldman_ver01/data/sn82015313/00383349217/1929111301/0392.xml&format=alto_xml"], "index": 16, "language": ["english"], "location": ["indianapolis", "marion county", "marion", "indiana", "united states"], "location_city": ["indianapolis"], "location_country": ["united states"], "location_county": ["marion"], "location_state": ["indiana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "3", "0", "9", "8", "0000000016", "7", "sn82015313", "1", "4"], "number_edition": ["1"], "number_lccn": ["sn82015313"], "number_page": ["0000000016"], "number_reel": ["0", "0", "3", "8", "3", "3", "4", "9", "2", "1", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the indianapolis times (indianapolis [ind.]) 1922-1965", "serial and government publications division", "chronicling a