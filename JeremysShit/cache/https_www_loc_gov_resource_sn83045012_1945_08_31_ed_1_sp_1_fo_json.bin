v/image-services/iiif/service:ndnp:ohi:batch_ohi_buttercup_ver01:data:sn83045012:00340580540:1945083101:0358/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ohi/batch_ohi_buttercup_ver01/data/sn83045012/00340580540/1945083101/0358.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn83045012/1945-08-31/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ohi/batch_ohi_buttercup_ver01/data/sn83045012/00340580540/1945083101/0358.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83045012/1945-08-31/ed-1/?sp=1"], "batch": ["ohi_buttercup_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/ohio/", "2/united states/ohio/butler/", "3/united states/ohio/butler/hamilton/"], "contributor": ["ohio history connection, columbus, oh"], "date": "1945-08-31", "dates": ["1945-08-31"], "description": ["i v s KeriJiitlb 1r i s i New jobs are expected to open up in fairly large quantities in the serv ice trades and other lines of peace time business long starved by a man power shortage but wages and work ing conditions offered by such indus tries are far below the standards pre vailing in war industry Meanwhile the Committee for Eco nomic Development made public a sur LABOR DAY 1945 By William Green President of the American Federation of Labor This is the first peacetime Labor Day in four years It is a day for pro found celebration and thanksgiving For we have won a double victorya military victory over powerful enemies and a spiritual triumph over despo tism and dictatorship Now it is our supreme purpose to attain the fruits of victory for which we have paid so dearly First must come lasting world peace Already the United Nations have shown the way by the adoption of the San Francisco Charter which is an eloquent testimonial to human rights and human aspirations It is up to us and to all other peaceloving na tions to make that charter work and to banish war for all time"], "digitized": true, "extract_timestamp": "2023-09-04T23:15:12.463Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045012/1945-08-31/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_buttercup_ver01:data:sn83045012:00340580540:1945083101:0358/full/pct:3.125/0/default.jpg#h=271&w=190", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_buttercup_ver01:data:sn83045012:00340580540:1945083101:0358/full/pct:6.25/0/default.jpg#h=543&w=380", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_buttercup_ver01:data:sn83045012:00340580540:1945083101:0358/full/pct:12.5/0/default.jpg#h=1086&w=760", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_buttercup_ver01/data/sn83045012/00340580540/1945083101/0358.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["united states", "ohio", "butler", "hamilton"], "location_city": ["hamilton"], "location_country": ["united states"], "location_county": ["butler"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "sn83045012", "0", "1", "4", "8", "0000000001"], "number_edition": ["1"], "number_lccn": ["sn83045012"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "0", "5", "4", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the butler county press (hamilton, ohio) 1900-1946"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the butler county press (hamilton, ohio) 1900-19