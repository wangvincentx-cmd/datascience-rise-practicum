1/1945080301/0004.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_boozer_ver01:data:sn94050542:00414216791:1945080301:0001/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_boozer_ver01/data/sn94050542/00414216791/1945080301/0004.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn94050542/1945-08-03/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/az/batch_az_boozer_ver01/data/sn94050542/00414216791/1945080301/0004.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn94050542/1945-08-03/ed-1/?sp=4"], "batch": ["az_boozer_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arizona/", "2/united states/arizona/pinal/", "3/united states/arizona/pinal/coolidge/"], "contributor": ["arizona state library, archives and public records; phoenix, az"], "date": "1945-08-03", "dates": ["1945-08-03"], "description": ["Page Four ftolitmflttCnnto PUBLISHED EVERY FRIDAY MORNING __ Entered as secondclass matter March 7 1930 at the post office at Coolidge Arizona under the Act of March 3 1879 H H WRENN Publisher Subscription Rate Per Year Outalde Pinal County zav National Adveriiing Rapraiantatiea NBWSMPBB AuVBRTIiINC SERVICE IRC l W A S J iorvhg Amartrai Advsrtjson Home Town Newspapon r arricil Hdkms Bd V nrdma CA Unemployment Insurance Congress is tryinff to decide how much a man or woman should receive as unemployment compensation In this highly technical age where jobs for all are de pendent upon general prosperity it may be necessary to have some provision to help take care of those who are un able to find work But the whole situation must be handled with great wisdom We believe that the majority of Americans still insist on doing an honest days work to get a days pay But wo also realize that there is a growing minority which has no such compunctions and is hoping unemployment insurance will reach the level where they can make unemployment their profession In passing unemployment legislation Congress must guard against making unemployment attractive to any working man or woman New Automobile"], "digitized": true, "extract_timestamp": "2024-01-09T14:47:22.544Z", "group": ["ndnp/az", "arizona-state-university-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn94050542/1945-08-03/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_boozer_ver01:data:sn94050542:00414216791:1945080301:0004/full/pct:3.125/0/default.jpg#h=257&w=189", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_boozer_ver01:data:sn94050542:00414216791:1945080301:0004/full/pct:6.25/0/default.jpg#h=515&w=378", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_boozer_ver01:data:sn94050542:00414216791:1945080301:0004/full/pct:12.5/0/default.jpg#h=1031&w=757", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_boozer_ver01/data/sn94050542/00414216791/1945080301/0004.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["pinal county", "united states", "arizona", "coolidge", "pinal"], "location_city": ["coolidge"], "location_country": ["united states"], "location_county": ["pinal"], "location_state": ["arizona"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "sn94050542", "0000000004", "4", "7", "6", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn94050542"], "number_page": ["0000000004"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "6", "7", "9", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Includes supplement: Tri-Valley dispatch"], "partof": ["the coolidge examiner (coolidge, ar