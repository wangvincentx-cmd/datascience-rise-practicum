ata/sn82007637/00340580382/1945090701/1011.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_kaffirlily_ver01:data:sn82007637:00340580382:1945090701:1008/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ohi/batch_ohi_kaffirlily_ver01/data/sn82007637/00340580382/1945090701/1011.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn82007637/1945-09-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ohi/batch_ohi_kaffirlily_ver01/data/sn82007637/00340580382/1945090701/1011.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82007637/1945-09-07/ed-1/?sp=4"], "batch": ["ohi_kaffirlily_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/ohio/", "2/united states/ohio/lucas/", "3/united states/ohio/lucas/toledo/"], "contributor": ["ohio history connection, columbus, oh"], "date": "1945-09-07", "dates": ["1945-09-07"], "description": ["Page Four TOLEDO UN5ON JOURNAL Official Publication Toledo Industrial Union Council ORGANIZETOLEDO 100 Published every Eridav by Local No 12 LAW CIO 425 Winthrop Street Toledo Ohio Member of Amenoui Labor Pre Association Editor Melvin Schults Managing Editor O J Pecord Advertising Manager Burn Zawodny Board of Trustees Melvin Schultz Thomas Burke Randolph Grav SUBSCK1PT1ON RATES One year by mail In advance 15 Entered at the Toledo Ohio post office second class matter under tile act of Aug 24 1912 Critical Problems As Congress meets this week it faces problems of peace no less critical than the problems which were created by the Japs sneak attack on Pearl Harbor The Japs peace attack caught us just as flatfooted as their initial sneak military blow When the Japs brought the war to us Congress was in Washington Quickly in fact the very next day the representa tives of the people met to hear President Roosevelts narration of the day that will live in infamy and it responded by immediately declaring war on the aggres sor When the Japs brought sudden peace to us Congress was fishing or taking junkets to Europe at governmental ex pense or building political fences back home"], "digitized": true, "extract_timestamp": "2023-09-04T23:21:51.792Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82007637/1945-09-07/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_kaffirlily_ver01:data:sn82007637:00340580382:1945090701:1011/full/pct:3.125/0/default.jpg#h=280&w=212", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_kaffirlily_ver01:data:sn82007637:00340580382:1945090701:1011/full/pct:6.25/0/default.jpg#h=560&w=424", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_kaffirlily_ver01:data:sn82007637:00340580382:1945090701:1011/full/pct:12.5/0/default.jpg#h=1121&w=848", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_kaffirlily_ver01/data/sn82007637/00340580382/1945090701/1011.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["lucas county", "toledo", "ohio", "lucas", "united states"], "location_city": ["toledo"], "location_country": ["united states"], "location_county": ["lucas"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "4", "0000000004", "8", "0", "5", "2", "1", "sn82007637"], "number_edition": ["1"], "number_lccn": ["sn82007637"], "number_page": ["0000000004"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "0", "3", "8", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["toledo union journal (toledo, ohio) 1942-current", "chronicling america", "serial