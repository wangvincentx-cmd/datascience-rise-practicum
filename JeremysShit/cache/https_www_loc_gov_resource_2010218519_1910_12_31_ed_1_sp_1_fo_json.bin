ov/pictures/collection/cph/item/93506869/", "http://www.loc.gov/pictures/collection/cph/item/93506869/", "http://www.loc.gov/resource/cph.3c07924/", "http://lccn.loc.gov/93506869", "https://hdl.loc.gov/loc.pnp/cph.3c07924"], "campaigns": [], "contributor": ["jones, otto m."], "date": "1910-01-01", "dates": ["1910"], "description": ["1 photographic print. | Bird's-eye view of Salt Lake City, Utah."], "digitized": true, "extract_timestamp": "2021-08-24T21:44:50.680Z", "group": ["cph", "catalog-split-14", "catalog", "miscellaneous-items-high-demand", "main-catalog-split-14", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/93506869/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/cph/3c00000/3c07000/3c07900/3c07924_150px.jpg#h=120&w=150"], "index": 2, "language": ["english"], "location": ["utah", "salt lake city"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/11618606", "2002-11-09t14:49:48", "http://www.loc.gov/item/93506869", "93506869"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["miscellaneous items in high demand", "catalog", "prints and photographs division", "prints & photographs online catalog (library of congress)"], "score": 33.44562, "shelf_id": "U.S. GEOG FILE - Utah--Salt Lake City  <item> [P&P]", "site": ["pictures", "catalog"], "subject": ["photographic prints", "cityscape photographs", "buildings", "salt lake city (utah)", "utah", "salt lake city", "streets"], "timestamp": "2022-05-02T12:06:14.100Z", "title": "[Salt Lake City, Utah]", "url": "https://www.loc.gov/item/93506869/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017587026", "http://www.loc.gov/item/2017587026/", "https://search.catalog.loc.gov/instances/08e59c5a-661e-5d0e-9b3b-c841b758b67d", "https://hdl.loc.gov/loc.gmd/g4344s.ct011426", "http://www.loc.gov/resource/g4344s.ct011426/", "https://hdl.loc.gov/loc.gmd/g4344s.ct011427", "http://www.loc.gov/resource/g4344s.ct011427/"], "campaigns": [], "contributor": ["sherwood, henry garlick", "pratt, orson"], "date": "1847", "dates": ["1847"], "description": ["Manuscript plat map, pen-and-ink on thick flexible sheepskin, signed and inscribed by H.G. Sherwood, nailed at the top to its original wooden roller. This manuscript plat map is believed to be the first map of Salt Lake City, Utah. Title supplied by acquisition specialist. Sherwood retained ownership of the plat while the city was being constructed. In 1852, it passed into the hands of Jesse William Fox, Sr., Sherwood's successor as Territory Surveyor General of Utah. Accompanied by text (property of Jesse W. Fox): Engineer's field book / by C.S. Cross. New York : Baptist & Taylor Book, 1855. 43 pages ; 19 cm. Includes notes and diagrams. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:11.686Z", "group": ["gmd.mar", "catalog-split-06", "catalog", "general-maps", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/2017587026/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd434/g4344/g4344s/ct011426.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd434/g4344/g4344s/ct011426.gif#h=150&w=100", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd434:g4344:g4344s:ct011426/full/pct:12.5/0/default.jpg#h=812&w=541", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd434:g4344:g4344s:ct011426/full/pct:25/0/default.jpg#h=1625&w=1082"], "index": 3, "language": ["english"], "location": ["united states", "utah", "salt lake city"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2017587026", "2025-06-07t07:40:57.700000", "2019-09-30t10:59:53", "sheet"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "geography and map division", "cities and towns"], "score": 30.62515, "shelf_id": "G4344.S3 1847 .S4", "site": [