: ["united states", "elkins", "west virginia", "randolph"], "timestamp": "2026-07-22T07:48:49.232Z", "title": "The weekly inter-mountain", "type": ["title"], "url": "https://www.loc.gov/item/sn86092276/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn86092277/"], "batch": ["wvu_fonda_ver01"], "campaigns": [], "date": "1892", "description": ["Weekly Began in 1892. Cf. Bosworth, A.S. Hist. of Randolph Co. Ceased in 1907? Herman C. Johnson edited the paper in 1898 and returned to Elkins in 1902 to buy the paper. Cf. Board of Trade. Elkins, W. Va. Editors: N.G. Keim, 1892-1894; M.S. Cornwell, 1894-1896; William S. Ryan, 1896-1896; Chas. E. Beans, 1896-Aug., 1898; Herman Johnson, Aug., 1898-1907. Cf. Bosworth, A.S. Hist. of Randolph Co. Description based on: Vol. 1, no. 47 (June 2, 1893). Weekly inter-mountain (Elkins, W. Va.) (DLC)sn 86092276"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:15Z", "group": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn86092277/", "image_url": [], "index": 4, "language": ["english"], "latlong": [38.923908, -79.8443931], "location": ["united states", "elkins", "west virginia", "randolph"], "location_str": "", "lonlat": [-79.8443931, 38.923908], "number": ["1", "sn86092277", "online resource", "2026-04-13t21:30:13", "http://www.loc.gov/item/sn86092277/1903-08-20/ed-1/", "sn86092276", "165", "west virginia newsp proj", "2025-05-23t21:30:26", "microfilm service copy", "http://www.loc.gov/item/sn86092277/1896-01-31/ed-1/", "13201738"], "original_format": ["newspaper"], "other_title": ["Elkins inter-mountain"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "chronicling america", "the inter-mountain (elkins, w. va.) 1892-1907"], "publication_frequency": ["weekly"], "score": 40.065945, "shelf_id": "http://lccn.loc.gov/sn86092277", "site": ["chroniclingamerica", "usnd"], "subject": ["united states", "elkins", "west virginia", "randolph"], "timestamp": "2026-07-22T07:48:49.232Z", "title": "The inter-mountain", "type": ["title"], "url": "https://www.loc.gov/item/sn86092277/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn86092278/"], "batch": ["wvu_lupino_ver01"], "campaigns": [], "date": "1922", "description": ["Weekly Began in Jan., 1922?; ceased in 1929? Description based on: Vol. 29, no. 11 (Jan. 12, 1922)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:16.241Z", "group": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn86092278/", "image_url": [], "index": 5, "language": ["english"], "latlong": [38.923908, -79.8443931], "location": ["united states", "elkins", "west virginia", "randolph"], "location_str": "", "lonlat": [-79.8443931, 38.923908], "number": ["online resource", "2026-04-13t21:30:13", "17", "sn86092280", "http://www.loc.gov/item/sn86092278/1922-01-12/ed-1/", "13201741", "http://www.loc.gov/item/sn86092278/1927-05-26/ed-1/", "sn86092276", "sn86092278", "2025-05-23t21:30:26"], "original_format": ["newspaper"], "partof": ["the elkins inter-mountain (elkins, w. va.) 1922-1929", "directory of u.s. newspapers in american libraries", "serial and government publications division", "chronicling america"], "publication_frequency": ["weekly"], "score": 40.065945, "shelf_id": "http://lccn.loc.gov/sn86092278", "site": ["chroniclingamerica", "usnd"], "subject": ["united states", "elkins", "west virginia", "randolph"], "timestamp": "2026-07-22T07:48:49.232Z", "title": "The Elkins inter-mountain", "type": ["title"], "url": "https://www.loc.gov/item/sn86092278/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn86092279/"], "batch": ["wvu_fonda_ver01"], "campaigns": [], "date": "1907", "description": ["Daily Vol. 1, no. 1 (Oct. 1, 1907)-v. 6, no. 257 (July 30, 1913). Elkins inter-mountain (Daily) (DLC)sn 86092280"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:15Z", "group": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn86092279/", "image_url": [], "index": 6, "language": ["english"], "latlong": [38.923908, -79.8443931], "location": ["united states", "elkins", "west virginia", "randolph"], "location_str": "", "lonlat": [-79.8443931, 38.923908], "number": ["http://www.loc.gov/item/sn86092279/1913-07-30/ed-1/", "1", "online resource", "2026-04-13t21:30:13", "sn86092280", "sn86092279", "sn86092276", "13201756", "west virginia newsp proj", "2025-05-23t21:30:26", "microfilm service copy", "1163", "http://www.loc.gov/item/sn86092279/1907-10-01/ed-1/"], "original_format": ["newspaper"], "partof": ["the daily inter-mountain (elkins, w. va.) 1907-1913", "directory of u.s. newspapers in american libraries", "serial and government publications division", "chronicling america"], "publication_frequency": ["daily"], "score": 40.065945, "shelf_id": "http://lccn.loc.gov/sn86092279", "site": ["chroniclingamerica", "usnd"], "subject": ["united states", "elkins", "west virginia", "randolph"], "timestamp": "2026-07-22T07:48:49.232Z", "title": "The daily inter-mountain", "type": ["title"], "url": "https://www.loc.gov/item/sn86092279/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn86092285/"], "batch": ["wvu_monroe_ver01"], "campaigns": [], "date": "1889", "description": ["Weekly Began Sept. 13, 1889. Cf. Board of Trade. Elkins, W. Va. Ceased in 1913? Cf. W. Va. State Gazetteer. Paper was founded by James A. Bent and Floyd Triplett; the News Publ. Co. was composed of C.M. Marstiller, E.E. Taylor, Blain Taylor and A.F. Wilmoth in 1906. \"Democratic.\" Description based on: Vol. 4, no. 1 (Sept. 14, 1892)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:16.241Z", "group": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hasse