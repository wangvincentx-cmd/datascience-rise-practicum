6.25/0/default.jpg", "width": 332}, {"height": 857, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/service:ndnp:wvu:batch_wvu_garbo_ver02:data:sn86092280:00517011289:1927071401:0077/full/pct:12.5/0/default.jpg", "width": 664}, {"height": 6862, "info": "https://tile.loc.gov/image-services/iiif/service:ndnp:wvu:batch_wvu_garbo_ver02:data:sn86092280:00517011289:1927071401:0077/info.json", "language": ["english"], "mimetype": "application/json", "reel_number": "00517011289", "section_label": null, "size": 4557149, "title": "Image 2 of The Elkins inter-mountain (Elkins, W. Va.), July 14, 1927", "width": 5316}, {"fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wvu/batch_wvu_garbo_ver02/data/sn86092280/00517011289/1927071401/0077.xml&format=alto_xml&full_text=1", "mimetype": "text/plain", "use": "text"}], "pagination": {"current": 2, "first": "https://www.loc.gov/resource/sn86092280/1927-07-14/ed-1/?fo=json&sp=1", "from": 2, "last": "https://www.loc.gov/resource/sn86092280/1927-07-14/ed-1/?fo=json&sp=4", "next": "https://www.loc.gov/resource/sn86092280/1927-07-14/ed-1/?fo=json&sp=3", "of": 6, "page_list": [{"number": 1, "url": "https://www.loc.gov/resource/sn86092280/1927-07-14/ed-1/?fo=json&sp=1"}, {"number": 2, "url": null}, {"number": 3, "url": "https://www.loc.gov/resource/sn86092280/1927-07-14/ed-1/?fo=json&sp=3"}, {"number": 4, "url": "https://www.loc.gov/resource/sn86092280/1927-07-14/ed-1/?fo=json&sp=4"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": "https://www.loc.gov/resource/sn86092280/1927-07-14/ed-1/?fo=json&sp=1", "results": "2 - 2", "to": 2, "total": 6}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn86092280/1927-07-13/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/75696679", "http://www.loc.gov/item/75696679/", "https://search.catalog.loc.gov/instances/73e5cbdd-e793-5d8f-83da-32a4ec6e6003", "https://hdl.loc.gov/loc.gmd/g3894e.pm009930", "http://www.loc.gov/resource/g3894e.pm009930/"], "campaigns": [], "contributor": ["moyer, james b.", "fowler, t. m. (thaddeus mortimer)"], "date": "1897", "dates": ["1897"], "description": ["\"This panoramic map shows Elkins, West Virginia, as it appeared in 1897. The city was developed as a railroad hub in the 1880s by two entrepreneurs and politicians: Henry Gassaway Davis (1823-1916) and Stephen Benton Elkins (1841-1911), with the city named after the latter. Both men served terms representing West Virginia in the U.S. Senate. The map shows the city of Elkins along the Tygart's Valley River, with two bridges crossing the river--one for rail (adjacent to Railroad Avenue) and one for pedestrians and other transport (Davis Avenue). A train is seen on the far side of town, traveling on the West Virginia Central Railroad. The railroad enabled the success of industry involving the extraction of natural resources such as coal and timber. The index at the bottom of the map indicates points of interest, including the railroad hub, major industrial facilities, shops, schools, churches (Presbyterian, Baptist, Catholic, Methodist, Baptist Colored, and United Brethren), and the opera house. The panoramic map was a cartographic form in popular use to depict U.S. and Canadian cities and towns in the late 19th and early 20th centuries. Also known as bird's-eye views or perspective maps, these works are representations of cities portrayed as if viewed from above at an oblique angle. Not generally drawn to scale, they show street patterns, individual buildings, and major landscape features in perspective. This map is by Thaddeus Mortimer Fowler (1842-1922), one of the most prolific makers of panoramic maps. Fowler was born in Lowell, Massachusetts, and fought and was wounded in the American Civil War. After working for an uncle who was a photographer, in 1870 he established his own panoramic map firm. Over the course of a long career, Fowler made panoramic maps of cities in 21 states and parts of Canada.\" World Digital Library."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:44.245Z", "group": ["gmd.mar", "catalog-split-07", "catalog", "general-maps", "main-catalog-split-07"], "hassegments": false, "id": "http://www.loc.gov/item/75696679/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd389/g3894/g3894e/pm009930.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd389/g3894/g3894e/pm009930.gif#h=150&w=209", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd389:g3894:g3894e:pm009930/full/pct:12.5/0/default.jpg#h=699&w=975", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd389:g3894:g3894e:pm009930/full/pct:25/0/default.jpg#h=1398&w=1950"], "index": 2, "language": ["english"], "location": ["united states", "elkins", "west virginia"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t18:31:11.600000", "75696679", "2022-07-14t10:54:56"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "panoramic maps", "cities and towns", "world digital library", "geography and map division"], "score": 26.500292, "shelf_id": "G3894.E6A3 1897 .F6", "site": ["catalog"], "subject": ["aerial views", "west virginia", "elkins (w. va.)", "united states", "elkins"], "timestamp": "2026-04-29T16:17:25.775Z", "title": "Elkins, Randolph County, W.Va. 1897", "type": ["cartographic"], "url": "https://www.loc.gov/item/75696679/"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2017718087/", "http://www.loc.gov/item/2017718087/", "http://www.loc.gov/pictures/item/2017718087/", "https://www.loc.gov/pictures/collection/fsa/item/2017718087/", "http://www.loc.gov/pictures/collection/fsa/item/2017718087/", "https://hdl.loc.gov/loc.pnp/fsa.8a04273", "https://hdl.loc.gov/loc.pnp/fsa.8a04273", "http://www.loc.gov/resource/fsa.8a04273/", "http://lcc