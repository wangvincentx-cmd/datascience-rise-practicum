source/sn84020097/1930-05-30/ed-1/?fo=json&sp=1", "results": "2 - 2", "to": 2, "total": 6}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn84020097/1930-05-29/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/mm2022086540", "http://www.loc.gov/item/mm2022086540/", "https://openn.library.upenn.edu/Data/0007/html/SCMS0142.html"], "campaigns": [], "contributor": ["mcalpine, william j. (william jarvis)"], "description": ["Letterbooks containing correspondence, memoranda, interim and final project reports, construction diagrams, measurements and data sets, and cost and expense tabulations and reports.  Documents McAlpine's work as chief or consulting civil engineer on aqueduct, bridge, canal, and dry dock projects, primarily in New York State and Chicago, Illinois.  Projects include the Albany Water Works, Albany, New York; dry docks, Brooklyn Navy Yard (New York Naval Shipyard) Brooklyn, New York; Brooklyn Water Works, Brooklyn, New York; Chicago Water Works, Chicago, Illinois; Croton Aqueduct, New York; Erie Canal, New York; and the Harlem Bridge (Washington Bridge), New York, New York."], "digitized": true, "extract_timestamp": "2025-05-24T06:01:48.494Z", "group": ["catalog-split-07", "catalog", "main-catalog-split-07"], "hassegments": false, "id": "http://lccn.loc.gov/mm2022086540", "image_url": [], "index": 2, "language": ["english"], "location": ["illinois", "washington bridge", "croton aqueduct", "albany", "new york", "chicago", "erie canal"], "number": ["2025-05-22t15:10:13", "mm2022086540"], "original_format": ["manuscript/mixed material", "collection"], "other_title": ["William J. McAlpine papers"], "partof": ["manuscript division", "catalog"], "score": 27.3759, "shelf_id": "http://lccn.loc.gov/mm2022086540", "site": ["catalog"], "subject": ["civil engineering", "water works", "chicago (ill.)", "canals", "new york", "washington bridge (new york, n.y.)", "albany (n.y.)", "new york (state)", "design and construction", "chicago", "bridges", "illinois", "brooklyn (new york, n.y.)", "aqueducts", "albany", "water-supply", "new york naval shipyard", "waterworks", "croton aqueduct (n.y.)", "erie canal (n.y.)", "dry docks"], "timestamp": "2025-05-24T06:03:50.170Z", "title": "William J. McAlpine letterbooks, 1837-1861", "type": ["manuscript"], "url": "//lccn.loc.gov/mm2022086540"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2010651409/", "http://www.loc.gov/item/2010651409/", "http://www.loc.gov/pictures/item/2010651409/", "https://www.loc.gov/pictures/collection/cph/item/2010651409/", "http://www.loc.gov/pictures/collection/cph/item/2010651409/", "http://www.loc.gov/resource/ppmsca.25528/", "https://hdl.loc.gov/loc.pnp/ppmsca.25528", "http://lccn.loc.gov/2010651409"], "campaigns": [], "contributor": ["dalrymple, louis"], "date": "1901-05-15", "dates": ["1901-05-15", "1901"], "description": ["1 print : chromolithograph. | Illustration shows a large elderly colonial man labeled \"N.Y.\" sitting atop buildings on New York City's waterfront, strings attached to his fingers extend to ships at dock and beyond, presumably to overseas connections. In the background is a small figure labeled \"Neptune\" holding a trident and standing on Chicago's waterfront area, with a sign stating \"Chicago 1000 miles to the sea\" and with factories spewing thick black smoke."], "digitized": true, "extract_timestamp": "2021-08-24T23:50:47.902Z", "group": ["cph", "catalog-split-12", "catalog", "miscellaneous-items-high-demand", "main-catalog-split-12", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2010651409/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528_150px.jpg#h=150&w=116", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528t.gif#h=150&w=116", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528r.jpg#h=640&w=494", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/25500/25528v.jpg#h=1024&w=790"], "index": 3, "language": ["english"], "location": ["illinois", "new york city", "chicago", "new york"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2010651409", "2010-10-18t08:12:10", "http://www.loc.gov/item/16506129"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["miscellaneous items in high demand", "prints and photographs division", "prints & photographs online catalog (library of congress)", "catalog"], "score": 25.966146, "shelf_id": "Illus. in AP101.P7 1901 (Case X) [P&P]", "site": ["pictures", "catalog"], "subject": ["symbolic representation", "periodical illustrations", "magazine covers", "shipping", "chicago (ill.)", "new york", "tridents", "chromolithographs", "new york (n.y.)", "color", "new york (state)", "cartoons (commentary)"], "timestamp": "2022-05-02T05:35:51.632Z", "title": "The Chicago Neptune", "url": "https://www.loc.gov/item/2010651409/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/afc2011062.afc2011062_00387_ms01/", "http://www.loc.gov/item/2017655527/", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr01", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_ph/", "http://lccn.loc.gov/2017655527", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr02", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr03", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr01/", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr02/", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr03/"], "campaigns": [], "contributor": ["halker, bucky", "keane, jimmy", "occupational folklife project"], "date": "2013-01-01", "dates": ["2013"], "description": ["James \"Jimmy\" Keane, a prominent figure on the Irish music scene in Chicago and Ireland, discusses his career as an iron worker and member of Local 1 of the Iron Workers International Union. Keane, who was injured after ten years in the trade, then turned to music and selling real estate as a career. Keane's father, Jimmy \"Horse\" Keane, was a Local 1 member killed on the job in Chicago. Jimmy's three brothers also work in the iron trade. Jimmy Keane also discusses the music scene and the role of unions in America."], "digitized": true, "extract_timestamp": "2020-09-20T12:15:20.851Z", "group": ["afc/2011062", "catalog-split-08", "catalog", "iron-workers", "main-catalog-split-08", "main-catalog"], "hassegments": true, "id": "http://www.loc.gov/item/2017655527/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2011062/afc2011062_00387/afc2011062_00387_ph/afc2011062_00387_ph01.gif", "https://tile.loc.gov/storage-services/service/afc/afc2011062/afc2011062_00387/afc2011062_00387_ph/afc2011062_00387_ph01.gif#h=150&w=227", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:12.5/0/default.jpg#h=249&w=378", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:25/0/default.jpg#h=499&w=756", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:50/0/default.jpg#h=999&w=1512", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:100/0/default.jpg#h=1998&w=3024"], "index": 4, "language": ["english"], "location": ["illinois", "chicago", "middle west"], "mime_type": ["image/jpeg", "image/jp2", "audio/mp3", "image/gif", "audio/wav", "application/pdf", "application/x-audio"], "number": ["2017655527", "online resource", "2018-10-24t17:32:53"], "online_format": ["image", "audio", "pdf"], "original_format": ["sound recording"], "partof": ["cultural traditions of ironworkers in america's upper midwest", "american folklife center", "occupational folklife project", "catalog"], "score": 25.196444, "shelf_id": "http://lccn.loc.gov/2017655527", "site": ["catalog"], "subject": ["irish americans", "personal narratives", "interviews", "songs", "chicago (ill.)", "work and family", "keane, jimmy", "middle west", "employee rights", "industrial relations", "training of", "industrial safety", "wages", "labor contract", "music", "event place", "chicago", "hazardous occupations", "humor in the workplace", "illinois", "digital photographs", "blue collar workers", "work environment", "iron and steel workers", "irish american labor union members", "oral histories", "interviews (sound recordings)", "professional associations", "self-employed", "ironwork", "social life and customs", "apprenticeship programs", "manners and customs", "corporations", "labor unions", "color", "employees"], "timestamp": "2022-04-27T11:35:06.573Z", "title": "James Robert Keane interview conducted by Clark Douglas Halker, 2013-01-13.", "url": "https://www.loc.gov/item/2017655527/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/mm77035121", "http://www.loc.gov/item/mm77035121/", "https://hdl.loc.gov/loc.mss/collmss.ms000067"], "campaigns": [], "contributor": ["olmsted, frederick law", "olmsted, gideon", "olmsted, john"], "description": ["Correspondence, letterbooks, journals, drafts of articles and books, speeches and lectures, biographical and genealogical data, business papers, legal and financial papers, scrapbooks, printed material, maps, drawings, and other papers encompassing Olmsted's career and private life. The papers focus on Olmsted's career as a landscape architect, specifically as a designer of parks and the grounds of private estates and public buildings and as a city and regional planner.  Includes material pertaining to his designs chiefly of Central Park in New York, N.Y., of the area surrounding Niagara Falls, N.Y., of the U.S. Capitol grounds, Washington, D.C., and of the grounds of the World's Columbian Exposition, Chicago, Ill., 1893.  Material pertains, in part, to work undertaken by Olmsted and the firms of Olmsted and Vaux (1858), Frederick Law Olmsted (1858-1884), F.L. and J.C. Olmsted (1884-1889), F.L. Olmsted and Company (1889-1893), Olmsted, Olmsted, and Eliot (1893-1897), F.L. and J.C. Olmsted (1897-1898), and Olmsted Brothers (1898-1961).  Also documents Olmsted's writings, his investigation of slavery in the South (1850s), his role as general secretary of the U.S. Sanitary Commission during the Civil War, and his work as superintendent of John C. Fre\u0301mont's gold mining estates in Mariposa, Calif. Olmsted family papers include a journal and other papers of Gideon Olmsted documenting his adventures as a privateer during the Revolutionary war; journals kept by Frederick Law Olmsted's father, John, recording activities of the Olmsted family as well as local and national events; and correspondence of John Olmsted (father), John Hull Olmsted (brother), Frederick Law Olmsted, Jr. (son), and John Charles Olmsted (nephew). Correspondents include Henry W. Bellows, Samuel Bowles, Charles Loring Brace, Daniel Hudson Burnham, H.W.S. Cleveland, George William Curtis, Charles A. Dana, Edwin Lawrence Godkin, A.H. Green, Edward Everett Hale, William James, Clarence King, Frederick John Kingsbury, Frederick Newman Knapp, Charles Follen McKim, Charles Eliot Norton, Whitelaw Reid, H.H. Richardson, Charles N. Riotte, Carl Schurz, George Templeton Strong, George Washington Vanderbilt, Calvert Vaux, Henry Villard, George E. Waring, Jr., and Katherine Prescott Wormeley."], "digitized": true, "extract_timestamp": "2025-05-25T06:00:47.553Z", "group": ["catalog-split-04", "catalog", "main-catalog-split-04"], "hassegments": false, "id": "http://lccn.loc.gov/mm77035121", "image_url": [], "index": 5, "language": ["english"], "location": ["illinois", "ontario", "southern states", "central park", "mariposa", "washington d.c.", "new york", "california", "niagara falls", "chicago", "united states"], "number": ["mm77035121", "2025-05-23t09:59:54"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["manuscript division", "catalog"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/mm77035121", "site": ["catalog"], "subject": ["reid, whitelaw", "cleveland, h. w. s.", "richardson, h. h.", "waring, george e.", "mariposa", "niagara falls (n.y. and ont.)", "new york", "olmsted, john charles", "revolution", "bowles, samuel", "new york (state)", "burnham, daniel hudson", "regional planning", "dana, charles a.", "andrew haswell)", "mckim, charles follen", "united states sanitary commission", "gold mines and mining", "villard, henry", "design and construction", "kingsbury, frederick john", "godkin, edwin lawrence", "exhibitions", "world's columbian exposition", "correspondence", "southern states", "gold discoveries", "mariposa (calif.)", "chicago, ill.)", "california", "horace william shaler)", "naval operations", "chicago", "olmsted, frederick law", "bellows, henry w.", "norton, charles eliot", "vaux, calvert", "schurz, carl", "olmsted brothers", "illinois", "18th century", "brace, charles loring", "landscape architecture", "central park (new york, n.y.)", "fr\u00e9mont, john charles", "health aspects", "frederick law olmsted (firm)", "hale, edward everett", "henry whitney)", "vanderbilt, george washington", "f.l. olmsted and company", "king, clarence", "olmsted family", "knapp, frederick newman", "washington (d.c.)", "riotte, carl nicolaus", "privateering", "history", "civil war", "green, a. h.", "united states", "olmsted and vaux (firm)", "george edwin)", "wormeley, katherine prescott", "henry hobson)", "slavery", "city planning", "charles anderson)", "james, william", "olmsted, john hull", "united states capitol (washington, d.c.)", "parks", "curtis, george william", "olmsted, olmsted, and eliot", "strong, george templeton", "f.l. and j.c. olmsted (firm)"], "timestamp": "2025-05-25T06:04:13.927Z", "title": "Frederick Law Olmsted papers, 1777-1952", "type": ["manuscript"], "url": "//lccn.loc.gov/mm77035121"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/mm79032243", "http://www.loc.gov/item/mm79032243/", "https://search.catalog.loc.gov/instances/738e29de-abad-5d65-9aa6-686dafcb6951", "https://link.gale.com/apps/collection/6DDT/SAS?u=loc_main&sid=SAS"], "campaigns": [], "contributor": ["mckim, charles follen"], "description": ["Correspondence, letterbooks, memoranda, diary transcript, notes, legal and financial records, sketches, drawings, photographs, and other papers relating chiefly to the firm of McKim, Mead, & White, New York, New York. Documents McKim's designs for the Boston Public Library and Symphony Hall, Boston, Mass.; Columbia University's Morningside Heights campus and the University Club, New York, New York; Rhode Island State House, Providence, Rhode Island; restoration of the White House, Washington, D.C.; and the World's Columbian Exposition, Chicago, Illinois, 1893. Also documents McKim's work on the U.S. Senate Commission for the Improvement of the District of Columbia concerned with the location and treatment of public buildings and grounds along the Mall and his membership on the Grant Memorial Commission. Includes material pertaining to McKim's membership in societies and clubs including the American Institute of Architects, the Century Club, and the University Club. Subjects include the development of American architecture, establishment of the American Academy in Rome, and efforts of abolitionists to provide aid for newly freed slaves in the years following the Civil War. Diary includes McKim's account of an 1863 walking tour with Francis Jackson Garrison and Wendell Phillips Garrison to the Gettysburg battlefield and other areas in eastern Pennsylvania. Family correspondents include McKim's daughter, Margaret McKim; his father, J. Miller M'Kim; and other family members. Other correspondents include Daniel Chester French, John La Farge, Francis Jackson Garrison, Wendell Phillips Garrison, William Lloyd Garrison, Francis Davis Millet, Charles Moore, H. Siddons Mowbray, Frederick Law Olmsted, and Augustus Saint-Gaudens."], "digitized": true, "extract_timestamp": "2026-05-27T11:39:20.039Z", "group": ["catalog-split-08", "catalog", "main-catalog-split-08"], "hassegments": false, "id": "http://lccn.loc.gov/mm79032243", "image_url": [], "index": 6, "language": ["english"], "location": ["italy", "gettysburg", "illinois", "pennsylvania", "boston", "massachusetts", "washington d.c.", "the mall", "new york", "rome", "rhode island", "chicago", "united states"], "number": ["mm79032243", "2026-05-26t17:44:12.600000"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["manuscript division", "catalog"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/mm79032243", "site": ["catalog"], "subject": ["american institute of architects", "james miller)", "clubs", "music-halls", "massachusetts", "architecture", "garrison, william lloyd", "mowbray, h. siddons", "new york", "century club (new york, n.y.)", "university club (new york, n.y.)", "new york (state)", "public buildings", "symphony hall (boston, mass.)", "exhibitions", "african americans", "congress", "correspondence", "world's columbian exposition", "architectural firms", "conservation and restoration", "chicago, ill.)", "garrison, francis jackson", "libraries", "study and teaching", "reconstruction (u.s. history,)", "mall, the (washington, d.c.)", "rhode island", "gettysburg (pa.)", "la farge, john", "chicago", "olmsted, frederick law", "illinois", "universities and colleges", "pennsylvania", "mckim, mead, & white", "washington (d.c.)", "french, daniel chester", "capital and capitol", "harry siddons)", "senate", "commission for the improvement of the district of columbia", "mckim family", "m'kim, j. miller", "grant memorial commission", "rhode island state house (providence, r.i.)", "columbia university", "history", "united states", "19th century", "boston public library", "white house (washington, d.c.)", "italy", "civil war", "moore, charles", "societies, etc", "garrison, wendell phillips", "saint-gaudens, augustus", "boston", "freed persons", "american academy in rome", "rome", "parks", "description and travel", "mckim, margaret", "millet, francis davis"], "timestamp": "2026-05-27T11:48:52.327Z", "title": "Charles Follen McKim papers, 1838-1929", "type": ["manuscript"], "url": "//lccn.loc.gov/mm79032243"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2023655343", "http://www.loc.gov/item/2023655343/", "https://search.catalog.loc.gov/instances/9cefb0b0-347c-5c42-8c28-443ae250a473", "https://hdl.loc.gov/loc.afc/collafc.afc2022012"], "campaigns": [], "contributor": ["pel\u00e1ez sordo, claudio", "parks, charles lee", "twan-twan", "kirk, wayne weezy", "rp boo", "belle, jonathan", "scott k.", "feliciano, frankie", "gilliam, gbari", "caballero, dan", "sarakul, ryan", "boyd, jaron", "randolph, chris chosen", "kumta, prem", "croshaw, ren (lauren lucia)", "grant, arnez", "george-wheeler, hannah", "ishida, h. k.", "pause eddie", "tate, jay jay", "bobb, merlin", "hlinkov\u00e1, michaela", "sloan, ronnie", "ultra nat\u00e9", "kenlo key", "blancaflor, cynthia", "chambers, marlon", "lopez, jackie", "malapit, michael", "guerrero, jake", "becquette, wyatt", "eddy, john f.", "williams, wayne", "kg superstar", "valenzuela, lorena", "woods, tyrone", "johnson, sire dhone", "prosper, d. (derick)", "carter chu, eric", "harris, isaac crossfire", "joyner, sherri", "lomelin, andrea", "smith, jesse", "urban artistry", "foaad, leigh", "stewart, wesley", "daniels, tre", "dozier, brandon marcelas", "verdoodt, vanessa neva", "parisi, dolores ninja", "huff, ricki", "yarbrough, decimus", "dunnington, geno", "d.j. slugo", "nouri, farid", "andrew w. mellon foundation", "sugiyama, emiko", "ferreira, ami tsunami", "cummings, maren", "basa, ray", "de clive-lowe, mark", "creation global (dance group)", "huggins, kimyon", "dj nativesun", "vaca, jos\u00e9", "melendez, miley", "harris, jamal m.", "mendoza, rhonda", "torrence, kim", "reyes, rose", "blondet, thomas", "garcia, leyda", "guerrero, noah", "neff, ad\u00e9 e.", "brickhouse, junious", "haynes, jeremiah supaman", "burns, rita jean kelly", "forman, kelli", "hall, rama mahesh", "morris, oji", "simon, morgan", "ferreira, cody coflo", "dj gargamel", "mendoza, juliet e.", "paulos, angelo jiwa", "dj paul howard", "benedetti, cristina", "kell-abrams, maya", "riddick, will (william keith)", "kosmik", "lazee, ken", "creative netwerk (organization)", "battle, shadawn", "dj underdog", "american folklife center", "joyner, michael", "gar\u00e7on, jeffery miyake-mugler", "james, bradford", "liao, leslie"], "date": "1994", "dates": ["1994"], "description": ["\"Follow the Music: Exploring Multi-Linear Legacies of House Culture\" aims to expand upon the common narratives documenting a wider range of community voices that define the multi-linear legacies of House Music and Dance Cultures (HMDC). This collection documents the culture of Black and Brown urban communities through dance forms including Breakin', House, Hip Hop, Popping/Boogaloo, and locking. This includes oral histories documenting community voices in Washington, D.C.; Baltimore, Maryland; Chicago, Illinois; New York, New York; Los Angeles, California; and Oakland, California."], "digitized": true, "extract_timestamp": "2026-06-16T06:37:55.629Z", "group": ["catalog-split-01", "catalog", "main-catalog-split-01"], "hassegments": false, "id": "http://lccn.loc.gov/2023655343", "image_url": [], "index": 7, "language": ["english"], "location": ["illinois", "maryland", "baltimore", "los angeles", "oakland", "new york", "washington d.c.", "california", "chicago", "united states"], "number": ["2023655343", "2026-06-15t13:44:13.100000"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["american folklife center", "catalog"], "score": 22.570621, "shelf_id": "http://lccn.loc.gov/2023655343", "site": ["catalog"], "subject": ["interviews", "video recordings", "ghetto house (music)", "los angeles", "new york", "house music", "nightclubs", "new york (state)", "music and dance", "maryland", "california", "gay community", "chicago", "illinois", "digital photographs", "gay culture", "social aspects", "washington (d.c.)", "oakland", "hip-hop", "oral histories", "electronic dance music", "united states", "baltimore", "voguing (dance)", "hip-hop dance", "color"], "timestamp": "2026-06-16T07:09:11.517Z", "title": "Follow the Music : Exploring Multi-Linear Legacies of House Culture : Community Collections Grant Project, 1994-2023,", "type": ["manuscript"], "url": "//lccn.loc.gov/2023655343"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897652/1930053001/0580.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897652:1930053001:0579/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897652/1930053001/0580.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn84020097/1930-05-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897652/1930053001/0580.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897652:1930053001:0579/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897652/1930053001/0580.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn84020097/1930-05-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897652/1930053001/0580.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020097/1930-05-30/ed-1/?sp=2"], "batch": ["iune_fluorite_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/new york/", "2/united states/new york/new york/", "3/united states/new york/new york/new york/", "1/united states/illinois/", "2/united states/illinois/cook/", "3/united states/illinois/cook/chicago/"], "contributor": ["university of illinois at urbana-champaign library, urbana, il"], "date": "1930-05-30", "dates": ["1930-05-30"], "description": ["Page Two FASCIST FISH TO LEAD RED PROBE TO HIDE HUNGER WAR MOVES Committee Composed of Southern Lawyers Noted for Their Black Reactionism Red Scare Hearings to Begin This Summer and Include the Daily Worker WASHINGTON D C May 29 Nicolas Longworth speaker of the House of Representatives whose family fortune was made from rent als of the old red light district of Cincinnati yesterday appointed the investigation committee which 1 is to try to cover up growing unem ployment under a cloud of red plots and to continue the use of the Whalen forgeries as material to whip up propaganda for war against the Soviet Union That this is the purpose of the j Hoover regime for which Longworth acts is seen in the naming of J Hamilton Fish New York fascist who spoke in the fascist May Dayj antiCommunist meeting at Union Square as chairman of the Anti Communist Committee In such committees the chairman usually is the boss of the committee the others being mere stuffing However the remarks of Fish in the House when the resolution to appoint the committee was adopted showed that the fascist Fish looked for the Southern capitalists sup port hence three"], "digitized": true, "extract_timestamp": "2025-05-21T10:20:25.710Z", "group": ["ndnp/iune", "university-of-illinois-at-urbana-champaign-library-urbana-il-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020097/1930-05-30/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897652:1930053001:0580/full/pct:3.125/0/default.jpg#h=273&w=212", "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897652:1930053001:0580/full/pct:6.25/0/default.jpg#h=546&w=425", "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_fluorite_ver01:data:sn84020097:00332897652:1930053001:0580/full/pct:12.5/0/default.jpg#h=1092&w=851", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_fluorite_ver01/data/sn84020097/00332897652/1930053001/0580.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["illinois", "new york", "cook", "new york city", "chicago", "united states"], "location_city": ["new york", "chicago"], "location_country": ["united states"], "location_county": ["new york", "cook"], "location_state": ["new york", "illinois"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "3", "9", "6", "8", "7", "0000000002", "1", "sn84020097", "5"], "number_edition": ["1"], "number_lccn": ["sn84020097"], "number_page": ["0000000002"], "number_reel": ["0", "0", "3", "3", "2", "8", "9", "7", "6", "5", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the daily worker (chicago, ill.;new york, n.y.) 1924-1958", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the daily worker (chicago, ill.;new york, n.y.) 1924-1958