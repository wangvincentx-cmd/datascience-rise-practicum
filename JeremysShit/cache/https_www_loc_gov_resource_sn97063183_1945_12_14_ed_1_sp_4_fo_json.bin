, "sn97063182", "2024-01-10t18:39:57.321128", "sn97063184", "1", "http://www.loc.gov/item/sn97063183/1940-09-02/ed-1/", "library of michigan", "http://www.loc.gov/item/sn97063183/1946-04-15/ed-1/", "online resource", "university of michigan", "microfilm service copy", "1727"], "original_format": ["newspaper"], "partof": ["chronicling america", "directory of u.s. newspapers in american libraries", "serial and government publications division", "catalog", "the ypsilanti daily press (ypsilanti, mich.) 1928-1962"], "publication_frequency": ["daily"], "score": 84.16476, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["washtenaw county", "ypsilanti", "washtenaw", "united states", "michigan", "washtenaw county (mich.)", "newspapers", "ypsilanti (mich.)"], "timestamp": "2026-07-18T09:38:22.884Z", "title": "The Ypsilanti daily press", "type": ["title"], "url": "https://www.loc.gov/item/sn97063183/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013272176/"], "campaigns": [], "date": "1843", "dates": ["[1843 TO 1900]"], "description": ["Weekly Began December 20, 1843; ceased in 1900. Editor: C. Woodruff, <1876>. Publishers: Charles Woodruff, <1852>; C. Woodruff & Son, <1876>. \"Democratic,\" <1876>. Whole numbering added: Vol. 2, no. 47 (Dec. 17, 1845) = whole no. 99. Whole numbering dropped: <Vol. 15, no. 3 (Mar. 6, 1861)> and resumed <Vol. 28, no. 30 (May 12, 1875) = whole no. 1434>. Issue called: Ypsilanti sentinel--extra, June 17, 1844, and July 3, 1847. Merged with: Ypsilanti commercial (Ypsilanti, Mich. : 1865), to form: Ypsilanti sentinel-commercial. Description based on: Vol. I, no. 4 (Jan. 10, 1844); title from masthead (Chroniclingamerica.loc.gov, viewed December 11, 2013). Latest issue consulted: Vol. 4, no. 50 (April 12, 1848) (Chroniclingamerica.loc.gov, viewed December 11, 2013). Ypsilanti sentinel-commercial (Online) Ypsilanti commercial (Ypsilanti, Mich. : 1865 : Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:24.080Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013272176/", "image_url": [], "index": 5, "language": ["english"], "location": ["washtenaw county", "ypsilanti", "washtenaw", "united states", "michigan"], "number": ["2013272176", "2026-04-13t21:30:13", "2332-628x", "online resource", "862979714"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "ypsilanti sentinel (ypsilanti, washtenaw co. michigan) 1843-1900 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 74.957405, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["washtenaw county", "ypsilanti", "washtenaw", "united states", "michigan", "washtenaw county (mich.)", "newspapers", "ypsilanti (mich.)"], "timestamp": "2026-05-26T20:49:47.660Z", "title": "Ypsilanti sentinel", "type": ["title"], "url": "https://www.loc.gov/item/2013272176/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn85026593/", "http://lccn.loc.gov/sn85026593"], "batch": ["mimtptc_alpena_ver01"], "campaigns": [], "date": "1843", "description": ["Weekly Began with Dec. 20, 1843 issue; ceased in 1900. Cf. Gregory, W. Amer. newspapers. Editor: C. Woodruff, <1876>. Publishers: Charles Woodruff, <1852>; C. Woodruff & Son, <1876>. \"Democratic,\" <1876>. Whole numbering added: Vol. 2, no. 47 (Dec. 17, 1845) = whole no. 99. Whole numbering dropped: <Vol. 15, no. 3 (Mar. 6, 1861)> and resumed <Vol. 28, no. 30 (May 12, 1875) = whole no. 1434>. Issue called: Ypsilanti sentinel--extra, June 17, 1844, and July 3, 1847. Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection. Merged with: Ypsilanti commercial (Ypsilanti, Mich. : 1865), to form: Ypsilanti sentinel-commercial. Description based on: Vol. 1, no. 4 (Jan. 10, 1844). Ypsilanti commercial (