object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.017402, "shard": "02", "shelf_id": "sn95079154, 1908-01-09, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/vi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["tazewell (va.)", "tazewell", "virginia", "newspapers", "united states"], "subject_headings": ["Tazewell (Va.)--Newspapers", "Virginia--Tazewell", "United States--Virginia--Tazewell--Tazewell"], "subjects": [{"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"tazewell": "https://www.loc.gov/search/?fa=subject:tazewell&fo=json"}, {"tazewell (va.)": "https://www.loc.gov/search/?fa=subject:tazewell+%28va.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"virginia": "https://www.loc.gov/search/?fa=subject:virginia&fo=json"}], "timestamp": "2024-02-08T10:46:29.893Z", "title": "Tazewell Republican (Tazewell, Va.), January 9, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn95079154/1908-01-09/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95079154/", "http://lccn.loc.gov/sn95079154"], "batch": ["vi_navy_ver01"], "campaigns": [], "date": "1892", "description": ["Weekly(except Christmas) Began in 1892; ceased in 1919. Cf. Cappon, L.J. Va. Newspapers. Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection. Description based on: Vol. 5, no. 40 (Oct. 1, 1896). Latest issue consulted: Vol. 21, no. 51 (Dec. 19, 1912)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:09.423Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-09", "catalog", "united-states-newspaper-directory", "main-catalog-split-09"], "hassegments": false, "id": "http://www.loc.gov/item/sn95079154/", "image_url": [], "index": 2, "language": ["english"], "latlong": [37.115943, -81.520025], "location": ["tazewell", "virginia", "united states"], "location_str": "", "lonlat": [-81.520025, 37.115943], "number": ["sn95079154", "sn99066746", "original", "2024-01-28t09:26:30.871975", "2157-7994", "http://www.loc.gov/item/sn95079154/1897-01-07/ed-1/", "32574652", "2026-04-13t21:30:13", "2025-06-25t14:25:38", "793", "http://www.loc.gov/item/sn95079154/1912-12-19/ed-1/", "inp(nvf) cataloging region 2", "library of virginia, the", "online resource", "1", "microfilm service copy"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "tazewell republican (tazewell, va.) 1892-1919", "chronicling america", "catalog", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 44.917145, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["tazewell (va.)", "tazewell", "virginia", "newspapers", "united states"], "timestamp": "2026-07-18T09:37:35.627Z", "title": "Tazewell Republican", "type": ["title"], "url": "https://www.loc.gov/item/sn95079154/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021220121/"], "campaigns": [], "date": "18??", "dates": ["[1800 TO 9999]"], "description": ["Weekly Print began in 1845; Print ceased with v. 145, no. 36 (May 29, 2019). Called Jeffersonville until Feb. 29, 1892, then called Tazewell. \"Devoted to local and general news, agriculture and miscellany.\" Publisher varies. Numbering inconsistent. By 1966, Southwest Virginia Newspapers, Inc. also published: the Richlands news-press; and the Saltville progress. Merged with the Richlands News Press to form the Clinch Valley News & Richlands Press. July 7, 1886; title from caption (Chronicling America's website, viewed Feb. 10, 2021). December 22, 1922 (Chronicling America's website, viewed Feb. 10, 2021). Richlands news-press Clinch Valley news & Richlands press"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:23.371Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021220121/", "image_url": [], "index": 3, "language": ["english"], "location": ["tazewell", "virginia", "jeffersonville", "united states"], "number": ["online resource", "862969120", "2021220121", "2767-1283", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "clinch valley news (jeffersonville, va.) 18??-current [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 35.675518, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["tazewell (va.)", "tazewell", "virginia", "newspapers", "united states", "jeffersonville"], "timestamp": "2026-05-26T21:01:49.831Z", "title": "Clinch Valley news", "type": ["title"], "url": "https://www.loc.gov/item/2021220121/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2012203861/"], "campaigns": [], "date": "1892", "dates": ["[1892 TO 1919]"], "description": ["Weekly(except Christmas) Began in 1892; ceased in 1919. Cf. Cappon, L.J. Va. Newspapers. Also issued in print. Mode of access: World Wide Web. Description based on print version record. Latest issue consulted: Vol. 21, no. 5 (Dec. 12, 1912) (Chroniclingamerica.loc.gov, viewed Sept. 4, 2012)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:13.555Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2012203861/", "image_url": [], "index": 4, "language": ["english"], "location": ["tazewell", "virginia", "united states"], "number": ["701515023", "online resource", "2012203861", "2026-04-13t21:30:13", "2169-5415"], "original_format": ["newspaper"], "partof": ["tazewell republican (tazewell, va.) 1892-1919 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 35.675518, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["tazewell (va.)", "tazewell", "virginia", "newspapers", "united states"], "timestamp": "2026-05-26T20:47:02.218Z", "title": "Tazewell Republican", "type": ["title"], "url": "https://www.loc.gov/item/2012203861/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn85034357/", "http://lccn.loc.gov/sn85034357"], "batch": ["vi_fortis_ver01"], "campaigns": [], "date": "18??", "description": ["Weekly Began in 1845. -v. 145, no. 36 (May 29, 2019). Called Jeffersonville until Feb. 29, 1892, then called Tazewell. \"Devoted to local and general news, agriculture and miscellany.\" Publisher varies. Numbering inconsistent. Microfilm available from the University of Virginia, and Bell & Howell. Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection. By 1966, Southwest Virginia Newspapers, Inc. also published: the Richlands news-press; and the Saltville progress. Merged with the Richlands News Press to form the Clinch Valley News & Richlands Press. Description based on: \"Extra\" issued on June 28, 1867. Richlands news press (DLC)sn 00064818 Clinch Valley news & Richlands press (DLC) 2016270566"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:12.378Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-04", "catalog", "united-states-newspaper-directory", "main-catalog-split-04"], "hassegments": false, "id": "http://www.loc.gov/item/sn85034357/", "image_u