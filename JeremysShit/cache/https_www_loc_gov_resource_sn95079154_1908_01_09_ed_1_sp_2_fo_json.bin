e": "Sunset Drive-in Theater, Tazewell, Virginia", "type": ["still image"], "url": "https://www.loc.gov/item/2017704001/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2009632165", "http://www.loc.gov/item/2009632165/", "https://hdl.loc.gov/loc.pnp/ppmsca.09448", "http://www.loc.gov/resource/ppmsca.09448/", "https://www.loc.gov/pictures/item/2009632165/", "http://www.loc.gov/pictures/item/2009632165/", "https://www.loc.gov/pictures/collection/cph/item/2009632165/", "http://www.loc.gov/pictures/collection/cph/item/2009632165/"], "campaigns": [], "contributor": ["brooks, charlotte"], "date": "1953-01-01", "dates": ["1953"], "description": ["Photograph showing Dr. Whitten sitting in a chair, reading a newspaper, with a long line of shoes in the foreground."], "digitized": true, "extract_timestamp": "2022-08-02T19:14:19.016Z", "group": ["catalog", "cph", "catalog-split-02", "main-catalog", "miscellaneous-items-high-demand", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/2009632165/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppmsca/09400/09448_150px.jpg#h=150&w=119", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/09400/09448t.gif#h=150&w=119", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/09400/09448r.jpg#h=640&w=509", "https://tile.loc.gov/storage-services/service/pnp/ppmsca/09400/09448v.jpg#h=1024&w=815"], "index": 3, "language": ["english"], "location": ["tazewell", "virginia"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2022-06-15t09:19:01", "2009632165", "http://www.loc.gov/item/15734481"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "catalog", "prints and photographs division", "miscellaneous items in high demand"], "score": 22.821127, "shelf_id": "LC-L917-53-2797, no. 1", "site": ["catalog", "pictures"], "subject": ["tazewell", "virginia", "shoes", "film negatives", "foster home care"], "timestamp": "2022-08-02T19:16:35.307Z", "title": "[Dr. Jack Whitten of North Tazewell, Virginia, foster father to almost 200 children over the course of 47 years, in a rare quiet moment]", "type": ["still image"], "url": "https://www.loc.gov/item/2009632165/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2024655288", "http://www.loc.gov/item/2024655288/", "https://hdl.loc.gov/loc.afc/afc2023017.afc2023017_009_sr01", "http://www.loc.gov/resource/afc2023017.afc2023017_009_sr01/", "http://www.loc.gov/resource/afc2023017.afc2023017_009_ph/", "http://www.loc.gov/resource/afc2023017.afc2023017_009_ms01/"], "campaigns": [], "contributor": ["wilson, jeanette", "musgrave, nicole", "wilson, peggy"], "date": "2024", "dates": ["2024"], "description": ["Jeanette Wilson of Tazewell, Virginia has worked for Clinch Valley Community Action (CVCA) in Tazewell for 38 years. She is currently the School Readiness Coordinator and a Practice-Based Coach for Head Start. Peggy Wilson of Tazewell has worked for CVCA for about 18 years. She is currently the Disabilities Mental Health Coordinator for Head Start. Both Jeanette and Peggy have years of experience teaching in the classroom at Head Start. In their interview, Jeanette and Peggy discuss their trajectories in child care; pivoting their work roles when Head Start classrooms closed for several months during the early pandemic; Head Start teachers navigating virtual learning; Covid-related safety protocols; increased workload and stress for teachers; experiencing high turnover and being short-staffed; observing and navigating behavioral challenges in the children; and increased awareness and support around mental health."], "digitized": true, "extract_timestamp": "2025-02-14T19:52:54.821Z", "group": ["afc/cahp/2023017", "rural-central-appalachian-childcare-providers-covid-19-experiences"], "hassegments": true, "id": "http://www.loc.gov/item/2024655288/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:afc:afc2023017:afc2023017_009:afc2023017_009_ph:afc2023017_009_ph01/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:afc:afc2023017:afc2023017_009:afc2023017_009_ph:afc2023017_009_ph01/full/pct:12.5/0/default.jpg#h=250&w=375", "https://tile.loc.gov/image-services/iiif/service:afc:afc2023017:afc2023017_009:afc2023017_009_ph:afc2023017_009_ph01/full/pct:25/0/default.jpg#h=500&w=750", "https://tile.loc.gov/image-services/iiif/service:afc:afc2023017:afc2023017_009:afc2023017_009_ph:afc2023017_009_ph01/full/pct:50/0/default.jpg#h=1000&w=1500", "https://tile.loc.gov/image-services/iiif/service:afc:afc2023017:afc2023017_009:afc2023017_009_ph:afc2023017_009_ph01/full/pct:100/0/default.jpg#h=2000&w=3000"], "index": 4, "language": ["english"], "location": ["tazewell", "virginia", "appalachian region"], "mime_type": ["audio/mp3", "image/gif", "application/pdf", "image/jpeg", "image/jp2"], "number": ["2025-01-13t14:48:17", "online resource", "2024655288"], "online_format": ["audio", "image", "pdf"], "original_format": ["sound recording"], "partof": ["catalog", "covid-19 american history project", "american folklife center", "it takes a village : rural central appalachian childcare providers' covid-19 experiences : covid-19 american history project, 2023-2024"], "score": 13.602562, "shelf_id": "http://lccn.loc.gov/2024655288", "site": ["catalog"], "subject": ["quality of work life", "interviews", "personal narratives", "work environment", "appalachian region", "child care services", "child care workers", "wilson, jeanette", "educational aspects", "oral histories", "influence", "sound recordings", "wilson, peggy", "color", "psychological aspects", "virginia", "job stress", "covid-19 pandemic", "digital photographs"], "timestamp": "2025-02-14T19:55:23.596Z", "title": "Jeanette Wilson and Peggy Wilson interview conducted by Nicole Musgrave, 2024-01-31", "type": ["sound recording-nonmusical"], "url": "https://www.loc.go