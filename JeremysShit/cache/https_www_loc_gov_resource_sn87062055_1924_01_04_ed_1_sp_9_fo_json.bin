ess_restricted": false, "aka": ["http://www.loc.gov/item/2021220465/"], "campaigns": [], "date": "1883", "dates": ["[1883 TO 1891]"], "description": ["Weekly Print began Sept. 14, 1883. Print ceased with Vol. VIII, No. 35 (May 16, 1891). Published in Flagstaff, Ariz., Feb. 2, 1884-May 16, 1891. Some numbers issued out of chronological order. Issues for Apr. 4, 1885-Nov. 30, 1889 are numbered as whole numbers. Issues for Sept. 17, 1887-Nov. 30, 1889 also have regular numbering. Vol. 1, No. 4 (Oct. 6, 1863); title from caption (Chronicling America's website, viewed July 12, 2021). Vol. VIII, No. 35 (May 16, 1891) (Chronicling America's website, viewed July 12, 2021). Coconino sun (Flagstaff, Ariz. : 1891) 2769-2361 (DLC) 2021220466 (OCoLC)701546268"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:13.555Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021220465/", "image_url": [], "index": 10, "language": ["english"], "location": ["arizona", "flagstaff", "mohave", "mohave county", "coconino", "coconino county", "peach springs", "united states"], "number": ["701546248", "2026-04-13t21:30:13", "online resource", "2021220465", "2021220466", "2769-237x"], "original_format": ["newspaper"], "other_title": ["Weekly champion"], "partof": ["the arizona champion (peach springs, mohave county, a.t. [ariz.]) 1883-1891 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 75.023315, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["arizona", "coconino county (ariz.)", "newspapers", "coconino county", "flagstaff", "mohave county", "peach springs", "coconino", "mohave county (ariz.)", "mohave", "flagstaff (ariz.)", "united states", "peach springs (ariz.)"], "timestamp": "2026-05-26T21:02:05.412Z", "title": "The Arizona champion", "type": ["title"], "url": "https://www.loc.gov/i