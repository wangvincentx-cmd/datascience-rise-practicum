/item/2021220513/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021220096/"], "campaigns": [], "date": "1885", "dates": ["[1885 TO 1893]"], "description": ["Weekly Print began in 1885. Print ceased with vol. 8, No. 27 (June 11, 1893) Vol. 3, No. 1 (December 17, 1887); title from caption (Chronicling America's website, viewed February 2, 2021). Vol. 8, No. 27 (June 11, 1893) (Chronicling America's website, viewed February 2, 2021). Sunday morning courier 2767-2611 (DLC) 2021220097 (OCoLC)778033340"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:17.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021220096/", "image_url": [], "index": 6, "language": ["english"], "location": ["lancaster", "united states", "lancaster county", "lincoln", "nebraska"], "number": ["2026-04-13t21:30:13", "2767-2603", "778030356", "online resource", "2021220096", "2021220097"], "original_format": ["newspaper"], "partof": ["capital city courier (lincoln, nebraska) 1885-1893 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 63.062023, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lincoln (neb.)", "lancaster", "united states", "lancaster county", "lincoln", "nebraska", "lancaster county (neb.)", "newspapers"], "timestamp": "2026-05-26T21:01:49.831Z", "title": "Capital city courier", "type": ["title"], "url": "https://www.loc.gov/item/2021220096/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019271171/"], "campaigns": [], "date": "1896", "dates": ["[1896 TO 1902]"], "description": ["Weekly Began with vol. VII, no. 32 (January 16, 1896); ceased with vol. XIV, no. 23 (October 30, 1902). Continues the numbering of: Wealth makers of the world. Merger of: Wealth makers of the world, and: Lincoln independent (Lincoln, Neb.). Description based on: Vol. VII, no. 32 (January 16, 1896); title from masthead (Chroniclingamerica.loc.gov, viewed June 19, 2019). Latest issue consulted: Vol. XIV, no. 23 (October 30, 1902) (Chroniclingamerica.loc.gov, viewed June 19, 2019). Independent (Lincoln, Neb.)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:48.715Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019271171/", "image_url": [], "index": 7, "language": ["english"], "location": ["lancaster", "united states", "lancaster county", "lincoln", "nebraska"], "number": ["2019271248", "2026-04-13t21:30:13", "2019271171", "2019271170", "online resource", "1104965585", "2644-335x"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the nebraska independent (lincoln, nebraska) 1896-1902 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 63.062023, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lincoln (neb.)", "lancaster", "united states", "lancaster county", "lincoln", "nebraska", "lancaster county (neb.)", "newspapers"], "timestamp": "2026-05-26T20:58:47.437Z", "title": "The Nebraska independent", "type": ["title"], "url": "https://www.loc.gov/item/2019271171/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019271172/"], "campaigns": [], "date": "1902", "dates": ["[1902 TO 1907]"], "description": ["Weekly Began with vol. XIV, no. 24 (Nov. 6, 1902); ceased with twentieth year (April 25, 1907). Merged with: Weekly state journal (Lincoln, Neb.), and: Western swine breeder, to form: Independent farmer and western swine breeder. Description based on: Vol. XIV, no. 24 (Nov. 6, 1902); title from masthead (Chroniclingamerica.loc.gov, viewed June 19, 2019). Latest issue consulted: Twentieth year (April 25, 1907) (Chroniclingamerica.loc.gov, viewed June 19, 2019). Weekly state journal (Lincoln, Neb.) Western