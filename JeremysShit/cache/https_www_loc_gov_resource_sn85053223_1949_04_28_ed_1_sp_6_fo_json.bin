, "url": "https://www.loc.gov/resource/sn85053223/1949-04-28/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_dillon_ver01/data/sn85053223/00517178469/1949042801/0806.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85053223/1949-04-28/ed-1/?sp=6"], "batch": ["mthi_dillon_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/sanders/", "3/united states/montana/sanders/hot springs/", "3/united states/montana/sanders/camas/"], "contributor": ["montana historical society; helena, mt"], "date": "1949-04-28", "dates": ["1949-04-28"], "description": ["XI HaaraAN AIXX BWOTOA CAMAS HOT SPRINGS EXCHANGE Edna B Gannaway Editor A weekly newspaper published every Thursday at Camas Montana Entered at the post oflice at Hot Springs Montana under the act of Congress March 5 1879 Subscription prices 1 year S3M 6 Months 9190 Dorothy Von Segen Hot Springs Representative can be contacted at the drug store every morning ex cept Sunday 1949 EDITORIALS If you have news or want to know about advertising you may leave with Mrs Dorothy VonSegen in the morning hours at the Hot Springs drug store In the afternoon she can be reached in her home either in person or by telephone Please do not telephone her at the drug store as her time there belongs to the business but you may leave any news or advertising with her there In others sections in this paper you will find at least three notices calling attention to the Cancer DrivePublic service stuff so it is billed I is not news unless you interpret it bad news People are get ting tired of being asked for a handout every time they turn a round The newspapers are clutter ed with the calls for publicity If"], "digitized": true, "extract_timestamp": "2023-07-03T13:49:54.726Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85053223/1949-04-28/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_dillon_ver01:data:sn85053223:00517178469:1949042801:0806/full/pct:6.25/0/default.jpg#h=342&w=281", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_dillon_ver01:data:sn85053223:00517178469:1949042801:0806/full/pct:12.5/0/default.jpg#h=685&w=563", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_dillon_ver01/data/sn85053223/00517178469/1949042801/0806.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["hot springs", "montana", "sanders", "camas", "united states"], "location_city": ["hot springs", "camas"], "location_country": ["united states"], "location_county": ["sanders"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "9", "sn85053223", "6", "8", "7", "4", "1", "0000000006", "5"], "number_edition": ["1"], "number_lccn": ["sn85053223"], "number_page": ["0000000006"], "number_reel": ["0", "0", "5", "1", "7", "1", "7", "8", "4", "6", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the camas hot springs exchange (camas, mont.) 1926-1959", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the camas hot springs exchange (camas, mont.) 1926-1959"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn85053223/1949-04-28/ed-1/?sp=6"}], "segmentof": ["http://www.loc.gov/resource/sn85053223/1949-04-28/ed-1/"], "shelf_id": "6", "site": ["chroniclingamerica"], "subject": ["montana", "sanders", "united states", "camas", "hot springs"], "timestamp": "2