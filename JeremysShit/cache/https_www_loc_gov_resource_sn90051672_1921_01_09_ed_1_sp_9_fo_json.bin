service:ndnp:cohi:batch_cohi_kebler_ver01:data:sn90051672:00383341346:1921010901:0065/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/cohi/batch_cohi_kebler_ver01/data/sn90051672/00383341346/1921010901/0073.pdf", "segment_count": 26, "url": "https://www.loc.gov/resource/sn90051672/1921-01-09/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/cohi/batch_cohi_kebler_ver01/data/sn90051672/00383341346/1921010901/0073.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn90051672/1921-01-09/ed-1/?sp=9"], "batch": ["cohi_kebler_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/colorado/", "2/united states/colorado/pueblo/", "3/united states/colorado/pueblo/pueblo/"], "contributor": ["history colorado"], "date": "1921-01-09", "dates": ["1921-01-09"], "description": ["OUR ANNUAL JANUARY CLEARANCE SALE I I OUR ANNUAL JANUARY CLEARANCE SALE Begins January the 10th and for Ten days We will offer our entire Stock of Ladies and Mens Clothing Furnishings and I Drygoods at a great Sacrifice For the past few months we have kept pace with the times and have been marking our merchandise Downwards but for this Sale we have taken the Bull by the Floms and decided to CLEAR OUR ENTIRE STOCK QUICKLY by marking our goods SO LOW as to make you buy Weve gone through our stock and slashed the I I already low prices still lower We are swallowing a big loss We have discarded Cost for we are determined to Clear the Entire Stock of Winter Goods to make room for the Spring I Goods soon to begin arriving So its up to you Come to this BARGAIN FEAST MONDAY MORNING Doors will open 9am at 409 N Union Ave where everything is always I fi JUST A LITTLE CHEAPER Boys Flannelette Blouse waists a special value at 49c I MENS EVERYDAY SOX BLACK AND WHITE BACK TO Boys Everyday Blue Chambray Shirts 75c and 98c To the First One Hundred"], "digitized": true, "extract_timestamp": "2023-12-27T22:05:22.460Z", "group": ["ndnp/cohi", "history-colorado-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn90051672/1921-01-09/ed-1/?sp=9", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_kebler_ver01:data:sn90051672:00383341346:1921010901:0073/full/pct:6.25/0/default.jpg#h=305&w=244", "https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_kebler_ver01:data:sn90051672:00383341346:1921010901:0073/full/pct:12.5/0/default.jpg#h=610&w=488", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/cohi/batch_cohi_kebler_ver01/data/sn90051672/00383341346/1921010901/0073.xml&format=alto_xml"], "index": 9, "language": ["english"], "location": ["colorado", "united states", "pueblo"], "location_city": ["pueblo"], "location_country": ["united states"], "location_county": ["pueblo"], "location_state": ["colorado"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000009", "3", "0", "1", "4", "8", "sn90051672", "6"], "number_edition": ["1"], "number_lccn": ["sn90051672"], "number_page": ["0000000009"], "number_reel": ["0", "0", "3", "8", "3", "3", "4", "1", "3", "4", "6"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Pueblo daily chieftain", "Published as: Pueblo chieftain and Sunday star-journal", "Published on Sundays as: Pueblo star-journal and the Sunday chieftain", "Published on Sundays as: Sunday chieftain and star-journal"], "partof": ["chronicling america", "serial and government publications division", "pueblo chieftain (pueblo, colo.) 1889-current"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["pueblo chieftain (pueblo, colo.) 1889-current"], "publication_frequency": ["daily"], "resources": 