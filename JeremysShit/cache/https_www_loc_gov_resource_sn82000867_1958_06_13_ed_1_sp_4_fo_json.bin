061301/0254.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_educatedfella_ver02:data:sn82000867:00414217011:1958061301:0251/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_educatedfella_ver02/data/sn82000867/00414217011/1958061301/0254.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn82000867/1958-06-13/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_educatedfella_ver02/data/sn82000867/00414217011/1958061301/0254.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_educatedfella_ver02:data:sn82000867:00414217011:1958061301:0251/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_educatedfella_ver02/data/sn82000867/00414217011/1958061301/0254.pdf", "segment_count": 10, "url": "https://www.loc.gov/resource/sn82000867/1958-06-13/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/az/batch_az_educatedfella_ver02/data/sn82000867/00414217011/1958061301/0254.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82000867/1958-06-13/ed-1/?sp=4"], "batch": ["az_educatedfella_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arizona/", "2/united states/arizona/pima/", "3/united states/arizona/pima/tucson/"], "contributor": ["arizona state library, archives and public records; phoenix, az"], "date": "1958-06-13", "dates": ["1958-06-13"], "description": ["Page Four David Schwartz Noah Had A Vision WHEN MORDECAI Manuel Noah was a little boy his father once took him walking through the streets of Philadelphia and pointed out one of the leading citizens of the town a man named Benja min Franklin You can see by this that Noah goes way back in American history When Mordecai Noah grew up he became a man of considerable prominence himself He became one of Americas foremost editors and he was the first American Jew appointed to a post in the diplomatic service He filled the office of Consul to Tunis which figures so prominently in the newspaper headlines today What he saw in North Africa put ideas in his head Schwartz Noah has been called the first American Zionist and it was his stay in North Africa which was largely responsible for it He believed that the North Africa Jewry could supply 100000 Jews for an army to wrest control of the Holy Land from the Turks and make the Zionist dream real It hasnt come about exactly as Noah envisaged it but to some extent he did foreshadow history Noah was a peculiar figure He was an Oxthodox Jew"], "digitized": true, "extract_timestamp": "2024-01-09T14:48:44.539Z", "group": ["ndnp/az", "arizona-state-university-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82000867/1958-06-13/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_educatedfella_ver02:data:sn82000867:00414217011:1958061301:0254/full/pct:6.25/0/default.jpg#h=425&w=288", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_educatedfella_ver02:data:sn82000867:00414217011:1958061301:0254/full/pct:12.5/0/default.jpg#h=851&w=576", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_educatedfella_ver02/data/sn82000867/00414217011/1958061301/0254.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["arizona", "pima", "pima county", "tucson", "united states"], "location_city": ["tucson"], "location_country": ["united states"], "location_county": ["pima"], "location_state": ["arizona"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "applicat