mage"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "prints and photographs division"], "score": 24.38965, "shelf_id": "PCRD 4 - New Mexico - Tucumcari, no. 1 [P&P]", "site": ["pictures", "catalog"], "subject": ["united states", "photographs", "tucumcari", "postcards", "new mexico"], "timestamp": "2024-03-02T14:41:12.048Z", "title": "Ranch scene, Tucumcari, N.M.", "type": ["still image"], "url": "https://www.loc.gov/item/2024690663/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nmu/batch_nmu_dogbane_ver01/data/sn93061711/00280773712/1908032101/0856.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:nmu:batch_nmu_dogbane_ver01:data:sn93061711:00280773712:1908032101:0844/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/nmu/batch_nmu_dogbane_ver01/data/sn93061711/00280773712/1908032101/0856.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/sn93061711/1908-03-21/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nmu/batch_nmu_dogbane_ver01/data/sn93061711/00280773712/1908032101/0856.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:nmu:batch_nmu_dogbane_ver01:data:sn93061711:00280773712:1908032101:0844/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/nmu/batch_nmu_dogbane_ver01/data/sn93061711/00280773712/1908032101/0856.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/sn93061711/1908-03-21/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/nmu/batch_nmu_dogbane_ver01/data/sn93061711/00280773712/1908032101/0856.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn93061711/1908-03-21/ed-1/?sp=13"], "batch": ["nmu_dogbane_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/new mexico/", "2/united states/new mexico/quay/", "3/united states/new mexico/quay/tucumcari/"], "contributor": ["university of new mexico"], "date": "1908-03-21", "dates": ["1908-03-21"], "description": ["OUR GREAT ANNUAL LIMIT SALE i In anticipation of this great sale our buyer spent about four weeks searching the markets of St Louis Chicago and New York for values His efforts were fuiiy repaid and we are going to demonstrate to the people of Quay county the sensational purchasing power of a dollar The recent financial panic left numbers of manufacturers and jobbers in a bad way overloaded with merchandise and short on cash and on this account we made some very satisfactory purchases Our stock is larger better selected and more comprehensive than ever before We call thi the Limit Sale because quantities are limited and we are forced to limit each customer to certain quantities on some lines and the time is limited in which to avail vourself of these matchless values J Our store will be closed all day Wednesday and Thursday March 18 and 19 arranging and marking down for this sale Thi will be the greatest sale ever held in Tucumcari Extra sales people to wait on the crowds Hose Ladies fast black with white feet 15c values limit sale price 3 pairs No 1 120 ladies mercerized lace hose a 25c value limit"], "digitized": true, "extract_timestamp": "2020-09-15T13:16:58.615Z", "group": ["ndnp/nmu", "university-of-new-mexico-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn93061711/1908-03-21/ed-1/?sp=13", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nmu:batch_nmu_dogbane_ver01:data:sn93061711:00280773712:1908032101:0856/full/pct:6.25/0/default.jpg#h=456&w=311", "https://tile.loc.gov/image-services/iiif/service:ndnp:nmu:batch_nmu_dogbane_ver01:d