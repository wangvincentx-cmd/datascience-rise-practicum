.gov/image-services/iiif/service:ndnp:msar:batch_msar_hemp_ver01:data:sn87065167:00199916907:1914022501:0506/info.json", "language": ["English"], "mimetype": "application/json", "reel_number": "00199916907", "section_label": null, "size": 3376880, "title": "Image 1 of The Hattiesburg news (Hattiesburg, Miss.), February 25, 1914", "width": 4656}, {"fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/msar/batch_msar_hemp_ver01/data/sn87065167/00199916907/1914022501/0506.xml&format=alto_xml&full_text=1", "mimetype": "text/plain", "use": "text"}], "pagination": {"current": 1, "first": null, "from": 1, "last": "https://www.loc.gov/resource/sn87065167/1914-02-25/ed-1/?fo=json&sp=3", "next": "https://www.loc.gov/resource/sn87065167/1914-02-25/ed-1/?fo=json&sp=2", "of": 4, "page_list": [{"number": 1, "url": null}, {"number": 2, "url": "https://www.loc.gov/resource/sn87065167/1914-02-25/ed-1/?fo=json&sp=2"}, {"number": 3, "url": "https://www.loc.gov/resource/sn87065167/1914-02-25/ed-1/?fo=json&sp=3"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": null, "results": "1 - 1", "to": 1, "total": 4}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn87065167/1914-02-24/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/2016655401", "http://www.loc.gov/item/2016655401/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0110", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0110/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0110_mv08/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0110_ms01/"], "campaigns": [], "contributor": ["crosby, emilye", "bishop, john melville", "dahmer, ellie j.", "civil rights history project (u.s.)"], "date": "2015-01-01", "dates": ["2015"], "description": ["Ellie Dahmer discusses her involvement in the NAACP and voting rights activism in Forrest County, Mississippi. She recalls her experiences in education, both as a student at local schools, Alcorn State University, and Tennessee A&I, and as a teacher in schools throughout Mississippi. Her career as a Forrest County election commissioner is also discussed. She speaks about her husband, fellow activist Vernon Dahmer, and remembers the night when Klu Kulx Klan members burned her home, killing her husband and injuring her children."], "digitized": true, "extract_timestamp": "2022-10-04T17:35:53.116Z", "group": ["afc2010039", "catalog-split-14", "catalog", "civil-rights-history-project", "main-catalog-split-14", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2016655401/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0110/afc2010039_crhp0110_mv08.gif", "https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0110/afc2010039_crhp0110_ms01.gif#h=150&w=116"], "index": 1, "language": ["english"], "location": ["mississippi", "hattiesburg", "united states"], "mime_type": ["image/gif", "application/pdf", "image/jpeg", "application/x-video"], "number": ["2016655401", "online resource", "2020-01-23t09:39:29"], "online_format": ["image", "pdf", "video"], "original_format": ["film, video"], "partof": ["catalog", "civil rights history project", "american folklife center"], "score": 34.283405, "shelf_id": "http://lccn.loc.gov/2016655401", "site": ["catalog"], "subject": ["filmed interviews", "race relations", "ku klux klan (1915- )", "oral histories", "hattiesburg (miss.)", "suffrage", "african american women civil rights workers", "dahmer, vernon ferdinand", "dahmer, ellie j.", "alcorn state university", "video recordings", "ladner, dorie", "segregation in education", "history", "ladner, joyce a", "mississippi freedom project", "mississippi", "violence", "kennard, clyde", "national association for the advancement of colored people", "civil rights movements", "personal narratives", "hattiesburg", "voter registration", "african american women teachers", "murder", "mississippi southern college", "african americans", "united states", "interviews"], "timestamp": "2022-10-17T14:38:46.135Z", "title": "Ellie Dahmer oral history interview conducted by Emilye Crosby in Hattiesburg, Mississippi, 2015 November 30", "type": ["moving image"], "url": "https://www.loc.gov/item/2016655401/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2016655403", "http://www.loc.gov/item/2016655403/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0112", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0112/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0112_mv07/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0112_ms01/"], "campaigns": [], "contributor": ["bishop, john melville", "branch, raylawni g.", "smith, jeanette", "crosby, emilye", "civil rights history project (u.s.)"], "date": "2015-01-01", "dates": ["2015"], "description": ["Raylawni G. Branch and Jeanette Smith discuss their involvement in the Hattiesburg, Mississippi-based Civil Rights Movement. They remember their upbringings as mixed race children, Smith in Mississippi and Branch in Mississippi and Chicago, Illinois. Branch recalls entering as one of the first black students at the University of Southern Mississippi. Both speak about their activism for voting rights and education, as well as sharing their philosophies on issues of race, discrimination, and activism."], "digitized": true, "extract_timestamp": "2022-10-04T17:35:53.116Z", "group": ["afc2010039", "catalog-split-00", "catalog", "civil-rights-history-project", "main-catalog-split-00", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2016655403/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0112/afc2010039_crhp0112_mv07.gif", "https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0112/afc2010039_crhp0112_ms01.gif#h=150&w=116"], "index": 2, "language": ["english"], "location": ["mississippi", "hattiesburg", "united states"], "mime_type": ["image/gif", "application/pdf", "image/jpeg", "application/x-video"], "number": ["online resource", "2016655403", "2020-02-20t15:36:11"], "online_format": ["image", "pdf", "video"], "original_format": ["film, video"], "partof": ["catalog", "civil rights history project", "american folklife center"], "score": 34.283405, "shelf_id": "http://lccn.loc.gov/2016655403", "site": ["catalog"], "subject": ["filmed interviews", "race relations", "oral histories", "till, emmett", "hattiesburg (miss.)", "suffrage", "dahmer, vernon ferdinand", "african american women civil rights workers", "religious aspects", "video recordings", "carmichael, stokely", "social justice", "washington, d.c.)", "segregation in education", "history", "medical committee for human rights (u.s.)", "branch, raylawni g.", "mississippi freedom project", "mississippi", "university of southern mississippi", "deacons for defense and justice", "christianity", "national association for the advancement of colored people", "civil rights movements", "william david)", "march on washington for jobs and freedom", "personal narratives", "student nonviolent coordinating committee (u.s.)", "hattiesburg", "mccain, william d.", "head start program (u.s.)", "council of federated organizations (u.s.)", "evers, charles", "smith, jeanette", "african americans", "school integration", "united states", "interviews"], "timestamp": "2022-10-17T14:38:46.135Z", "title": "Raylawni G. Branch and Jeanette Smith oral history interview conducted by Emilye Crosby in Hattiesburg, Mississippi, 2015 December 01", "type": ["moving image"], "url": "https://www.loc.gov/item/2016655403/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2016655406", "http://www.loc.gov/item/2016655406/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0115", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0115/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0115_mv11/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0115_ms01/"], "campaigns": [], "contributor": ["holloway, eddie a.", "bishop, john melville", "civil rights history project (u.s.)", "crosby, emilye"], "date": "2015-01-01", "dates": ["2015"], "description": ["Eddie Holloway discusses growing up in Hattiesburg, Mississippi, as well as his involvement in Freedom Schools and other civil rights causes. He remembers his experiences as a child in a segregated society and school system, attending University of Southern Mississippi during its transition from a segregated to an integrated school, and his observations of the current educational environment as Dean of Students at USM."], "digitized": true, "extract_timestamp": "2022-10-04T17:35:53.116Z", "group": ["afc2010039", "catalog-split-03", "catalog", "civil-rights-history-project", "main-catalog-split-03", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2016655406/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0115/afc2010039_crhp0115_mv11.gif", "https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0115/afc2010039_crhp0115_ms01.gif#h=150&w=116"], "index": 3, "language": ["english"], "location": ["mississippi", "hattiesburg", "united states"], "mime_type": ["image/gif", "application/pdf", "image/jpeg", "application/x-video"], "number": ["online resource", "2020-01-23t09:41:04", "2016655406"], "online_format": ["image", "pdf", "video"], "original_format": ["film, video"], "partof": ["catalog", "civil rights history project", "american folklife center"], "score": 34.283405, "shelf_id": "http://lccn.loc.gov/2016655406", "site": ["catalog"], "subject": ["filmed interviews", "race relations", "mississippi freedom schools", "magee, clarence", "connor, peggy jean", "oral histories", "hattiesburg (miss.)", "suffrage", "video recordings", "segregation in education", "history", "mississippi", "kennard, clyde", "university of southern mississippi", "civil rights movements", "burger, n. r.", "holloway, eddie a.", "personal narratives", "hattiesburg", "african american civil rights workers", "segregation", "african americans", "school integration", "united states", "interviews"], "timestamp": "2022-10-17T14:38:46.135Z", "title": "Eddie Holloway oral history interview conducted by Emilye Crosby in Hattiesburg, Mississippi, 2015 December 02", "type": ["moving image"], "url": "https://www.loc.gov/item/2016655406/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2016655405", "http://www.loc.gov/item/2016655405/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0114", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0114_mv13/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0114_ms01/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0114/"], "campaigns": [], "contributor": ["crosby, emilye", "dahmer, vernon", "civil rights history project (u.s.)", "bishop, john melville"], "date": "2015", "dates": ["2015"], "description": ["Vernon Dahmer, Jr., remembers growing up near Hattiesburg, Mississippi, and discusses his experiences relating to segregation and race, as a child and in the military. He also recalls the night his family's home in Hattiesburg was firebombed, killing his father, Vernon Dahmer, Sr., and his subsequent involvement in the trials of the Klu Klux Klan members who staged the bombing."], "digitized": true, "extract_timestamp": "2024-10-10T06:08:20.431Z", "group": ["catalog-split-02", "catalog", "afc2010039", "main-catalog-split-02", "civil-rights-history-project"], "hassegments": false, "id": "http://www.loc.gov/item/2016655405/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0114/afc2010039_crhp0114_mv13.gif", "https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0114/afc2010039_crhp0114_ms01.gif#h=150&w=116"], "index": 4, "language": ["engli