rfect: Brittle, missing sections at sheet edges, fold-lined, annotated in pencil and ink. Includes 24 insets of towns/villages (including the cities of Pittsburgh, Allegheny, and McKeesport), business directories (some indexed), distance table, statistical table/data, ill., and state coat-of-arms. LC Land ownership maps, 701 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:22.369Z", "group": ["gmd.mar", "catalog-split-12", "catalog", "general-maps", "main-catalog-split-12"], "hassegments": false, "id": "http://www.loc.gov/item/2012592151/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd382/g3823/g3823a/la000701.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd382/g3823/g3823a/la000701.gif#h=158&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd382:g3823:g3823a:la000701/full/pct:12.5/0/default.jpg#h=2351&w=2231", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd382:g3823:g3823a:la000701/full/pct:25/0/default.jpg#h=4703&w=4462"], "index": 9, "language": ["english"], "location": ["pennsylvania", "allegheny county", "allegheny", "united states", "pittsburgh metropolitan area", "pittsburgh", "mckeesport"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t05:07:22.100000", "2012592151", "sheet", "2012-06-11t13:22:00"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "county landownership maps", "geography and map division", "cultural landscapes"], "score": 53.159866, "shelf_id": "G3823.A4 1862 .B4", "site": ["catalog"], "subject": ["pennsylvania", "allegheny county", "mckeesport (pa.)", "villages", "pittsburgh (pa.)", "united states", "pittsburgh", "administrative and political divisions", "pittsburgh metropolitan area", "allegheny (pittsburgh, pa.)", "landowners", "allegheny county (pa.)", "maps", "business enterprises", "cities and towns", "directories", "mc