ldsby, frank s.", "h.s. crocker & co"], "date": "1881", "dates": ["1881"], "description": ["Color lithograph map showing mining claim names and locations in the Tombstone mining district, Cochise County. \"Entered according to an Act of Congress, in the year 1881, by Kelleher Peel & Ingoldsby, in the Office of the Librarian of Congress at Washington.\" \"Authorities: S.M. Allis, H.G. Howe, H.B. Maxson, J.G. Manning ... United States Deputy Mineral Surveyors ...\" Oriented with north toward the upper right. Insets: California District -- Cochise County -- Turquoise District -- Plat of Hartford District -- Plat of Warren District. Includes illustrations of \"City of Tombstone\" and prominent buildings. Available also through the Library of Congress Web site as a raster image. 2 copies: Copy 2 mounted on 4 separate sheets (cloth backing)"], "digitized": true, "extract_timestamp": "2026-04-29T15:39:07.708Z", "group": ["gmd.mar", "catalog-split-00", "catalog", "general-maps", "main-catalog-split-00"], "hassegments": false, "id": "http://www.loc.gov/item/2012586611/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd433/g4333/g4333c/ct003583.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd433/g4333/g4333c/ct003583.gif#h=150&w=205", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd433:g4333:g4333c:ct003583/full/pct:12.5/0/default.jpg#h=1685&w=2299", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd433:g4333:g4333c:ct003583/full/pct:25/0/default.jpg#h=3370&w=4599"], "index": 4, "language": ["english"], "location": ["united states", "arizona", "tombstone", "cochise county"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2012-05-07t10:07:06", "2025-06-07t05:00:38.400000", "2012586611", "sheet"], "online_format": ["image"], "original_format": ["map"], "other_title": ["Cochise Co., Arizona Ter"], "partof": ["additional conservation and environment cartographic items", "catalog", "geography and map