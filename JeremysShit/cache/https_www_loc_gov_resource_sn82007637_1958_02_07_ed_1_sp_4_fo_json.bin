["image"], "original_format": ["photo, print, drawing"], "partof": ["prints and photographs division", "farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "american memory", "catalog"], "score": 32.178528, "shelf_id": "LC-USW3- 016490-C [P&P]", "site": ["pictures", "catalog"], "subject": ["toledo", "ohio", "lucas county", "safety film negatives", "united states"], "timestamp": "2022-04-26T06:46:26.183Z", "title": "[Untitled photo, possibly related to: Toledo, Ohio. Ward Canaday, a millionaire]", "url": "https://www.loc.gov/item/2017844695/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_goyle_ver01/data/sn82007637/00516993832/1958020701/0156.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_goyle_ver01:data:sn82007637:00516993832:1958020701:0153/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ohi/batch_ohi_goyle_ver01/data/sn82007637/00516993832/1958020701/0156.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn82007637/1958-02-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_goyle_ver01/data/sn82007637/00516993832/1958020701/0156.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_goyle_ver01:data:sn82007637:00516993832:1958020701:0153/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ohi/batch_ohi_goyle_ver01/data/sn82007637/00516993832/1958020701/0156.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn82007637/1958-02-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ohi/batch_ohi_goyle_ver01/data/sn82007637/00516993832/1958020701/0156.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82007637/1958-02-07/ed-1/?sp=4"], "batch": ["ohi_goyle_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/ohio/", "2/united states/ohio/lucas/", "3/united states/ohio/lucas/toledo/"], "contributor": ["ohio history connection, columbus, oh"], "date": "1958-02-07", "dates": ["1958-02-07"], "description": ["THE UNION JOURNALS Editorial Page Friday February 71958 Time For Action 0 NE OF THE SHAMES of Ohio is its failure to establish decent minimum wage rates for women and minors who work in the laundry dry cleaning and re tail store trades The minimum of 27 12 cents an hour for the laundry trade has been unchanged since 1934 The minimum of 35 cents an hour for the dry cleaning trade has been unchanged since 1935 There is no mini mum for the retail trade Petitions requesting the appointment of wage boards to establish more realistic minimums in the laundry and dry clean ing trades were filed last Friday with Di rector Hugh D Wait of the Ohio Indus trial Relations Board by the Consumers League of Ohio They also requested a study of wage rates in retail trades Political pressures from employer groups has kept the minimum rates for women and minor workers at their pres ent shameful and disgraceful levels for more than 20 years Ohio should have taken the lead long before this in making certain that women and children are being paid decent wages and are not being forced to work 50 and 60 hours"], "digitized": true, "extract_timestamp": "2025-04-13T08:03:35.315Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82007637/1958-02-07/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_goyle_ver01:data:sn82007637:00516993832:1958020701:0156/full/pct:6.25/0/default.jpg#h=419&w=304", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_goyle_ver01:data:sn82007637:00516993832:1958020701:0156/full/pct:12.5/0/default.jpg#h=838&w=608", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_goyle_ver01/data/sn82007637/00516993832/1958020701/0156.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["toledo", "lucas", "lucas county", "ohio", "united states"], "location_city": ["toledo"], "location_country": ["united states"], "location_county": ["lucas"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "3", "0000000004", "9", "6", "8", "1", "sn82007637", "5"], "number_edition": ["1"], "number_lccn": ["sn82007637"], "number_page": ["0000000004"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "3", "8", "3", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["toledo union journal (toledo, ohio) 1942-current", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["toledo union journal (toledo, ohio) 1942-current"], "publication_frequency": ["biweekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn82007637/1958-02-07/ed-1/?sp=4"}], "segmentof": ["http://www.loc.gov/resource/sn82007637/1958-02-07/ed-1/"], "shelf_id": "4", "site": ["chroniclingamerica"], "subject": ["toledo", "international union, united automobile workers of america (cio)", "toledo (ohio)", "lucas", "local 12 (toledo, ohio)", "lucas county (ohio)", "labor unions", "ohio", "newspapers", "lucas county", "united states"], "timestamp": "2025-04-13T10:34:03.111Z", "title": "Image 4 of Toledo union journal (Toledo, Ohio), February 