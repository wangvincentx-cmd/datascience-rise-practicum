loc.gov/storage-services/service/pnp/det/4a20000/4a27000/4a27600/4a27626t.gif#h=105&w=150", "https://tile.loc.gov/storage-services/service/pnp/det/4a20000/4a27000/4a27600/4a27626r.jpg#h=471&w=640", "https://tile.loc.gov/storage-services/service/pnp/det/4a20000/4a27000/4a27600/4a27626v.jpg#h=754&w=1024"], "index": 4, "language": ["english"], "location": ["minneapolis", "minnesota", "united states", "saint paul"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2017-11-03t12:17:44", "2016818115", "http://www.loc.gov/item/20126100", "http://www.loc.gov/item/det1994024076/pp", "http://www.loc.gov/item/2016818115"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "prints & photographs online catalog (library of congress)", "prints and photographs division", "american memory", "detroit publishing company"], "score": 33.26546, "shelf_id": "LC-D418-71236 [P&P]", "site": ["pictures", "catalog"], "subject": ["minneapolis", "minnesota", "dry plate negatives", "saint paul", "reproductions", "united states", "rivers", "railroad bridges"], "timestamp": "2022-04-25T08:50:36.958Z", "title": "Short line bridge between St. Paul and Minneapolis", "url": "https://www.loc.gov/item/2016818115/"}, {"access_restricted": true, "aka": ["https://www.loc.gov/pictures/item/86707352/", "http://www.loc.gov/item/86707352/", "http://www.loc.gov/pictures/item/86707352/", "https://www.loc.gov/pictures/collection/coll/item/86707352/", "http://www.loc.gov/pictures/collection/coll/item/86707352/", "http://lccn.loc.gov/86707352"], "campaigns": [], "contributor": ["frances benjamin johnston photograph collection (library of congress)", "johnston, frances benjamin"], "date": "1903", "dates": ["1903"], "description": ["301 photoprints : 257 gelatin silver, 44 cyanotype ; 23 x 28 cm. or smaller. | State fair in Saint Paul, Minn., including parents and children, booths, rides, and health exhibit. Locomotive; steamboat with people standing on landing; group attending unidentified ceremony; black women posed for portrait; church in Saint Paul. Horse farm, arches in Palo Alto, Calif.--probably on Stanford University campus. Landscapes and train at Mt. Tamalpais, Calif.; sea lions on beach, dwellings, and store windows in Calif. San Francisco Chinatown. Boats on Columbia River, Washington. Yellowstone National Park landscapes, including geysers, rivers, canyons, frost-covered trees; Park tour showing teamsters, wagons, stagecoaches, camping party, tourists--including Johnston--and guides."], "digitized": true, "extract_timestamp": "2026-03-07T13:35:42.285Z", "group": ["coll", "catalog-split-06", "catalog", "groups-of-images", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/86707352/", "image_url": ["https://www.loc.gov/static/images/original-format/group-of-images.svg"], "index": 5, "language": ["english"], "location": ["minnesota", "chinatown", "wyoming", "washington", "mount", "saint paul", "columbia river", "yellowstone national park", "california", "united states", "tamalpais", "san francisco", "palo alto"], "mime_type": ["image/jpg"], "number": ["http://www.loc.gov/item/11510945", "86707352", "2021-10-19t13:14:32", "http://www.loc.gov/item/86707352"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints and photographs division", "catalog", "groups of images (lots)", "lot 11739"], "score": 32.762306, "shelf_id": "LOT 11739 (G) [P&P]", "site": ["pictures", "catalog"], "subject": ["minnesota", "sea lions", "gelatin silver prints", "stanford university", "yellowstone national park", "churches", "columbia river", "rivers", "tourism", "vehicles", "families", "educational facilities", "cyanotypes", "portrait photographs", "saint paul", "ethnic neighborhoods", "canyons", "boats", "geysers", "women", "california", "group portraits", "landscape photographs", "arches", "washington (state)", "waterfalls", "palo alto (calif.)", "horse farms", "fairs", "johnston, frances benjamin", "streets", "tamalpais, mount (calif.)", "window displays", "san francisco", "saint paul (minn.)", "health education", "railroads", "national parks & reserves", "universities & colleges", "camping", "wyoming", "railroad locomotives", "united states", "chinatown (san francisco, calif.)", "beaches", "palo alto", "african americans"], "timestamp": "2026-03-07T14:22:00.661Z", "title": "Frances Benjamin Johnston's trip to the western United States", "type": ["still image"], "url": "https://www.loc.gov/item/86707352/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2002624046", "http://www.loc.gov/item/2002624046/", "https://search.catalog.loc.gov/instances/189dcde6-b2dd-5e54-b2d3-9543e2b4a466", "https://hdl.loc.gov/loc.gmd/g4144m.ct000810", "http://www.loc.gov/resource/g4144m.ct000810/"], "campaigns": [], "contributor": ["blodgett & moore"], "date": "1897", "dates": ["1897"], "description": ["From Blodgett & Moore: The pathfinder cyclists map and guide book. Minneapolis, c1897. Available also through the Library of Congress web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:58.800Z", "group": ["gmd.mar", "catalog-split-10", "catalog", "general-maps", "main-catalog-split-10"], "hassegments": false, "id": "http://www.loc.gov/item/2002624046/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd414/g4144/g4144m/ct000810.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd414/g4144/g4144m/ct000810.gif#h=150&w=183", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd414:g4144:g4144m:ct000810/full/pct:12.5/0/default.jpg#h=529&w=646", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd414:g4144:g4144m:ct000810/full/pct:25/0/default.jpg#h=1058&w=1292"], "index": 6, "language": ["english"], "location": ["minneapolis", "minnesota", "united states", "saint paul"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-06t19:41:48.200000", "2005-07-25t10:54:19", "2002624046", "sheet"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "cities and towns", "catalog"], "score": 31.584732, "shelf_id": "G4144.M5P1 1897 .B5 TIL", "site": ["catalog"], "subject": ["minneapolis", "minnesota", "transportation", "maps", "saint paul", "united states"], "timestamp": "2026-04-29T15:44:13.233Z", "title": "Outline map of Minneapolis and St. Paul", "type": ["cartographic"], "url": "https://www.loc.gov/item/2002624046/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/mss844300001/", "https://hdl.loc.gov/loc.mss/ms003030.mss84430dig.142902", "http://www.loc.gov/resource/mss84430dig.142902/", "http://www.loc.gov/item/mss84430dig.142902/", "http://lccn.loc.gov/mm99084430", "http://www.loc.gov/item/mm99084430/", "https://search.catalog.loc.gov/instances/43402ad7-e790-501e-bf86-d934ab9f9640", "http://blackmun.wustl.edu/introduction.html", "https://hdl.loc.gov/loc.mss/ms003030.mss84430.int"], "campaigns": [], "contributor": ["blackmun, harry a. (harry andrew)", "koh, harold hongju"], "date": "1997", "dates": ["1997"], "description": ["Correspondence, appointment books, memoranda, case files, legal papers, subject files, speeches, and writings chiefly documenting Blackmun's career as associate justice of the U.S. Supreme Court (1970-1994) and as judge of the U.S. Court of Appeals (8th Circuit). Also includes material relating to his boyhood in Saint Paul, Minn., his undergraduate and law school studies at Harvard University, his private law practice in Minneapolis, Minn., his work as counsel for the Mayo Clinic and Mayo Association, and his association with the Advisory Committee on Judicial Activities for the Judicial Conference of the United States, Aspen Institute, and the United Methodist Church. U.S. Court of Appeals case topics include taxation, civil rights, and labor, administrative, constitutional, and criminal law. Documents Blackmun's decision to declare the use of corporal punishment in prisons unconstitutional. Subjects in the Supreme Court files include abortion rights, adoption, research use of fetal tissues, reverse discrimination, and legal issues stemming from the Watergate affair. Correspondents include Robert A. Bezoier, Myron H. Bright, Warren E. Burger, Daniel C. Connolly, James Russell Eckman, Felix Frankfurter, Erwin N. Griswold, Henry Earnest Halladay, Russell C. Jewell, A. M. Keith, Robert E. Merry, Roy M. Mersky, Norval Morris, John Bell Sanborn, James F. Simon, Scott Turow, and Charles Alan Wright."], "digitized": true, "extract_timestamp": "2026-06-29T12:08:51.204Z", "group": ["mssadhoc", "catalog-split-15", "catalog", "mss-nonmarc-adhoc", "main-catalog-split-15"], "hassegments": true, "id": "http://www.loc.gov/item/mm99084430/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:mss:mss84430dig:mss84430dig:1429:02:0001/full/pct:25/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:mss:mss84430dig:mss84430dig:1429:02:0001/full/pct:25/0/default.jpg#h=320&w=250", "https://tile.loc.gov/image-services/iiif/service:mss:mss84430dig:mss84430dig:1429:02:0001/full/pct:50/0/default.jpg#h=640&w=500", "https://tile.loc.gov/image-services/iiif/service:mss:mss84430dig:mss84430dig:1429:02:0001/full/pct:100/0/default.jpg#h=1280&w=1000"], "index": 7, "language": ["english"], "location": ["minneapolis", "minnesota", "united states", "saint paul"], "mime_type": ["image/jpeg", "image/jp2", "application/pdf", "application/xml", "image/tiff", "text/plain"], "number": ["mm99084430", "2025-09-12t17:25:55.100000"], "online_format": ["image", "pdf", "online text"], "original_format": ["book", "manuscript/mixed material", "collection"], "partof": ["harry a. blackmun papers: supreme court file, 1918-1999", "catalog", "manuscript division", "harry a. blackmun papers"], "score": 31.504124, "shelf_id": "series: Supreme Court File, 1918-1999 Box: Box 1429", "site": ["catalog"], "subject": 