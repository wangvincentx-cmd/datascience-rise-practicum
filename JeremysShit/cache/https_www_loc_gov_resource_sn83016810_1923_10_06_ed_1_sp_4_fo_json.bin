neapolis", "minnesota", "aliens", "saint paul", "united states", "education"], "timestamp": "2025-08-11T10:25:38.958Z", "title": "Nationality and school progress; a study in Americanization,", "type": ["text"], "url": "https://www.loc.gov/item/22002226/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn83016810/00383348158/1923100601/0161.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_limbo_ver01:data:sn83016810:00383348158:1923100601:0158/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn83016810/00383348158/1923100601/0161.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn83016810/1923-10-06/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn83016810/00383348158/1923100601/0161.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_limbo_ver01:data:sn83016810:00383348158:1923100601:0158/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn83016810/00383348158/1923100601/0161.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn83016810/1923-10-06/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn83016810/00383348158/1923100601/0161.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83016810/1923-10-06/ed-1/?sp=4"], "batch": ["mnhi_limbo_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/minnesota/", "2/united states/minnesota/ramsey/", "3/united states/minnesota/ramsey/saint paul/", "2/united states/minnesota/hennepin/", "3/united states/minnesota/hennepin/minneapolis/", "1/united states/illinois/", "2/united states/illinois/cook/", "3/united states/illinois/cook/chicago/"], "contributor": ["minnesota historical society; saint paul, mn"], "date": "1923-10-06", "dates": ["1923-10-06"], "description": ["Dont forget the Banquet De Luxe at the Arcade Dancing Palace Min neapolis Monday evening October 15 1923 In Honor of the Shuffle Along Co Dont forget the Universal Prom at the Lexington Coliseum St Paul Monday evening October 22 1923 In Honor of the Shuffle Along Co Dorft forget the Universal Prom at the Lexington Coliseum St Paul Monday evening October 22 1923 In Honor of the Shuffl Along Co The problem of the ages began in the garden of Eden Do not think there is anything new about them now except in their incidpental and superficial features The humanity priblem began in the garden of Eden and has continued to this day The theological problem began in the garden of Eden and has continued to this day ONE HEAD By E W Giles A twoheaded anything in nature is a monstrosity A twoheaded anything otherwise is a calamity How many institutions I have seen fail possibly because of having two or more equal heads with no one ac tually the head One head is head tw heads equal half a head and three heads equal no head at all If you wish your institution to suc ceed give"], "digitized": true, "extract_timestamp": "2024-01-04T03:50:42.724Z", "group": ["ndnp/mnhi", "minnesota-historical-society-saint-paul-mn-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83016810/1923-10-06/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_limbo_ver01:data:sn83016810:00383348158:1923100601:0161/full/pct:3.125/0/default.jpg#h=329&w=253", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_limbo_ver01:data:sn83016810:00383348158:1923100601:0161/full/pct:6.25/0/default.jpg#h=658&w=506", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn83016810/00383348158/1923100601/0161.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["minneapolis", "illinois", "ramsey", "minnesota", "hennepin", "saint paul", "cook", "united states", "chicago"], "location_city": ["saint paul", "minneapolis", "chicago"], "location_country": ["united states"], "location_county": ["ramsey", "hennepin", "cook"], "location_state": ["minnesota", "illinois"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["sn83016810", "0000000004", "3", "1", "8", "4", "0", "5"], "number_edition": ["1"], "number_lccn": ["sn83016810"], "number_page": ["0000000004"], "number_reel": ["0", "0", "3", "8", "3", "3", "4", "8", "1", "5", "8"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["National Afro-American newspaper"], "partof": ["serial and government publications division", "chronicling america", "the appeal (saint paul, minn. ; minneapolis, minn. ; chicago, ill.) 1889-19??"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the appeal (saint paul, minn. ; minneapolis, minn. ; chicago, ill.) 1889-19??"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn83016810/1923-10-06/ed-1/?sp=4"}], "segmentof": ["http://www.loc.gov/resource/sn83016810/1923-10-06/ed-1/"], "shelf_id": "4", "site": ["chroniclingamerica"], "subject": ["minneapolis", "illinois", "minnesota", "ramsey", "minneapolis (minn.)", "hennepin", "saint paul", "newspapers", "saint paul (minn.)", "united states", "cook", "african american", "african american newspapers", "chicago (ill.)", "chicago", "african americans