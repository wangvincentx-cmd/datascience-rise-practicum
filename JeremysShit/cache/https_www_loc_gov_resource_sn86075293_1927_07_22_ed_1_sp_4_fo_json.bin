 "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075293/00340581908/1927072201/0229.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075293:00340581908:1927072201:0226/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075293/00340581908/1927072201/0229.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86075293/1927-07-22/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075293/00340581908/1927072201/0229.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075293:00340581908:1927072201:0226/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075293/00340581908/1927072201/0229.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86075293/1927-07-22/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075293/00340581908/1927072201/0229.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86075293/1927-07-22/ed-1/?sp=4"], "batch": ["mthi_horsetail_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/sheridan/", "3/united states/montana/sheridan/plentywood/"], "contributor": ["montana historical society; helena, mt"], "date": "1927-07-22", "dates": ["1927-07-22"], "description": ["Jlnttyfaoob \u00eeferalb PUBLISHED EVERY FRIDAY C S NELSON Editor and Publisher Entered as ecoodclaa matter Novemtar 13 108 at the poat office at Plentywood Montana under the Act of March J 187M TermsIn Advance per year 200 Advertising Rales very reasonable will be furnished upon application The Road Hog The road hog season is herein fact we are in the midst of itand one is apt to meet most any variety of this most dangerous of modern wild animals on the streets or highways especially of an eve ning When confronted by a road hog two courses of proceedure are open to the mo torist he can hold his half of the road and smash it out with the best or give it gangway by taking to the fields or the ditch as the case may be In a majority of eases it is the ditch Either course however is nerverack ing and often productive of extensive damage to both car and feelings And not only are the feelings likely to be hurt but there is always the possibility of breaking a few bones at inconvenient places Road hogs may be divided into two principal classesthe deliberate ones who escape"], "digitized": true, "extract_timestamp": "2023-07-03T13:47:34.176Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075293/1927-07-22/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075293:00340581908:1927072201:0229/full/pct:6.25/0/default.jpg#h=480&w=326", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_horsetail_ver01:data:sn86075293:00340581908:1927072201:0229/full/pct:12.5/0/default.jpg#h=961&w=653", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_horsetail_ver01/data/sn86075293/00340581908/1927072201/0229.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["united states", "montana", "plentywood", "sheridan"], "location_city": ["plentywood"], "location_country": ["united states"], "location_county": ["