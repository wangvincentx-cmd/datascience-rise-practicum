tion": ["united states", "montana", "plentywood", "sheridan"], "number": ["2026-04-13t21:30:13", "online resource", "862979351", "2332-9777", "2013271996"], "original_format": ["newspaper"], "partof": ["the producers news (plentywood, sheridan county, montana) 1918-1937 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 41.88582, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["plentywood (mont.)", "plentywood", "newspapers", "sheridan", "united states", "montana"], "timestamp": "2026-05-26T20:49:31.434Z", "title": "The producers news", "type": ["title"], "url": "https://www.loc.gov/item/2013271996/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2022270587/"], "campaigns": [], "date": "1908", "dates": ["[1908 TO 9999]"], "description": ["Weekly Began in 1908. Description based on: Vol. 19, No. 15 (January 7, 1927); title from masthead (Chroniclingamerica.loc.gov, viewed March 25, 2022). Latest issue consulted: Volume 29, No. 19 (December 30, 1937) (Chroniclingamerica.loc.gov, viewed March 25, 2022)."], "digitized": true, "extract_timestamp": "2026-05-19T21:38:02.758Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2022270587/", "image_url": [], "index": 6, "language": ["english"], "location": ["united states", "montana", "plentywood", "sheridan"], "number": ["2831-4603", "2026-04-13t21:30:13", "online resource", "1305505523", "2022270587"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "plentywood herald (plentywood, sheridan county, montana) 1908-current [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 41.88582, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["plentywood (mont.)", "plentywood", "newspapers", "sheridan", "unite