ongress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.45633, "shard": "04", "shelf_id": "sn84026912, 1923-09-05, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/scu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["south carolina", "pickens (s.c.)", "pickens", "pickens county", "oconee county", "walhalla", "oconee", "newspapers", "united states", "pickens county (s.c.)", "oconee county (s.c.)", "walhalla (s.c.)"], "subject_headings": ["Pickens (S.C.)--Newspapers", "Pickens County (S.C.)--Newspapers", "Walhalla (S.C.)--Newspapers", "Oconee County (S.C.)--Newspapers", "South Carolina--Oconee County", "South Carolina--Pickens", "South Carolina--Pickens County", "South Carolina--Walhalla", "United States--South Carolina--Oconee--Walhalla", "United States--South Carolina--Pickens--Pickens"], "subjects": [{"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"oconee": "https://www.loc.gov/search/?fa=subject:oconee&fo=json"}, {"oconee county": "https://www.loc.gov/search/?fa=subject:oconee+county&fo=json"}, {"oconee county (s.c.)": "https://www.loc.gov/search/?fa=subject:oconee+county+%28s.c.%29&fo=json"}, {"pickens": "https://www.loc.gov/search/?fa=subject:pickens&fo=json"}, {"pickens (s.c.)": "https://www.loc.gov/search/?fa=subject:pickens+%28s.c.%29&fo=json"}, {"pickens county": "https://www.loc.gov/search/?fa=subject:pickens+county&fo=json"}, {"pickens county (s.c.)": "https://www.loc.gov/search/?fa=subject:pickens+county+%28s.c.%29&fo=json"}, {"south carolina": "https://www.loc.gov/search/?fa=subject:south+carolina&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:u