/1958041701/0081.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_greenville_ver01:data:sn95047212:00529042334:1958041701:0073/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/fu/batch_fu_greenville_ver01/data/sn95047212/00529042334/1958041701/0081.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn95047212/1958-04-17/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/fu/batch_fu_greenville_ver01/data/sn95047212/00529042334/1958041701/0081.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn95047212/1958-04-17/ed-1/?sp=9"], "batch": ["fu_greenville_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/florida/", "2/united states/florida/dade/", "3/united states/florida/dade/miami/"], "contributor": ["university of florida"], "date": "1958-04-17", "dates": ["1958-04-17"], "description": ["FORTIETH ANNIVERSARY EDITION Cab or Citizen Vol XXXXNo 1 Towle Talks by Chas F Towle Forty Years In Retrospect For the benefit of those readers who may not have seen our column of February 13th relative to the founding of the labor paper in this area we are reprinting our column Forty Years in Retro Central shared the quarters of Miami Carpenters Local Union No 993 with other unions existing here at the time In fact it was a typical labor hangout where anything could happenand usually did And of all the oldtimers left if any Ill bet a plugged nickel A D Cain was present at this same meeting Well anyway this particular night E K Dahlman led off with a sizzling remark about the activities of the unions and their mem bership being hampered because they were not getting much pub licity in the Herald and the Daily Metropolis now the Daily News and where have we heard that plaint before and he thought it would be a good idea for Central to start a paper of its own Walter Hoyt a member of the Teamsters Union and J M Sand erson a union painter added their bit"], "digitized": true, "extract_timestamp": "2026-01-27T17:02:00.860Z", "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn95047212/1958-04-17/ed-1/?sp=9", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_greenville_ver01:data:sn95047212:00529042334:1958041701:0081/full/pct:3.125/0/default.jpg#h=286&w=195", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_greenville_ver01:data:sn95047212:00529042334:1958041701:0081/full/pct:6.25/0/default.jpg#h=573&w=390", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_greenville_ver01:data:sn95047212:00529042334:1958041701:0081/full/pct:12.5/0/default.jpg#h=1146&w=780", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_greenville_ver01/data/sn95047212/00529042334/1958041701/0081.xml&format=alto_xml"], "index": 9, "language": ["english"], "location": ["united states", "miami", "dade", "dade county", "florida"], "location_city": ["miami"], "location_country": ["united states"], "location_county": ["dade"], "location_state": ["florida"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000009", "5", "3", "0", "2", "sn95047212", "1", "4", "9"], "number_edition": ["1"], "number_lccn": ["sn95047212"], "number_page": ["0000000009"], "number_reel": ["0", "0", "5", "2", "9", "0", "4", "2", "3", "3", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "labor citizen (miami, fla.) 1956-19??", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["labor cit