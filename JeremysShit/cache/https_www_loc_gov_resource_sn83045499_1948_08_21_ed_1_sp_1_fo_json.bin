"url": "https://www.loc.gov/item/2018218604/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218606/"], "campaigns": [], "date": "1921", "dates": ["[1921 TO 1931]"], "description": ["Weekly Began with vol. 23, no. 33 (July 9, 1921); ceased November 20, 1931. Description based on: Vol. 23, no. 33 (July 9, 1921); title from masthead (Chroniclingamerica.loc.gov, viewed February 21, 2018). Latest issue consulted: Vol. 25 (December 30, 1922) (Chroniclingamerica.loc.gov, viewed February 21, 2018). Stroller's weekly"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:41.529Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218606/", "image_url": [], "index": 3, "language": ["english"], "location": ["juneau", "alaska", "united states", "douglas"], "number": ["2018218605", "online resource", "2576-9758", "1023801180", "2018218606", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the stroller's weekly and douglas island news (juneau, alaska) 1921-1931 [online resource]"], "publication_frequency": ["weekly"], "score": 31.731373, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "juneau (alaska)", "united states", "douglas", "douglas (juneau, alaska)", "juneau", "alaska", "douglas (juneau)"], "timestamp": "2026-05-26T20:55:54.213Z", "title": "The Stroller's weekly and Douglas Island news", "type": ["title"], "url": "https://www.loc.gov/item/2018218606/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021270909/"], "campaigns": [], "date": "1926", "dates": ["[1926 TO 1964]"], "description": ["Daily (except Saturday) Began with vol. XXIX, no. 4346 (December 8, 1926); ceased July 21, 1964. Supplements accompany some numbers. J bird was issued with the Daily Alaska empire from <1932-May 16, 1936>, with separate enumeration. It then resumed publishing on its own September 25, 1936. Vol. XXIX, No. 4346 (December 8, 1926); title from masthead (Chroniclingamerica.loc.gov, viewed January 3, 2022). Vol. XXX, No. 4572 (August 31, 1927) (Chroniclingamerica.loc.gov, viewed January 3, 2022). Juneau Alaska empire"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:01.956Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021270909/", "image_url": [], "index": 4, "language": ["english"], "location": ["juneau", "alaska", "united states"], "number": ["online resource", "1290682950", "2771-2656", "2018218604", "2021270909", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the daily alaska empire (juneau, alaska) 1926-1964 [online resource]"], "publication_frequency": ["daily"], "score": 31.731373, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "juneau (alaska)", "united states", "juneau", "alaska"], "timestamp": "2026-05-26T21:03:28.349Z", "title": "The daily Alaska empire", "type": ["title"], "url": "https://www.loc.gov/item/2021270909/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270612/"], "campaigns": [], "contributor": ["alaska native brotherhood"], "date": "1923", "dates": ["[1923 TO 1932]"], "description": ["Monthly Print began with vol. 1, no. 1 (February 15, 1923); ceased in 1932? Published in Juneau, Alaska, February-April, 1923; Ketchikan, Alaska, May, 1923-<Apr. 1931>; Petersburg, Alaska <May, 1931-1932>. Issue numbering irregular. Vol. 1, No. 2 (May, 1923); title from caption (Chroniclingamerica.loc.gov, viewed May 8, 2023). Volume 9, No. 5 (September 1932) (Chroniclingamerica.loc.gov, viewed May 8, 2023)."], "digitized": true, "extract_timestamp": "2026-05-19T21:38:09.301Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2023270612/", "image_url": [], "index": 5, "language": ["english"], "location": ["petersburg", "united states", "ketchikan", "juneau", "alaska"], "number": ["1378518132", "2026-04-13t21:30:13", "2023270612", "2837-6269", "online resource"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the alaska fisherman (ketchikan, alaska;petersburg, alaska) 1923-1932 [online resource]"], "publication_frequency": ["monthly"], "score": 31.731373, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["petersburg", "newspapers", "ketchikan (alaska)", "juneau (alaska)", "united states", "ketchikan", "juneau", "petersburg (alaska)", "alaska", "indians of north america"], "timestamp": "2026-05-26T21:08:46.277Z", "title": "The Alaska fisherman", "type": ["title"], "url": "https://www.loc.gov/item/2023270612/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270652/"], "campaigns": [], "contributor": ["juneau high school (juneau, alaska)", "juneau-douglas high school (juneau, alaska)"], "date": "1923", "dates": ["[1923 TO 1999]"], "description": ["Biweekly, <1925-1936> Print began in 1923. J bird was issued with the Daily Alaska empire from <1932-May 16, 1936>, with separate enumeration. It then resumed publishing on its own September 25, 1936. Volume V, Number I (December 17, 1932); title from masthead (Chroniclingamerica.loc.gov, viewed August 2, 2023). Vol. VIII, No. 33 (May 16, 1933) (Chroniclingamerica.loc.gov, viewed August 2, 2023)."], "digitized": true, "extract_timestamp": "2026-05-19T21:38:10.725Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2023270652/", "image_url": [], "index": 6, "language": ["english"], "location": ["juneau", "alaska", "united states"], "number": ["online resource", "2023270652", "1391997256", "2993-