: ["english"], "location": ["tucson", "united states", "arizona", "pima county", "nogales"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["77692954", "2011-11-28t13:39:51", "2025-06-07t18:32:05.200000"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "county landownership maps", "geography and map division", "cultural landscapes"], "score": 32.59222, "shelf_id": "G4333.P4 1893 .R6 G4333.P4 1893 .R6 G4333.P4 1893 .R6", "site": ["catalog"], "subject": ["tucson (ariz.)", "tucson", "united states", "arizona", "nogales (ariz.)", "maps", "pima county", "pima county (ariz.)", "nogales"], "timestamp": "2026-04-29T16:18:09.713Z", "title": "Official map of Pima County, Arizona", "type": ["cartographic"], "url": "https://www.loc.gov/item/77692954/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2020655666", "http://www.loc.gov/item/2020655666/", "https://hdl.loc.gov/loc.afc/afc2015028.afc2015028_03002_sr01", "http://www.loc.gov/resource/afc2015028.afc2015028_03002_sr01/", "http://www.loc.gov/resource/afc2015028.afc2015028_03002_ms02/"], "campaigns": [], "contributor": ["occupational folklife project", "hartmann, nic", "thomas, charlie (charles, sr.)"], "date": "2015", "dates": ["2015"], "description": ["Charlie Thomas of Thomas Produce in Tucson, Arizona, talks about his life in the fresh produce industry of both North Carolina and Arizona. He discusses his father's and family's involvement in produce industry; handling different vegetables; determining ripeness; changes in industry; the impact of Wal-Mart; growing areas in Mexico; Greco-Mexican connections in produce industry; winter produce and Florida; cash vs. credit; the local industry in Arizona; competition from elsewhere; and etc."], "digitized": true, "extract_timestamp": "2025-08-14T14:52:29.355Z", "group": ["afc/2015028", "catalog-split-06", "catalog", "produce-workers", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/2020655666/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:afc:afc2015028:afc2015028_03002:afc2015028_03002_ms02/full/pct:25/0/default.jpg"], "index": 9, "language": ["english"], "location": ["arizona", "tucson", "nogales"], "mime_type": ["audio/mp3", "application/pdf"], "number": ["2021-01-11t12:50:47", "online resource", "2020655666"], "online_format": ["audio", "pdf"], "original_format": ["sound recording"], "partof": ["occupational folklife project", "american folklife center", "catalog", "fresh produce workers in arizona: archie green fellows project, 2015-2016"], "score": 31.482609, "shelf_id": "http://lccn.loc.gov/2020655666", "site": ["catalog"], "subject": ["quality of work life", "social life and customs", "interviews", "personal narratives", "arizona", "work environment", "nogales", "family-owned business enterprises", "work ethic", "charles, sr.)", "occupational training", "quality", "oral histories", "thomas, charlie", "folklore", "sound recordings", "job satisfaction", "farm produce", "nogales (ariz.)", "produce trade"], "timestamp": "2025-08-14T14:53:11.604Z", "title": "Charles \"Charlie\" Thomas, Sr. interview conducted by Nic Hartmann, 2015-08-25", "type": ["sound recording-nonmusical"], "url": "https://www.loc.gov/item/2020655666/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2020655667", "http://www.loc.gov/item/2020655667/", "https://hdl.loc.gov/loc.afc/afc2015028.afc2015028_03021_sr01", "http://www.loc.gov/resource/afc2015028.afc2015028_03021_sr01/", "http://www.loc.gov/resource/afc2015028.afc2015028_03021_ms02/"], "campaigns": [], "contributor": ["occupational folklife project", "hartmann, nic", "cathey, jim"], "date": "2015", "dates": ["2015"], "description": ["Interview with Jim Cathey, Sales and Sourcing Manager of Red Sun Farms in Tubac, Arizona. He talks about entering the industry; moving to Arizona; going into the greenhouse industry; McAllen's (TX) rise as a produce center, and Nogales' response; an average work day; the challenges of the industry; labor and labor shortages; the impact of technology on the trade; and etc."], "digitized": true, "extract_timestamp": "2025-08-14T14:52:29.355Z", "group": ["afc/2015028", "catalog-split-07", "catalog", "produce-workers", "main-catalog-split-07"], "hassegments": false, "id": "http://www.loc.gov/item/2020655667/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:afc:afc2015028:afc2015028_03021:afc2015028_03021_ms02/full/pct:25/0/default.jpg"], "index": 10, "language": ["english"], "location": ["arizona", "tubac", "nogales"], "mime_type": ["audio/mp3", "application/pdf"], "number": ["2020655667", "2021-01-11t09:07:35", "online resource"], "online_format": ["audio", "pdf"], "original_format": ["sound recording"], "partof": ["occupational folklife project", "american folklife center", "catalog", "fresh produce workers in arizona: archie green fellows project, 2015-2016"], "score": 31.482609, "shelf_id": "http://lccn.loc.gov/2020655667", "site": ["catalog"], "subject": ["quality", "social life and customs", "oral histories", "interviews", "farm produce", "folklore", "work ethic", "sound recordings", "personal narratives", "arizona", "nogales (ariz.)", "cathey, jim", "produce trade", "work environment", "work-life balance", "nogales"], "timestamp": "2025-08-14T14:53:11.604Z", "title": "Jim Cathey interview conducted by Nic Hartmann, 2015-08-26", "type": ["sound recording-nonmusical"], "url": "https://www.loc.gov/item/2020655667/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_elk_ver01/data/sn85032933/00202192828/1908053001/1197.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_elk_ver01:data:sn85032933:00202192828:1908053001:1193/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_elk_ver01/data/sn85032933/0020219