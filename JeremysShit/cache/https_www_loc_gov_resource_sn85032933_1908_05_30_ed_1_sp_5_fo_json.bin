hise", "santa cruz", "united states", "arizona", "nogales (ariz.)", "pinal", "benson (ariz.)", "santa cruz county (ariz.)", "benson", "santa cruz county", "arizola", "nogales"], "timestamp": "2026-07-18T09:14:06.588Z", "title": "The oasis", "type": ["title"], "url": "https://www.loc.gov/item/sn85032933/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218372/"], "campaigns": [], "date": "1893", "dates": ["[1893 TO 1920]"], "description": ["Weekly Began with vol. I, no. 1 (May 11, 1983); ceased October 9, 1920). Published in Benson, Ariz., May 17, 1894-Nov. 22, 1894; Nogales, Ariz., Dec. 1, 1894-Oct. 9, 1920. \"An authority on mines and mining.\" \"Devoted to Southern Arizona and Sonora.\" Description based on: Vol. I, no. 1 (May 11, 1983); title from masthead (Chroniclingamerica.loc.gov, viewed May 28, 2014). Latest issue consulted: Second series, vol. XX, no. 9 (December 28, 1912) whole no. 1024 (Chroniclingamerica.loc.gov, viewed May 28, 2014)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:26.498Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218372/", "image_url": [], "index": 6, "language": ["english"], "location": ["cochise", "santa cruz", "united states", "arizona", "pinal", "santa cruz county", "benson", "arizola", "nogales"], "number": ["online resource", "2020271978", "2373-2067", "880611939", "2014218372", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["the oasis (arizola, arizona) 1893-1920 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 143.97939, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "cochise", "santa cruz", "united states", "arizona", "nogales (ariz.)", "pinal", "benson (ariz.)", "santa cruz county (ariz.)", "benson", "santa cruz county", "arizola", "nogales"], "times