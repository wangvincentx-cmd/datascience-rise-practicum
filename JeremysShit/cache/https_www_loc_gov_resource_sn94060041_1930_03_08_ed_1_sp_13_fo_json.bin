 the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn94060041, 1930-03-08, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/vi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["accomac", "newspapers", "accomack", "accomac (va.)", "virginia", "united states"], "subject_headings": ["Accomac (Va.)--Newspapers", "Virginia--Accomac", "United States--Virginia--Accomack--Accomac"], "subjects": [{"accomac": "https://www.loc.gov/search/?fa=subject:accomac&fo=json"}, {"accomac (va.)": "https://www.loc.gov/search/?fa=subject:accomac+%28va.%29&fo=json"}, {"accomack": "https://www.loc.gov/search/?fa=subject:accomack&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"virginia": "https://www.loc.gov/search/?fa=subject:virginia&fo=json"}], "timestamp": "2024-02-06T20:20:05.741Z", "title": "Peninsula enterprise (Accomac, Va.), March 8, 1930", "type": ["issue"], "url": "https://www.loc.gov/item/sn94060041/1930-03-08/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn94060041/", "http://lccn.loc.gov/sn94060041"], "batch": ["vi_eterna_ver01"], "campaigns": [], "date": "1881", "description": ["Weekly Vol. 1, no. 1 (June 30, 1881)- Ceased in 1965. Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection. Eastern shore news (Onancock, Va.) (DLC)sn 94060036 (OCoLC