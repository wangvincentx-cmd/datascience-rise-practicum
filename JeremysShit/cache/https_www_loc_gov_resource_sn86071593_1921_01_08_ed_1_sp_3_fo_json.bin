gns": [], "date": "1901", "dates": ["[1901 TO 1906]"], "description": ["Weekly Began with volume XXVI, number 25 (October 25, 1901); ceased with volume XXXI, number 52 (December 28, 1906). Publisher: The Vermont Printing Company, <December 29, 1905>-December 28, 1906. Description based on: Volume XXVI, number 25 (October 25, 1901); title from masthead (Chroniclingamerica.loc.gov, viewed July 13, 2016). Latest issue consulted: Volume XXXI, number 52 (December 28, 1906) (Chroniclingamerica.loc.gov, viewed July 13, 2016). Brattleboro reformer (Brattleboro, Vt. : 1907)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:36.478Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271145/", "image_url": [], "index": 7, "language": ["english"], "location": ["brattleboro", "windham", "united states", "windham county", "vermont"], "number": ["online resource", "2473-4233", "953530614", "2026-04-13t21:30:13", "2016271145"], "original_format": ["newspaper"], "other_title": ["Reformer"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "windham county reformer (brattleboro, vermont) 1901-1906 [online resource]"], "publication_frequency": ["weekly"], "score": 51.624874, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["windham county (vt.)", "brattleboro (vt.)", "brattleboro", "newspapers", "windham", "united states", "windham county", "vermont"], "timestamp": "2026-05-26T20:53:59.281Z", "title": "Windham County reformer", "type": ["title"], "url": "https://www.loc.gov/item/2016271145/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013271929/"], "campaigns": [], "date": "1836", "dates": ["[1836 TO 1853]"], "description": ["Weekly Began in Oct. 1836? Ceased in 1853. Publishers: J. Steen <1837>; G.W. Nichols <1837-1853>. \"One of the earliest champions of woman's rights in the country.\" Hemenway, A. Vt. histor