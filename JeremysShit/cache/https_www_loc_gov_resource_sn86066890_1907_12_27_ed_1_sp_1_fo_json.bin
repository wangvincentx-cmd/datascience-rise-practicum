r is mainly valuable for Lome building and forest reserve laws should be 8o changed as to prevent the indiscriminate slaughter of forests for the benefit of distant communities A String of Rainbow Trout Gunnison and its incomparable trout stream is rapidly becoming a Switzerland of America"], "digitized": true, "extract_timestamp": "2023-12-27T19:39:49.042Z", "group": ["ndnp/cohi", "history-colorado-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86066890/1907-12-27/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_gothic_ver01:data:sn86066890:00513680697:1907122701:0426/full/pct:6.25/0/default.jpg#h=328&w=238", "https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_gothic_ver01:data:sn86066890:00513680697:1907122701:0426/full/pct:12.5/0/default.jpg#h=656&w=477", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/cohi/batch_cohi_gothic_ver01/data/sn86066890/00513680697/1907122701/0426.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["colorado", "gunnison", "united states"], "location_city": ["gunnison"], "location_country": ["united states"], "location_county": ["gunnison"], "location_state": ["colorado"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["sn86066890", "3", "8", "0", "0000000001", "5", "7", "1", "6", "9"], "number_edition": ["1"], "number_lccn": ["sn86066890"], "number_page": ["0000000001"], "number_reel": ["0", "0", "5", "1", "3", "6", "8", "0", "6", "9", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "gunnison news-champion (gunnison, colo.) 1905-1932", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["gunnison news-champion