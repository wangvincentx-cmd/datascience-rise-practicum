 more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.331948, "shard": "06", "shelf_id": "sn91068245, 1908-03-05, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ncu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["clinton (n.c.)", "raleigh (n.c.)", "raleigh", "newspapers", "clinton", "goldsboro", "goldsboro (n.c.)", "united states", "wake", "sampson", "north carolina", "wayne"], "subject_headings": ["Clinton (N.C.)--Newspapers", "Goldsboro (N.C.)--Newspapers", "Raleigh (N.C.)--Newspapers", "North Carolina--Clinton", "North Carolina--Goldsboro", "North Carolina--Raleigh", "United States--North Carolina--Wake--Raleigh", "United States--North Carolina--Wayne--Goldsboro", "United States--North Carolina--Sampson--Clinton"], "subjects": [{"clinton": "https://www.loc.gov/search/?fa=subject:clinton&fo=json"}, {"clinton (n.c.)": "https://www.loc.gov/search/?fa=subject:clinton+%28n.c.%29&fo=json"}, {"goldsboro": "https://www.loc.gov/search/?fa=subject:goldsboro&fo=json"}, {"goldsboro (n.c.)": "https://www.loc.gov/search/?fa=subject:goldsboro+%28n.c.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"north carolina": "https://www.loc.gov/search/?fa=subject:north+carolina&fo=json"}, {"raleigh": "https://www.loc.gov/search/?fa=subject:raleigh&fo=json"}, {"raleigh (n.c.)": "https://www.loc.gov/search/?fa=subject:raleigh+%28n.c.%29&fo=json"}, {"sampson": "https://www.loc.gov/search/?fa=subject:sampson&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"wake": "https://www.loc.gov/search/?fa=subject:wake&fo=json"}, {"wayne": "https://www.loc.gov/s