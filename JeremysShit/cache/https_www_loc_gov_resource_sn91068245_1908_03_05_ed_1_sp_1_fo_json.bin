oc.gov/resource/sn91068245/1908-03-05/ed-1/?sp=1"], "batch": ["ncu_haw_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/north carolina/", "2/united states/north carolina/wake/", "3/united states/north carolina/wake/raleigh/", "2/united states/north carolina/wayne/", "3/united states/north carolina/wayne/goldsboro/", "2/united states/north carolina/sampson/", "3/united states/north carolina/sampson/clinton/"], "contributor": ["university of north carolina at chapel hill library, chapel hill, nc"], "date": "1908-03-05", "dates": ["1908-03-05"], "description": ["CAUCASIANo j VOL XXVI RALEIGH NORTH CAROLINA THURSDAY MARCH 5 J90S NO 8 V i i i I I 4 V 1 at The Indian Court of Which Adams Was Chief Justice Under Fire in Congress In the Speech of Congressman Ste phens is a Statement That It la Charged that the Indian Citizen ship Conrt ot Which Adams Was Chief Justice Was Bribed Sena tor Tillman Offers a Resolution of Inquiry Washington D C March 3 190S Special to The Caucasian The Congressional Record contains a statement that it is charged that Judge Adams Indian Citizenship Court in Indian Territory was bribed That court was created to determine which members of the Choctaw and Chickasaw tribes of Indians were en titled to share in a distribution of many millions of dollars of money and other valuable property belong ing to these tribes The chiefs of these tribes employed a firm of attorneys to try to have stricken from the rolls as many mem lcrs of the tribes as possible so the sunount that would go to each person sharing in the distribution would be increased The attorneys were to have their fee increased in propor tion to the number"], "digitized": true, "extract_timestamp": "2023-08-12T17:35:54.086Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn91068245/1908-03-05/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/se