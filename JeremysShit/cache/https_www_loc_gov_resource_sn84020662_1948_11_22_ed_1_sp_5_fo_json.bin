ieves his adminis tration can avert another depres sion Representative Sam Rayburn speakertobe of the House laid the administration position on the line here before flying back to Texas and a specking engagement a Dallas If a major recession or depres sion should comewhich I do not expectit will not be justified by our economic situation but will be manmade Rayburn told a news conference after"], "digitized": true, "extract_timestamp": "2024-05-22T12:57:43.806Z", "group": ["ndnp/ak", "alaska-state-library-historical-collections-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020662/1948-11-22/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_chinooksalmon_ver03:data:sn84020662:00414185940:1948112201:0637/full/pct:6.25/0/default.jpg#h=423&w=318", "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_chinooksalmon_ver03:data:sn84020662:00414185940:1948112201:0637/full/pct:12.5/0/default.jpg#h=847&w=636", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_chinooksalmon_ver03/data/sn84020662/00414185940/1948112201/0637.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["nome", "alaska", "united states"], "location_city": ["nome"], "location_country": ["united states"], "location_county": ["nome"], "location_state": ["alaska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "9", "8", "0000000005", "sn84020662", "4", "1"], "number_edition": ["1"], "number_lccn": ["sn84020662"], "number_page": ["0000000005"], "number_reel": ["0", "0", "4", "1", "4", "1", "8", "5", "9", "4", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Nugget"], "partof": ["serial and government publications division", "the nome nugget (nome, alaska) 1938-current", "chronicling america"], "partof_collection":