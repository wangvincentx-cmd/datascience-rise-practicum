olfold.ak-051/"], "campaigns": [], "date": "1867", "dates": ["1867"], "description": ["This record covers single maps of Alaska cities and towns, which are not represented in the LC database by separate catalog records. This collection includes single printed maps and blueline prints and photocopies of printed or manuscript single maps and may also include some multi-sheet single maps, plates from atlases, books or periodicals, and printed facsimiles. These maps may also show various subjects, such as recreation and tourism. To request a specific map or for more information, contact a reference librarian in the Geography & Map Division (202) 707-6277 or through the \"Ask a librarian\" link through the Geography & Map Division website https://ask.loc.gov/map-geography/. Title supplied by cataloger. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:17:51.023Z", "group": ["gmd/multimap", "catalog-split-08", "catalog", "multimaps", "main-catalog-split-08"], "hassegments": true, "id": "http://www.loc.gov/item/2022589354/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:ak:-0:51:ak-051:ak-051-02-01/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:ak:-0:51:ak-051:ak-051-02-01/full/pct:12.5/0/default.jpg#h=996&w=1110", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:ak:-0:51:ak-051:ak-051-02-01/full/pct:25/0/default.jpg#h=1993&w=2220"], "index": 7, "language": ["english"], "location": ["nome", "kodiak", "alaska", "united states"], "mime_type": ["image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t11:32:21.500000", "2022589354", "sheet", "2022-12-08t17:53:11"], "online_format": ["image"], "original_format": ["map", "collection"], "other_title": ["Alternate supplied title: Alaska title collection--drawer 51", "Alternate supplied title: Alaska title collection--cities and tow