/resource/sn83016209/1949-06-30/ed-1/?sp=7"], "batch": ["mdu_jackinthepulpit_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/maryland/", "2/united states/maryland/montgomery/", "3/united states/maryland/montgomery/rockville/", "3/united states/maryland/montgomery/gaithersburg/"], "contributor": ["university of maryland, college park, md"], "date": "1949-06-30", "dates": ["1949-06-30"], "description": ["Thursday June 30 1949 SEALED BIDS Sealed bids will be received by the Purchasing Bureau Court House Rockville Md on July 15 1949 at 1100 A M for furnish ing Montgomery County with gar bage and refuse disposal service Further specifications may be ob tAied from the Purchasing Bu reau I G McNAYR 363 Purchasing Agent Order Nisi IN THE CIRCUIT COURT FOR MONTGOMERY COUNTY AS A COURT OF EQUITY No 13616 Equity Charles V Imlay Plaintiff vs Eletta Money William Money et al Defendants ORDERED this 27th day of June A D 1949 by the Circuit Court for Montgomery County as a Court of Equity that the sale made by Donald A DeLashmutt Trustee to Brooke B Jackson and reported in the above entitled cause be ratified and confirmed unless cause to the contrary there of be shown on or before the 25th day of July next Provided a copy of this order be inserted in some newspaper published in said Mont gomery county once in each of three successive weeks before the said 25th day of July 1949 The report states the amount of the sale to be 250000 CLAYTON K WATKINS Clerk of the Circuit Court for"], "digitized": true, "extract_timestamp": "2023-03-01T18:28:41.400Z", "group": ["ndnp/mdu", "university-of-maryland-college-park-college-park-md-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83016209/1949-06-30/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_jackinthepulpit_ver01:data:sn83016209:00383342156:1949063001:0353/full/pct:6.25/0/default.jpg#h=510&w=407", "https://tile.loc.gov/image-servi