ne_dove_ver03/data/sn90053031/00542864655/1908010401/0653.xml&format=alto_xml&full_text=1", "mimetype": "text/plain", "use": "text"}], "pagination": {"current": 2, "first": "https://www.loc.gov/resource/sn90053031/1908-01-04/ed-1/?fo=json&sp=1", "from": 2, "last": "https://www.loc.gov/resource/sn90053031/1908-01-04/ed-1/?fo=json&sp=4", "next": "https://www.loc.gov/resource/sn90053031/1908-01-04/ed-1/?fo=json&sp=3", "of": 8, "page_list": [{"number": 1, "url": "https://www.loc.gov/resource/sn90053031/1908-01-04/ed-1/?fo=json&sp=1"}, {"number": 2, "url": null}, {"number": 3, "url": "https://www.loc.gov/resource/sn90053031/1908-01-04/ed-1/?fo=json&sp=3"}, {"number": 4, "url": "https://www.loc.gov/resource/sn90053031/1908-01-04/ed-1/?fo=json&sp=4"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": "https://www.loc.gov/resource/sn90053031/1908-01-04/ed-1/?fo=json&sp=1", "results": "2 - 2", "to": 2, "total": 8}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn90053031/1907-12-28/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/2004695177", "http://www.loc.gov/item/2004695177/", "https://hdl.loc.gov/loc.afc/collafc.afc1981004"], "campaigns": [], "contributor": ["klymasz, shirley", "fleischhauer, carl", "brzovich, mato", "gonz\u00e1lez, jos\u00e9 gamaliel", "kubose, minnie somi", "swenson, greta e.", "moloney, mick", "bartis, peter", "robinson, beverly j.", "trbuhovic-grasa, gordana", "mack, james", "dovydenas, jonas", "american folklife center", "libonati, roland v. (roland victor)", "chicago ethnic arts project", "illinois arts council", "choi, chungmoo", "mathias, elizabeth", "bradunas, elena", "epstein, shifra", "george, philip b.", "lund, jens", "fiske-rusciano, roberta", "march, richard", "klymasz, robert bogdan", "archive of folk culture (library of congress)", "metcalfe, ralph h.", "hellenberg, antony", "kal\u010dik, susan j."], "date": "1976", "dates": ["1976"], "description": ["The collection consists of sound recordings, photographs, manuscript materials, videorecordings, publications, ephemera, administrative files, and field notes produced and collected during the 1977 Chicago Ethnic Arts Project field survey from 1976-1981; but primarily during fieldwork conducted by fourteen folklorists directed by the American Folklife Center in 1977. The final project report presented to the Illinois Arts Council summarized the current conditions and folk arts needs in a number of Chicago's ethnic communities. Materials from post-project activities such as workshops in the ethnic communities and a traveling photographic exhibit by Jonas Dovydenas are also included."], "digitized": true, "extract_timestamp": "2024-09-18T06:31:35.657Z", "group": ["catalog-split-09", "catalog", "main-catalog-split-09"], "hassegments": false, "id": "http://lccn.loc.gov/2004695177", "image_url": [], "index": 2, "language": ["english"], "location": ["chicago", "illinois"], "number": ["2024-09-16t08:09:38", "2004695177"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["american folklife center", "catalog"], "score": 28.025639, "shelf_id": "http://lccn.loc.gov/2004695177", "site": ["catalog"], "subject": ["korean americans", "danish americans", "brzovich, mato", "festivals", "musicians", "kubose, minnie somi", "indians of north america", "social aspects", "oral histories", "murals", "emigration and immigration", "pentecostals", "macedonian americans", "songs", "ura senke school", "illinois", "orthodox eastern church members", "cuban americans", "slovak americans", "bakeries", "needlework", "dance", "african americans", "musical instruments", "italian americans", "artists", "processions, religious", "fox indians", "greek americans", "czech americans", "social life and customs", "dance, black", "austrian americans", "fishing", "chicago (ill.)", "street art", "libonati, roland v.", "field recordings", "catholics", "dolls", "weaving", "folk dancing", "parades", "community life", "ukrainian americans", "video recordings", "sound recordings", "jews", "photographs", "ethnic arts", "wood-carving", "slides", "lithuanian americans", "interviews", "chinese americans", "ethnography", "finnish americans", "videocassettes", "roland victor)", "religious life and customs", "swedish americans", "buddhists", "german americans", "quilts", "norwegian americans", "serbian americans", "croatian americans", "puerto ricans", "chicago", "weddings", "folk music", "slovenian americans", "irish americans", "music", "american indian center of chicago", "costume", "polish americans", "japanese americans", "folklore", "manuscripts", "traveling exhibitions", "blues (music)", "hispanic americans", "japanese tea ceremony"], "timestamp": "2024-09-18T06:32:49.116Z", "title": "Chicago Ethnic Arts Project collection,", "type": ["manuscript"], "url": "//lccn.loc.gov/2004695177"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/afc2011062.afc2011062_00387_ms01/", "http://www.loc.gov/item/2017655527/", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr01", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_ph/", "http://lccn.loc.gov/2017655527", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr02", "https://hdl.loc.gov/loc.afc/afc2011062.afc2011062_00387_sr03", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr01/", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr02/", "http://www.loc.gov/resource/afc2011062.afc2011062_00387_sr03/"], "campaigns": [], "contributor": ["halker, bucky", "keane, jimmy", "occupational folklife project"], "date": "2013-01-01", "dates": ["2013"], "description": ["James \"Jimmy\" Keane, a prominent figure on the Irish music scene in Chicago and Ireland, discusses his career as an iron worker and member of Local 1 of the Iron Workers International Union. Keane, who was injured after ten years in the trade, then turned to music and selling real estate as a career. Keane's father, Jimmy \"Horse\" Keane, was a Local 1 member killed on the job in Chicago. Jimmy's three brothers also work in the iron trade. Jimmy Keane also discusses the music scene and the role of unions in America."], "digitized": true, "extract_timestamp": "2020-09-20T12:15:20.851Z", "group": ["afc/2011062", "catalog-split-08", "catalog", "iron-workers", "main-catalog-split-08", "main-catalog"], "hassegments": true, "id": "http://www.loc.gov/item/2017655527/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2011062/afc2011062_00387/afc2011062_00387_ph/afc2011062_00387_ph01.gif", "https://tile.loc.gov/storage-services/service/afc/afc2011062/afc2011062_00387/afc2011062_00387_ph/afc2011062_00387_ph01.gif#h=150&w=227", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:12.5/0/default.jpg#h=249&w=378", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:25/0/default.jpg#h=499&w=756", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:50/0/default.jpg#h=999&w=1512", "https://tile.loc.gov/image-services/iiif/service:afc:afc2011062:afc2011062_00387:afc2011062_00387_ph:afc2011062_00387_ph01/full/pct:100/0/default.jpg#h=1998&w=3024"], "index": 3, "language": ["english"], "location": ["chicago", "illinois", "middle west"], "mime_type": ["image/jpeg", "image/jp2", "audio/mp3", "image/gif", "audio/wav", "application/pdf", "application/x-audio"], "number": ["online resource", "2018-10-24t17:32:53", "2017655527"], "online_format": ["image", "audio", "pdf"], "original_format": ["sound recording"], "partof": ["american folklife center", "cultural traditions of ironworkers in america's upper midwest", "occupational folklife project", "catalog"], "score": 27.651352, "shelf_id": "http://lccn.loc.gov/