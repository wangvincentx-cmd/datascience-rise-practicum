, "composite_location": ["0/united states/", "1/united states/south dakota/", "2/united states/south dakota/lake/", "3/united states/south dakota/lake/madison/"], "contributor": ["south dakota state historical society \u2013 state archives"], "date": "1910-09-13", "dates": ["1910-09-13"], "description": ["POWDER Absolutely Pure The only baking powder made from Royal Grape Cream of Tartar No Alum No Lime Phosphate has cueist OF EHMOiS Comptroller Murray Would Bar Certain Men READY TO FlRNISa NAMES Tells State Bank Examiners That the List in His Office Will Be Given Them for Use Should Any of the Undesirables1 Attempt to Organize State Institutions Has Refused Many Applications Since Taking Office Washington St 13The Na tional Association of Supervisors of State Banks begun a three days con vention in Washington The exam iners gathered at the treasury build ing and were addressed by Lawrence O Murray comptroller of the cur rency Mr Murray proposed to the state supervisors a working cooperation with the national examiners He de clared he had in his office a list of men who as officers of the national banks had proved incompetent and had been removed from office and said that if any of them should make application to order state banks their names would he furnished to the state banking authorities In turn he pro posed that the state supervisors fur nish to the national system the names of men who had been driven out ot the state bankB"], "digitized": true, "extract_timestamp": "2023-06-25T23:47:43.209Z", "group": ["ndnp/sdhi", "south-dakota-state-historical-society-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn99062034/1910-09-13/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_grenada_ver01:data:sn99062034:00279523064:1910091301:1174/full/pct:3.125/0/default.jpg#h=257&w=205", "https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_grenada_ver01:data:sn99062034:0027952