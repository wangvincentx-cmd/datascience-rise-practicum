 growing on this property SPECIAL prices for the first 100 lots 100 to 200 each Only 10 down and 5 to 10 per month A discount of 10 per cent will be allowed for a short time for all cash if paid within 30 days after date of sale IMMEDIATE POSSESSION can be given to those wishing to plant a garden now or to those who desire to build Here is your opportunity to cut down the HIGH COST of LIVING For further informaflion inquire at farm house on prop erty or EVANS G SLAUGHTER Owner Wildwood N J Premier Bakery Pine and Pacific Aves Wildwood N J Our Own BakingWheat and Rye Breads Assorted Cakes and Pies Customers from Anglesea and Crest"], "digitized": true, "extract_timestamp": "2025-12-01T12:41:49.363Z", "group": ["ndnp/njr", "rutgers-university-libraries-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn90063041/1920-06-11/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_irene_ver02:data:sn90063041:0033289707A:1920061101:0463/full/pct:6.25/0/default.jpg#h=407&w=287", "https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_irene_ver02:data:sn90063041:0033289707A:1920061101:0463/full/pct:12.5/0/default.jpg#h=814&w=575", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/njr/batch_njr_irene_ver02/data/sn90063041/0033289707A/1920061101/0463.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["new jersey", "cape may", "five mile beach", "united states", "wildwood"], "location_city": ["wildwood", "five mile beach"], "location_country": ["united states"], "location_county": ["cape may"], "location_state": ["new jersey"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0000000001", "0", "3", "9", "8", "7", "sn90063041", "a", "1"], "number_edition": ["1"], "number_lccn": ["sn90063041"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "3", "2", "8