{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn84037548/?st=calendar", "cite_this": {"apa": "(1957, November 28)  <cite>The West end news</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn84037548/1957-11-28/ed-1/.", "chicago": "<cite>The West end news</cite>. (Frederiksted, VI), Nov. 28 1957. https://www.loc.gov/item/sn84037548/1957-11-28/ed-1/.", "mla": "<cite>The West end news</cite>. (Frederiksted, VI) 28 Nov. 1957, p. 2. Retrieved from the Library of Congress, www.loc.gov/item/sn84037548/1957-11-28/ed-1/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/vnstcsc/batch_vnstcsc_fredensdal_ver01/data/sn84037548/00513689871/1957112801/0938.xml&format=alto_xml&full_text=1", "item": {"_version_": 1781194093135659008, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn84037548/1957-11-28/ed-1/", "http://www.loc.gov/resource/sn84037548/1957-11-28/ed-1/"], "batch": ["vnstcsc_fredensdal_ver01"], "call_number": ["Newspaper"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/virgin islands/", "2/united states/virgin islands/saint croix/", "3/united states/virgin islands/saint croix/frederiksted/"], "contributor_names": ["University of the Virgin Islands"], "contributors": [{"university of the virgin islands": "https://www.loc.gov/search/?fa=contributor:university+of+the+virgin+islands&fo=json"}], "created_published": ["Frederiksted, St. Croix [V.I.], November 28, 1957"], "date": "1957-11-28", "date_issued": "1957-11-28", "dates": [{"1957-11-28": "https://www.loc.gov/search/?dates=1957-11-28/1957-11-28&fo=json"}], "dates_of_publication": "1912-1973", "description": ["Frederiksted, St. Croix [V.I.]"], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2023-10-30T12:57:34.919Z", "extract_urls": ["file:/service/ndnp//vnstcsc/batch_vnstcsc_fredensdal_ver01/data/sn84037548/00513689871/1957