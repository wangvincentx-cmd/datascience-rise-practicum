ns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/new haven/", "3/united states/connecticut/new haven/new haven/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1910-11-04", "dates": ["1910-11-04"], "description": ["THE NEW HAVEN UNION FOUNDED BY ALEXANDER TROUP FRIDAY NOVEMBER 4 1910 ELEVENTHHOUR AWAKENING OF AN EVENING This paper has never assailed the integrity or character of Senator Blakeslee as a citizen of thi3 community or as a business man and it has recog nized the conspicuous and deserving place he occu pies in the world of business But in that other world the world of politics we have said a few sharp things about this leading Re publican and we repeat for the benefit of an evening contemporary that has so suddenly and significantly jumped to the defense of Senator Blakesleea sort of an eleventhhour jump too by the waythat his standard of politics is not the standard or the quality or the kind that appeals to The Union or in our judgment appeals to the reason or commendation of fairminded citizens generally We think his mind is warped politically that is he cannot see anything Commendable that is urged or endorsed by a Democrat His partisanship is alto gether too rank for progress for that which makes r the common good Politically in a word he is too narrow for the development of this age He would never"], "digitized": true, "extract_timestamp": "2023-11-19T03:45:16.085Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92051126/1910-11-04/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_indeed_ver02:data:sn92051126:0051717421A:1910110401:0595/full/pct:6.25/0/default.jpg#h=400&w=309", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_indeed_ver02:data:sn92051126:0051717421A:1910110401:0595/full/pct:12.5/0/default.jpg#h=801&w=61