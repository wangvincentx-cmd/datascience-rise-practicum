1957-08-16/ed-1/?sp=2"], "batch": ["mthi_douglasfir_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/lewis and clark/", "3/united states/montana/lewis and clark/helena/"], "contributor": ["montana historical society; helena, mt"], "date": "1957-08-16", "dates": ["1957-08-16"], "description": ["Editorial More Fuel To Feed Inflation ___ i o m y i i The Mountain states TgI Toi Company lias petitioned the state Public Service Commission for approval of a new schedule of business and residential rates ranging from 30 to 40 per cent above current schedules In so doing the telephone monopoly reminds Montana peo pie that the company has not had a rate increase since 19o3 and that in the years since the cost of providing service particularly laborhas gone up substantially In its adver tising the utility convevs the impression that wages have been increased by about forty per cent Such a conclusion is patently erroneous as any telephone company worker will tell you that much of the increased outlay for wage payments is due to greatly expanded operations by MSTT in the last four years necessitating the hiring of more manpower The company also points to tax increases as another reason why rates should be increased It is true that the last legislature did vote a moderate increase in the telephone license tax and other taxes paid by corporate enterprise It is also true that that same legislature voted to reimburse utilities to the extent of"], "digitized": true, "extract_timestamp": "2023-07-03T13:45:52.190Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075189/1957-08-16/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_douglasfir_ver01:data:sn86075189:00414211045:1957081601:0403/full/pct:6.25/0/default.jpg#h=418&w=285", "https://tile.loc.gov/image-services/iiif/service:ndn