ited states/", "1/united states/texas/", "2/united states/texas/potter/", "3/united states/texas/potter/amarillo/"], "contributor": ["university of north texas; denton, tx"], "date": "1921-02-27", "dates": ["1921-02-27"], "description": ["tj y 1 iii hat the una now ow is over H II il AMARILLO DAILY NEWS SUNDAY MORNING FEBRUARY 27 1921 PART ONE 8 3 h Ml I in su if t We feel that we have demonstrated to the people that we have a definite place in the affairs of Amarjllo and the Plains Country of Texas At a time when there was every evidence of a financial and consequent business depression we staged an event declared by those who are in position to know to be the best and most thor ough gloomdispelling agency ever known in this section Reference is here made to the Auto mobile and Style Shows held simultaneously with the annual convention of the Buyers and Sellers Association In making this statement about the success of the event just closed we are not arrogating to pur selves any of the glory attaching to business men in other lines We accqrd to them the full measure of credit that is theirs and it is in no mean propor tion in rounding out the ultimate scope of success achieved Having reached the conclusion that the de pression was in large measure psychologicalthe AmarilloPanhandle Automotive Association"], "digitized": true, "extract_timestamp": "2025-06-05T16:51:22.110Z", "group": ["ndnp/txdn", "university-of-north-texas-denton-tx-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85042551/1921-02-27/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:txdn:batch_txdn_honda_ver02:data:sn85042551:00200294324:1921022701:0572/full/pct:6.25/0/default.jpg#h=439&w=317", "https://tile.loc.gov/image-services/iiif/service:ndnp:txdn:batch_txdn_honda_ver02:data:sn85042551:00200294324:1921022701:0572/full/pct:12.5/0/default.jpg#h=878&w=634", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/txdn