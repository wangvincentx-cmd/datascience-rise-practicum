": "06", "shelf_id": "sn93061777, 1921-03-10, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/nmu", "subject": ["clovis (n.m.)", "curry", "curry county (n.m.)", "roosevelt", "curry county", "clovis", "newspapers", "roosevelt county", "new mexico", "roosevelt county (n.m.)", "united states"], "subject_headings": ["Clovis (N.M.)--Newspapers", "Curry County (N.M.)--Newspapers", "Roosevelt County (N.M.)--Newspapers", "New Mexico--Clovis", "New Mexico--Curry County", "New Mexico--Roosevelt County", "United States--New Mexico--Curry--Clovis", "United States--New Mexico--Roosevelt--Clovis"], "subjects": [{"clovis": "https://www.loc.gov/search/?fa=subject:clovis&fo=json"}, {"clovis (n.m.)": "https://www.loc.gov/search/?fa=subject:clovis+%28n.m.%29&fo=json"}, {"curry": "https://www.loc.gov/search/?fa=subject:curry&fo=json"}, {"curry county": "https://www.loc.gov/search/?fa=subject:curry+county&fo=json"}, {"curry county (n.m.)": "https://www.loc.gov/search/?fa=subject:curry+county+%28n.m.%29&fo=json"}, {"new mexico": "https://www.loc.gov/search/?fa=subject:new+mexico&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"roosevelt": "https://www.loc.gov/search/?fa=subject:roosevelt&fo=json"}, {"roosevelt county": "https://www.loc.gov/search/?fa=subject:roosevelt+county&fo=json"}, {"roosevelt county (n.m.)": "https://www.loc.gov/search/?fa=subject:roosevelt+county+%28n.m.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2022-11-22T17:06:03.350Z", "title": "The Clovis news (Clovis, N.M.), March 10, 1921", "type": ["issue"], "url": "https://www.loc.gov/item/sn93061777/1921-03-10/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/sn93061777", "http://www.loc.gov/item/sn93061777/"], "batch": ["nmu_barberry_ver04"], "campaigns": [], "date": "1907", "description": ["Weekly Began with May 1,