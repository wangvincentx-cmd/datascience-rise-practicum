": ["newspaper"], "other_title": ["Sunday herald"], "partof": ["directory of u.s. newspapers in american libraries", "the evening herald (albuquerque, new mexico) 1914-1922 [online resource]", "serial and government publications division"], "publication_frequency": ["daily"], "score": 70.85589, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "albuquerque", "bernalillo county (n.m.)", "bernalillo county", "bernalillo", "periodicals", "albuquerque (n.m.)", "electronic journals", "united states", "new mexico"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The evening herald", "type": ["title"], "url": "https://www.loc.gov/item/2021201433/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218649/"], "campaigns": [], "date": "1903", "dates": ["[1903 TO 1926]"], "description": ["Daily Began October 7, 1903; ceased June 19, 1926. Publisher: Journal Publishing Co., <July 2-Spetember 30, 1908>. Carries designation of Morning journal and Morning Democrat, Oct. 7, 1903- Numeric designation includes several changes in the numbering system and numerous inconsistencies. Available on microfilm from the Library of Congress, Photoduplication Service, and Southwest Micropublishing, Inc. Evening ed.: Albuquerque herald, 1922-1926. Description based on: Twenty-seventh year (October 1, 1905); title from masthead (Chroniclingamerica.loc.gov, viewed October 22, 2014). Latest issue consulted: Thirtieth year (September 30, 1908) (Chroniclingamerica.loc.gov, viewed October 22, 2014). Albuquerque journal (Albuquerque, N.M. : 1926 : Online) (OCoLC)137344748"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:28.190Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218649/", "image_url": [], "index": 3, "language": ["english"], "location": ["albuquerque", "bernalillo county", "bernalillo", "united states", "new mexico"], "number": ["online resource", "2375-5911",