433/g4333/g4333p/la000006.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd433/g4333/g4333p/la000006.gif#h=150&w=278", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd433:g4333:g4333p:la000006/full/pct:12.5/0/default.jpg#h=1109&w=2052", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd433:g4333:g4333p:la000006/full/pct:25/0/default.jpg#h=2218&w=4105"], "index": 4, "language": ["english"], "location": ["united states", "tucson", "nogales", "arizona", "pima county"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t18:32:05.200000", "77692954", "2011-11-28t13:39:51"], "online_format": ["image"], "original_format": ["map"], "partof": ["cultural landscapes", "county landownership maps", "catalog", "geography and map division"], "score": 32.555054, "shelf_id": "G4333.P4 1893 .R6 G4333.P4 1893 .R6 G4333.P4 1893 .R6", "site": ["catalog"], "subject": ["united states", "pima county (ariz.)", "tucson", "nogales (ariz.)", "arizona", "pima county", "nogales", "tucson (ariz.)", "maps"], "timestamp": "2026-04-29T16:18:09.713Z", "title": "Official map of Pima County, Arizona", "type": ["cartographic"], "url": "https://www.loc.gov/item/77692954/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2020655666", "http://www.loc.gov/item/2020655666/", "https://hdl.loc.gov/loc.afc/afc2015028.afc2015028_03002_sr01", "http://www.loc.gov/resource/afc2015028.afc2015028_03002_sr01/", "http://www.loc.gov/resource/afc2015028.afc2015028_03002_ms02/"], "campaigns": [], "contributor": ["hartmann, nic", "occupational folklife project", "thomas, charlie (charles, sr.)"], "date": "2015", "dates": ["2015"], "description": ["Charlie Thomas of Thomas Produce in Tucson, Arizona, talks about his life in the fresh produce industry of both North Carolina and Arizona. He discusses his father's and family's involvement in produce industry; handling different vegetables; determining ripeness; changes in industry; the impact of Wal-Mart; growing areas in Mexico; Greco-Mexican connections in produce industry; winter produce and Florida; cash vs. credit; the local industry in Arizona; competition from elsewhere; and etc."], "digitized": true, "extract_timestamp": "2025-08-14T14:52:29.355Z", "group": ["afc/2015028", "catalog-split-06", "catalog", "produce-workers", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/2020655666/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:afc:afc2015028:afc2015028_03002:afc2015028_03002_ms02/full/pct:25/0/default.jpg"], "index": 5, "language": ["english"], "location": ["nogales", "arizona", "tucson"], "mime_type": ["audio/mp3", "application/pdf"], "number": ["online resource", "2021-01-11t12:50:47", "2020655666"], "online_format": ["audio", "pdf"], "original_format": ["sound recording"], "partof": ["occupational folklife project", "catalog", "american folklife center", "fresh produce workers in arizona: archie green fellows project, 2015-2016"], "score": 31.45955, "shelf_id": "http://lccn.loc.gov/2020655666", "site": ["catalog"], "subject": ["personal narratives", "interviews", "occupational training", "family-owned business enterprises", "job satisfaction", "farm produce", "folklore", "work ethic", "produce trade", "sound recordings", "social life and customs", "nogales", "work environment", "nogales (ariz.)", "charles, sr.)", "arizona", "quality of work life", "oral histories", "thomas, charlie", "quality"], "timestamp": "2025-08-14T14:53:11.604Z", "title": "Charles \"Charlie\" Thomas, Sr. interview conducted by Nic Hartmann, 2015-08-25", "type": ["sound recording-nonmusical"], "url": "https://www.loc.gov/item/2020655666/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2020655667", "http://www.loc.gov/item/2020655667/", "https://hdl.loc.gov/loc.afc/afc2015028.afc2015028_03021_sr01", "http://www.loc.gov/resource/afc2015028.afc2015028_03021_sr01/", "http://www.loc.gov/resource/afc2015028.afc2015028_03021_ms02/"], "campaigns": [], "contributor": ["hartmann, nic", "occupational folklife project", "cathey, jim"], "date": "2015", "dates": ["2015"], "description": ["Interview with Jim Cathey, Sales and Sourcing Manager of Red Sun Farms in Tubac, Arizona. He talks about entering the industry; moving to Arizona; going into the greenhouse industry; McAllen's (TX) rise as a produce center, and Nogales' response; an average work day; the challenges of the industry; labor and labor shortages; the impact of technology on the trade; and etc."], "digitized": true, "extract_timestamp": "2025-08-14T14:52:29.355Z", "group": ["afc/2015028", "catalog-split-07", "catalog", "produce-workers", "main-catalog-split-07"], "hassegments": false, "id": "http://www.loc.gov/item/2020655667/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:afc:afc2015028:afc2015028_03021:afc2015028_03021_ms02/full/pct:25/0/default.jpg"], "index": 6, "language": ["english"], "location": ["tubac", "nogales", "arizona"], "mime_type": ["audio/mp3", "application/pdf"], "number": ["2020655667", "online resource", "2021-01-11t09:07:35"], "online_format": ["audio", "pdf"], "original_format": ["sound recording"], "partof": ["occupational folklife project", "catalog", "american folklife center", "fresh produce workers in arizona: archie green fellows project, 2015-2016"], "score": 31.45955, "shelf_id": "http://lccn.loc.gov/2020655667", "site": ["catalog"], "subject": ["personal narratives", "quality", "produce trade", "interviews", "sound recordings", "social life and customs", "nogales (ariz.)", "arizona", "nogales", "farm produce", "cathey, jim", "folklore", "oral histories", "work-life balance", "work ethic", "work environment"], "timestamp": "2025-08-14T14:53:11.604Z", "title": "Jim Cathey interview conducted by Nic Hartmann, 2015-08-26", "type": ["sound recording-nonmusical"], "url": "https://www.loc.gov/item/2020655667/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414217618/1927010201/0245.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414217618:1927010201:0245/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414217618/1927010201/0245.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn96060774/1927-01-02/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414217618/1927010201/0245.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414217618:1927010201:0245/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414217618/1927010201/0245.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn96060774/1927-01-02/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414217618/1927010201/0245.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn96060774/1927-01-02/ed-1/?sp=1"], "batch": ["az_groomcreek_ver04"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arizona/", "2/united states/arizona/santa cruz/", "3/united states/arizona/santa cruz/nogales/"], "contributor": ["arizona state library, archives and public records; phoenix, az"], "date": "1927-01-02", "dates": ["1927-01-02"], "description": ["WINOGALES INTERNATIONAL spf Vol 2No 318 Pages LINE OR TWOJ Our Resolution for 1927T0 sing the praises of Nogales when ever and wherever the chance af fords to tolerate no abuse and un fair criticism and to help make Nogales a bigger brighter and bet ter city Will you join Here is a sour note from Geor ge Bernard Shaw British dramat ist recently awarded the Nobel prize for literature 1925 writing in the New Leader It has be come an unbearable nuisance but the difficulty is to draft a bill making the celebration of Christ mas a criminal act and compensat ing the shopkeepers who are just enabled by the Christmas trade to pay their rents not to mention all the other people who make money out of it and who do not know that the landlords pocket it all In the long run Bernard must be i feeling badly 1 Just before Christmas tL New 1 health society of London issued the following list of Christmas Donts j Dont let the children stuff themselves all day long with cand ies Dried fruits are much bet ter for them Imagine the par ents feeding their children dried fruits on"], "digitized": true, "extract_timestamp": "2024-01-09T14:50:01.683Z", "group": ["ndnp/az", "arizona-state-university-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn96060774/1927-01-02/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414217618:1927010201:0245/full/pct:3.125/0/default.jpg#h=279&w=195", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414217618:1927010201:0245/full/pct:6.25/0/default.jpg#h=559&w=391", "https://tile.loc.gov/image-services/iiif/service:ndnp:az:batch_az_groomcreek_ver04:data:sn96060774:00414217618:1927010201:0245/full/pct:12.5/0/default.jpg#h=1118&w=783", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/az/batch_az_groomcreek_ver04/data/sn96060774/00414217618/1927010201/0245.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["santa cruz county", "united states", "nogales"