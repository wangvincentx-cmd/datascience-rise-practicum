igns": [], "composite_location": ["0/united states/", "1/united states/colorado/", "2/united states/colorado/gunnison/", "3/united states/colorado/gunnison/crested butte/", "3/united states/colorado/gunnison/irwin/", "3/united states/colorado/gunnison/ruby camp/"], "contributor": ["history colorado"], "date": "1921-01-27", "dates": ["1921-01-27"], "description": ["THE ELK MOUNTAIN PILOT VOLUME XXXXV Local and Personal Roger Nelson arrived home on Sun days train o Mrs M J Boyle came in on last Thursdays train A L Mi ls returned home from Gunnison Wednesday Frank Buster is in town from over on the Perry Bros ranch P G Elder returned home from a short business trip to Denver Wednesday The Bulkley mine is to resume ope rations again this week after a cou ple of weeks ideness John McGosker arrived home Wednesday He has been spending some time in Gunnison Mike Fisher made a business trip down to the Eccher section Wednesday of last week Jos Faussone went to Glacier Thursday to serve some papers on a man by tho name of Frock HJ Cha a Henderson an employee at the Bulkley mne for several months left for Denver Wednesday W H Whalen returned heme from Denver Sunday where he attended the Good Roads convention Mrs John Heuchemer went tover to Sargent Thursday for a short visit with her daughter Mrs Ruie Watters Mr W F Bragg Sociological work er for the C F I company came in last Thursday remaining several days Mrs W S Bailey"], "digitized": true, "extract_timestamp": "2023-12-27T21:33:59.197Z", "group": ["ndnp/cohi", "history-colorado-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86063397/1921-01-27/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_jasper_ver01:data:sn86063397:00340586177:1921012701:0153/full/pct:6.25/0/default.jpg#h=309&w=230", "https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_jasper_ver01:data:sn86063397:00340586177:1921012701:0153/full/pct:12.5/0/default.jpg#h=618&w=4