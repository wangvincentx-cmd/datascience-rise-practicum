out Uio tack drew a long breath and manfully con trlled his feelings Why ho asked himself holding up the tack should I permit a llttlo thing llko Ibis lo make mo unhappy If I wore lo give way lo anger now I should Injure myself and Inflict no damage whatever upon this tack When a man becomes angry he pois ons"], "digitized": true, "extract_timestamp": "2025-12-01T12:40:33.009Z", "group": ["ndnp/nbu", "university-of-nebraska-of-nebraska-lincoln-libraries-lincoln-ne-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn94056446/1908-05-15/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_gering_ver01:data:sn94056446:00211102603:1908051501:1243/full/pct:6.25/0/default.jpg#h=433&w=311", "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_gering_ver01:data:sn94056446:00211102603:1908051501:1243/full/pct:12.5/0/default.jpg#h=866&w=622", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_gering_ver01/data/sn94056446/00211102603/1908051501/1243.xml&format=alto_xml"], "index": 3, "language": ["english"], "location": ["richardson county", "richardson", "nebraska", "falls city", "united states"], "location_city": ["falls city"], "location_country": ["united states"], "location_county": ["richardson"], "location_state": ["nebraska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0", "2", "0000000003", "1", "6", "sn94056446"], "number_edition": ["1"], "number_lccn": ["sn94056446"], "number_page": ["0000000003"], "number_reel": ["0", "0", "2", "1", "1", "1", "0", "2", "6", "0", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "the falls city tribune (falls city, neb.) 1904-191?", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["