html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn85025371, 1930-09-18, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/vi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "clarke county", "clarke", "https://id.oclc.org/worldcat/entity/e39pbjxcc46ty6wrkfchmcpvpp", "https://id.oclc.org/worldcat/entity/e39pbjcgryry7kdb3vmrpqfthc", "berryville", "berryville (va.)", "virginia", "clarke county (va.)", "united states"], "subject_headings": ["Clarke County (Va.)--Newspapers", "Berryville (Va.)--Newspapers", "Virginia--Berryville.--https://id.oclc.org/worldcat/entity/E39PBJxCC46Ty6wRkFChMCPvpP", "Virginia--Clarke County.--https://id.oclc.org/worldcat/entity/E39PBJcgrYry7KDB3VMRPQfTHC", "United States--Virginia--Clarke--Berryville"], "subjects": [{"berryville": "https://www.loc.gov/search/?fa=subject:berryville&fo=json"}, {"berryville (va.)": "https://www.loc.gov/search/?fa=subject:berryville+%28va.%29&fo=json"}, {"clarke": "https://www.loc.gov/search/?fa=subject:clarke&fo=json"}, {"clarke county": "https://www.loc.gov/search/?fa=subject:clarke+county&fo=json"}, {"clarke county (va.)": "https://www.loc.gov/search/?fa=subject:clarke+county+%28va.%29&fo=json"}, {"https://id.oclc.org/worldcat/entity/e39pbjcgryry7kdb3vmrpqfthc": "https://www.loc.gov/search/?fa=subject:https://id.oclc.org/worldcat/entity/e39pbjcgryry7kdb3vmrpqfthc&fo=json"}, {"https://id.oclc.org/worldcat/entity/e39pbjxcc46ty6wrkfchmcpvpp": "https://www.loc.gov/search/?fa=subject:https://id.oclc.org/worldcat/entity/e39pbjxcc46ty6wrkfchmcpvpp&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"virginia": "https://www.loc.gov/search/?fa=subject:virginia&fo=json"}], "timestamp": "2024-09-29T00:09:49.819Z", "title": "Clarke courier (Berryville, Va.), September 18, 1930", "type": ["issue"], "url": "https://www.loc.gov/item/sn85025371/1930-09-18