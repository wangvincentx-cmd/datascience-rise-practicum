9/1907113001/0087.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:wa:batch_wa_alder_ver01:data:sn88085318:00211108289:1907113001:0085/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/wa/batch_wa_alder_ver01/data/sn88085318/00211108289/1907113001/0087.pdf", "segment_count": 22, "url": "https://www.loc.gov/resource/sn88085318/1907-11-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wa/batch_wa_alder_ver01/data/sn88085318/00211108289/1907113001/0087.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:wa:batch_wa_alder_ver01:data:sn88085318:00211108289:1907113001:0085/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/wa/batch_wa_alder_ver01/data/sn88085318/00211108289/1907113001/0087.pdf", "segment_count": 22, "url": "https://www.loc.gov/resource/sn88085318/1907-11-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/wa/batch_wa_alder_ver01/data/sn88085318/00211108289/1907113001/0087.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn88085318/1907-11-30/ed-1/?sp=3"], "batch": ["wa_alder_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/washington/", "2/united states/washington/stevens/", "3/united states/washington/stevens/colville/"], "contributor": ["washington state library; olympia, wa"], "date": "1907-11-30", "dates": ["1907-11-30"], "description": ["THE COLVILLE EXAMINER Issued Every Saturday by the Stevens County Publishing Company Inc Subscription Price 150 a Year 5c a Copy J C Harrigan Editor and Manager Roosevelt Makes More Moneyfor Whom When Grover Cleveland was president of the United States there was a panica financial panic in the land The republican party press stood out in regimental lines and pointed the finger of accusation directly at the democratic party and charged to its policy of government the fault of the damaged condition of affairs When Mr Cleve land caused an issue of 50000000 in government bonds as an expedient for the occasion there was a shout of derision from the same grand army of political Pharisees which could be heard from ocean to ocean and to this dayor to be more ac curate up to the 17threpublican partisans have pointed to the Cleveland bond issue as the cause and the beginning of the decadence of the republic On the 17th of November A D 1907 be it re membered Theodore Roosevelt guided by his golden instinct and amidst the clamor of the great captains of finance in his New York home where the friends of his youth and shapers"], "digitized": true, "extract_timestamp": "2024-04-26T11:23:27.150Z", "group": ["ndnp/wa", "washington-state-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88085318/1907-11-30/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:wa:batch_wa_alder_ver01:data:sn88085318:00211108289:1907113001:0087/full/pct:6.25/0/default.jpg#h=315&w=230", "https://tile.loc.gov/image-services/iiif/service:ndnp:wa:batch_wa_alder_ver01:data:sn88085318:00211108289:1907113001:0087/full/pct:12.5/0/default.jpg#h=631&w=460", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wa/batch_wa_alder_ver01/data/sn88085318/00211108289/1907113001/0087.xml&format=alto_xml"], "index": 3, "language": ["english"], "location": ["colville", "stevens", "washington", "united states"], "location_city": ["colville"], "location_country": ["united states"], "location_county": ["stevens"], "location_state": ["washington"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["8", "