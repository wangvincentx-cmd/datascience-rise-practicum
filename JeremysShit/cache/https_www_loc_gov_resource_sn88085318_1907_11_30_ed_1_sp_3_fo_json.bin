/hdl.loc.gov/loc.gmd/g4284ym.gct00281", "http://www.loc.gov/resource/g4284ym.gct00281/"], "campaigns": [], "contributor": ["julius bien & co", "northern transcontinental survey", "hilgard, eugene w. (eugene woldemar)"], "date": "1883", "dates": ["1883"], "description": ["Relief shown by contours on all maps. Covers parts of the Yakima and Colville valleys. Title from accompanying text sheet. Accompanied by title sheet. At head of title sheet: Northern Transcontinental Survey. Available also through the Library of Congress Web site as a raster image. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:32.654Z", "group": ["gmd.mar", "catalog-split-09", "catalog", "general-maps", "main-catalog-split-09"], "hassegments": true, "id": "http://www.loc.gov/item/2013593288/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd428m/g4284m/g4284ym/gct00281/cs000001.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd428m/g4284m/g4284ym/gct00281/cs000001.gif#h=150&w=116", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd428m:g4284m:g4284ym:gct00281:cs000001/full/pct:12.5/0/default.jpg#h=931&w=717", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd428m:g4284m:g4284ym:gct00281:cs000001/full/pct:25/0/default.jpg#h=1862&w=1435"], "index": 3, "language": ["english"], "location": ["colville river valley", "washington", "colville", "yakima river valley", "yakama indian reservation", "washington (state)", "united states", "yakima"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2025-09-24t18:55:34.300000", "2013593288"], "online_format": ["image"], "original_format": ["map"], "partof": ["general maps", "catalog", "geography and map division"], "score": 36.59571, "shelf_id": "G4284.Y2J3 1883 .H5", "site": ["catalog"], "subject": ["colville (wash.)", "colville river valley", "colville river valley (wash.)", "topographic maps", "colville", "yakima river valley", "yakama indian reservation", "yakima (wash.)", "early maps", "united states", "yakima river valley (wash.)", "washington (state)", "soils", "yakama indian reservation (wash.)", "yakima", "maps"], "timestamp": "2026-04-29T16:08:35.525Z", "title": "Soils of the Yakima and Colville regions", "type": ["cartographic"], "url": "https://www.loc.gov/item/2013593288/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2003663148", "http://www.loc.gov/item/2003663148/", "https://hdl.loc.gov/loc.pnp/cph.3g11419", "http://www.loc.gov/resource/cph.3g11419/", "https://www.loc.gov/pictures/item/2003663148/", "http://www.loc.gov/pictures/item/2003663148/", "https://www.loc.gov/pictures/collection/cph/item/2003663148/", "http://www.loc.gov/pictures/collection/cph/item/2003663148/"], "campaigns": [], "date": "1860-01-01", "dates": ["1860"], "description": ["Photograph shows three men with a mule with two casks tied to its back at the British North American Boundary Commission base in Colville; also shows two Boundary Commission huts."], "digitized": true, "extract_timestamp": "2022-11-29T18:36:02.172Z", "group": ["pp/mtfront", "cph", "catalog-split-01", "catalog", "meeting-of-frontiers-prints-and-photographs", "miscellaneous-items-high-demand", "main-catalog-split-01", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2003663148/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/cph/3g10000/3g11000/3g11400/3g11419_150px.jpg#h=121&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3g10000/3g11000/3g11400/3g11419t.gif#h=121&w=150", "https://tile.loc.gov/storage-services/service/pnp/cph/3g10000/3g11000/3g11400/3g11419r.jpg#h=517&w=640", "https://tile.loc.gov/storage-services/service/pnp/cph/3g10000/3g11000/3g11400/3g11419v.jpg#h=828&w=1024"], "index": 4, "language": ["english"], "location": ["colville", "washington"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2003663148", "2013-01-18t14:28:53", "http://www.loc.gov/item/13181491"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["prints & photographs online catalog (library of congress)", "miscellaneous items in high demand", "prints and photographs division", "meeting of frontiers", "catalog"], "score": 25.610748, "shelf_id": "Unprocessed in PR 13 CN 1999:001, no. 1, leaf 19", "site": ["catalog", "pictures"], "subject": ["log buildings", "colville", "mules", "british north american boundary commission", "muleteers", "buildings", "albumen prints", "washington (state)"], "timestamp": "2022-11-29T19:46:22.054Z", "title": "Mule laden with casks - Boundary Commission huts, Colville, Columbia R.", "type": ["still image"], "url": "https://www.loc.gov/item/2003663148/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017434347", "http://www.fs.fed.us/pnw/pubs/pnw_rp588.pdf", "http://www.loc.gov/item/2017434347/"], "campaigns": [], "contributor": ["gordon, ryan patrick", "pacific northwest research station (portland, or.)"], "date": "2012", "dates": ["2012"], "description": ["Concerns about forest health and the threat of wildfire across the Western United States increasingly provide the impetus for communities to find land management solutions that serve multiple interests. Funding and procedural changes over the past decade have positioned federal agencies to put greater emphasis on multistakeholder partnerships and public outreach efforts. Partnerships build slowly over time, but can result in a healthier resource, reduced fire risk, greater stability for agency planning processes, and more resilient communities. Drawing on interviews with stakeholders representing broad interests in a partnership between the Northeast Washington Forestry Coalition and the Colville National Forest, we examine some of the critical factors leading to the partnership's success and identify challenges along the way. We illustrate how the citizens of Colville, Washington, overcame conflicts by learning to communicate their interests and use existing resources to advance a variety of goals, ranging from fuels reduction and active forest management to roadless area and wilderness management. We highlight a set of important organizational themes that have emerged from Colville to provide managers and other stakeholders with ideas for similar efforts."], "digitized": true, "extract_timestamp": "2023-06-02T15:47:25.049Z", "group": ["catalog-split-03", "catalog", "main-catalog-split-03", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2017434347", "image_url": [], "index": 5, "language": ["english"], "location": ["colville", "colville national forest", "washington"], "number": ["2017434347", "2017-12-19t07:20:23", "n798281730"], "original_format": ["book"], "other_title": ["Colville National Forest and Northeast Washington Forestry Coalition experience"], "partof": ["catalog"], "score": 25.610748, "shelf_id": "SD421.32.W2 G67 2012", "site": ["catalog"], "subject": ["colville national forest", "lumber trade", "citizen participation", "forest management", "environmental aspects", "colville", "colville national forest (wash.)", "northeast washington forestry coalition", "conflict management", "fire management", "environmentalists", "communication in forestry", "public opinion", "forestry and community", "logging", "washington (state)", "management", "forests and forestry"], "timestamp": "2023-07-07T23:29:38.972Z", "title": "Building a citizen-agency partnership among diverse interests : the Colville National Forest and Northeast Washington Forestry Coalition experience", "type": ["text"], "url": "//lccn.loc.gov/2017434347"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2019271233", "http://www.loc.gov/item/2019271233/", "https://search.catalog.loc.gov/instances/2bc63760-aada-522d-be1e-54ed5b7002b6"], "campaigns": [], "date": "1982", "dates": ["[1982 TO 9999]"], "description": ["Daily, Feb. 1, 19