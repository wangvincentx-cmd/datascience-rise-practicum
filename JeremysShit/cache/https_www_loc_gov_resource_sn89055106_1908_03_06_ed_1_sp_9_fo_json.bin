], "original_format": ["book"], "partof": ["catalog"], "score": 17.014864, "shelf_id": "F746", "site": ["catalog"], "subject": ["societies, etc", "idaho state historical society", "historic preservation", "history", "idaho"], "timestamp": "2023-07-07T13:11:03.927Z", "title": "The Idaho State Historical Society", "type": ["text"], "url": "//lccn.loc.gov/2003618672"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2020445566", "http://www.loc.gov/item/2020445566/", "https://hdl.loc.gov/loc.gdc/gdcebookspublic.2020445566", "http://www.loc.gov/resource/gdcebookspublic.2020445566/", "https://history.idaho.gov/wp-content/uploads/Idaho-State-Historic-Preservation-Plan-2016-2022_Updated_Compressed-1.pdf"], "campaigns": [], "contributor": ["idaho state historical society"], "date": "2014-01-01", "dates": ["2014"], "description": ["Also available in digital form on the Library of Congress Web site. Title from cover. Includes bibliographical references (pages 35-36). Description based on print version record."], "digitized": true, "extract_timestamp": "2022-05-07T14:01:39.174Z", "group": ["gdc/scd", "catalog-split-02", "catalog", "general-collections-scan-on-demand-new", "main-catalog-split-02", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2020445566/", "image_url": ["https://tile.loc.gov/storage-services/master/gdc/gdcebookspublic/20/20/44/55/66/2020445566/2020445566.gif", "https://tile.loc.gov/storage-services/master/gdc/gdcebookspublic/20/20/44/55/66/2020445566/2020445566.gif#h=401&w=310"], "index": 10, "language": ["english"], "location": ["idaho"], "mime_type": ["image/gif", "application/pdf"], "number": ["2020445566", "online resource", "2022-04-11t15:59:20"], "online_format": ["image", "pdf"], "original_format": ["book"], "other_title": ["Preserving our past, enriching our future, 2016-2022"], "partof": ["lc online resource", "u.s. government digital resources", "catalog", "general collections"], "score": 16.008514, "shelf_id": "F747", "site": ["catalog"], "subject": ["management", "planning", "historic sites", "historic preservation", "idaho"], "timestamp": "2022-12-10T08:57:03.544Z", "title": "Idaho State historic preservation plan, 2016-2022 : \"preserving our past, enriching our future\"", "type": ["text"], "url": "https://www.loc.gov/item/2020445566/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2013593230", "http://www.loc.gov/item/2013593230/", "https://search.catalog.loc.gov/instances/4a9b6546-873a-5fb6-a7ad-db3453c3d752", "https://hdl.loc.gov/loc.gmd/g3803r.la000545", "http://www.loc.gov/resource/g3803r.la000545/"], "campaigns": [], "contributor": ["smith, robert pearsall", "balch, e. a.", "rogerson, a. e. (andrew e.)"], "date": "1854", "dates": ["1854"], "description": ["General-content county map showing towns (townships), rural buildings, householders' names, and forested areas. Hand colored to emphasize town boundaries. Relief shown by hachures. \"Entered according to Act of Congress in the year 1854 by Robert Pearsall Smith in the ... Eastern District of Pennsylvania.\" LC copy imperfect: Mounted on cloth backing, fold-lined, quartered to enable folding. Includes statistical tables, local business directories, insets of Troy/Lansingburgh cities, 7 village insets, illustrations of prominent buildings/residences/bells, and state coat-of-arms. LC Land ownership maps, 545 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:27.072Z", "group": ["gmd.mar", "catalog-split-12", "catalog", "general-maps", "main-catalog-split-12"], "hassegments": false, "id": "http://www.loc.gov/item/2013593230/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd380/g3803/g3803r/la000545.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd380/g3803/g3803r/la000545.gif#h=210&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd380:g3803:g3803r:la000545/full/pct:12.5/0/default.jpg#h=2217&w=1582", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd380:g3803:g3803r:la000545/full/pct:25/0/default.jpg#h=4434&w=3165"], "index": 11, "language": ["english"], "location": ["rensselaer county", "lansingburgh", "new york", "new york (state)", "united states", "troy"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2013593230", "sheet", "2025-06-07t05:45:56", "2013-09-09t08:35:59"], "online_format": ["image"], "original_format": ["map"], "partof": ["cultural landscapes", "county landownership maps", "geography and map division", "catalog"], "score": 14.64134, "shelf_id": "G3803.R4 1854 .R6", "site": ["catalog"], "subject": ["rensselaer county", "maps", "lansingburgh (n.y.)", "united states", "lansingburgh", "villages", "troy", "rensselaer county (n.y.)", "new york (state)", "landowners", "troy (n.y.)"], "timestamp": "2026-04-29T16:08:18.461Z", "title": "Map of Rensselaer County, New York : from actual surveys", "type": ["cartographic"], "url": "https://www.loc.gov/item/2013593230/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2016585052", "http://www.loc.gov/item/2016585052/", "https://search.catalog.loc.gov/instances/55c74902-071e-5974-a9f4-55615c5675f2", "https://hdl.loc.gov/loc.gmd/g3804t.la002343", "http://www.loc.gov/resource/g3804t.la002343/"], "campaigns": [], "contributor": ["barton, william", "w. barton & j. chace jr", "barker, wm. j. (william j.)"], "date": "1858", "dates": ["1858"], "description": ["City cadastral street map showing lot/tract lines, lot numbers, names of owners of rural tracts, building coverage, ward boundaries, and ward numbers. Also covers West Troy (now City of Watervliet). Oriented with north toward the upper right. \"Entered according to act of Congress in the year 1858 by William Barton in the Clerks Office of the District Court for the Northern District of New York.\" No coloration is present. LC copy imperfect: Small areas lightly soiled/stained. Includes notes, statistical table, historical list of names of Troy city mayors, illustrations of prominent buildings, and advertisements. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:29.782Z", "group": ["gmd.mar", "catalog-split-02", "catalog", "general-maps", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/2016585052/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd380/g3804/g3804t/la002343.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd380/g3804/g3804t/la002343.gif#h=126&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd380:g3804:g3804t:la002343/full/pct:12.5/0/default.jpg#h=2408&w=2875", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd380:g3804:g3804t:la002343/full/pct:25/0/default.jpg#h=4816&w=5750"], "index": 12, "language": ["english"], "location": ["watervliet", "new york", "new york (state)", "united states", "troy"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2016-06-22t09:32:03", "2016585052", "2025-06-07t07:04:28.100000"], "online_format": ["image"], "original_format": ["map"], "partof": ["general maps", "county landownership maps", "geography and map division", "catalog"], "score": 14.64134, "shelf_id": "G3804.T7G46 1858 .B3", "site": ["catalog"], "subject": ["cadastral maps", "administrative and political divisions", "maps", "watervliet", "watervliet (n.y.)", "buildings", "buildings, structures, etc", "united states", "real property", "real oroperty", "troy (n.y.)", "new york (state)", "landowners", "troy"], "timestamp": "2026-04-29T16:09:11.150Z", "title": "City of Troy, N.Y. : from actual surveys", "type": ["cartographic"], "url": "https://www.loc.gov/item/2016585052/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/75694855", "http://www.loc.gov/item/75694855/", "https://search.catalog.loc.gov/instances/9a5049ed-c064-5f93-be