_ver01:data:sn85025570:00383348390:1937120901:0603/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn85025570/00383348390/1937120901/0612.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn85025570/1937-12-09/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn85025570/00383348390/1937120901/0612.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_limbo_ver01:data:sn85025570:00383348390:1937120901:0603/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn85025570/00383348390/1937120901/0612.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn85025570/1937-12-09/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn85025570/00383348390/1937120901/0612.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85025570/1937-12-09/ed-1/?sp=10"], "batch": ["mnhi_limbo_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/minnesota/", "2/united states/minnesota/redwood/", "3/united states/minnesota/redwood/redwood falls/"], "contributor": ["minnesota historical society; saint paul, mn"], "date": "1937-12-09", "dates": ["1937-12-09"], "description": ["THE REDWOOD GAZETTE Published By REDWOOD GAZETTE PUB CO Inc SCOTT SCHOEN EDITOR Entered as Second Class Matter at the Posteffice Redwood Falls Minnesota under Act of March B 1879 68 Years of Service to City and County MEMBER National Editorial Association Minnesota Editorial Association Redwood County Press Association Subscription price 2 per year Outside United States 250 GOVERNOR BENSON WENT OUT to California last week to help in another attempt to get Tom Mooney out of jail Which strikes us as a long way to go to get into an argument THE THOMAS J MOONEY AND Warren K Billings convictions for murder in connection with the preparedness parade bombings in 1916 may or may not have been just California courts evidently think there was no mistake since the men are still in jail but noisy efforts to obtain their re lease have been the hottest kind of political appeal to the radical labor vote for two de cades and Benson is only following the ex ample of Floyd B Olson in his efforts TO MOST MINNESOTANS THE KIND of labor troubles we have had in Minnesota particularly Minneapolis and the current trouble there which led to the murder of"], "digitized": true, "extract_timestamp": "2024-01-04T03:52:54.721Z", "group": ["ndnp/mnhi", "minnesota-historical-society-saint-paul-mn-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85025570/1937-12-09/ed-1/?sp=10", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_limbo_ver01:data:sn85025570:00383348390:1937120901:0612/full/pct:3.125/0/default.jpg#h=291&w=233", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_limbo_ver01:data:sn85025570:00383348390:1937120901:0612/full/pct:6.25/0/default.jpg#h=582&w=466", "https://tile.loc.gov/image-services/iiif/service:ndnp:mnhi:batch_mnhi_limbo_ver01:data:sn85025570:00383348390:1937120901:0612/full/pct:12.5/0/default.jpg#h=1165&w=932", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mnhi/batch_mnhi_limbo_ver01/data/sn85025570/00383348390/1937120901/0612.xml&format=alto_xml"], "index": 10, "language": ["english"], "location": ["redwood", "minnesota", "redwood county", "redwood falls", "united states"], "location_city": ["redwood falls"], "location_country": ["united states"], "location_county": ["redwood"], "location_state": ["mi