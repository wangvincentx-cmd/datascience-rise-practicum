master general a place he has filled to the entire sat isf action of the postmaster general and the administration Most of this ffossio has arisen from a call on the secretary of war by Mr Hitchcock on the return of the for mer from the far"], "digitized": true, "extract_timestamp": "2020-09-15T12:07:14.994Z", "group": ["ndnp/mohi", "state-historical-society-of-missouri-columbia-mo-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89066129/1908-01-18/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_linus_ver01:data:sn89066129:00294557209:1908011801:0443/full/pct:6.25/0/default.jpg#h=419&w=279", "https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_linus_ver01:data:sn89066129:00294557209:1908011801:0443/full/pct:12.5/0/default.jpg#h=839&w=559", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mohi/batch_mohi_linus_ver01/data/sn89066129/00294557209/1908011801/0443.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["linn", "united states", "laclede", "missouri"], "location_city": ["laclede"], "location_country": ["united states"], "location_county": ["linn"], "location_state": ["missouri"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000004", "5", "0", "2", "1", "4", "7", "9", "sn89066129"], "number_edition": ["1"], "number_lccn": ["sn89066129"], "number_page": ["0000000004"], "number_reel": ["0", "0", "2", "9", "4", "5", "5", "7", "2", "0", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the laclede blade (laclede, mo.) 1890-1945"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the laclede blade (laclede, mo.) 1890-1945"], "publica