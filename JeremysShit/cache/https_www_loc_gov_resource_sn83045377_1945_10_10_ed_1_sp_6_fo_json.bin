nian", "illinois"], "timestamp": "2026-05-26T20:55:54.213Z", "title": "Proletarec", "type": ["title"], "url": "https://www.loc.gov/item/2018218543/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83045203/", "http://lccn.loc.gov/sn83045203", "https://search.catalog.loc.gov/instances/5dd0cc8e-6ee8-5250-a28d-25e96baeca75"], "batch": ["iune_iris_ver02"], "campaigns": [], "date": "1902", "description": ["Semiweekly, Apr. 1925-<Apr. 12, 1927> Published 1902-1931? Cf. Gregory, W. Amer. newspapers. Publisher varies. Published on Tuesday and Friday (Monday, Wednesday, and Friday, Feb. 1923-Mar. 1925). \"Glasilo svobodomiselnih Slovencev v Ameriki.\" Archived issues are available in digital format from the Library of Congress Chronicling America online collection. In Slovenian. Description based on: Vol. 16, no. 69 (Aug. 28th, 1917)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:14.592Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-10", "catalog", "united-states-newspaper-directory", "main-catalog-split-10"], "hassegments": false, "id": "http://www.loc.gov/item/sn83045203/", "image_url": [], "index": 8, "language": ["slovenian"], "latlong": [41.883229, -87.632398], "location": ["united states", "chicago", "cook", "illinois"], "location_str": "", "lonlat": [-87.632398, 41.883229], "number": ["microfilm master", "2025-07-01t13:40:44.100000", "http://www.loc.gov/item/sn83045203/1922-12-29/ed-1/", "online resource", "557", "center for res libr, newsp proj", "1", "microfilm service copy", "2025-05-12t17:27:14.722511", "9353628", "http://www.loc.gov/item/sn83045203/1917-08-28/ed-1/", "2643-6345", "sn83045203", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Voice of liberty"], "partof": ["glas svobode (chicago, ill.) 1902-1931", "catalog", "chronicling america", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["semiweekly"]