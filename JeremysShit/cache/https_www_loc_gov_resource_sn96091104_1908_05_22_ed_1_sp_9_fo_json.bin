apers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218396/", "image_url": [], "index": 10, "language": ["english"], "location": ["tennessee", "maury", "maury county", "columbia", "united states"], "number": ["online resource", "2373-4698", "881273860", "2014218396", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the herald and mail (columbia, tennessee) 1873-188? [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 71.404045, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["tennessee", "newspapers", "maury county (tenn.)", "maury", "maury county", "columbia", "columbia (tenn.)", "united states"], "timestamp": "2026-05-26T20:50:11.310Z", "title": "The herald and mail", "type": ["title"], "url": "https://www.loc.gov/item/2014218396/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218614/"], "campaigns": [], "date": "18??", "dates": ["[1800 TO 1935]"], "description": ["Weekly Ceased July 25, 1935. Published \"extra to weekly\" on Tue. from May 10-Nov. 29, 1892. Publishers: Columbia Herald Co., 1882-<1885>; Herald Pub. Co., 1892-1917; Columbia Herald Co., 1917-1935. Editors: F.D. Lander, 1889-1909; H.D. Harkreader, 1909; J.I. Finney, 1909-1917; Robert H. Clagett, 1917-1920; Richard H. Wyatt, 1920-1924; J.I. Finney, 1924-1925; J.W. Finney, 1925-1935. Continues: Herald and mail. Absorbed: Columbia journal (Columbia, Tenn. : 1875), and: Maury sentinel, in 1881. Description based on: Vol. XXVII, no. 40 (September 29, 1882); title from masthead Latest issue consulted: Vol. XLVI, no. 52 (December 27, 1901)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:27.286Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218614/", "image_url": [], "index": 11, "language": ["english"], "location": ["tennessee", "maury", "maury county", "columbia", "united states"], "number": ["2375-1878", "online resource", "2014218614", "891728831", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the columbia herald (columbia, tennessee) 18??-1935 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 71.404045, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["tennessee", "newspapers", "maury county (tenn.)", "maury", "maury county", "columbia", "columbia (tenn.)", "united states"], "timestamp": "2026-05-26T20:50:29.180Z", "title": "The Columbia herald", "type": ["title"], "url": "https://www.loc.gov/item/2014218614/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013218711/"], "campaigns": [], "date": "1850", "dates": ["[1850 TO 1873]"], "description": ["Weekly Began in 1850. Cf. Gregory, W. Amer. newspapers. Ceased with Dec. 19, 1873. Publishers: Hunter Nicholson, <1850-1865>; Alfred S. Horsley, <1869>-1871; Horsley & Figuers, 1871; Horsley Bros. & Figuers, 1871-1872. Editor: Hunter Nicholson, <1861, 1866>. Also issued in print. Merged with: Mail (Columbia, Tenn.), to form: Herald and mail. Vol. XI, no. 39 (May 12, 1866); title from masthead (Chroniclingamerica.loc.gov, viewed Apr 10, 2013). Vol. XVIII, no. 24 (December 20, 1872) (Chroniclingamerica.loc.gov, viewed Apr 10, 2013). Mail (Columbia, Tenn. : Online) Herald and mail (Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:20.215Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013218711/", "image_url": [], "index": 12, "language": ["english"], "location": ["tennessee", "maury", "maury county", "columbia", "united states"], "number": ["2013218711", "online resource", "2328-0913", "837600467", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "par