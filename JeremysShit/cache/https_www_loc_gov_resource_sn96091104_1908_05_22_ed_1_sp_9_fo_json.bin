essing very carefully R GEORGE Mt PleasantTenn REMEMBER THE OPENING DATE THURSDAY MAY 28th The entire 40000 stock of high grade"], "digitized": true, "extract_timestamp": "2020-10-19T16:57:29.316Z", "group": ["ndnp/tu", "university-of-tennessee-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn96091104/1908-05-22/ed-1/?sp=9", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:tu:batch_tu_louie_ver01:data:sn96091104:00415621541:1908052201:0840/full/pct:6.25/0/default.jpg#h=441&w=306", "https://tile.loc.gov/image-services/iiif/service:ndnp:tu:batch_tu_louie_ver01:data:sn96091104:00415621541:1908052201:0840/full/pct:12.5/0/default.jpg#h=883&w=613", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/tu/batch_tu_louie_ver01/data/sn96091104/00415621541/1908052201/0840.xml&format=alto_xml"], "index": 9, "language": ["english"], "location": ["tennessee", "maury", "maury county", "columbia", "united states"], "location_city": ["columbia"], "location_country": ["united states"], "location_county": ["maury"], "location_state": ["tennessee"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "0", "sn96091104", "0000000009", "5", "2", "1", "6"], "number_edition": ["1"], "number_lccn": ["sn96091104"], "number_page": ["0000000009"], "number_reel": ["0", "0", "4", "1", "5", "6", "2", "1", "5", "4", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "the columbia herald (columbia, tenn.) 18??-1935", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the columbia herald (columbia, tenn.) 18??-1935"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn96091104/1908-05-22/ed-1/?sp=9