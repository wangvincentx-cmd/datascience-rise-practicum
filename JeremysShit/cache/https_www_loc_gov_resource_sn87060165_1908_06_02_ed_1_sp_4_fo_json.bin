://lccn.loc.gov/95686019", "http://www.loc.gov/item/95686019/", "https://search.catalog.loc.gov/instances/e50afcc8-78f7-57b0-8df1-f98dc84b4e53", "https://hdl.loc.gov/loc.gmd/g3883s.ct009268", "http://www.loc.gov/resource/g3883s.ct009268/"], "campaigns": [], "contributor": ["virginia. division of mineral resources", "geological survey (u.s.)"], "date": "1991", "dates": ["1991"], "description": ["Relief shown by contours and spot heights. Title in left upper margin: Spotsylvania County, city of Fredericksburg, Virginia. Title in right lower margin: Spotsylvania County, city of Fredericksburg, Va. In center upper margin: Commonwealth of Virginia, Division of Mineral Resources. \"Map edited 1991.\" Includes location map, index to 24,000-scale maps, and conversion table. \"38077-C4-CF-050.\" Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:32.212Z", "group": ["gmd.mar", "catalog-split-12", "catalog", "general-maps", "main-catalog-split-12"], "hassegments": false, "id": "http://www.loc.gov/item/95686019/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd388/g3883/g3883s/ct009268.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd388/g3883/g3883s/ct009268.gif#h=119&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd388:g3883:g3883s:ct009268/full/pct:12.5/0/default.jpg#h=1436&w=1816", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd388:g3883:g3883s:ct009268/full/pct:25/0/default.jpg#h=2872&w=3633"], "index": 5, "language": ["english"], "location": ["virginia", "fredericksburg", "spotsylvania county", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t18:42:56.500000", "95686019", "sheet", "2020-08-07t09:02:32"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "geography and map division", "general maps"], "score": 57.62268, "shelf_id": "G3883.S6 1991 .G4", "site": ["catalog"], "subject": ["virginia", "spotsylvania county", "united states", "fredericksburg (va.)", "fredericksburg", "topographic maps", "spotsylvania county (va.)", "maps"], "timestamp": "2026-04-29T16:29:28.248Z", "title": "Spotsylvania County, city of Fredericksburg, Virginia : 1:50 000-scale topographic map", "type": ["cartographic"], "url": "https://www.loc.gov/item/95686019/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/csas/item/2017891842/", "http://www.loc.gov/item/2017891842/", "http://www.loc.gov/pictures/item/2017891842/", "https://hdl.loc.gov/loc.pnp/csas.06108", "http://www.loc.gov/resource/csas.06108/", "http://lccn.loc.gov/2017891842"], "campaigns": [], "contributor": ["johnston, frances benjamin"], "date": "1927-01-01", "dates": ["1927"], "description": ["1 negative : safety film ; 8 x 10 in."], "digitized": true, "extract_timestamp": "2021-09-01T23:09:47.197Z", "group": ["csas", "catalog-split-10", "catalog", "carnegie-survey-architecture-of-the-south", "main-catalog-split-10", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017891842/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/csas/06100/06108_150px.jpg#h=121&w=150", "https://tile.loc.gov/storage-services/service/pnp/csas/06100/06108r.jpg#h=516&w=640", "https://tile.loc.gov/storage-services/service/pnp/csas/06100/06108v.jpg#h=826&w=1024"], "index": 6, "language": ["english"], "location": ["fredericksburg", "spotsylvania county", "virginia", "united states"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/csas200906151", "2017891842", "http://www.loc.gov/item/2017891842", "2018-03-12t15:55:31", "http://www.loc.gov/item/20402461"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["carnegie survey of the architecture of the south", "catalog", "prints & photographs online catalog (library of congress)", "prints and photographs division"], "score": 35.051105, "shelf_id": "LC-J7-VA- 3038 [P&P]", "site": ["pictures", "catalog"], "subject": ["virginia", "spotsylvania county", "united states", "houses", "porches", "chimneys", "fredericksburg", "safety film negatives", "brickwork", "gables"], "timestamp": "2022-04-23T11:18:33.421Z", "title": "Oakley, Fredericksburg vic., Spotsylvania County, Virginia", "url": "https://www.loc.gov/item/2017891842/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/resource/gvhs01.vhs00232/", "http://www.loc.gov/item/gvhs01.vhs00232/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00232", "http://www.loc.gov/item/001-CABIB20007469/"], "campaigns": [], "contributor": ["sneden, robert knox"], "description": ["While labelled the Battle of the Wilderness (May 5-6), this map depicts troop locations and movements during engagements in the days immediately following as both armies met at Spotsylvania Court House (May 8-12) and Union forces under Grant made slow but steady progress moving southeast toward the James River and their ultimate goal, Richmond. This map encompasses the Rapidan River to the northeast, and identifies troops surrounding Old Wilderness Run and Wilderness Tavern in Spotsylvania County, Va. The location of Gen. Grant's Headquarters is also indicated."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:28.681Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00232/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00232.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00232.gif#h=150&w=247", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00232/full/pct:12.5/0/default.jpg#h=186&w=306", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00232/full/pct:25/0/default.jpg#h=373&w=613"], "index": 7, "language": ["english"], "location": ["virginia", "spotsylvania county", "united states"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-04-21t11:33:43"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "civil war maps", "geography and map division", "american memory"], "score": 33.385254, "shelf_id": "http://www.loc.gov/item/001-CABIB20007469/", "site": ["ammem"], "subject": ["history", "virginia", "wilderness, battle of the, va", "spotsylvania county", "united states", "spotsylvania county (va.)", "maps", "civil war", "wilderness, battle of the, va."], "timestamp": "2022-03-30T06:52:35.344Z", "title": "Plan of the Battle of the Wilderness, Va. : May 5th to 12th.", "url": "https://www.loc.gov/item/gvhs01.vhs00232/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/gvhs01.vhs00238/", "http://www.loc.gov/resource/gvhs01.vhs00238/", "http://www.loc.gov/item/001-CABIB20007476/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00238"], "campaigns": [], "contributor": ["sneden, robert knox"], "description": ["Shows the Confederate forces located around and to the north of Spotsylvania Court House, with the Po River at their back. The Union forces were positioned along the Ny River so as to attack on both the Confederate left and right. Several landmarks are indicated, including houses used as headquarters by various officers, and the \"mule shoe\" salient known as the \"bloody angle\" because of the fierce fighting and heavy losses required to take it."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:30.444Z", "group": ["gmd_vhs.mar", "virginia-historical-society-maps"], "hassegments": false, "id": "http://www.loc.gov/item/gvhs01.vhs00238/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00238.gif", "https://tile.loc.gov/storage-services/service/gmd/gmdvhs/gvhs/gvhs01/vhs00238.gif#h=195&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00238/full/pct:25/0/default.jpg#h=494&w=379"], "index": 8, "language": ["english"], "location": ["virginia", "spotsylvania county", "united states"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-04-21t17:00:09"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "civil war maps", "geography and map division", "american memory"], "score": 33.385254, "shelf_id": "http://www.loc.gov/item/001-CABIB20007476/", "site": ["ammem"], "subject": ["history", "spotsylvania court house, battle of va.", "virginia", "spotsylvania court house, battle of, va", "spotsylvania county", "united states", "spotsylvania county (va.)", "maps", "civil war"], "timestamp": "2022-03-30T06:52:35.344Z", "title": "Plan of the Battle of Spotsylvania C.H., Virginia : fought May 8th to 21st 1864.", "url": "https://www.loc.gov/item/gvhs01.vhs00238/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/001-CABIB20007643/", "https://hdl.loc.gov/loc.ndlpcoop/gvhs01.vhs00262", "http://www.loc.gov/resource/gvhs01.vhs00262/", "http://www.loc.gov/item/gvhs01.vhs00262/"], "campaigns": [], "contributor": ["paine, william h.", "sneden, robert knox"], "description": ["Map depicts Hooker's attempt to flank Lee's position at Fredericksburg via Kelly's Ford and Chancellorsville, which backfired when Lee discovered it. Dividing his forces, Lee turned half to meet Hooker's Federals head on near Chancellorsville while Jackson's division moved through the Wilderness to flank Hooker's right. Meanwhile, Sedgwick's forces managed to cross the Rappahannock opposite Fredericksburg and dislodge the Confederates holding Marie's Heights, but were prevented from moving west to relieve Hooker by Early and forced back across the river. Hooker, despite his strongly entrenched position, believed himself outnumbered, and so also retreated north of the river."], "digitized": true, "extract_timestamp": "2020-09-23T16:30:33.992Z", "group": ["gmd_vhs.mar", 