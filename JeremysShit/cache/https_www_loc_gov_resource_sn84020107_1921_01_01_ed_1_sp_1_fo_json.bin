ed": true, "extract_timestamp": "2026-05-19T21:38:15.756Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2024271114/", "image_url": [], "index": 2, "language": ["english"], "location": ["gage", "gage county", "united states", "nebraska", "beatrice"], "number": ["2026-04-13t21:30:13", "1435957185", "online resource", "2024271114", "2997-8939"], "original_format": ["newspaper"], "partof": ["the beatrice daily express (beatrice, nebraska) 1884-1924 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 68.468605, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["gage county (neb.)", "gage", "gage county", "united states", "nebraska", "beatrice", "newspapers"], "timestamp": "2026-05-26T21:13:57.142Z", "title": "The Beatrice daily express", "type": ["title"], "url": "https://www.loc.gov/item/2024271114/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn85038008/", "http://lccn.loc.gov/sn85038008", "https://search.catalog.loc.gov/instances/babda716-583d-5740-912c-4dbc211d9ffb"], "batch": ["nbu_europeanstarling_ver01"], "campaigns": [], "contributor": ["international council of women", "nebraska woman suffrage association", "national american woman suffrage association"], "date": "1883", "description": ["Fortnightly, Apr. 30, 1904-<Mar. 6, 1909> Ceased in 1909. [Vol. 1, no. 1] (Aug. 1883)- \"Equality Before the Law.\" Published in Beatrice, Neb., Aug. 1883-Nov. 16, 1889, Washington, D.C. and Beatrice, Neb., Dec. 7, 1889-Dec. 31, 1892, Washington, D.C., Jan. 7, 1893-Aug. 20, 1904, Portland, Or., and Washington, D.C., Oct. 29, 1904-May 26, 1906, and Portland, Or., June [9], 1906-<Mar. 6, 1909>. Published daily in Washington, D.C. during the International Council of Women, Mar. 27-Apr. 5, 1888, and the 25th and 26th Annual National American Woman Suffrage Association Convention, Jan. 14-19, 1893 and Feb. 15-24, 1894. No issues published between Aug.-Nov. 1, 1883, Aug. 20-Oct. 29, 1904, Oct. 26, 1907-Jan. 4, 1908, and Dec. 12, 1908-Mar. 6, 1909. Also issued online as part of the Gerritsen collection of Aletta H. Jacobs."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:16.670Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-01", "catalog", "united-states-newspaper-directory", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/sn85038008/", "image_url": [], "index": 3, "language": ["english"], "latlong": [40.267947, -96.746795], "location": ["portland", "multnomah", "gage", "washington d.c.", "united states", "oregon", "nebraska", "beatrice"], "location_str": "", "lonlat": [-96.746795, 40.267947], "number": ["original", "harriet beecher stowe ctr", "chicago hist soc libr", "2026-04-13t21:30:13", "univ of texas at austin", "721", "11614854", "univ of georgia", "1", "western rsv hist soc, newsp proj", "2025-05-23t21:30:26", "online resource", "sn85038008", "wisconsin hist soc, newsp proj", "http://www.loc.gov/item/sn85038008/1883-08-01/ed-1/", "1938-4475", "http://www.loc.gov/item/sn85038008/1909-03-06/ed-1/", "2025-11-07t12:30:39.300000"], "original_format": ["newspaper"], "partof": ["chronicling america", "directory of u.s. newspapers in american libraries", "serial and government publications division", "catalog", "rare book and special collections division", "the woman's tribune ([beatrice, nebraska]) 1883-1909"], "publication_frequency": ["other"], "score": 43.6785, "shelf_id": "JK1880 .W7", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["beatrice (neb.)", "washington (d.c.)", "portland", "multnomah", "portland (or.)", "women", "gage", "united states", "women's rights", "oregon", "nebraska", "beatrice", "newspapers", "suffrage"], "timestamp": "2026-07-18T09:15:01.231Z", "title": "The woman's tribune", "type": ["title"], "url": "https://www.loc.gov/item/sn8