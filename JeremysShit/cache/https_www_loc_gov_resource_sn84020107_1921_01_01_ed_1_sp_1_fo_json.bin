www.loc.gov/resource/sn84020107/1921-01-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_housesparrow_ver01/data/sn84020107/00517014679/1921010101/0374.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_housesparrow_ver01:data:sn84020107:00517014679:1921010101:0374/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/nbu/batch_nbu_housesparrow_ver01/data/sn84020107/00517014679/1921010101/0374.pdf", "segment_count": 6, "url": "https://www.loc.gov/resource/sn84020107/1921-01-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/nbu/batch_nbu_housesparrow_ver01/data/sn84020107/00517014679/1921010101/0374.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020107/1921-01-01/ed-1/?sp=1"], "batch": ["nbu_housesparrow_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/nebraska/", "2/united states/nebraska/gage/", "3/united states/nebraska/gage/beatrice/"], "contributor": ["university of nebraska-lincoln libraries, lincoln, ne"], "date": "1921-01-01", "dates": ["1921-01-01"], "description": ["FORECAST FOR i 1921 BRIGHT BUSINESS DEPRESSION BEGIN NING TO DISSOLVE VIEWS OF PRICE EXPERT Optimistic Prediction of Govern ment Officials and Business Men Is Based on Facts Now Developing Washington Jan 1Prosperity like the lowers ot the song will bloom In the spring The business depression Is already beginning to dissolve This according to government of ficials in the treasury agriculture and labor departments is the fore cast for 1921 If true the forecast means an end of unemployment now involving hundreds of thousands of workers It also will end the great national buying strike which swept the entire country early in the summer Ethelbert Stewart government price expert believes the 1921 prices should be far lower than those at present Business depression will disap pear within a few weeks if manu facturers and retail dealers will give up the idea that they can cling to war prices he said The buying public is in need of almost every necessity If prices were reduced to a reasonable point there would be a new rush of buy ing which would turn every factory wheel in the country and blot out unemployment almost immediately The optimistic prediction of gov ernment officials"], "digitized": true, "extract_timestamp": "2025-12-01T12:41:43.519Z", "group": ["ndnp/nbu", "university-of-nebraska-of-nebraska-lincoln-libraries-lincoln-ne-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020107/1921-01-01/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_housesparrow_ver01:data:sn84020107:00517014679:1921010101:0374/full/pct:6.25/0/default.jpg#h=424&w=322", "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_housesparrow_ver01:data:sn84020107:00517014679:1921010101:0374/full/pct:12.5/0/default.jpg#h=848&w=644", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_housesparrow_ver01/data/sn84020107/00517014679/1921010101/0374.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["gage", "gage county", "united states", "nebraska", "beatrice"], "location_city": ["beatrice"], "location_country": ["united states"], "location_county": ["gage"], "location_state": ["nebraska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "sn84020107", "1", "4", "7", "9", "6", "0000000001"], "number_edition": ["1"], "number_lccn": ["sn84020107"], "number_page": ["0000000001"], "number_reel": ["0", "0", "5", "1", "7", "0", "1", "4", "6",