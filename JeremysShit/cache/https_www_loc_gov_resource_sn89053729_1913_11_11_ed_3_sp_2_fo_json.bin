{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn89053729/?st=calendar", "cite_this": {"apa": "(1913, November 11)  <cite>Atlanta Georgian</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn89053729/1913-11-11/ed-3/.", "chicago": "<cite>Atlanta Georgian</cite>. (Atlanta, GA), Nov. 11 1913. https://www.loc.gov/item/sn89053729/1913-11-11/ed-3/.", "mla": "<cite>Atlanta Georgian</cite>. (Atlanta, GA) 11 Nov. 1913, p. 2. Retrieved from the Library of Congress, www.loc.gov/item/sn89053729/1913-11-11/ed-3/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_kesil_ver01/data/sn89053729/00393344581/1913111103/0785.xml&format=alto_xml&full_text=1", "item": {"_version_": 1799816824938823680, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn89053729/1913-11-11/ed-3/", "http://www.loc.gov/resource/sn89053729/1913-11-11/ed-3/"], "batch": ["gu_kesil_ver01"], "call_number": ["Newspaper"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/georgia/", "2/united states/georgia/fulton/", "3/united states/georgia/fulton/atlanta/"], "contributor_names": ["Digital Library of Georgia, a project of GALILEO located at the University of Georgia Libraries"], "contributors": [{"digital library of georgia, a project of galileo located at the university of georgia libraries": "https://www.loc.gov/search/?fa=contributor:digital+library+of+georgia,+a+project+of+galileo+located+at+the+university+of+georgia+libraries&fo=json"}], "created_published": ["Atlanta, Ga., November 11, 1913"], "date": "1913-11-11", "date_issued": "1913-11-11", "dates": [{"1913-11-11": "https://www.loc.gov/search/?dates=1913-11-11/1913-11-11&fo=json"}], "dates_of_publication": "1912-1939", "description": ["Atlanta, Ga."], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2024-05-22T12:58:30.451Z", "extract_urls": ["file:/service/ndnp//gu/batch_gu_kesil_ver01/data/sn89053729/00393344581/1913111103/1913111103_1.xml#ndnp/gu"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/gu", "digital-library-of-georgia-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn89053729/1913-11-11/ed-3/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_kesil_ver01:data:sn89053729:00393344581:1913111103:0784/full/pct:3.125/0/default.jpg#h=257&w=213", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_kesil_ver01:data:sn89053729:00393344581:1913111103:0784/full/pct:6.25/0/default.jpg#h=514&w=426", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_kesil_ver01:data:sn89053729:00393344581:1913111103:0784/full/pct:12.5/0/default.jpg#h=1028&w=852"], "index": 2, "item": {"batch": ["gu_kesil_ver01"], "call_number": ["Newspaper"], "contributor_names": ["Digital Library of Georgia, a project of GALILEO located at the University of Georgia Libraries"], "created_published": ["Atlanta, Ga., November 11, 1913"], "date": "1912", "date_issued": "1913-11-11", "dates": ["1913-11-11"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn89053729", "location": ["Atlanta (Ga.)", "Fulton County (Ga.)", "Georgia--Atlanta", "Georgia--Fulton County"], "medium": "12 pages", "newspaper_title": ["Atlanta Georgian"], "notes": ["Daily", "Began with vol. 10, no. 218 (Apr. 13, 1912); ceased with v. 38, no. 292 (Dec. 16, 1939).", "Published in several chronological editions. Some issues may also carry statements such as \"Florida extra\" and \"Extra for Carolina\"; cannot always be determined whether these issues are part of true separate geographical editions.", "Some irregularities in enumeration.", "Stated publication frequency is every afternoon except Sunday, <May 3, 1912>-September 12, 1913. Sunday American appears to have consituted the Sunday issue of this title and to have existed also as a separate publication in editions for various cities.", "Sunday edition has its own numbering.", "Archived issues are available in digital format from the Library of Congress Chronicling America online collection.", "American Sunday monthly magazine may appear as part of Sunday issue, <June 1913->. May have been issued with various newspapers.", "Unable to determine relationship to: The Georgian's weekly news briefs and its succeeding title: Weekly Georgian (Atlanta, Ga.). May be weekly editions of this title or may simply be titles also published by the Georgian Company.", "Vol. X, no. 236 (May 3, 1912) (extra) (online surrogate); title from masthead (Georgia Historic Newspapers archive, viewed July 29, 2021).", "Vol. XIV, no. 31(September 8, 1915) (final) (online surrogate) (Georgia Historic Newspapers archive, viewed July 29, 2021).", "Atlanta journal (Atlanta, Ga. : 1889) (DLC)sn 82015426 (OCoLC)8807964"], "other_formats": ["https://tile.loc.gov/storage-services/service/ndnp//gu/batch_gu_kesil_ver01/data/sn89053729/00393344581/1913111103/1913111103_1.xml", "http://lccn.loc.gov/sn89053729/marcxml"], "other_title": ["Atlanta Georgian and news", "Sunday issues published with title: Sunday American", "Sunday issues may be called: Hearst's Sunday American", "Sunday issues may sometimes be called: Atlanta American", "One extra for May 31, 1913 called: Georgian Atlanta", "May sometimes be called: Georgian-American"], "place_of_publication": "Atlanta, Ga.", "raw_lccn": "sn 89053729 ", "reel_numbers": ["00393344581"], "source_group": "ndnp/gu", "subjects": ["Atlanta (Ga.)--Newspapers", "Fulton County (Ga.)--Newspapers", "Georgia--Atlanta", "Georgia--Fulton County", "United States--Georgia--Fulton--Atlanta"], "title": "Atlanta Georgian (Atlanta, Ga.), November 11, 1913, (EVENING)"}, "language": ["english"], "languages": [{"english": "https://www.loc.gov/search/?fa=l