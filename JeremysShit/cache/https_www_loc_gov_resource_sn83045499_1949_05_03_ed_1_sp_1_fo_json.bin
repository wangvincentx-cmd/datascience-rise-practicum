ov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_junco_ver01/data/sn83045499/00514154442/1949050301/0755.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_junco_ver01:data:sn83045499:00514154442:1949050301:0755/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ak/batch_ak_junco_ver01/data/sn83045499/00514154442/1949050301/0755.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn83045499/1949-05-03/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ak/batch_ak_junco_ver01/data/sn83045499/00514154442/1949050301/0755.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83045499/1949-05-03/ed-1/?sp=1"], "batch": ["ak_junco_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/alaska/", "2/united states/alaska/juneau/", "3/united states/alaska/juneau/juneau/"], "contributor": ["alaska state library historical collections"], "date": "1949-05-03", "dates": ["1949-05-03"], "description": ["THE DAILY ALASKA EMPIRE ALL THE NEWS ALL THE TIME VOL LXXIII NO 11186 JUNEAU ALASKA TUESDAY MAY 3 1949 MEMBER ASSOCIATED PRESS PRICE TEN CENTS REDS CAPTURE KWANGJEH IN NEW ACTION Victory by Communists Is Also Claimed Along Border By FRED HAMPSON SHANGHAIKwangteh im portant city midway between Wuhu end Hangchow has been captured by Red troops the Peiping Com munist radio said today The radio claimed victory for the Communists in a battle on the borders of KiangsuAnhwei and Chekiang provinces The radio said 2400 Nationalists were captured The report has not been con firmed by any other source Eflorts to telephone Hangchow 121 miles southwest of here brought the reply the lines were out of order TATUNG TAKEN The Communist radio said also that Tatung 125 miles west of Peiping had teen taken The city last Nationalist bastion north of the Yangtze except surrounded Tsingtao on the coast surrendered on May 1 the radio said Tsingtao is the base of the US Western Pacific fleet WARSHIPS SUNK A Nationalist garrison communi que earlier said that six Chinese warships captured at Nanking by the Communists had been sunk by government planes The assertion came a few hours after"], "digitized": true, "extract_timestamp": "2024-05-22T13:01:08.949Z", "group": ["ndnp/ak", "alaska-state-library-historical-collections-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045499/1949-05-03/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_junco_ver01:data:sn83045499:00514154442:1949050301:0755/full/pct:6.25/0/default.jpg#h=419&w=330", "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_junco_ver01:data:sn83045499:00514154442:1949050301:0755/full/pct:12.5/0/default.jpg#h=839&w=661", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_junco_ver01/data/sn83045499/00514154442/1949050301/0755.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["juneau", "united states", "alaska"], "location_city": ["juneau"], "location_country": ["united states"], "location_county": ["juneau"], "location_state": ["alaska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["4", "0", "sn83045499", "0000000001", "5", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn83045499"], "number_page": ["0000000001"], "number_reel": ["0", "0", "5", "1", "4", "1", "5", "4", "4", "4", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the daily alaska empire (juneau, alaska) 1926-1964", "chronicling america", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications divisio