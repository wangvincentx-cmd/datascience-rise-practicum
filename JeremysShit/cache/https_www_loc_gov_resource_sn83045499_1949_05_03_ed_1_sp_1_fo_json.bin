cabc-5492-9d64-499006e907f4", "https://hdl.loc.gov/loc.gmd/gmdtitlecolmaps.ak-050", "http://www.loc.gov/resource/gmdtitlecolmaps.ak-050/", "https://hdl.loc.gov/loc.gmd/gmdtitlecolfold.ak-050", "http://www.loc.gov/resource/gmdtitlecolfold.ak-050/"], "campaigns": [], "date": "1867", "dates": ["1867"], "description": ["This record covers single maps of Alaska cities and towns, which are not represented in the LC database by separate catalog records. This collection includes single printed maps and blueline prints and photocopies of printed or manuscript single maps and may also include some multi-sheet single maps, plates from atlases, books or periodicals, and printed facsimiles. These maps may also show various subjects, such as recreation and tourism. To request a specific map or for more information, contact a reference librarian in the Geography & Map Division (202) 707-6277 or through the \"Ask a librarian\" link through the Geography & Map Division website https://ask.loc.gov/map-geography/. Title supplied by cataloger. If a map in this collection may be in copyright, there is no online image available. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:17:56.090Z", "group": ["gmd/multimap", "catalog-split-07", "catalog", "multimaps", "main-catalog-split-07"], "hassegments": true, "id": "http://www.loc.gov/item/2022589353/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:ak:-0:50:ak-050:ak5027/full/pct:12.5/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:ak:-0:50:ak-050:ak5027/full/pct:12.5/0/default.jpg#h=1636&w=5687", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdtitlecolmaps:ak:-0:50:ak-050:ak5027/full/pct:25/0/default.jpg#h=3273&w=11375"], "index": 4, "language": ["english"], "location": ["juneau", "united states", "klukwan", "alaska"], "mime_type": ["image/tiff", "image/jpeg", "image/jp2"], "