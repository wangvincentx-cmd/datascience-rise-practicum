ly"], "score": 61.059917, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "south carolina", "abbeville county (s.c.)", "abbeville county", "abbeville (s.c.)", "abbeville", "united states"], "timestamp": "2026-05-26T20:50:11.310Z", "title": "Abbeville press", "type": ["title"], "url": "https://www.loc.gov/item/2014218386/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218606/"], "campaigns": [], "date": "1853", "dates": ["[1853 TO 1860]"], "description": ["Weekly Began in 1853; ceased with volume VIII, no. 27 (November 2, 1860). Publishers: W. A. Lee and Hugh Wilson, Jr., <January 6>-November 2, 1860. Description based on: Volume 2, no. 4 (June 3, 1854), whole number 56; title from mastead (Chroniclingamerica.loc.gov, viewed September 24, 2014). Latest issue consulted: Volume VIII, no. 27 (November 2, 1860) (Chroniclingamerica.loc.gov, viewed September 24, 2014). Abbeville press (Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:27.286Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218606/", "image_url": [], "index": 9, "language": ["english"], "location": ["abbeville", "united states", "south carolina", "abbeville county"], "number": ["2026-04-13t21:30:13", "online resource", "2375-0170", "887952497", "2014218606"], "original_format": ["newspaper"], "partof": ["the independent press (abbeville c.h., south carolina) 1853-1860 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 61.059917, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "south carolina", "abbeville county (s.c.)", "abbeville county", "abbeville (s.c.)", "abbeville", "united states"], "timestamp": "2026-05-26T20:50:29.180Z", "title": "The independent press", "type": ["title"], "url": "https://www.loc.gov/item/2014218606/"}], 