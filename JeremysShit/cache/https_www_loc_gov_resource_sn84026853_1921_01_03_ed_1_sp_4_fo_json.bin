ica.loc.gov, viewed May 21, 2014). Abbeville banner (Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:26.498Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014216368/", "image_url": [], "index": 5, "language": ["english"], "location": ["abbeville", "united states", "south carolina", "abbeville county"], "number": ["online resource", "2373-1346", "2014216368", "880355815", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the banner (abbeville, c.h., s.c.) 1844-1847 [online resource]"], "publication_frequency": ["weekly"], "score": 61.059917, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "south carolina", "abbeville county (s.c.)", "abbeville county", "abbeville (s.c.)", "abbeville", "united states"], "timestamp": "2026-05-26T20:49:47.660Z", "title": "The banner", "type": ["title"], "url": "https://www.loc.gov/item/2014216368/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218290/"], "campaigns": [], "date": "1869", "dates": ["[1869 TO 1924]"], "description": ["Triweekly, Jan. 7, 1920-Feb. 13, 1924 Began with volume XVII, no. 23 (October 1, 1869); ceased with February 13, 1924 issue. Title varies slightly. Publisher: The Press and Banner Company, <January 9-December 29, 1922>. Formed by the union of: Abbeville press and: Abbeville banner. Description based on: Volume XVII, no. 23 (October 1, 1869); title from masthead (Chroniclingamerica.loc.gov, viewed April 30, 2014). Latest issue consulted: 78th Year (December 29, 1922) (Chroniclingamerica.loc.gov, viewed April 30, 2014). Press and banner (Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:25.703Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218290/", "image_url": [], "index": 6, "language": ["english"], "location": ["abbeville", "united states", "south carolina", "abbeville county"], "number": ["878675611", "2372-6776", "online resource", "2014218290", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Issues for Sept. 9-Oct. 23, 1912 have caption title: Press and banner"], "partof": ["directory of u.s. newspapers in american libraries", "the abbeville press and banner (abbeville, s.c.) 1869-1924 [online resource]", "serial and government publications division"], "publication_frequency": ["triweekly"], "score": 61.059917, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "south carolina", "abbeville county (s.c.)", "abbeville county", "abbeville (s.c.)", "abbeville", "united states"], "timestamp": "2026-05-26T20:50:11.310Z", "title": "The Abbeville press and banner", "type": ["title"], "url": "https://www.loc.gov/item/2014218290/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2014218369/"], "campaigns": [], "date": "1847", "dates": ["[1847 TO 1869]"], "description": ["Weekly Bean with vol. 4, no. 1 (March 3, 1847); ceased with volume XXV, no. 47 (September 29, 1869). Publication suspended, <1861-1865>. Publisher: W.W. Farrow, <September 29, 1869>. Description based on: Vol. 4, no. 1 (March 3, 1847); title from masthead (Chroniclingamerica.loc.gov, viewed May 21, 2014). Latest issue consulted: Volume XXV, no. 47 (September 29, 1869) (Chroniclingamerica.loc.gov, viewed May 21, 2014). Abbeville press (Online) Abbeville press and banner (Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:26.498Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218369/", "image_url": [], "index": 7, "language": ["english"], "location": ["abbeville", "united states", "south carolina", "abbeville county"], "number": ["online resource", "880356652", "2373-1389", "2014218369", "2026-04-1