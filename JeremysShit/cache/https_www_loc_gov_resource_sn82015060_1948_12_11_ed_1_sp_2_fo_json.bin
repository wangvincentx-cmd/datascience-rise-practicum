/item/2017788818/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn82015060/00332897986/1948121101/0113.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_cinnabar_ver01:data:sn82015060:00332897986:1948121101:0112/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn82015060/00332897986/1948121101/0113.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn82015060/1948-12-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn82015060/00332897986/1948121101/0113.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_cinnabar_ver01:data:sn82015060:00332897986:1948121101:0112/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn82015060/00332897986/1948121101/0113.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn82015060/1948-12-11/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn82015060/00332897986/1948121101/0113.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82015060/1948-12-11/ed-1/?sp=2"], "batch": ["iune_cinnabar_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/illinois/", "2/united states/illinois/cook county/", "3/united states/illinois/cook county/chicago/"], "contributor": ["university of illinois at urbana-champaign library, urbana, il"], "date": "1948-12-11", "dates": ["1948-12-11"], "description": ["Prices still unbridled unemployment going up Is depression around the corner Has inflation reached its peak How secure is the job These questions made headlines throughout the nation this week and created new fears in budgetbroken homes Out of the welter ot gov ernment reports and state ments from business econom ists certain facts were undis puted Skyrocketing prices have drained away savings and cut consumer goods purchases to the point where retail sales are dropping Cutbacks in various consumer goods industries are reported and a slowdown has started in housing construction With workers unable to buy back the commodities they turn out of the factories unemploy ment is spreading Staggering cuts in prices paid by Big Business to farmers for corn and wheat have resulted in the almost imperceptible drop of only 15 per cent in food costs to the consumer while other home budget prices continue the inflationary spiral Corporation profits which reached the alltime high of 17000000000 in 1947 are ex pected to zoom on up to 20 400000000 this year according to the U S Department of Com merce Big Business and Big Brass joined in pressuring the govern ment for even greater war ex penditures"], "digitized": true, "extract_timestamp": "2025-05-21T10:17:58.603Z", "group": ["ndnp/iune", "university-of-illinois-at-urbana-champaign-library-urbana-il-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82015060/1948-12-11/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_cinnabar_ver01:data:sn82015060:00332897986:1948121101:0113/full/pct:6.25/0/default.jpg#h=307&w=209", "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_cinnabar_ver01:data:sn82015060:00332897986:1948121101:0113/full/pct:12.5/0/default.jpg#h=614&w=418", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_cinnabar_ver01/data/sn82015060/00332897986/1948121101/0113.xml&forma