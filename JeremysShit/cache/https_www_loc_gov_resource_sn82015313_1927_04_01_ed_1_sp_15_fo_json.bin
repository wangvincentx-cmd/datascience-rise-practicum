iif/service:ndnp:in:batch_in_feynman_ver01:data:sn82015313:00383348997:1927040101:0071/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/in/batch_in_feynman_ver01/data/sn82015313/00383348997/1927040101/0085.pdf", "segment_count": 28, "url": "https://www.loc.gov/resource/sn82015313/1927-04-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/in/batch_in_feynman_ver01/data/sn82015313/00383348997/1927040101/0085.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82015313/1927-04-01/ed-1/?sp=15"], "batch": ["in_feynman_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/indiana/", "2/united states/indiana/marion/", "3/united states/indiana/marion/indianapolis/"], "contributor": ["indiana state library"], "date": "1927-04-01", "dates": ["1927-04-01"], "description": ["Second Section f 1 1 i BUSINESS OUTLOOK HERE NEVER BETTERVERDICT SISTER OF LENIN INDIES UNIQUE NEWSPAPER POST Conducts Department De voted to Complaints Made by Workers Bu United Press MOSCOW April 1 Lenins sister is a newspaper editor with a job unlike that of any other person engaged in newspaper work She is the editor of the complaints depart ment of Pravda the Communist partys official publication Anybody with a grievance is in vited to air it in this fourcolumn de partment of Pravda and many and strange are the articles which ap pear there The Soviet officials keep a sharp watch on these columns and make investigations of the com plaints Most of the criticisms concern bosses in the factories The Bolshe vik count the privilege on complaint concerning their bosses as one of the finest new liberties won by the work ers in the 1917 uprising Comrade Berkovetz runs a typi cal complaint is never to be found at her work as manager of the Mos cow subdepartment for protection of mothers and babies She is al ways in conference or at meetings or busy in her studio whenever one wants to see her Comrade Berko is"], "digitized": true, "extract_timestamp": "2023-08-22T13:11:51.657Z", "group": ["ndnp/in", "indiana-state-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82015313/1927-04-01/ed-1/?sp=15", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_feynman_ver01:data:sn82015313:00383348997:1927040101:0085/full/pct:6.25/0/default.jpg#h=512&w=382", "https://tile.loc.gov/image-services/iiif/service:ndnp:in:batch_in_feynman_ver01:data:sn82015313:00383348997:1927040101:0085/full/pct:12.5/0/default.jpg#h=1025&w=765", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/in/batch_in_feynman_ver01/data/sn82015313/00383348997/1927040101/0085.xml&format=alto_xml"], "index": 15, "language": ["english"], "location": ["united states", "marion", "marion county", "indianapolis", "indiana"], "location_city": ["indianapolis"], "location_country": ["united states"], "location_county": ["marion"], "location_state": ["indiana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "9", "0", "4", "7", "0000000015", "8", "sn82015313", "1"], "number_edition": ["1"], "number_lccn": ["sn82015313"], "number_page": ["0000000015"], "number_reel": ["0", "0", "3", "8", "3", "3", "4", "8", "9", "9", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the indianapolis times (indianapolis [ind.]) 1922-1965", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the indianapolis times (indianapolis [ind.]) 1922-1965"], "publication_frequency": ["daily"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn82015313/1927-04-01/ed-1/?sp=15"}], "segmentof": [