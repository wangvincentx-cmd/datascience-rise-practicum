, "url": "https://www.loc.gov/item/2016271267/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218615/"], "campaigns": [], "date": "1937", "dates": ["[1937 TO 1954]"], "description": ["Weekly Began with vol. 1, no. 1 (November 24, 1937); ceased with vol. 19, no. 6 (September 16, 1954). Issues for July 29, 1954-Sept. 16. 1954 published without title, pending selection of a new name. Publisher: Greenbelt Cooperative Publishing Association, Inc., <January 2, 1942-March 12, 1943>. Vol. 1, no. 1 (November 24, 1937); title from masthead (Chroniclingamerica.loc.gov, viewed February 21, 2018). Vol. 19, no. 6 (September 16, 1954) (Chroniclingamerica.loc.gov, viewed February 21, 2018). Greenbelt news review 2832-7594 (DLC) 2022270692 (OCoLC)1335888187"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:41.529Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218615/", "image_url": [], "index": 4, "language": ["english"], "location": ["greenbelt", "maryland", "prince george's county", "prince george's", "united states"], "number": ["online resource", "2018218615", "2022270692", "2577-008x", "2026-04-13t21:30:13", "1023812488"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "greenbelt cooperator (greenbelt, maryland) 1937-1954 [online resource]"], "publication_frequency": ["weekly"], "score": 53.70931, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["greenbelt", "maryland", "prince george's county", "prince george's county (md.)", "newspapers", "greenbelt (md.)", "prince george's", "united states"], "timestamp": "2026-05-26T20:55:54.213Z", "title": "Greenbelt cooperator", "type": ["title"], "url": "https://www.loc.gov/item/2018218615/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/sn89061521", "http://www.loc.gov/item/sn89061521/", "https://search.cata