ns, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.96732, "shard": "04", "shelf_id": "sn89060124, 1908-03-06, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/mdu", "subject": ["maryland", "prince george's county", "prince george's county (md.)", "southern maryland", "newspapers", "prince george's", "maryland, southern", "united states", "upper marlboro"], "subject_headings": ["Prince George's County (Md.)--Newspapers", "Maryland, Southern--Newspapers", "Maryland--Prince George's County", "Southern Maryland", "United States--Maryland--Prince George's--Upper Marlboro"], "subjects": [{"maryland": "https://www.loc.gov/search/?fa=subject:maryland&fo=json"}, {"maryland, southern": "https://www.loc.gov/search/?fa=subject:maryland,+southern&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"prince george's": "https://www.loc.gov/search/?fa=subject:prince+george%27s&fo=json"}, {"prince george's county": "https://www.loc.gov/search/?fa=subject:prince+george%27s+county&fo=json"}, {"prince george's county (md.)": "https://www.loc.gov/search/?fa=subject:prince+george%27s+county+%28md.%29&fo=json"}, {"southern maryland": "https://www.loc.gov/search/?fa=subject:southern+maryland&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"upper marlboro": "https://www.loc.gov/search/?fa=subject:upper+marlboro&fo=json"}], "timestamp": "2023-03-07T20:17:43.007Z", "title": "The Prince George's enquirer and southern Maryland advertiser (Upper Marlborough, Md.), March 6, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn89060124/1908-03-06/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/sn89060124", "http://www.loc.gov/item/sn89060124/"], "batch": ["mdu_irving_ver01"], "campaigns": [], "date": "1882", "description": ["Weekly Began i