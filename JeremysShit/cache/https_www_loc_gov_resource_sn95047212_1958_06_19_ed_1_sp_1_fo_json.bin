ts": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn95047212/1958-06-19/ed-1/?sp=1"], "batch": ["fu_greenville_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/florida/", "2/united states/florida/dade/", "3/united states/florida/dade/miami/"], "contributor": ["university of florida"], "date": "1958-06-19", "dates": ["1958-06-19"], "description": ["tToivle I i Talks j CHAS F TOWLE I Publisher Clerks Mail a publication of the PO clerks Soundwaves of the Communication Workers and a half dozen other lesser publica tions in the Miami area are legitimate welledited and cir LABOR PAPERS culated labor papers dealing specifically with affairs of their own unions With them the Labor Citizen has no quarrel They are doing a good job with in the confines of their own in dividual unions and we commend them each and every one for the job they are doing The Labor Citizen as the official organ of the Dade County Federation of Labor the Miami Building Trades Council and the Florida Federated Labor Council AFLCIO has a much broader field to cover However there are publications in this area and one in particular which pounce ghoulishly upon any excuse to use the cloak of labor for their own particular profit The sheet to which we refer not only does not even patronize a union printer but it has no standing as a legal newspaper does not publish regularly and uses highpressure blackjack methods to blacken the name of labor in this vicinity And as we write this they"], "digitized": true, "extract_timestamp": "2026-01-27T17:02:00.860Z", "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn95047212/1958-06-19/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_greenville_ver01:data:sn95047212:00529042334:1958061901:0117/full/pct:3.125/0/default.jpg#h=287&w=193", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_gre