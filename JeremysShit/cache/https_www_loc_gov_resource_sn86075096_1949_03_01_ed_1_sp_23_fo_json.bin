rvices/service/ndnp/mthi/batch_mthi_beargrass_ver01/data/sn86075096/00340581702/1949030101/1254.pdf", "segment_count": 48, "url": "https://www.loc.gov/resource/sn86075096/1949-03-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_beargrass_ver01/data/sn86075096/00340581702/1949030101/1254.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_beargrass_ver01:data:sn86075096:00340581702:1949030101:1232/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_beargrass_ver01/data/sn86075096/00340581702/1949030101/1254.pdf", "segment_count": 48, "url": "https://www.loc.gov/resource/sn86075096/1949-03-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_beargrass_ver01/data/sn86075096/00340581702/1949030101/1254.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86075096/1949-03-01/ed-1/?sp=23"], "batch": ["mthi_beargrass_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/cascade/", "3/united states/montana/cascade/great falls/"], "contributor": ["montana historical society; helena, mt"], "date": "1949-03-01", "dates": ["1949-03-01"], "description": ["Market Outlook By GILBERT GUSLER FEB 21 1949 BUSINESS ACTIVITY has con tinued to ease from the record peak Price weakness has been spreading into industrial raw materials Furth er layoffs and plant curtailment or shutdowns are being reported al though total industrial production is still at an extremely high peace time level The present downward trend probably will continue While a majority of economists do not expect a severe recession the risk of a snowballing effect when business starts down from an ex tremely high peak is great Consumer buying power for foods and clothing will decline more than total income because of many rela tively fixed living costs Much of the drop in retail prices from lower consumer incomes will be passed back to the producer because of rigidity in distribution charges The farmers share of the con sumer dollar is declining In Decem ber 1948 farmers received 51 cents of the consumers food dollar com pared with 55 cents a year earlier In 193539 they received only 40 cents According to the U S depart ment of agriculture the annual cost of typical foods for a family of three at last Decembers retail prices was 663 compared"], "digitized": true, "extract_timestamp": "2023-07-03T13:44:39.080Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075096/1949-03-01/ed-1/?sp=23", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_beargrass_ver01:data:sn86075096:00340581702:1949030101:1254/full/pct:6.25/0/default.jpg#h=333&w=232", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_beargrass_ver01:data:sn86075096:00340581702:1949030101:1254/full/pct:12.5/0/default.jpg#h=666&w=464", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_beargrass_ver01/data/sn86075096/00340581702/1949030101/1254.xml&format=alto_xml"], "index": 23, "language": ["english"], "location": ["great falls", "cascade", "united states", "montana"], "location_city": ["great falls"], "location_country": ["united states"], "location_county": ["cascade"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "8", "3", "4", "7", "sn86075096", "2", "1", "0000000023"], "number_edition": ["1"], "number_lccn": ["sn86075096"], "number_page": ["