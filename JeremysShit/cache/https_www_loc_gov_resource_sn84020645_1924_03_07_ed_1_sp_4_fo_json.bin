21:37:21.057Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013254326/", "image_url": [], "index": 6, "language": ["english"], "location": ["montgomery county", "alabama", "montgomery", "united states"], "number": ["844394869", "online resource", "2026-04-13t21:30:13", "2835-6462", "2013254326"], "original_format": ["newspaper"], "other_title": ["Enterprise"], "partof": ["the montgomery enterprise (montgomery, ala.) 1898-19?? [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 52.460976, "shelf_id": "ISSN RECORD AN", "site": ["usnd"], "subject": ["montgomery county (ala.)", "montgomery county", "montgomery (ala.)", "united states", "african american", "newspapers", "alabama", "montgomery", "african americans", "african american newspapers"], "timestamp": "2026-05-26T20:48:57.173Z", "title": "The Montgomery enterprise", "type": ["title"], "url": "https://www.loc.gov/item/2013254326/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270666/"], "campaigns": [], "date": "1885", "dates": ["[1885 TO 1982]"], "description": ["Daily Print began with new ser. v. 21, no. 24 (Aug. 16, 1885); ceased November 21, 1982. On Saturday published as: Saturday morning, Apr. 2, 1977-Apr. 1, 1978; The Montgomery advertiser/Alabama journal, Apr. 8, 1978-Nov. 20, 1982. On Sunday published as: Montgomery advertiser and Alabama journal, Dec. 1, 1940-Nov. 21, 1982. Publisher varies: Screws, Cory & Glass, August 16, 1885-; The Advertiser Co., <1887-1909> Numbering is irregular. New series, vol. 35, no. 323 (July 19, 1900) followed by vol. 71, no. 168 (July 20, 1900). Issues for Aug 16, 1885-July 19, 1899 called also old series v. 54-v. 68. Also issued on microfilm from the University of Alabama Library, and the Library of Congress, Photoduplication Services. Weekly eds.: Montgomery wee