401/0064.pdf", "segment_count": 18, "url": "https://www.loc.gov/resource/sn87075277/1958-04-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ohi/batch_ohi_clover_ver01/data/sn87075277/0034058059A/1958042401/0064.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn87075277/1958-04-24/ed-1/?sp=8"], "batch": ["ohi_clover_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/ohio/", "2/united states/ohio/noble/", "3/united states/ohio/noble/caldwell/"], "contributor": ["ohio history connection, columbus, oh"], "date": "1958-04-24", "dates": ["1958-04-24"], "description": ["Page TwoB Riglit to Petition For the past 45 years the initiative and referendum have been guaranteed to the peo ple of Ohio by their state Constitution The people themselves wrote the initiative and referendum into their basic law by approving a constitutional amendment submitted to them by the Constitutional Convention of 1912 The initiative and referendum is an in strumentation of the earlier guarantee of the right of petition by the Constitution of the United States Even Congress may not inter fere with the peoples light of petition Any attempt to interfere with the circu lation of petitions is an assault upon one of the basic rights of the people and is thorough ly reprehensible If a majority of the people are opposed to the subject matter of any con stitutional amendment or law proposed by petitions they will have the opportunity to register their opposition at the polls But the right to obtain signatures for a popular vote Oil any issue should at all times be protected Yet at the present time there is evidence that opponents of the socalled RighttoWork Amendment to the Constitution of Ohio are seeking to impede the circulation of petitions for the proposed"], "digitized": true, "extract_timestamp": "2023-09-04T23:15:54.632Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn87075277/1958-04-24/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_clover_ver01:data:sn87075277:0034058059A:1958042401:0064/full/pct:3.125/0/default.jpg#h=282&w=222", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_clover_ver01:data:sn87075277:0034058059A:1958042401:0064/full/pct:6.25/0/default.jpg#h=565&w=445", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_clover_ver01:data:sn87075277:0034058059A:1958042401:0064/full/pct:12.5/0/default.jpg#h=1130&w=890", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_clover_ver01/data/sn87075277/0034058059A/1958042401/0064.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["noble county", "caldwell", "noble", "ohio", "united states"], "location_city": ["caldwell"], "location_country": ["united states"], "location_county": ["noble"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000008", "sn87075277", "0", "3", "9", "8", "a", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn87075277"], "number_page": ["0000000008"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "0", "5", "9", "a"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the journal (caldwell, ohio) 1934-1961", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the journal (caldwell, ohio) 1934-1961"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn87075277/1958-04-24/ed-1/?sp=8"}], "segmentof": ["http://www.loc.gov/resource/sn8