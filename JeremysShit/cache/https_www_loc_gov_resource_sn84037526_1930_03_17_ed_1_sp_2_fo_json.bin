ML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//vnstcsc/batch_vnstcsc_enighed_ver01/data/sn84037526/00414180012/1930031701/1930031701_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn84037526/marcxml"}], "other_title": ["Saint Croix avis", "Avis"], "partof": [{"count": 16309, "title": "st. croix avis (christiansted, st. croix [v.i.]) 1844-current", "url": "https://www.loc.gov/search/?fa=partof:st.+croix+avis+%28christiansted,+st.+croix+%5Bv.i.%5D%29+1844-current&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["st. croix avis (christiansted, st. croix [v.i.]) 1844-current"], "place_of_publication": "Christiansted, St. Croix [V.I.]", "publication_frequency": ["daily"], "raw_lccn": "sn 84037526 ", "reel_numbers": ["00414180012"], "resources": [{"files": 4, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:vnstcsc:batch_vnstcsc_enighed_ver01:data:sn84037526:00414180012:1930031701:0249/full/pct:6.25/0/default.jpg", "url": "https://www.loc.gov/resource/sn84037526/1930-03-17/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.844794, "shard": "06", "shelf_id": "sn84037526, 1930-03-17, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/vnstcsc", "source_modified": "2000-01-01T12:00:00Z", "subject": ["charlotte amalie", "virgin islands", "saint thomas", "christiansted (united states virgin islands)", "saint croix (united states virgin islands)", "newspapers", "saint thomas (united states virgin islands : island)", "christiansted", "united states", "united states virgin islands", "charlotte amalie (united states virgin islands)", "saint croix", "saint thomas (island)"], "subject_headings": ["Christiansted (United States Virgin Islands)--Newspapers", "Saint Croix (United States Virgin Islands)--Newspapers", "Charlotte Amalie (United States Virgin Islands)--Newspapers", "Saint Thomas (United States Virgin Islands : Island)--Newspapers", "United States Virgin Islands--Charlotte Amalie", "United States Virgin Islands--Christiansted", "United States Virgin Islands--Saint Croix", "United States Virgin Islands--Saint Thomas (Island)", "United States--Virgin Islands--Saint Croix--Christiansted", "United States--Virgin Islands--Saint Thomas--Charlotte Amalie"], "subjects": [{"charlotte amalie": "https://www.loc.gov/search/?fa=subject:charlotte+amalie&fo=json"}, {"charlotte amalie (united states virgin islands)": "https://www.loc.gov/search/?fa=subject:charlotte+amalie+%28united+states+virgin+islands%29&fo=json"}, {"christiansted": "https://www.loc.gov/search/?fa=subject:christiansted&fo=json"}, {"christiansted (united states virgin islands)": "https://www.loc.gov/search/?fa=subject:christiansted+%28united+states+virgin+islands%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"saint croix": "https://www.loc.gov/search/?fa=subject:saint+croix&fo=json"}, {"saint croix (united states virgin islands)": "https://www.loc.gov/search/?fa=subject:saint+croix+%28united+states+virgin+islands%29&fo=json"}, {"saint thomas": "https://www.loc.gov/search/?fa=subject:saint+thomas&fo=json"}, {"saint thomas (island)": "https://www.loc.gov/search/?fa=subject:saint+thomas+%28island%29&fo=json"}, {"saint thomas (united states virgin islands : island)": "https://www.loc.gov/search/?fa=subject:saint+thomas+%28united+states+virgin+islands+:+island%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"united states virgin islands": "https://www.loc.gov/search/?fa=subject:united+states+virgin+islands&fo=json"}, {"virgin islands": "https://www.loc.gov/search/?fa=subject:virgin+islands&fo=json"}], "summary": ["The St. Croix Avis (sn84037526) began publication in 1844 under the direction of editor and publisher Richard Hatchett in Christiansted, St. Croix (VI). It is a successor of the Royal Danish American Gazette (sn84037521), the first known newspaper published in the Virgin Islands. R. Hatchett published the Avis until the 1860s, under the authority of the Danish West Indian Government. The first digitized issue confirms that on January 3, 1865, the newspaper was edited by Hans Hatchett, and that it \"published every Tuesday and Friday for the proprietress\". The masthead includes a printed note in Danish during this time \"Udgiver: Hans Hatchett - Trykt I Enken Harriet Hatchett's Bogtrykerri\" which translates to \"Publisher: Hans Hatchett - Printed in the widow Harriet Hatchett's printing house\". Throughout its publication, issues of the Avis were formatted into three columns and were typically four pages in length, with an occasional addition of a fifth or sixth \"supplemental\" page. From its inception until 1917, the Avis published a considerable amount of its content in Danish, indicative of the island's Danish-speaking population of the time. Common Danish-language sections included Bekendtgorelse (Announcement), Proklama (Proclamation), Auktion (Auction), and Ansaettelser (Appointments). The shift to a primarily English-language publication began after the US purchased the Virgin Islands from Denmark in 1917. The St. Croix Avis reported on local weather and natural disasters. It frequently printed records of rainfall on the island, and coverage of hurricanes and their damage, not only as they occurred, but also on the anniversary of major events to acknowledge and observe past disasters and the damage left in their wake. Reports of natural disasters extended beyond the Virgin Islands and often included coverage of their impact throughout the Caribbean. The content of the St. Croix Avis offers a critical reflection of its unique importance as the first newspaper of the United States Virgin Islands. The paper catered to, reflected, informed, and represented the interests of all the individual governing nations of the region and their territorial residents. Perspectives are many and varied: from the delightful excursion into the social media of the day when library books were recalled through newspaper announcements, employees disputed termination causes in the media, to reports about the presence of yellow fever and cholera as they plagued the Caribbean and Latin America, to coverage of the imposition of property taxes with respect to \"king\" sugar. The Avis' journalists often compared what was happening in the European governed territories regarding slavery on the island and its management, reflecting more on the economic advantages that are critical to understanding the \"why\" of slavery. The paper provides a rich diversity of reporting picked up from national and international correspondents and the Avis' own contacts in Cuba, Latin America, and Europe. These reports demonstrate the anxieties of residents, preoccupations of the U.S. mainland with social and economic conditions, and challenges in the territory."], "timestamp": "2023-10-30T14:47:42.184Z", "title": "St. Croix avis (Christiansted, St. Croix [V.I.]), March 17, 1930", "type": ["issue"], "url": "https://www.loc.gov/item/sn84037526/1930-03-17/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn84037526/", "http://lccn.loc.gov/sn84037526", "https://search.catalog.loc.gov/instances/7cf6c922-8431-5360-b2bd-df985ff51fa1"], "batch": ["vnstcsc_adelphi_ver01"], "campaigns": [], "date": "1844", "description": ["The St. Croix Avis (sn84037526) began publication in 1844 under the direction of editor and publisher Richard Hatchett in Christiansted, St. Croix (VI). It is a successor of the Royal Danish American Gazette (sn84037521), the first known newspaper published in the Virgin Islands. R. Hatchett published the Avis until the 1860s, under the authority of the Danish West Indian Government. The first digitized issue confirms that on January 3, 1865, the newspaper was edited by Hans Hatchett, and that it \"published every Tuesday and Friday for the proprietress\". The masthead includes a printed note in Danish during this time \"Udgiver: Hans Hatchett - Trykt I Enken Harriet Hatchett's Bogtrykerri\" which translates to \"Publisher: Hans Hatchett - Printed in the widow Harriet Hatchett's printing house\". Throughout its publication, issues of the Avis were formatted into three columns and were typically four pages in length, with an occasional addition of a fifth or sixth \"supplemental\" page. From its inception until 1917, the Avis published a considerable amount of its content in Danish, indicative of the island's Danish-speaking population of the time. Common Danish-language sections included Bekendtgorelse (Announcement), Proklama (Proclamation), Auktion (Auction), and Ansaettelser (Appointments). The shift to a primarily English-language publication began after the US purchased the Virgin Islands from Denmark in 1917. The St. Croix Avis reported on local weather and natural disasters. It frequently printed records of rainfall on the island, and coverage of hurricanes and their damage, not only as they occurred, but also on the anniversary of major events to acknowledge and observe past disasters and the damage left in their wake. Reports of natural disasters extended beyond the Virgin Islands and often included coverage of their impact throughout the Caribbean. The content of the St. Croix Avis offers a critical reflection of its unique importance as the first newspaper of the United States Virgin Islands. The paper catered to, reflected, informed, and represented the interests of all the individual governing nations of the region and their territorial residents. Perspectives are many and varied: from the delightful excursion into the social media of the day when library books were recalled through newspaper announcements, employees disputed termination causes in the media, to reports about the presence of yellow fever and cholera as they plagued the Caribbean and Latin America, to coverage of the imposition of property taxes with respect to \"king\" sugar. The Avis' journalists often compared what was happening in the European governed territories regarding slavery on the island and its management, reflecting more on the economic advantages that are critical to understanding the \"why\" of slavery. The paper provides a rich diversity of reporting picked up from national and international correspondents and the Avis' own contacts in Cuba, Latin America, and Europe. These reports demonstrate the anxieties of residents, preoccupations of the U.S. mainland with social and economic conditions, and challenges in the territory."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:07.408Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-04", "catalog", "united-states-newspaper-directory", "main-catalog-split-04"], "hassegments": false, "id": "http://www.loc.gov/item/sn84037526/", "image_url": [], "index": 2, "language": ["english", "danish"], "latlong": [18.3419, -64.9307], "location": ["charlotte amalie", "virgin islands", "saint thomas", "christiansted", "united states", "united states virgin islands", "saint croix", "island"], "location_str": "", "lonlat": [-64.9307, 18.3419], "number": ["2025-07-01t13:27:28.900000", "16308", "sn84037523", "10476288", "sn84037526", "http://www.loc.gov/item/sn84037526/1865-01-03/ed-1/", "franklin d roosevelt libr", "http://www.loc.gov/item/sn84037526/1963-12-31/ed-1/", "2023-10-20t08:56:28.548910", "2026-04-13t21:30:13", "bureau of libr, mus & archeological serv", "2831-4212", "library of congress", "online resource", "original", "1", "microfilm service copy"], "original_format": ["newspaper"], "other_title": ["Saint Croix avis", "Avis", "Issues for Dec. 31, 2000/Jan. 2, 2001-<May 31, 2001> called: Avis"], "partof": ["serial and government publications division", "chronicling america", "catalog", "directory of u.s. newspapers in american libraries", "st. croix avis (christiansted, st. croix [v.i.]) 1844-2024", "st. croix avis (christiansted, st. croix [v.i.]) 1844-current"], "publication_frequency": ["daily"], "score": 159.45277, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["caribbean americans", "charlotte amalie", "virgin islands", "saint thomas", "christiansted (united states virgin islands)", "saint croix (united states virgin islands)", "newspapers", "saint thomas (united states virgin islands : island)", "christiansted", "african americans", "caribbean", "united states", "united states virgin islands", "charlotte amalie (united states virgin islands)", "saint croix", "african american", "saint thomas (island)", "african american newspapers"], "timestamp": "2026-07-18T09:12:23.572Z", "title": "St. Croix avis", "type": ["title"], "url": "https://www.loc.gov/item/sn84037526/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2022270582/", "http://lccn.loc.gov/2022270582", "https://search.catalog.loc.gov/instances/b4eb4e25-0bd4-5442-be79-117a16daf3ba"], "campaigns": [], "date": "1844", "dates": ["[1844 TO 2024]"], "description": ["Daily (combined issue Sunday/Monday), Dec. 1989-2024 Print began with Aarg. 1, nr. 1 (Jan. 1, 1844) Ceased with: 180th year, no. 5 (Jan. 7/8, 2024). Virgin Islands daily news, Jan. 19, 2024 Publishers: Hariet Hatchett, 1864- ; Peter Hatchett, 1867-1868; Hans Hatchett, 1869-1872; Lauritz Holm, 1872-1873; Christian Dahl, 1874-1876; Julius Knuthsen, 1877; John T. Quin, 1878-1879; A. Paludan Muller, 1878-1879; Albert Hanschell, 1880-1883; John T. Quin, 1884-1916; Canute A. Brodhurst; G. Johansen, <January 2, 1920-December 31, 1934>; Fred Clarke; Rena Brodhurst, <2001>-2024. The St. Croix Avis (sn84037526) began publication in 1844 under the direction of editor and publisher Richard Hatchett in Christiansted, St. Croix (VI). It is a successor of the Royal Danish American Gazette (sn84037521), the first known newspaper published in the Virgin Islands. R. Hatchett published the Avis until the 1860s, under the authority of the Danish West Indian Government. The first digitized issue confirms that on January 3, 1865, the newspaper was edited by Hans Hatchett, and that it \"published every Tuesday and Friday for the proprietress\". The masthead includes a printed note in Danish during this time \"Udgiver: Hans Hatchett - Trykt I Enken Harriet Hatchett's Bogtrykerri\" which translates to \"Publisher: Hans Hatchett - Printed in the widow Harriet Hatchett's printing house\". Throughout its publication, issues of the Avis were formatted into three columns and were typically four pages in length, with an occasional addition of a fifth or sixth \"supplemental\" page. From its inception until 1917, the Avis published a considerable amount of its content in Danish, indicative of the island's Danish-speaking population of the time. Common Danish-language sections included Bekendtgorelse (Announcement), Proklama (Proclamation), Auktion (Auction), and Ansaettelser (Appointments). The shift to a primarily English-language publication began after the US purchased the Virgin Islands from Denmark in 1917. The St. Croix Avis reported on local weather and natural disasters. It frequently printed records of rainfall on the island, and coverage of hurricanes and their damage, not only as they occurred, but also on the anniversary of major events to acknowledge and observe past disasters and the damage left in their wake. Reports of natural disasters extended beyond the Virgin Islands and often included coverage of their impact throughout the Caribbean. The content of the St. Croix Avis offers a critical reflection of its unique importance as the first newspaper of the United States Virgin Islands. The paper catered to, reflected, informed, and represented the interests of all the individual governing nations of the region and their territorial residents. Perspectives are many and varied: from the delightful excursion into the social media of the day when library books were recalled through newspaper announcements, employees disputed termination causes in the media, to reports about the presence of yellow fever and cholera as they plagued the Caribbean and Latin America, to coverage of the imposition of property taxes with respect to \"king\" sugar. The Avis' journalists often compared what was happening in the European governed territories regarding slavery on the island and its management, reflecting more on the economic advantages that are critical to understanding the \"why\" of slavery. The paper provides a rich diversity of reporting picked up from national and international correspondents and the Avis' own contacts in Cuba, Latin America, and Europe. These reports demonstrate the anxieties of residents, preoccupations of the U.S. mainland with social and economic conditions, and challenges in the territory. Also issued on microfilm from Library of Congress, Photoduplication Service. Danish and English, 1844-<Dec. 30, 1916>; English, <Jan. 23, 1919-2001>. Published by the authority of the Danish West Indian Government, 1844-1917. 21de Aarg. (3die Januar 1865); title from masthead (Chroniclingamerica.loc.gov, viewed March 17, 2022). 180th year, no. 5 (January 7/8, 2024) (viewed August 12, 2024)."], "digitized": true, "extract_timestamp": "2026-05-19T21:38:01.092Z", "group": ["ndnp/newspapers", "catalog-split-14", "catalog", "united-states-newspaper-directory", "main-catalog-split-14"], "hassegments": false, "id": "http://www.loc.gov/item/2022270582/", "image_url": [], "index": 3, "language": ["english", "danish"], "location": ["charlotte amalie", "virgin islands", "\u00eeles vierges am\u00e9ricaines", "saint thomas", "croix", "christiansted", "sainte", "united states", "united states virgin islands", "saint croix", "british west indies", "\u00eele", "island", "west indies"], "number": ["online resource", "2022270582", "2025-07-01t13:40:57.500000", "1264171644", "2831-4220", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Issues for December 31, 2000/January 2, 2001-<May 31, 2001> called: Avis", "Saint Croix avis", "Avis"], "partof": ["serial and government publications division", "st. croix avis (christiansted, [st. croix, v.i.]) 1844-2024 [online resource]", "directory of u.s. newspapers in american libraries", "catalog"], "publication_frequency": ["daily"], "score": 150.33853, "shelf_id": "ISSN RECORD", "site": ["usnd", "catalog"], "subject": ["sainte-croix (\u00eeles vierges am\u00e9ricaines)", "charlotte amalie", "christiansted", "united states", "united states virgin islands", "charlotte amalie (united states virgin islands)", "british west indies", "saint thomas (island)", "west indies", "caribbean americans", "newspapers", "saint croix", "african american", "saint thomas", "christiansted (united states virgin islands)", "saint thomas (united states virgin islands : island)", "african americans", "caribbean", "african american newspapers", "virgin islands", "journaux", "saint croix (united states virgin islands)", "danish american newspapers", "saint thomas (\u00eeles vierges am\u00e9ricaines : \u00eele)"], "timestamp": "2026-05-26T21:06:08.233Z", "title": "St. Croix avis", "type": ["title"], "url": "https://www.loc.gov/item/2022270582/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023238864/"], "campaigns": [], "contributor": ["st. croix cooperative society,", "chabert, r. de (ralph de magne de),"], "date": "1922", "dates": ["[1922 TO 1937]"], "description": ["Daily (except Sunday) Began with 1st year, no. 1 (July 1, 1922). Ceased in 1937? Cf. Ayer, 1937. Editor: Ralph De Chabert, 1922-1937. \"A journal for the progress of the people. Let justice be done though the heavens should fall.\" Twelfth year, no. 146 (January 2, 1934); title from banner (Chronicling America, viewed March 27, 2023). Fifteenth year, no. 115 (December 18, 1936) (Chronicling America, viewed March 27, 2023)."], "digitized": true, "extract_timestamp": "2026-05-19T21:38:08.561Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2023238864/", "image_url": [], "index": 4, "language": ["english"], "location": ["virgin islands", "christiansted", "united states", "united states virgin islands", "saint croix"], "number": ["online resource", "2023238864", "1374059786", "2996-9182", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Saint Croix tribune", "Tribune"], "partof": ["st. croix tribune (christiansted, st. croix, v.i.) 1922-1937 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["daily"], "score": 74.35971, "shelf_id": "ISSN RECORD AN2.S2.C47 T75", "site": ["usnd"], "subject": ["caribbean americans", "virgin islands", "christiansted (united states virgin islands)", "newspapers", "african americans", "christiansted", "caribbean", "united states", "united states virgin islands", "saint croix", "african american", "african american newspapers"], "timestamp": "2026-05-26T21:07:38.222Z", "title": "St. Croix tribune", "type": ["title"], "url": "https://www.loc.gov/item/2023238864/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn84037536/", "http://lccn.loc.gov/sn84037536", "https://search.catalog.loc.gov/instances/e3a0a408-49d9-5622-90a4-612b18b248b1"], "batch": ["vnstcsc_annaly_ver02"], "campaigns": [], "contributor": ["st. croix cooperative society", "chabert, r. de (ralph de magne de)"], "date": "1922", "description": ["Daily (except Sunday) 1st year, no. 1 (July 1, 1922)- Ceased in 1937? Cf. Ayer, 1937. Editor: Ralph De Chabert, 1922-1937. \"A journal for the Progress of the People.\" Also issued on microfilm from the Library of Congress, Photoduplication Service."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:07.408Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-05", "catalog", "united-states-newspaper-directory", "main-catalog-split-05"], "hassegments": false, "id": "http://www.loc.gov/item/sn84037536/", "image_url": [], "index": 5, "language": ["english"], "latlong": [17.746333, -64.7037], "location": ["virgin islands", "christiansted", "united states", "united states virgin islands", "saint croix"], "location_str": "", "lonlat": [-64.7037, 17.746333], "number": ["http://www.loc.gov/item/sn84037536/1936-12-18/ed-1/", "sn84037536", "2996-9174", "http://www.loc.gov/item/sn84037536/1934-01-02/ed-1/", "2025-09-20t12:58:13.200000", "2023-10-20t08:56:28.548910", "2026-04-13t21:30:13", "769", "bureau of libr, mus & archeological serv", "library of congress", "10486779", "online resource", "original", "1", "microfilm service copy"], "original_format": ["newspaper"], "other_title": ["Saint Croix tribune", "Tribune"], "partof": ["serial and government publications division", "chronicling america", "st. croix tribune (christiansted, st. croix, v.i.) 1922-1937", "catalog", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 74.35971, "shelf_id": "Newspaper 10020 AN2.S2.C47 T75", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["caribbean americans", "virgin islands", "christiansted (united states virgin islands)", "newspapers", "african americans", "christiansted", "caribbean", "united states", "united states virgin islands", "saint croix", "african american", "african american newspapers"], "timestamp": "2026-07-18T09:12:23.572Z", "title": "St. Croix tribune", "type": ["title"], "url": "https://www.loc.gov/item/sn84037536/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2024271072/"], "campaigns": [], "date": "1955", "dates": ["[1955 TO 1978]"], "description": ["Daily (except Sunday) Print began with 26th year, no. 8712 (Aug. 1, 1955); ceased with 48th year, no. 12043 (May 17, 1978). \"The only independent Virgin Islands newspaper serving the people of the Virgin Islands.\" Editor: Ariel Melchior, Sr., Aug. 1, 1955-July 31, 1964; Ariel Melchior, Jr., Aug. 1, 1964-Dec. 31, 1976; Ronald Walker, Jan. 3, 1977-Apr. 19, 1977; John Thompson, Apr. 20-Oct. 11, 1977. Publisher: Ariel Melchior, Sr., <Jan. 2, 1963>-Dec. 31, 1976; Ariel Melchior, Jr., Jan. 3, 1977-May 17, 1978. Issue numbering is highly irregular and does not reflect actual number issued since publication began on Aug. 1, 1930. 40th anniversary ed., Aug. 1, 1970; 160 pp., 45th anniversary ed., Aug. 1, 1975. Contained ill. history of the islands and newspaper publishing in the territory. 26th year, no. 8712 (Aug. 1, 1955); title from banner (news.google.com, viewed Dec. 12, 2024). 48th year, no. 12043 (May 17, 1978) (news.google.com, viewed Dec. 12, 2024). Virgin Islands daily news (DLC) 2024239015 (OCoLC)729865957"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:15Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2024271072/", "image_url": [], "index": 6, "language": ["english"], "location": ["virgin islands", "charlotte amalie", "saint thomas", "united states", "united states virgin islands"], "number": ["online resource", "2024271072", "1427515942", "2996-914x", "2024238983", "2026-04-13t21:30:13", "2024239015"], "original_format": ["newspaper"], "other_title": ["Running title: Daily news"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the daily news of the virgin islands (charlotte amalie, st. thomas, v.i.) 1955-1978 [online resource]"], "publication_frequency": ["daily"], "score": 73.974915, "shelf_id": "ISSN RECORD AN2.V63.C5 D35", "site": ["usnd"], "subject": ["caribbean americans", "charlotte amalie", "virgin islands", "saint thomas", "newspapers", "african americans", "caribbean", "united states", "united states virgin islands", "charlotte amalie (united states virgin islands)", "african american"], "timestamp": "2026-05-26T21:13:38.179Z", "title": "The daily news of the Virgin Islands", "type": ["title"], "url": "https://www.loc.gov/item/2024271072/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2024271073/"], "campaigns": [], "contributor": ["ottley, earle b."], "date": "1951", "dates": ["[1951 TO 1973]"], "description": ["Daily (except Sun.), Dec. 1971-1973 Print began with 1st year, no. 1 (Jan. 25, 1951); ceased with 21st year, no. 6144 (Jan. 12, 1973). Issue numbering is continuous. Issues for Nov. 7, 1956-<Dec. 31, 1958> lack issue no. Vols. for Oct. 1969-Mar. 1971 include a monthly supplement called Carib. Includes a weekly supplement called Focus, Sundays to Nov. 1971; Saturdays, Dec. 1971-Dec. 1972. Available on microfilm from Library of Congress Photoduplication Service. Saturday edition, 1968-1969, distributed and sold separately on St. Croix as the Crucian journal. 2nd Year, No. 115 (February 4, 1952); title from masthead (Chroniclingamerica.loc.gov, viewed March 21, 2024). 7th Year (December 31, 1958) (Chroniclingamerica.loc.gov, viewed March 21, 2024). Weekly journal (Charlotte Amalie, United States Virgin Islands : 1973)"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:15Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2024271073/", "image_url": [], "index": 7, "language": ["english"], "location": ["virgin islands", "charlotte amalie", "saint thomas", "united states", "united states virgin islands"], "number": ["2996-9166", "online resource", "1427518360", "2024271073", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Sunday issues for <June 22, 1969-> have title: Sunday journal"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the home journal (st. thomas, virgin islands) 1951-1973 [online resource]"], "publication_frequency": ["daily"], "score": 73.974915, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["caribbean americans", "charlotte amalie", "virgin islands", "saint thomas", "newspapers", "african americans", "caribbean", "united states", "united states virgin islands", "charlotte amalie (united states virgin islands)", "african american", "african american newspapers"], "timestamp": "2026-05-26T21:13:38.179Z", "title": "The home journal", "type": ["title"], "url": "https://www.loc.gov/item/2024271073/"}], "next_resource": {"label": "Next Issue", "url": "https://www.loc.gov/resource/sn84037526/1930-03-18/ed-1/?fo=json&sp=1"}, "options": {"access_group": [""], "access_group_raw": "", "all": null, "api_version": "1", "app_context": null, "application_version": "$Revision$", "attribute": null, "attribute!": null, "attribute_map": null, "cache_tags": ["ndnp/vnstcsc", "university-of-virgin-islands", "newspaper-titles", "ndnp/newspapers", "catalog-split-04", "catalog", "united-states-newspaper-directory", "main-catalog-split-04", "catalog-split-14", "main-catalog-split-14", "catalog-split-05", "main-catalog-split-05", "gmd.mar", "catalog-split-15", "general-maps", "main-catalog-split-15", "catalog-split-00", "main-catalog-split-00", "gmd/multimap", "catalog-split-01", "multimaps", "main-catalog-split-01", "catalog-split-06", "main-catalog-split-06", "cph", "catalog-split-10", "miscellaneous-items-high-demand", "main-catalog-split-10"], "callback": null, "clip": null, "clip_image_width": null, "clip_rotation": null, "content_filter": null, "content_replacement": "", "count": null, "dates": null, "default_count": 1, "delimiter": null, "digital_id": "sn84037526/1930-03-17/ed-1", "display_level": null, "display_options": {"options": [{"field": "all", "label": "All"}, {"field": "title", "label": "Titles", "type": "title"}, {"field": "issue", "label": "Issues", "type": "issue"}, {"field": "page", "label": "Pages (Full Text)", "type": "segment"}]}, "distance": null, "downloadOption": null, "duration": 1.7919080257415771, "embed": [], "embed!": [], "error_response_status": null, "excludeTerms": null, "facetLimits": "", "facetPrefix": null, "facet_count": null, "facet_style": null, "field": null, "form_facets": [{"field": "location_state", "required": true, "se