"https://www.loc.gov/resource/sn89075239/1930-10-31/ed-1/?fo=json&sp=2", "of": 4, "page_list": [{"number": 1, "url": null}, {"number": 2, "url": "https://www.loc.gov/resource/sn89075239/1930-10-31/ed-1/?fo=json&sp=2"}, {"number": 3, "url": "https://www.loc.gov/resource/sn89075239/1930-10-31/ed-1/?fo=json&sp=3"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": null, "results": "1 - 1", "to": 1, "total": 4}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn89075239/1930-10-24/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": true, "aka": ["https://www.loc.gov/pictures/item/2023708571/", "http://www.loc.gov/item/2023708571/", "http://www.loc.gov/pictures/item/2023708571/", "https://hdl.loc.gov/loc.pnp/ppbd.11401", "https://hdl.loc.gov/loc.pnp/ppbd.11401", "http://www.loc.gov/resource/ppbd.11401/", "http://lccn.loc.gov/2023708571"], "campaigns": [], "contributor": ["de miguel, mariano"], "date": "2020", "dates": ["2020"], "description": ["1 photograph : digital, tiff file, b&w."], "digitized": true, "extract_timestamp": "2025-03-01T13:43:01.919Z", "group": ["pp_other", "catalog-split-03", "catalog", "prints-and-photographs-other", "main-catalog-split-03"], "hassegments": false, "id": "http://www.loc.gov/item/2023708571/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ppbd/11400/11401_150px.jpg#h=100&w=150"], "index": 1, "language": ["english"], "location": ["sylvania", "united states", "ohio", "lucas"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2025-02-19t20:00:59", "2023708571", "http://www.loc.gov/item/23375148", "online resource"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "prints and photographs division"], "score": 21.2209, "shelf_id": "LC-DIG-ppbd- 11401 (ONLINE) [P&P]", "site": ["pictures", "catalog"], "subject": ["ckd awareness", "digital photographs", "b&w", "portraits", "face masks", "lucas", "covid-19 pandemic", "united states", "patients", "renal failure", "coronavirus", "sylvania", "ohio", "esrd", "ppi", "healthcare"], "timestamp": "2025-03-01T13:46:49.881Z", "title": "World at Siege. The threat of Covid-19: healthcare workers and dialysis patient at risk", "type": ["still image"], "url": "https://www.loc.gov/item/2023708571/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/73694517", "http://www.loc.gov/item/73694517/", "https://search.catalog.loc.gov/instances/e45926f3-4b0e-544b-9b04-b386d751220a", "https://hdl.loc.gov/loc.gmd/g4084t.pm007100", "http://www.loc.gov/resource/g4084t.pm007100/"], "campaigns": [], "contributor": ["charles shober & co", "chicago lithographing co", "stoner, j. j.", "ruger, a."], "date": "1876", "dates": ["1876"], "description": ["\"This panoramic map shows Toledo, Ohio, as it appeared in 1876. Toledo is located at the western end of Lake Erie and is where the Miami and Erie Canal enters the lake. The map shows a busy harbor and major points of interest, including freight elevators, the city's many churches, and the depot of the Lake Shore & Michigan Southern Railway, the main rail line between Chicago and Buffalo. The panoramic map was a cartographic form in popular use to depict U.S. and Canadian cities and towns in the late 19th and early 20th centuries. Also known as bird's-eye views or perspective maps, these maps are representations of cities portrayed as if viewed from above at an oblique angle. Not generally drawn to scale, they show street patterns, individual buildings, and major landscape features in perspective. This map is by Albert Ruger (1829-99), the first American to achieve success as a panoramic artist. Born in Prussia, Ruger immigrated to the United States and worked initially as a mason. While serving with the Ohio Volunteers during the Civil War, he drew views of Union campsites. After the war, Ruger settled in Battle Creek, Michigan, where he began his panoramic mapping career by sketching Michigan cities. In the late 1860s, Ruger formed a partnership with J.J. Stoner of Madison, Wisconsin, and together they published numerous city panoramas.\" World Digital Library."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:48.490Z", "group": ["gmd.mar", "catalog-split-10", "catalog", "general-maps", "main-catalog-split-10"], "hassegments": false, "id": "http://www.loc.gov/item/73694517/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd408/g4084/g4084t/pm007100.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd408/g4084/g4084t/pm007100.gif#h=150&w=259", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4084:g4084t:pm007100/full/pct:12.5/0/default.jpg#h=603&w=1040", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd408:g4084:g4084t:pm007100/full/pct:25/0/default.jpg#h=1206&w=2080"], "index": 2, "language": ["english"], "location": ["toledo", "ohio", "united states"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2022-07-14t10:56:33", "2025-06-07t18:29:52.500000", "73694517"], "online_format": ["image"], "original_format": ["map"], "partof": ["world digital library", "catalog", "geography and map division", "cities and towns", "panoramic maps"], "score": 20.386139, "shelf_id": "G4084.T6A35 1876 .R3", "site": ["catalog"], "subject": ["aerial views", "toledo (ohio)", "toledo", "united states", "ohio"], "timestamp": "2026-04-29T16:12:55.935Z", "title": "Toledo, Ohio 1876", "type": ["cartographic"], "url": "https://www.loc.gov/item/73694517/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2016586562", "http://www.loc.gov/item/2016586562/", "https://search.catalog.loc.gov/instances/716776b4-9df0-597e-9c73-34af3aea65db", "https://hdl.loc.gov/loc.gmd/g4084tm.g4084tm_g069111868", "http://www.loc.gov/resource/g4084tm.g069111868/"], "campaigns": [], "contributor": ["sanborn, d. a. (daniel alfred)"], "date": "1868", "dates": ["1868"], "description": ["\"Entered according to Act of Congress, in the year 1868, by D. A. Sanborn, in the Clerk's Office of the District Court of the United States, for the Southern District of New York.\" Shows cadastral information, buildings with construction and insurance characteristics, and names of major landholders. Sheets individually annotated: e.g. Sheet no. 3. Available also through the Library of Congress Web site as a raster image. Conserved; 003273.98 1977 Library of Congress Conservation Division. For treatment information, contact the Preservation Directorate. https://ask.loc.gov/preservation pda LC copy accompanied by title sheet."], "digitized": true, "extract_timestamp": "2026-06-13T14:00:11.619Z", "group": ["gmd.mar", "catalog-split-09", "catalog", "general-maps", "main-catalog-split-09"], "hassegments": false, "id": "http://www.loc.gov/item/2016586562/", "image_url": [], "index": 3, "language": ["english"], "location": ["toledo", "ohio"], "number": ["2026-06-05t15:22:41.500000", "sheet", "2016586562"], "original_format": ["map"], "partof": ["geography and map division", "cities and towns", "catalog"], "score": 19.276451, "shelf_id": "G4084.T6G46 s06 .S3", "site": ["catalog"], "subject": ["property insurance", "toledo (ohio)", "toledo", "real property", "ohio", "maps"], "timestamp": "2026-06-13T14:00:57.672Z", "title": "Insurance map of Toledo, Ohio", "type": ["cartographic"], "url": "//lccn.loc.gov/2016586562"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/19003389", "http://www.loc.gov/item/19003389/", "http://www.loc.gov/resource/gdcmassbookdig.reportoneliminat00tole/", "https://hdl.loc.gov/loc.gdc/scd0001.00332664463", "http://www.loc.gov/resource/scd0001.00332664463/"], "campaigns": [], "contributor": ["harmon, watson g.", "toledo. dept. of public service"], "date": "1918", "dates": ["1918"], "description": ["A report by Watson G. Harmon, special sanitary engineer of the Division of engineering and construction, Dept. of public service. Also available in digital for