/sn89075239/00340580965/1930103101/0191.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn89075239/1930-10-31/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ohi/batch_ohi_alastor_ver02/data/sn89075239/00340580965/1930103101/0191.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89075239/1930-10-31/ed-1/?sp=1"], "batch": ["ohi_alastor_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/ohio/", "2/united states/ohio/lucas/", "3/united states/ohio/lucas/toledo/"], "contributor": ["ohio history connection, columbus, oh"], "date": "1930-10-31", "dates": ["1930-10-31"], "description": ["Meghalt Kekes Berti K\u00e9kes J\u00f3zsef \u00e9s neje sz\u00fcletett S\u00fct\u0151 Erzs\u00e9bet 18 \u00e9ves fia Al bert vas\u00e1rnap d\u00e9lel\u0151tt a Szent Vince k\u00f3rh\u00e1zban elhal\u00e1lozott K\u00f6r\u00fclbel\u00fcl 3 h\u00e9t el\u0151tt hivt\u00e1k Dr Marcus magyar orvosunkat Jlerti beteg\u00e1gy\u00e1hoz Mid\u0151n az orvos meg\u00e1llap\u00edtotta a vakb\u00e9l gyullad\u00e1st \u00e9s arra val\u00f3 tckin tettel hogy az m\u00e1r kifakadt a beteget azonnal a k\u00f3rh\u00e1zba sz\u00e1llitatta A r\u00f6gt\u00f6n alkalma zott m\u0171t\u00e9t igazolta Dr Marcus pontos diagn\u00f3zis\u00e1t valamint azt is hogy rendk\u00edv\u00fcli s\u00falyos esetr\u0151l van sz\u00f3 Vagy k\u00e9t h\u00e9ttel az oper\u00e1ci\u00f3 ut\u00e1n a beteget hazahozt\u00e1k mi ut\u00e1n m\u00e1r a javul\u00e1s \u00fatj\u00e1n volt Itthon azonban b\u00e9lelz\u00e1r\u00f3d\u00e1s k\u00f6 ss vetkezett be amit\u0151l az orvos nagyon tartott \u00e9s \u00e1 mi ily ese tekben gyakran el\u0151fordul \u00dajabb r\u00f6gt\u00f6ni oper\u00e1ci\u00f3 v\u00e1lt sz\u00fcks\u00e9gess\u00e9 amit azouban az uiuugy is gyenge ifj\u00fa ui\u00e1r nem birt el mert k\u00f6zben dolgozott is \u00e9s a legnagyobb lelkinyuga lonnnal miut\u00e1n sz\u00fcleit\u0151l \u00e9s testv\u00e9reit\u0151l \u00e9s s\u00f3gor\u00e1t\u00f3l elb\u00fa cs\u00fazott vas\u00e1rnap d\u00e9lel\u0151tt b\u00e9 k\u00e9ben elszender\u00fclt Sz\u00fclein k\u00edv\u00fcl 10 testv\u00e9re si ratja a kora ifj\u00fas\u00e1giban el hunyt j\u00f3 fi\u00fat illetve szeretett testv\u00e9rt Kedden reggel Ft Heged\u0171s Istv\u00e1n tartotta a halotti szer tart\u00e1st a h\u00e1zn\u00e1l \u00e9s a Szent Ist v\u00e1n templomban az elhunyt lelki\u00fcdv\u00e9rt bemutatott gy\u00e1sz mise ut\u00e1n a K\u00e1lv\u00e1ria sirkertbe helyezt\u00e9k \u00f6r\u00f6k pihen\u0151re1 Nyugodj\u00e9k b\u00e9k\u00e9ben a szen telt"], "digitized": true, "extract_timestamp": "2025-03-24T16:01:45.297Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89075239/1930-10-31/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_alastor_ver02:data:sn89075239:00340580965:1930103101:0191/full/pct:6.25/0/default.jpg#h=411&w=323", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_alastor_ver02:data:sn89075239:00340580965:1930103101:0191/full/pct:12.5/0/default.jpg#h=822&w=647", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_alastor_ver02/data/sn89075239/00340580965/1930103101/0191.xml&format=alto_xml"], "index": 1, "language": ["hungarian", "english"], "location": ["united states", "toledo", "ohio", "lucas"], "location_city": ["toledo"], "location_country": ["united states"], "location_county": ["lucas"], "location_state": ["ohio"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "sn89075239", "1", "8", "4", "9", "6", "0000000001"], "number_edition": ["1"], "number_lccn": ["sn89075239"], "number_page": ["0000000001"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "0", "9", "6", "5"], "online_format": ["ima