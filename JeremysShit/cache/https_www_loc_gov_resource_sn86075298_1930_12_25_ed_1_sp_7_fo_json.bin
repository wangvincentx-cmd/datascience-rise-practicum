0.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_ekalaka_ver01:data:sn86075298:00517178573:1930122501:0834/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_ekalaka_ver01/data/sn86075298/00517178573/1930122501/0840.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86075298/1930-12-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_ekalaka_ver01/data/sn86075298/00517178573/1930122501/0840.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86075298/1930-12-25/ed-1/?sp=7"], "batch": ["mthi_ekalaka_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/lake/", "3/united states/montana/lake/ronan/"], "contributor": ["montana historical society; helena, mt"], "date": "1930-12-25", "dates": ["1930-12-25"], "description": ["FUND ALLOINENT MADE BY BOARD State Educational Body Lays Plana For Distributing Bond Money For Building Purposes At a meeting of the state board of education at Helena the past week a decision was reached by that body to recommend to the Montana legisla ture which convenes in January ap propriation aggregating 2355000 for the six units of the greater university and the four other institutions under the boards direction Other state institutions Governor Erickson told the board request the following amonuts for buildings Penitentiary 300000 hospital 200000 sanitarium 200000 sol diers home 15000 The combined requests amount to 3070000 which in excess of the bond issue voted at the last election The board will make the following recommendations for appropriations for structures and repairs at institu ions it supervises Northern Montana school at Havre 500000 for administration and in struction building residence hall for women and heating plant Eastern Montana Normal school at Billings 600000 for a main building with 30 classrooms and a teachers training school physical education plant aud itorium and library and repairs State college at Bozeman 390000 for a residence for women an insti tutional management house a new service shop a steam and forge"], "digitized": true, "extract_timestamp": "2023-07-03T13:50:04.736Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075298/1930-12-25/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_ekalaka_ver01:data:sn86075298:00517178573:1930122501:0840/full/pct:6.25/0/default.jpg#h=372&w=258", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_ekalaka_ver01:data:sn86075298:00517178573:1930122501:0840/full/pct:12.5/0/default.jpg#h=744&w=517", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_ekalaka_ver01/data/sn86075298/00517178573/1930122501/0840.xml&format=alto_xml"], "index": 7, "language": ["english"], "location": ["lake", "montana", "ronan", "united states"], "location_city": ["ronan"], "location_country": ["united states"], "location_county": ["lake"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "3", "sn86075298", "8", "7", "1", "0000000007", "5"], "number_edition": ["1"], "number_lccn": ["sn86075298"], "number_page": ["0000000007"], "number_reel": ["0", "0", "5", "1", "7", "1", "7", "8", "5", "7", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the ronan pioneer (ronan, mont.) 1910-1970"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_t