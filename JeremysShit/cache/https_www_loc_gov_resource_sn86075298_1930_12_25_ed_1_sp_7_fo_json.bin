 "ronan", "newspapers", "united states"], "timestamp": "2026-07-18T09:20:06.081Z", "title": "The Ronan pioneer", "type": ["title"], "url": "https://www.loc.gov/item/sn86075298/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013271993/"], "campaigns": [], "date": "1910", "dates": ["[1910 TO 1970]"], "description": ["Weekly Began in 1910; ceased July 30, 1970. Merged with: Hot Springs citizen, to form: Ronan pioneer and the Hot Springs citizen. Description based on: Volume I, no. 38 (February 3, 1911) (Chroniclingamerica.loc.gov, viewed January 23, 2014). Latest issue consulted: Vol. VIII, no. 35 (December 28, 1917) (Chroniclingamerica.loc.gov, viewed January 23, 2014). Hot Springs citizen (Online) Ronan pioneer and the Hot Springs citizen (Online)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:24.080Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013271993/", "image_url": [], "index": 8, "language": ["english"], "location": ["lake", "montana", "ronan", "united states"], "number": ["online resource", "862979445", "2013271993", "2026-04-13t21:30:13", "2332-9815"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the ronan pioneer (ronan, missoula county, montana) 1910-1970 [online resource]"], "publication_frequency": ["weekly"], "score": 53.817566, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["lake", "montana", "ronan (mont.)", "ronan", "newspapers", "united states"], "timestamp": "2026-05-26T20:49:31.434Z", "title": "The Ronan pioneer", "type": ["title"], "url": "https://www.loc.gov/item/2013271993/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2024271112/"], "campaigns": [], "date": "1946", "dates": ["[1946 TO 1962]"], "description": ["Weekly Began with volume I, number 1 (June 20, 1946); ceased with volume XVII, no. 16 (Dec. 27, 1