ewspaper"], "partof": ["catalog", "chronicling america", "serial and government publications division", "directory of u.s. newspapers in american libraries", "carson city daily appeal (carson city, nev.) 1907-1930"], "publication_frequency": ["daily"], "score": 62.312477, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "catalog", "usnd"], "subject": ["nevada", "carson city (nev.)", "ormsby", "newspapers", "united states", "carson city"], "timestamp": "2026-07-22T07:47:08.656Z", "title": "Carson City daily appeal.", "type": ["title"], "url": "https://www.loc.gov/item/sn86076241/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271163/"], "campaigns": [], "date": "1870", "dates": ["[1870 TO 1872]"], "description": ["Daily (except Mon.) Began with vol. I, no. 1 (December 29, 1870 ); ceased with vol. IV, no. 145 (December 15, 1872). Microfilm available from Bell & Howell. \"After the revival of The Appeal by Mighels in September, Booth faced stiff competition for subscribers and advertisers thus, when Mighels finally offered to buy him out, he accepted.\" Cf. Lingenfelter, R. Newspapers of Nev., 1854-1979. Description based on: Vol. I, no. 1 (December 29, 1870 ); title from masthead (Chroniclingamerica.loc.gov, viewed September 14, 2016). Latest issue consulted: Vol. IV, no. 132 (November 30, 1872) (Chroniclingamerica.loc.gov, viewed September 14, 2016). New daily appeal 2472-0410 (DLC) 2016271057 (OCoLC)947005431"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:36.478Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271163/", "image_url": [], "index": 3, "language": ["english"], "location": ["united states", "nevada", "ormsby", "carson city"], "number": ["online resource", "2026-04-13t21:30:13", "958381084", "2016271057", "2016271163", "2016271056", "2474-2163"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the daily state register (carson city, nev.) 1870-1872 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 53.033363, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["nevada", "carson city (nev.)", "ormsby", "newspapers", "united states", "carson city"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "The Daily state register", "type": ["title"], "url": "https://www.loc.gov/item/2016271163/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271195/"], "campaigns": [], "date": "1906", "dates": ["[1906 TO 1907]"], "description": ["Daily (except Sun.) Began with vol. LXVII, no. 27 (May 3, 1906); ceased with vol. 63, no. 211 (July 8, 1907). Publisher: Appeal Publishing Company, July 8, 1907. Frequent misnumbering. Description based on: Vol. LXVII, no. 27 (May 3, 1906); title from masthead (Chroniclingamerica.loc.gov, viewed October 12, 2016). Latest issue consulted: Vol. LXIII, no. 211 (July 8, 1907) (Chroniclingamerica.loc.gov, viewed October 12, 2016). Carson City daily appeal"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:36.478Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271195/", "image_url": [], "index": 4, "language": ["english"], "location": ["united states", "nevada", "ormsby", "carson city"], "number": ["960463949", "online resource", "2026-04-13t21:30:13", "2016271195", "2474-6282"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the daily appeal (carson city, nevada) 1906-1907 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 53.033363, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["nevada", "carson city (nev.)", "ormsby", "newspapers", "united states", "carson city"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "The daily appeal", "type": ["title"], "url": "https://www.loc.gov/item/2016271195/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271196/"], "campaigns": [], "date": "1907", "dates": ["[1907 TO 1930]"], "description": ["Daily (except Sun.) Began with vol. XLIII, no. 213 (July 10, 1907); ceased April 30, 1930). Merged with: Carson City news: to form: Carson City daily appeal and Carson City news. Desccription based on: Vol. XLIII, no. 213 (July 10, 1907); title from masthead (Chroniclingamerica.loc.gov, viewed October 12, 2016). Latest issue consulted: Vol. XLV, no. 153 (June 30, 1908) (Chroniclingamerica.loc.gov, viewed October 12, 2016). Carson City news Carson City daily appeal and Carson City news"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:36.478Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271196/", "image_url": [], "index": 5, "language": ["english"], "location": ["united states", "nevada", "ormsby", "carson city"], "number": ["2026-04-13t21:30:13", "online resource", "2016271196", "960463993", "2474-6312"], "original_format": ["newspaper"], "partof": ["carson city daily appeal (carson city, nevada) 1907-1930 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 53.033363, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["nevada", "carson city (nev.)", "ormsby", "newspapers", "united states", "carson city"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "Carson City daily appeal", "type": ["title"], "url": "https://www.loc.gov/item/2016271196/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271056/"], "campaigns": [], "contributor": ["mighels, henry r. (henry rust),"], "date": "1865", "dates": ["[1865 TO 1870]"], "description": ["Daily (except Monday) Began May 16, 1865; ceased December 28, 1870. Editor: H.R. Mighels. 