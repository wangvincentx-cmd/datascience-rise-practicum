 freres on the Commission and recently submitted to the Council of the League of Nations for their action provides that when a dispute lias arisen between nations which is found to be impossible to settle by diplomatic means or by an agreement to arbitrate the complain"], "digitized": true, "extract_timestamp": "2020-09-15T15:04:15.078Z", "group": ["ndnp/okhi", "oklahoma-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86090528/1920-10-01/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:okhi:batch_okhi_ham_ver01:data:sn86090528:00295864667:1920100101:0223/full/pct:6.25/0/default.jpg#h=413&w=315", "https://tile.loc.gov/image-services/iiif/service:ndnp:okhi:batch_okhi_ham_ver01:data:sn86090528:00295864667:1920100101:0223/full/pct:12.5/0/default.jpg#h=826&w=630", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/okhi/batch_okhi_ham_ver01/data/sn86090528/00295864667/1920100101/0223.xml&format=alto_xml"], "index": 8, "language": ["english"], "location": ["indian territory", "oklahoma", "grady county", "united states", "grady", "chickasha"], "location_city": ["chickasha"], "location_country": ["united states"], "location_county": ["grady"], "location_state": ["oklahoma"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "sn86090528", "2", "1", "8", "4", "7", "9", "0000000008", "6"], "number_edition": ["1"], "number_lccn": ["sn86090528"], "number_page": ["0000000008"], "number_reel": ["0", "0", "2", "9", "5", "8", "6", "4", "6", "6", "7"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Daily express", "Chickasha morning express"], "partof": ["chronicling america", "serial and government publications division", "the chickasha daily express (chickasha, indian territory [okla.]) 1899-current"], "partof_collection": ["chroniclin