 advertis ing Caldwell Interesting people In this locality encouraging Immigra tion and building up the country around us We understand that the club has inquiries"], "digitized": true, "extract_timestamp": "2023-07-06T12:32:35.710Z", "group": ["ndnp/idhi", "idaho-state-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86091092/1907-11-23/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_angelou_ver01:data:sn86091092:00295869409:1907112301:0990/full/pct:6.25/0/default.jpg#h=414&w=295", "https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_angelou_ver01:data:sn86091092:00295869409:1907112301:0990/full/pct:12.5/0/default.jpg#h=829&w=590", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/idhi/batch_idhi_angelou_ver01/data/sn86091092/00295869409/1907112301/0990.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["caldwell", "canyon", "idaho", "united states"], "location_city": ["caldwell"], "location_country": ["united states"], "location_county": ["canyon"], "location_state": ["idaho"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "9", "0", "8", "0000000004", "sn86091092", "4", "6", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn86091092"], "number_page": ["0000000004"], "number_reel": ["0", "0", "2", "9", "5", "8", "6", "9", "4", "0", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "the caldwell tribune (caldwell, idaho territory [idaho]) 1883-1928"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the caldwell tribune (caldwell, idaho territory [idaho]) 1883-1928"], "publication_frequency": ["weekly"], "resour