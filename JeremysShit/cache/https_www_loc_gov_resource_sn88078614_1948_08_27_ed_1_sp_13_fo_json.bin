": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn90068513/", "image_url": [], "index": 14, "language": ["english"], "latlong": [41.753666, -81.269537], "location": ["fairport harbor", "lake county", "lake", "ohio", "united states"], "location_str": "", "lonlat": [-81.269537, 41.753666], "number": ["sn90068513", "4", "22761056", "http://www.loc.gov/item/sn90068513/1935-01-18/ed-1/", "online resource", "1", "sn88078614", "http://www.loc.gov/item/sn90068513/1934-11-30/ed-1/", "2025-05-23t21:30:26", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["merchants news (fairport harbor, ohio) 1932-1935", "chronicling america", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 64.078156, "shelf_id": "http://lccn.loc.gov/sn90068513", "site": ["chroniclingamerica", "usnd"], "subject": ["newspapers", "fairport harbor", "lake county (ohio)", "lake", "ohio", "united states", "fairport harbor (ohio)"], "timestamp": "2026-07-18T09:31:30.780Z", "title": "Merchants news", "type": ["title"], "url": "https://www.loc.gov/item/sn90068513/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2015270853/"], "campaigns": [], "date": "1872", "dates": ["[1872 TO 1896]"], "description": ["Weekly Began with volume I, number 35 (March 9, 1872); ceased in 1896. \"A family paper, devoted to literature, science, agriculture, and general news,\" 1872-Nov. 3, 1877; \"A family paper, devoted to the interests of the people, and of the Democratic Party in the Nineteenth Congressional District,\" Nov. 10, 1877-Jan. 22, 1887; \"A family Democratic newspaper,\" Apr. 2, 1887-<1896>. Independent, 1872-1879; Democratic, 1880-1896. Suspended Apr. 23-May 28, 1881. Vol. 20, no. 1-3 (Jan. 4-18, 1890) misdated 1889. Vol. 21, no. 1-2 (Jan. 5-12, 1892) misdated 1890. Daily edition titled: Daily Painesville journal; Painesville daily journal. Description based on: Volume I, number 35 (March 9, 1872); title from masthead (Chroniclingamerica.loc.gov, viewed February 3, 2016). Latest issue consulted: Vol. IX, no. 52, whole no. 468 (June 26, 1880) (Chroniclingamerica.loc.gov, viewed February 3, 2016). Lake County advertiser"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:34.166Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2015270853/", "image_url": [], "index": 15, "language": ["english"], "location": ["lake county", "lake", "ohio", "united states", "painesville"], "number": ["936484456", "2026-04-13t21:30:13", "online resource", "2015270853", "sn84028196", "2470-6620", "sn84028195"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "northern ohio journal (painesville, lake county, ohio) 1872-1896 [online resource]"], "publication_frequency": ["weekly"], "score": 44.749416, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "painesville (ohio)", "lake county (ohio)", "lake county", "lake", "ohio", "united states", "painesville"], "timestamp": "2026-05-26T20:52:54.074Z", "title": "Northern Ohio journal", "type": ["title"], "url": "https://www.loc.gov/item/2015270853/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2015270854/"], "campaigns": [], "date": "1871", "dates": ["[1871 TO 1872]"], "description": ["Weekly Began with volume I, number I (July 15, 1871); ceased with volume I, number 34 (March 2, 1872). \"A family paper, devoted to literature, science, agriculture and general news.\" Description based on: Volume I, number I (July 15, 1871); title from masthead (Chroniclingamerica.loc.gov, viewed February 3, 2016). Latest issue consulted: Volume I, number 34 (March 2, 1872) (Chroniclingamerica.loc.gov, viewed February 3, 2016). Northern Ohio journa