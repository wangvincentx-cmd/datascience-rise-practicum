 the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.45633, "shard": "04", "shelf_id": "sn88078614, 1948-08-27, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ohi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "fairport harbor", "lake county (ohio)", "lake county", "lake", "ohio", "united states", "fairport harbor (ohio)"], "subject_headings": ["Fairport Harbor (Ohio)--Newspapers", "Lake County (Ohio)--Newspapers", "Ohio--Fairport Harbor", "Ohio--Lake County", "United States--Ohio--Lake--Fairport Harbor"], "subjects": [{"fairport harbor": "https://www.loc.gov/search/?fa=subject:fairport+harbor&fo=json"}, {"fairport harbor (ohio)": "https://www.loc.gov/search/?fa=subject:fairport+harbor+%28ohio%29&fo=json"}, {"lake": "https://www.loc.gov/search/?fa=subject:lake&fo=json"}, {"lake county": "https://www.loc.gov/search/?fa=subject:lake+county&fo=json"}, {"lake county (ohio)": "https://www.loc.gov/search/?fa=subject:lake+county+%28ohio%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"ohio": "https://www.loc.gov/search/?fa=subject:ohio&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2025-04-13T11:27:31.084Z", "title": "Fairport beacon (Fairport Harbor, Ohio), August 27, 1948", "type": ["issue"], "url": "https://www.loc.gov/item/sn88078614/1948-08-27/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn880