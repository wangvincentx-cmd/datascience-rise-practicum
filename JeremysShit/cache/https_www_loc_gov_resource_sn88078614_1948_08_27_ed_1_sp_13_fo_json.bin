ohi_irma_ver01/data/sn88078614/00516994071/1948082701/0547.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn88078614/1948-08-27/ed-1/?sp=13"], "batch": ["ohi_irma_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/ohio/", "2/united states/ohio/lake/", "3/united states/ohio/lake/fairport harbor/"], "contributor": ["ohio history connection, columbus, oh"], "date": "1948-08-27", "dates": ["1948-08-27"], "description": ["ATTEND RITES IN ASHTABULA Attending the funeral services for Arnold J Smesik 28 of Ash tabula recently were Mr and Mrs Steve Toth of Courtland st and their daughter Mrs Steve Tokar of Seventh st Mr Smesik was a relative of the local fami lly The young man died at his wo krat the Ohio and Western Pennsylvania Dock Co when he fell into the Ashtabula river and drowned A sister of the deceased is Mrs Michael Bodi of N St Clair st Painesville STORE ENTERED _ The door at the rear of Isalys Dairyt store forced on open High st was apparently by a crowbar or similar object some time before store opening hours eraly Sunday morning The door was damaged around the lock but nothing was found to be dis turbed and nothing was missed by the store manager Theodore Olle Confined To Hospital The condidtion of Theodore Olle of 680 N St Clair st who was removed to Lake County Me morial hospital Sunday in a seri ous condition is much improved today it was learned He had been seriously ill at his home for two days It was finally discov ered that he had a ruptured"], "digitized": true, "extract_timestamp": "2025-04-13T08:41:03.442Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88078614/1948-08-27/ed-1/?sp=13", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_irma_ver01:data:sn88078614:00516994071:1948082701:0547/full/pct:6.25/0/default.jpg#h=324&w=224", "https://tile.loc.gov/image-services/iiif/servi