96", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd375:g3754:g3754b:pm011000/full/pct:12.5/0/default.jpg#h=767&w=1003", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd375:g3754:g3754b:pm011000/full/pct:25/0/default.jpg#h=1534&w=2007"], "index": 2, "language": ["english"], "location": ["barre", "united states", "vermont"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-06t22:24:59.800000", "2005628428", "2005-12-23t11:10:56"], "online_format": ["image"], "original_format": ["map"], "other_title": ["Barre, Washington County, Vermont, 1884"], "partof": ["geography and map division", "cities and towns", "catalog", "panoramic maps"], "score": 34.632412, "shelf_id": "G3754.B3A3 1884 .N6", "site": ["catalog"], "subject": ["barre (vt.)", "aerial views", "united states", "vermont", "barre"], "timestamp": "2026-04-29T15:49:44.843Z", "title": "Barre, Washington County, VT, 1884", "type": ["cartographic"], "url": "https://www.loc.gov/item/2005628428/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2020655473", "http://www.loc.gov/item/2020655473/", "https://search.catalog.loc.gov/instances/f8a3d9b9-e4c0-5b18-af75-e3b6d379310d", "https://hdl.loc.gov/loc.afc/afc2018031.afc2018031_05200_sr01", "http://www.loc.gov/resource/afc2018031.afc2018031_05200_sr01/", "https://hdl.loc.gov/loc.afc/afc2018031.afc2018031_05200_sr02", "http://www.loc.gov/resource/afc2018031.afc2018031_05200_sr02/", "http://www.loc.gov/resource/afc2018031.afc2018031_05200_ph/", "http://www.loc.gov/resource/afc2018031.afc2018031_05200_ms01/"], "campaigns": [], "contributor": ["occupational folklife project", "nickerson, virginia", "hemenway, cassandra"], "date": "2018", "dates": ["2018"], "description": ["Cassandra Hemenway describes coming to solid waste education from an environmentalist and homesteading background. With professional training in journalism and freelance writing, and while raising her children on a single income she became very good at practicing reduce, reuse, recycle. She describes educational campaigns on the new organics law; working with schools; and setting up community compost sites. She describes her job as: \"get[ting] people to change the way that they do things;\" workshops and events such as e-waste (electronic waste) collections and Repair Cafes. She discusses the importance of backyard composting, seeing materials as resources; the right to repair; and her volunteer crew of Waste Warriors."], "digitized": true, "extract_timestamp": "2025-11-18T20:25:40.028Z", "group": ["afc/2018031", "catalog-split-02", "catalog", "trash-talk", "main-catalog-split-02"], "hassegments": true, "id": "http://www.loc.gov/item/2020655473/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:afc:afc2018031:afc2018031_05200:afc2018031_05200_ph:afc2018031_05200_ph01/full/pct:6.25/0/default.jpg", "https://tile.loc.gov/image-services/iiif/service:afc:afc2018031:afc2018031_05200:afc2018031_05200_ph:afc2018031_05200_ph01/full/pct:6.25/0/default.jpg#h=250&w=375", "https://tile.loc.gov/image-services/iiif/service:afc:afc2018031:afc2018031_05200:afc2018031_05200_ph:afc2018031_05200_ph01/full/pct:12.5/0/default.jpg#h=500&w=750", "https://tile.loc.gov/image-services/iiif/service:afc:afc2018031:afc2018031_05200:afc2018031_05200_ph:afc2018031_05200_ph01/full/pct:25/0/default.jpg#h=1000&w=1500", "https://tile.loc.gov/image-services/iiif/service:afc:afc2018031:afc2018031_05200:afc2018031_05200_ph:afc2018031_05200_ph01/full/pct:50/0/default.jpg#h=2000&w=3000", "https://tile.loc.gov/image-services/iiif/service:afc:afc2018031:afc2018031_05200:afc2018031_05200_ph:afc2018031_05200_ph01/full/pct:100/0/default.jpg#h=4000&w=6000"], "index": 3, "language": ["english"], "location": ["barre", "vermont"], "mime_type": ["audio/mp3", "audio/wav", "application/pdf", "image/jpeg", "image/jp2"], "number": ["2020655473", "2025-06-07t10:22:15.300000", "2020-06-29t12:17:39", "online resource"], "online_format": ["