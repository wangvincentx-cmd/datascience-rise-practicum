, "dates": ["[1903 TO 1920]"], "description": ["Weekly, Jan. 17, 1920-<Oct. 20, 1920> Began with Vol. 1, no. 1 (June 6, 1903); ceased in 1920. Imprint varies. Published in: Lynn, Mass., Feb. 10, 1912-July 18, 1918; Washington, D.C., <Mar. 20, 1919-May 1919>; Turin, Italy, Jan. 17, 1920-<Oct. 2, 1920>. Editor: Luigi Galleani. Description based on: Anno I, numero 1 (6 Giugno, 1903); title from masthead (Chroniclingamerica.loc.gov, viewed December 3, 2014). Latest issue consulted: Anno XVII, no. 2 (Maggio 1918) (Chroniclingamerica.loc.gov, viewed December 3, 2014)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:28.190Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2014218828/", "image_url": [], "index": 2, "language": ["italian"], "location": ["essex", "lynn", "massachusetts", "turin", "italy", "district of columbia", "united states", "washington", "vermont", "italie", "barre", "piedmont"], "number": ["2014218828", "2026-04-13t21:30:13", "895038707", "online resource", "2376-371x"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "cronaca sovversiva (barre, vermont) 1903-1920 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 46.25843, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["anarchism", "p\u00e9riodiques", "lynn", "district of columbia", "united states", "washington", "italie", "\u00e9tats-unis", "lynn (mass.)", "piedmont", "periodicals", "barre", "barre (vt.)", "essex", "massachusetts", "turin", "italy", "turin (italy)", "vermont", "newspapers", "anarchisme"], "timestamp": "2026-05-26T20:50:45.370Z", "title": "Cronaca sovversiva", "type": ["title"], "url": "https://www.loc.gov/item/2014218828/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271142/"], "campaigns": [], "date": "1897", "dates": ["[1897 TO 1959]"], "description": ["