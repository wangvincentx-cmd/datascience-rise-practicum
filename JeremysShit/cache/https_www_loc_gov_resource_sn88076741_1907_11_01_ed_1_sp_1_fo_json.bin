or the purpose of choosing the candidates of political parties A man who is not a member of a party cannot be voted for at a primary election and need not be as he is a candidate simply as an indi vidual citizen Under the old system the political panties selected their candi dates at conventions and independent candidates were nominated by petition as such Under the new system the primary election imply takes the place of a party convention Party candidates are nominated there Independent can didates may be nominated by petition as individuals as before That is what the Pioneer Express meant to say that an independent hay ing no party eannot get on a primary"], "digitized": true, "extract_timestamp": "2023-08-25T19:24:22.280Z", "group": ["ndnp/ndhi", "state-histrorical-society-of-north-dakota-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88076741/1907-11-01/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_almont_ver01:data:sn88076741:00295863614:1907110101:0796/full/pct:3.125/0/default.jpg#h=278&w=198", "https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_almont_ver01:data:sn88076741:00295863614:1907110101:0796/full/pct:6.25/0/default.jpg#h=556&w=396", "https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_almont_ver01:data:sn88076741:00295863614:1907110101:0796/full/pct:12.5/0/default.jpg#h=1112&w=793", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ndhi/batch_ndhi_almont_ver01/data/sn88076741/00295863614/1907110101/0796.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["pembina", "north dakota", "united states"], "location_city": ["pembina"], "location_country": ["united states"], "location_county": ["pembina"], "location_state": ["north dakota"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "9", 