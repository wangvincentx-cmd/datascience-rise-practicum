tps://www.loc.gov/item/2018677752/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/nclc/item/2018677755/", "https://hdl.loc.gov/loc.pnp/nclc.02949", "https://hdl.loc.gov/loc.pnp/cph.3a20272", "http://www.loc.gov/item/2018677755/", "http://www.loc.gov/pictures/item/2018677755/", "http://www.loc.gov/resource/nclc.02949/", "http://www.loc.gov/resource/cph.3a20272/", "http://lccn.loc.gov/2018677755"], "campaigns": [], "contributor": ["hine, lewis wickes"], "date": "1914-01-01", "dates": ["1914"], "description": ["1 photographic print."], "digitized": true, "extract_timestamp": "2021-09-01T22:53:51.949Z", "group": ["nclc", "catalog-split-00", "catalog", "national-child-labor-committee", "main-catalog-split-00", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2018677755/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02949_150px.jpg#h=107&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02949t.gif#h=108&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02949r.jpg#h=459&w=640", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02949v.jpg#h=734&w=1024"], "index": 6, "language": ["english"], "location": ["scotland neck", "united states", "north carolina"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/2018677755", "http://www.loc.gov/item/20688602", "2018-11-02t16:01:20", "2018677755", "http://www.loc.gov/item/ncl2004004146/pp"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 7479", "prints and photographs division", "prints & photographs online catalog (library of congress)", "national child labor committee collection", "catalog"], "score": 26.468523, "shelf_id": "LOT 7479, v. 6, no. 3853 [P&P]", "site": ["pictures", "catalog"], "subject": ["textile machinery", "textile mill workers", "scotland neck", "photographic prints", "hosiery industry", "north carolina", "girls", "united states"], "timestamp": "2022-04-30T19:02:59.984Z", "title": "Nannie Coleson, looper who said she was 11 years old, and has been working in the Crescent Hosiery Mill for some months. Makes about $3 a week. Has been through the 5th grade in school. She is bright, but unsophisticated. Told investigator, \"There are other little girls in the mill too. One of them, says she's 13, but she doesn't look any older than me.\"  Location: Scotland Neck, North Carolina.", "url": "https://www.loc.gov/item/2018677755/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/nclc/item/2018677758/", "https://hdl.loc.gov/loc.pnp/nclc.02952", "http://www.loc.gov/item/2018677758/", "http://www.loc.gov/pictures/item/2018677758/", "http://www.loc.gov/resource/nclc.02952/", "http://lccn.loc.gov/2018677758"], "campaigns": [], "contributor": ["hine, lewis wickes"], "date": "1914-01-01", "dates": ["1914"], "description": ["1 photographic print."], "digitized": true, "extract_timestamp": "2021-09-01T22:53:51.949Z", "group": ["nclc", "catalog-split-03", "catalog", "national-child-labor-committee", "main-catalog-split-03", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2018677758/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02952_150px.jpg#h=107&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02952t.gif#h=107&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02952r.jpg#h=455&w=640", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02952v.jpg#h=728&w=1024"], "index": 7, "language": ["english"], "location": ["scotland neck", "united states", "north carolina"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/20688605", "2018-11-02t16:01:22", "2018677758", "http://www.loc.gov/item/2018677758", "http://www.loc.gov/item/ncl2004004149/pp"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 7479", "prints and photographs division", "prints & photographs online catalog (library of congress)", "national child labor committee collection", "catalog"], "score": 26.468523, "shelf_id": "LOT 7479, v. 6, no. 3856 [P&P]", "site": ["pictures", "catalog"], "subject": ["textile mill workers", "cotton industry", "scotland neck", "photographic prints", "north carolina", "girls", "united states"], "timestamp": "2022-04-30T19:02:59.984Z", "title": "Scotland Neck Cotton Mill. Group showing some of the youngest workers taken in the mill at starting time. Tiniest girl, one apparently 8 or 9, I saw at work at her knitting machine perched up on a box, as she was too short to reach. The next in size I saw raveling. Both were steady workers.  Location: Scotland Neck, North Carolina.", "url": "https://www.loc.gov/item/2018677758/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/nclc/item/2018677760/", "https://hdl.loc.gov/loc.pnp/nclc.02954", "http://www.loc.gov/item/2018677760/", "http://www.loc.gov/pictures/item/2018677760/", "http://www.loc.gov/resource/nclc.02954/", "http://lccn.loc.gov/2018677760"], "campaigns": [], "contributor": ["hine, lewis wickes"], "date": "1914-01-01", "dates": ["1914"], "description": ["1 photographic print."], "digitized": true, "extract_timestamp": "2021-09-01T22:53:51.949Z", "group": ["nclc", "catalog-split-12", "catalog", "national-child-labor-committee", "main-catalog-split-12", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2018677760/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02954_150px.jpg#h=105&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02954t.gif#h=105&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02954r.jpg#h=449&w=640", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02954v.jpg#h=719&w=1024"], "index": 8, "language": ["english"], "location": ["scotland ne