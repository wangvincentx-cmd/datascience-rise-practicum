, "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2021-01-01", "dates": ["2021"], "description": ["Title, date, and keywords based on information provided by the photographer. Purchase Carol M. Highsmith Photography, Inc.; 2021  (DLC/PP-2021:107). Forms part of Carol M. Highsmith's America Project in the Carol M. Highsmith Archive. Credit Line: Photographs in Carol M. Highsmith's America Project in the Carol M. Highsmith Archive, Library of Congress, Prints and Photographs Division."], "digitized": true, "extract_timestamp": "2022-08-02T18:21:50.110Z", "group": ["catalog", "highsm", "catalog-split-08", "main-catalog", "carol-m-highsmith", "main-catalog-split-08"], "hassegments": false, "id": "http://www.loc.gov/item/2021757853/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/highsm/69600/69632_150px.jpg#h=100&w=150", "https://tile.loc.gov/storage-services/service/pnp/highsm/69600/69632r.jpg#h=427&w=640", "https://tile.loc.gov/storage-services/service/pnp/highsm/69600/69632v.jpg#h=683&w=1024"], "index": 2, "language": ["english"], "location": ["united states", "box butte county", "alliance", "nebraska"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["online resource", "http://www.loc.gov/item/22637394", "2021757853", "2022-06-09t14:48:27"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["highsmith (carol m.) archive", "catalog", "prints & photographs online catalog (library of congress)", "prints and photographs division"], "score": 42.731796, "shelf_id": "LC-DIG-highsm- 69632", "site": ["catalog", "pictures"], "subject": ["color", "digital photographs", "america", "box butte county", "nebraska", "freight trains", "coal trains", "united states", "long trains", "alliance"], "timestamp": "2022-08-02T18:36:27.081Z", "title": "Coal trains near Alliance in Box Butte County, Nebraska", "type": ["still image"], "url": "https://www.loc.gov/item/2021757853/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2021757808", "http://www.loc.gov/item/2021757808/", "https://hdl.loc.gov/loc.pnp/highsm.69587", "http://www.loc.gov/resource/highsm.69587/", "https://www.loc.gov/pictures/item/2021757808/", "http://www.loc.gov/pictures/item/2021757808/", "https://www.loc.gov/pictures/collection/highsm/item/2021757808/", "http://www.loc.gov/pictures/collection/highsm/item/2021757808/", "https://hdl.loc.gov/loc.pnp/highsm.69587"], "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2021-01-01", "dates": ["2021"], "description": ["Title, date, and keywords based on information provided by the photographer. Farmer and engineer Jim Reinders built the array of old automobiles, obtained from nearby farms and dumps and scrapyards, as a tribute to his father. At first the city lobbied to tear the odd monument down, then put a fence around it, but eventually embraced it and called Alliance the \"Home of Carhenge.\" Purchase Carol M. Highsmith Photography, Inc.; 2021  (DLC/PP-2021:107). Forms part of Carol M. Highsmith's America Project in the Carol M. Highsmith Archive. Credit Line: Photographs in Carol M. Highsmith's America Project in the Carol M. Highsmith Archive, Library of Congress, Prints and Photographs Division."], "digitized": true, "extract_timestamp": "2022-08-02T18:21:49.396Z", "group": ["catalog", "highsm", "catalog-split-08", "main-catalog", "carol-m-highsmith", "main-catalog-split-08"], "hassegments": false, "id": "http://www.loc.gov/item/2021757808/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/highsm/69500/69587_150px.jpg#h=76&w=150", "https://tile.loc.gov/storage-services/service/pnp/highsm/69500/69587r.jpg#h=323&w=640", "https://tile.loc.gov/storage-services/service/pnp/highsm/69500/69587v.jpg#h=517&w=1024"], "index": 3, "language": ["english"], "location": ["united states", "box butte county", "alliance", "nebraska"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2022-06-09t14:48:23"