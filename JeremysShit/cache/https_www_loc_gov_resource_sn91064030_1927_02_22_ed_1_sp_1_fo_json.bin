he rieasantville City budget for the year 1927 was passed by the onimon Council on first reading hist night The amount to be raised by taxation is 31905190 as against 25159215 for the year of 1926 Increases in the running expenses of the city appear in the divisions of streets and highways preser vation of life and property matur ing bonds sewer operation asses mont and collection of taxes health and charity school appropriations and elsewhere These reflect the growing city and also the payments of bonds due and interest on other bonds The division of streets and high ways shows an increase of from 7455000 to 8755000 There is an increase of over 6400 in the amount set aside for the police and fire departments Health and charity is increased about 2000 There is an"], "digitized": true, "extract_timestamp": "2025-12-01T12:40:43.734Z", "group": ["ndnp/njr", "rutgers-university-libraries-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn91064030/1927-02-22/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_galloway_ver01:data:sn91064030:00513685555:1927022201:0168/full/pct:6.25/0/default.jpg#h=414&w=329", "https://tile.loc.gov/image-services/iiif/service:ndnp:njr:batch_njr_galloway_ver01:data:sn91064030:00513685555:1927022201:0168/full/pct:12.5/0/default.jpg#h=829&w=659", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/njr/batch_njr_galloway_ver01/data/sn91064030/00513685555/1927022201/0168.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["united states", "pleasantville", "atlantic", "atlantic county", "new jersey"], "location_city": ["pleasantville"], "location_country": ["united states"], "location_county": ["atlantic"], "location_state": ["new jersey"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "sn91064030", "0", "5", "6", "0000000001", "8", "1"], "num