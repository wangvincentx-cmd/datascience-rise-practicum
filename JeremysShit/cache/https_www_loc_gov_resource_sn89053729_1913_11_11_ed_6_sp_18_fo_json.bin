{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn89053729/?st=calendar", "cite_this": {"apa": "(1913, November 11)  <cite>Atlanta Georgian</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn89053729/1913-11-11/ed-6/.", "chicago": "<cite>Atlanta Georgian</cite>. (Atlanta, GA), Nov. 11 1913. https://www.loc.gov/item/sn89053729/1913-11-11/ed-6/.", "mla": "<cite>Atlanta Georgian</cite>. (Atlanta, GA) 11 Nov. 1913, p. 18. Retrieved from the Library of Congress, www.loc.gov/item/sn89053729/1913-11-11/ed-6/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_kesil_ver01/data/sn89053729/00393344581/1913111106/0849.xml&format=alto_xml&full_text=1", "item": {"_version_": 1799816825836404736, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn89053729/1913-11-11/ed-6/", "http://www.loc.gov/resource/sn89053729/1913-11-11/ed-6/"], "batch": ["gu_kesil_ver01"], "call_number": ["Newspaper"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/georgia/", "2/united states/georgia/fulton/", "3/united states/georgia/fulton/atlanta/"], "contributor_names": ["Digital Library of Georgia, a project of GALILEO located at the University of Georgia Libraries"], "contributors": [{"digital library of georgia, a project of galileo located at the university of georgia libraries": "https://www.loc.gov/search/?fa=contributor:digital+library+of+georgia,+a+project+of+galileo+located+at+the+university+of+georgia+libraries&fo=json"}], "created_published": ["Atlanta, Ga., November 11, 1913"], "date": "1913-11-11", "date_issued": "1913-11-11", "dates": [{"1913-11-11": "https://www.loc.gov/search/?dates=1913-11-11/1913-11-11&fo=json"}], "dates_of_publication": "1912-1939", "description": ["Atlanta, Ga."], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2024-05-22T12:58:30.451Z", "extract_urls": ["file:/service/ndnp//gu/batch_gu_kesil_ver01/data/sn89053729/00393344581/1913111106/1913111106_1.xml#ndnp/gu"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/gu", "digital-library-of-georgia-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn89053729/1913-11-11/ed-6/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_kesil_ver01:data:sn89053729:00393344581:1913111106:0832/full/pct:3.125/0/default.jpg#h=260&w=214", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_kesil_ver01:data:sn89053729:00393344581:1913111106:0832/full/pct:6.25/0/default.jpg#h=521&w=428", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_kesil_ver01:data:sn89053729:00393344581:1913111106:0832/full/pct:12.5/0/default.jpg#h=1042&w=857"], "index": 18, "item": {"batch": ["gu_kesil_ver01"], "call_number": ["Newspaper"], "contributor_names": ["Digital Library of Georgia, a project of GALILEO located at the University of Georgia Libraries"], "created_published": ["Atlanta, Ga., November 11, 1913"], "date": "1912", "date_issued": "1913-11-11", "dates": ["1913-11-11"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn89053729", "location": ["Atlanta (Ga.)", "Fulton County (Ga.)", "Georgia--Atlanta", "Georgia--Fulton County"], "medium": "18 pages", "newspaper_title": ["Atlanta Georgian"], "notes": ["Daily", "Began with vol. 10, no. 218 (Apr. 13, 1912); ceased with v. 38, no. 292 (Dec. 16, 1939).", "Published in several chronological editions. Some issues may also carry statements such as \"Florida extra\" and \"Extra for Carolina\"; cannot always be determined whether these issues are part of true separate geographical editions.", "Some irregularities in enumeration.", "Stated publication frequency is every afternoon except Sunday, <May 3, 1912>-September 12, 1913. Sunday American appears to have consituted the Sunday issue of this title and to have existed also as a separate publication in editions for various cities.", "Sunday edition has its own numbering.", "Archived issues are available in digital format from the Library of Congress Chronicling America online collection.", "American Sunday monthly magazine may appear as part of Sunday issue, <June 1913->. May have been issued with various newspapers.", "Unable to determine relationship to: The Georgian's weekly news briefs and its succeeding title: Weekly Georgian (Atlanta, Ga.). May be weekly editions of this title or may simply be titles also published by the Georgian Company.", "Vol. X, no. 236 (May 3, 1912) (extra) (online surrogate); title from masthead (Georgia Historic Newspapers archive, viewed July 29, 2021).", "Vol. XIV, no. 31(September 8, 1915) (final) (online surrogate) (Georgia Historic Newspapers archive, viewed July 29, 2021).", "Atlanta journal (Atlanta, Ga. : 1889) (DLC)sn 82015426 (OCoLC)8807964"], "other_formats": ["https://tile.loc.gov/storage-services/service/ndnp//gu/batch_gu_kesil_ver01/data/sn89053729/00393344581/1913111106/1913111106_1.xml", "http://lccn.loc.gov/sn89053729/marcxml"], "other_title": ["Atlanta Georgian and news", "Sunday issues published with title: Sunday American", "Sunday issues may be called: Hearst's Sunday American", "Sunday issues may sometimes be called: Atlanta American", "One extra for May 31, 1913 called: Georgian Atlanta", "May sometimes be called: Georgian-American"], "place_of_publication": "Atlanta, Ga.", "raw_lccn": "sn 89053729 ", "reel_numbers": ["00393344581"], "source_group": "ndnp/gu", "subjects": ["Atlanta (Ga.)--Newspapers", "Fulton County (Ga.)--Newspapers", "Georgia--Atlanta", "Georgia--Fulton County", "United States--Georgia--Fulton--Atlanta"], "title": "Atlanta Georgian (Atlanta, Ga.), November 11, 1913, (FINAL)"}, "language": ["english"], "languages": [{"english": "https://www.loc.gov/search/?fa=language:english&fo=json"}], "library_of_congress_control_number": "sn89053729", "location": ["georgia", "united states", "atlanta", "fulton county", "fulton"], "location_city": ["atlanta"], "location_country": ["united states"], "location_county": ["fulton"], "location_state": ["georgia"], "locations": [{"atlanta": "https://www.loc.gov/search/?fa=location:atlanta&fo=json"}, {"fulton": "https://www.loc.gov/search/?fa=location:fulton&fo=json"}, {"fulton county": "https://www.loc.gov/search/?fa=location:fulton+county&fo=json"}, {"georgia": "https://www.loc.gov/search/?fa=location:georgia&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=location:united+states&fo=json"}], "locations_city": [{"atlanta": "https://www.loc.gov/search/?fa=location_city:atlanta&fo=json"}], "locations_country": [{"united states": "https://www.loc.gov/search/?fa=location_country:united+states&fo=json"}], "locations_county": [{"fulton": "https://www.loc.gov/search/?fa=location_county:fulton&fo=json"}], "locations_state": [{"georgia": "https://www.loc.gov/search/?fa=location_state:georgia&fo=json"}], "medium": "18 pages", "method": "mets_filesec", "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "newspaper_title": ["Atlanta Georgian"], "notes": ["Daily", "Began with vol. 10, no. 218 (Apr. 13, 1912); ceased with v. 38, no. 292 (Dec. 16, 1939).", "Published in several chronological editions. Some issues may also carry statements such as \"Florida extra\" and \"Extra for Carolina\"; cannot always be determined whether these issues are part of true separate geographical editions.", "Some irregularities in enumeration.", "Stated publication frequency is every afternoon except Sunday, <May 3, 1912>-September 12, 1913. Sunday American appears to have consituted the Sunday issue of this title and to have existed also as a separate publication in editions for various cities.", "Sunday edition has its own numbering.", "Archived issues are available in digital format from the Library of Congress Chronicling America online collection.", "American Sunday monthly magazine may appear as part of Sunday issue, <June 1913->. May have been issued with various newspapers.", "Unable to determine relationship to: The Georgian's weekly news briefs and its succeeding title: Weekly Georgian (Atlanta, Ga.). May be weekly editions of this title or may simply be titles also published by the Georgian Company.", "Vol. X, no. 236 (May 3, 1912) (extra) (online surrogate); title from masthead (Georgia Historic Newspapers archive, viewed July 29, 2021).", "Vol. XIV, no. 31(September 8, 1915) (final) (online surrogate) (Georgia Historic Newspapers archive, viewed July 29, 2021).", "Atlanta journal (Atlanta, Ga. : 1889) (DLC)sn 82015426 (OCoLC)8807964"], "number": ["00393344581", "6", "sn89053729"], "number_edition": ["6"], "number_lccn": ["sn89053729"], "number_reel": ["00393344581"], "numeric_shelf_id": 191311116, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//gu/batch_gu_kesil_ver01/data/sn89053729/00393344581/1913111106/1913111106_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn89053729/marcxml"}], "other_title": ["Atlanta Georgian and news", "Sunday issues published with title: Sunday American", "Sunday issues may be called: Hearst's Sunday American", "Sunday issues may sometimes be called: Atlanta American", "One extra for May 31, 1913 called: Georgian Atlanta", "May sometimes be called: Georgian-American"], "partof": [{"count": 3680, "title": "atlanta georgian (atlanta, ga.) 1912-1939", "url": "https://www.loc.gov/search/?fa=partof:atlanta+georgian+%28atlanta,+ga.%29+1912-1939&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["atlanta georgian (atlanta, ga.) 1912-1939"], "place_of_publication": "Atlanta, Ga.", "publication_frequency": ["daily"], "raw_lccn": "sn 89053729 ", "reel_numbers": ["00393344581"], "resources": [{"files": 18, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_kesil_ver01:data:sn89053729:00393344581:1913111106:0832/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn89053729/1913-11-11/ed-6/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn89053729, 1913-11-11, Edition 6", "site": ["chroniclingamerica"], "source_group": "ndnp/gu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["georgia", "united states", "atlanta", "fulton county (ga.)", "newspapers", "atlanta (ga.)", "fulton county", "fulton"], "subject_headings": ["Atlanta (Ga.)--Newspapers", "Fulton County (Ga.)--Newspapers", "Georgia--Atlanta", "Georgia--Fulton County", "United States--Georgia--Fulton--Atlanta"], "subjects": [{"atlanta": "https://www.loc.gov/search/?fa=subject:atlanta&fo=json"}, {"atlanta (ga.)": "https://www.loc.gov/search/?fa=subject:atlanta+%28ga.%29&fo=json"}, {"fulton": "https://www.loc.gov/search/?fa=subject:fulton&fo=json"}, {"fulton county": "https://www.loc.gov/search/?fa=subject:fulton+county&fo=json"}, {"fulton county (ga.)": "https://www.loc.gov/search/?fa=subject:fulton+county+%28ga.%29&fo=json"}, {"georgia": "https://www.loc.gov/search/?fa=subject:georgia&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2024-05-23T04:37:54.374Z", "title": "Atlanta Georgian (Atlanta, Ga.), November 11, 1913, (FINAL)", "type": ["issue"], "url": "https://www.loc.gov/item/sn89053729/1913-11-11/ed-6/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83016184/1882-10-24/ed-1/", "http://www.loc.gov/resource/sn83016184/1882-10-24/ed-1/"], "batch": ["dlc_fairview_ver01"], "campaigns": [], "contributor": ["library of congress, washington, dc"], "date": "1882-10-24", "dates": ["1882-10-24"], "description": ["Atlanta, Ga."], "digitized": true, "extract_timestamp": "2023-08-07T20:31:23.113Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-wash