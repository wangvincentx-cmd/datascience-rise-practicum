f", "image/jpeg", "image/jp2"], "number": ["75693192", "2025-06-07t18:30:51.900000", "2026-07-20t15:29:44.100000"], "online_format": ["image"], "original_format": ["map"], "partof": ["panoramic maps", "geography and map division", "catalog", "cities and towns"], "score": 31.420424, "shelf_id": "G3924.F5A3 1908 .F6", "site": ["catalog"], "subject": ["fitzgerald (ga.)", "aerial views", "georgia", "fitzgerald", "united states"], "timestamp": "2026-07-21T11:17:34.745Z", "title": "Bird's eye view of Fitzgerald, Georgia 1908", "type": ["cartographic"], "url": "https://www.loc.gov/item/75693192/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/fsa/item/2017753880/", "http://www.loc.gov/item/2017753880/", "http://www.loc.gov/pictures/item/2017753880/", "https://hdl.loc.gov/loc.pnp/fsa.8a40169", "http://www.loc.gov/resource/fsa.8a40169/", "http://lccn.loc.gov/2017753880"], "campaigns": [], "contributor": ["wolcott, marion post"], "date": "1939-01-01", "dates": ["1939"], "description": ["1 negative : nitrate ; 35 mm."], "digitized": true, "extract_timestamp": "2021-09-01T20:14:10.438Z", "group": ["fsa", "catalog-split-09", "catalog", "fsa-owi-black-and-white-negatives", "main-catalog-split-09", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017753880/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/fsa/8a40000/8a40100/8a40169_150px.jpg#h=107&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8a40000/8a40100/8a40169t.gif#h=99&w=150", "https://tile.loc.gov/storage-services/service/pnp/fsa/8a40000/8a40100/8a40169r.jpg#h=457&w=640", "https://tile.loc.gov/storage-services/service/pnp/fsa/8a40000/8a40100/8a40169v.jpg#h=731&w=1024"], "index": 5, "language": ["english"], "location": ["united states", "georgia", "fitzgerald"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/fsa1998012538/pp", "http://www.loc.gov/item/19846171", "2017753880", "http://www.loc.gov/item/2017753880", "2017-07-27t14:18:49"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["catalog", "farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "american memory", "prints and photographs division", "lot 1572"], "score": 25.312489, "shelf_id": "LC-USF33- 030372-M5 [P&P] LOT 1572  (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["united states", "nitrate negatives", "georgia", "fitzgerald"], "timestamp": "2022-04-25T17:36:03.928Z", "title": "Hanging around railroad tracks in center of town of Fitzgerald, Georgia", "url": "https://www.loc.gov/item/2017753880/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2010655308", "http://www.loc.gov/item/2010655308/", "https://hdl.loc.gov/loc.afc/collafc.afc1982010", "http://www.loc.gov/resource/collafc.afc1982010/"], "campaigns": [], "contributor": ["blackmarr, syd", "archive of folk culture (library of congress)", "fleischhauer, carl", "marshall, howard w.", "adler, thomas a.", "mcgraw, hugh", "american folklife center", "abraham baldwin agricultural college", "jabbour, alan", "lightfoot, william e. (william edwin)", "robinson, beverly j.", "hamrick, raymond c.", "stanley, david", "coelho, dennis"], "date": "1977", "dates": ["1977"], "description": ["Collection of documentary materials resulting from an ethnographic field research project conducted by the American Folklife Center in eight counties of south central Georgia, and at Mt. Zion, Georgia, in July and August 1977 in cooperation with the Arts Experiment Station of Abraham Baldwin Agricultural College. Topics of research were hymn singing conventions, gospel singing of white and African American residents, fiddling and old-time music, vernacular architecture, quilts and quilting, occupations, foodways, jokes and stories from the region, which were documented through approximately 300 hours of audio interviews and in recordings made at local events. The collection also includes photographs and sound recordings of the following people and activities: Hugh McGraw, Raymond Hamrick, J. C. Cooper, and others leading sacred harp singing; other congregational and gospel singing groups; African American children's games, singing games, handclapping, and hambone; and old-time and bluegrass music featuring local fiddle, guitar, piano, and banjo players. Subjects of documentary photography include: people interviewed for the project; copies of their family photographs; vernacular houses, barns, and outbuildings, including log buildings; tools, furniture, birdhouses, and yard art; wells; tobacco culture, including curing, harvesting, warehouses, auctions, and farms, as well as tobacco workers; peanut, cotton, soybean, corn, and wheat fields; crop dusting; churches; religious services, including baptisms; prayers, sermons, hymn singing, and tent revivals; church suppers; barbecue cooking; breakfasts; quilts, crochet, and basket work; woodcarving; vernacular boats, boat repair, and boat building; fishing; graveyards, gravesites and grave markers; grocery stores, restaurants, dry goods stores, and a barber shop; business and roadside signs; a piano repair shop; aerial photographs; gathering wild herbs; trees, landscapes; swamps and rivers; and turtles, catfish, cattle, and dogs.  The collection includes photographs of sculpture, paintings, and gardens at Pope's Museum, near Pelham, Georgia, featuring the sculpture and artwork of Laura Pope Forester who died in 1953, and artwork and sculpture of St. EOM (Eddie Owens Martin) and his creation, Pasaquan.  Includes photographs of President Nyerere of Tanzania visiting Abraham Baldwin Agricultural College, August 9, 1977. Also includes photographs of the reception held for the exhibition \"Folk Art and Folk Life,\" at the Library of Congress in Washington, D.C. with Dr. and Mrs. Daniel Boorstin; First Lady Rosalynn Carter, Amy Carter, Mrs. Mary Beth Busbee, J. Michael Carrigan, Jr., Don Yoder, and Reverend Howard Finster, January 26, 1978, and photographs of the exhibition, February, 1978.  Includes additional photographs of a seminar held in the Whittall Pavilion, Library of Congress, March 17, 1978, titled \"Southern Folk Pottery: The Meaders Family Tradition,\" with Lanier Meaders, Mrs. Cheever Meaders, John Burrison, and Ralph Rinzler.  More  photographs of south Georgia cemeteries were taken by Dennis Coelho, Georgia state folklorist, in the summer of 1979.  Thirty-one pen-and-ink drawings of vernacular buildings and floor plans were made by Howard Marshall.  The collection includes documentation of the exhibition, and proposed publication projects to 1982."], "digitized": true, "extract_timestamp": "2023-07-22T07:41:56.144Z", "group": ["catalog-split-14", "catalog", "main-catalog-split-14", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2010655308", "image_url": [], "index": 6, "language": ["english"], "location": ["turner county", "irwin county", "ben hill county", "grady county", "colquitt county", "washington d.c.", "tift county", "georgia", "cook county", "worth county", "berrien county"], "number": ["2023-07-20t10:58:01", "2010655308"], "original_format": ["manuscript/mixed material", "collection"], "partof": ["american folklife center", "catalog"], "score": 24.24367, "shelf_id": "http://lccn.loc.gov/2010655308", "site": ["catalog"], "subject": ["photographs", "tift county (ga.)", "cook county (ga.)", "grady county (ga.)", "oral histories", "sound recordings", "drawings", "hymns", "georgia", "songs", "cemeteries", "gopher tortoise", "documentary photography", "interviews", "colquitt county (ga.)", "event place", "south georgia sacred harp singing convention", "essays", "sermons", "quilts", "nyerere, julius k.", "fiddle tunes", "pictorial works", "bluegrass music", "field notes", "outsider art", "ben hill county (ga.)", "agriculture", "tales", "folklore", "forester, laura pope", "programs", "ethnography", "finster, howard", "food habits", "hymn festivals", "singing games", "methodist church buildings", "social life and customs", "irwin county (ga.)", "turner county (ga.)", "correspondence", "clippings", "african american quiltmakers", "baptist church buildings", "washington (d.c.)", "boats", "music", "videocassettes", "st. eom", "sculpture", "shape-note singing", "worth county (ga.)", "berrien county (ga.)", "african americans", "tobacco farms", "vernacular architecture", "folk music", "choral societies", "hymns, english", "old-time music", "aerial photographs", "gospel music", "worship programs", "fishing", "african american children's games"], "timestamp": "2023-07-22T07:44:32.027Z", "title": "South-Central Georgia Folklife Project collection,", "type": ["manuscript"], "url": "//lccn.loc.gov/2010655308"}, {"access_restricted": true, "aka": ["https://www.loc.gov/pictures/item/90714817/", "http://www.loc.gov/item/90714817/", "http://www.loc.gov/pictures/item/90714817/", "https://www.loc.gov/pictures/collection/cph/item/90714817/", "http://www.loc.gov/pictures/collection/cph/item/90714817/", "http://www.loc.gov/resource/cph.3c01968/", "https://hdl.loc.gov/loc.pnp/cph.3c01968", "http://lccn.loc.gov/90714817"], "campaigns": [], "date": "1897-01-01", "dates": ["1897"], "description": ["1 photographic print. | Bales of cotton on Central Avenue, Fitzgerald, Georgia."], "digitized": true, "extract_timestamp": "2021-08-24T21:05:27.043Z", "group": ["cph", "catalog-split-05", "catalog", "miscellaneous-items-high-demand", "main-catalog-split-05", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/90714817/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/cph/3c00000/3c01000/3c01900/3c01968_150px.jpg#h=120&w=150"], "index": 7, "language": ["english"], "location": ["georgia", "fitzgerald"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/90714817"