v/image-services/iiif/service:ndnp:gu:batch_gu_cookie_ver02:data:sn89053308:00517177258:1923092701:0795/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/gu/batch_gu_cookie_ver02/data/sn89053308/00517177258/1923092701/0798.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn89053308/1923-09-27/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/gu/batch_gu_cookie_ver02/data/sn89053308/00517177258/1923092701/0798.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89053308/1923-09-27/ed-1/?sp=4"], "batch": ["gu_cookie_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/georgia/", "2/united states/georgia/ben hill/", "3/united states/georgia/ben hill/fitzgerald/"], "contributor": ["digital library of georgia, a project of galileo located at the university of georgia libraries"], "date": "1923-09-27", "dates": ["1923-09-27"], "description": ["The Fitzgerald Leader ENTERPRISE and PRESS Official Organ City of Fitzgerald PUBLISHED EVERY THURSDAY By The Leader Publishing Company Subscription Price per Annum_______ 150 Entered at the Post m\u00e9czt Fitzgerald as Second Class Mail Matter under Act of Congress March 18 1897 SIDHOR GEILDERS 1 Hditof Mrs MAUD GELDERS _News Editor i R Kates lor display advertising furnished on application Local Readers 10c per line for each insertion No ad taken for less than 30 cents AMERICAN PRESS ASSOCIATION Foreign Advertising Representatives GOOD TIMES AHEAD Discussing with the two banks of the gity the present year end situa tion and the outlook for another year indicates that though times have been tight people are not broke by any means but have this year learned a mighty good Tessonthe lesson of appreciating a dollar and the lesson of economy and saving These bank ers are all the while peering into the future to guide away from dangers and they believe that with normal weather next year we are going to make good yields of several money crops includ ing nice yield of cotton peanuts tobacco hogs chickens and eggs cream oats potatoes syrup cte just such a combination as will give"], "digitized": true, "extract_timestamp": "2024-05-22T12:55:30.918Z", "group": ["ndnp/gu", "digital-library-of-georgia-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89053308/1923-09-27/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_cookie_ver02:data:sn89053308:00517177258:1923092701:0798/full/pct:3.125/0/default.jpg#h=300&w=222", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_cookie_ver02:data:sn89053308:00517177258:1923092701:0798/full/pct:6.25/0/default.jpg#h=601&w=445", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_cookie_ver02/data/sn89053308/00517177258/1923092701/0798.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["ben hill county", "ben hill", "georgia", "fitzgerald", "united states"], "location_city": ["fitzgerald"], "location_country": ["united states"], "location_county": ["ben hill"], "location_state": ["georgia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["1", "0", "7", "0000000004", "5", "sn89053308", "8", "2"], "number_edition": ["1"], "number_lccn": ["sn89053308"], "number_page": ["0000000004"], "number_reel": ["0", "0", "5", "1", "7", "1", "7", "7", "2", "5", "8"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Occasional issue may bear previous title: Leader enterprise and press"], "partof": ["the fitzgerald leader enterprise and press (fitzgerald, georgia) 1921-1964", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial an