une/batch_iune_charlie_ver01/data/sn84024055/00280761060/1914012401/0464.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn84024055/1914-01-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/iune/batch_iune_charlie_ver01/data/sn84024055/00280761060/1914012401/0464.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84024055/1914-01-24/ed-1/?sp=1"], "batch": ["iune_charlie_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/illinois/", "2/united states/illinois/cook county/", "3/united states/illinois/cook county/chicago/", "1/united states/utah/", "2/united states/utah/salt lake county/", "3/united states/utah/salt lake county/salt lake city/"], "contributor": ["university of illinois at urbana-champaign library, urbana, il"], "date": "1914-01-24", "dates": ["1914-01-24"], "description": ["7wij ffr wyiviy 4 C HEW TO THE LINOS LET THE CHIPS FALL WHERE THEY MAT HHHH yH I v JSB j1 mr55S CSr IM 1 Vl XIX CHICAGO JANUARY 24 1914 Nry Roger C Sullivan Frank D Comerford Hon Carl Vrooman James C McShane and John Z White Have So Far Entered the Race for United States Senator FEOM ILLINOIS AND FROM NOW UNTIL TTTR PRIMARIES IN SEP TEMBEE THEY WILL WAQE A VIOOBOT7S FIGHT FOE THE DIRECT NOMINATION AT THE HANDS OF rrrp VOTERS THROUGHOUT THIS STATE MR SULLIVAN ISSUES A PLAIN COMMON SENSE AND BUSINESSLIKE STATEMENT IN RELATION TO HIS ATTITUDE TOWARDS PRESI DENT WILSON AND HIS POLICIES AND THE OTHER LIVE AND IMPORTANT QUESTIONS OF THE DAY MR VROOMAN WILL ESTABLISH HIS SENATOBIALHEADQUARTERS IN TEE NATIONAL LIFE BUILDING AND HE WILL LEAVE NO STONE UNTURNED IN AN HONOBABB EFFORT TO SUCCEED THE HON LAWRENCE Y w jh THE UNITED STATES SENATE EOT ALDERMANIC SCRAP IN titt SECOND WARD BETWEEN MISS SARA HOPKINS ADERMAN HUGH NORRIS THOMAS HOYNE WILLIAM R COWAN AND MABIUS PETERSON PROGRESSIVE REPUBLICAN AT THE PRESENT TT IT IS TTATpn TO TELL JUST HOW THE FIGHT WILL END AND WHO WILL BE TTR LUCKY"], "digitized": true, "extract_timestamp": "2025-05-21T10:17:39.279Z", "group": ["ndnp/iune", "university-of-illinois-at-urbana-champaign-library-urbana-il-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84024055/1914-01-24/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_charlie_ver01:data:sn84024055:00280761060:1914012401:0464/full/pct:6.25/0/default.jpg#h=455&w=316", "https://tile.loc.gov/image-services/iiif/service:ndnp:iune:batch_iune_charlie_ver01:data:sn84024055:00280761060:1914012401:0464/full/pct:12.5/0/default.jpg#h=911&w=632", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/iune/batch_iune_charlie_ver01/data/sn84024055/00280761060/1914012401/0464.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["illinois", "cook county", "salt lake city", "united states", "salt lake county", "utah", "chicago"], "location_city": ["chicago", "salt lake city"], "location_country": ["united states"], "location_county": ["cook county", "salt lake county"], "location_state": ["illinois", "utah"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["1", "2", "8", "0000000001", "7", "sn84024055", "0", "6"], "number_edition": ["1"], "number_lccn": ["sn84024055"], "number_page": ["0000000001"], "number_reel": ["0", "0", "2", "8", "0", "7", "6", "1", "0", "6", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Broadax"], "partof": ["serial and government publications division", "chronicling america", "the broad ax (salt lake city, utah;chicago, ill.) 1895-19??"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the broad ax (salt lake city, utah;chicago, ill.) 1895-19??"], "publication_