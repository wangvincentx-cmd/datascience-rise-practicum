270000 to 0263216000 or 2239 per cnt exempt real property exclusive of Yellowstone National Park and Devils Tower National Monument from 09010000 to 326 530000 or 35241 per cent live stock from 154435000 to 059682000 or 96 per cent farm implements and ma ehiaary from 04129000 to 8624 000 or 1089 per cent maunfacturing machinery tools and implements from 03044000 to 028410000 or 8333 per cent and railroads and their equipment from 0104966000 to 0128700000 or 226 per cent Stocks of goods vehicles other than motor furniture and clothing"], "digitized": true, "extract_timestamp": "2023-12-17T00:26:04.905Z", "group": ["ndnp/wyu", "university-of-wyoming-libraries"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92067163/1924-03-07/ed-1/?sp=3", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_karig_ver02:data:sn92067163:00542862129:1924030701:0149/full/pct:6.25/0/default.jpg#h=332&w=236", "https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_karig_ver02:data:sn92067163:00542862129:1924030701:0149/full/pct:12.5/0/default.jpg#h=664&w=473", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wyu/batch_wyu_karig_ver02/data/sn92067163/00542862129/1924030701/0149.xml&format=alto_xml"], "index": 3, "language": ["english"], "location": ["lincoln", "united states", "lincoln county", "wyoming", "kemmerer"], "location_city": ["kemmerer"], "location_country": ["united states"], "location_county": ["lincoln"], "location_state": ["wyoming"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "2", "4", "1", "0000000003", "6", "sn92067163", "8", "5"], "number_edition": ["1"], "number_lccn": ["sn92067163"], "number_page": ["0000000003"], "number_reel": ["0", "0", "5", "4", "2", "8", "6", "2", "1", "2", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the ke