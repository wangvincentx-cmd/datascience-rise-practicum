789A/1908061801/0353.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_indio_ver01:data:sn85066387:0017504789A:1908061801:0343/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/curiv/batch_curiv_indio_ver01/data/sn85066387/0017504789A/1908061801/0353.pdf", "segment_count": 20, "url": "https://www.loc.gov/resource/sn85066387/1908-06-18/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/curiv/batch_curiv_indio_ver01/data/sn85066387/0017504789A/1908061801/0353.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_indio_ver01:data:sn85066387:0017504789A:1908061801:0343/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/curiv/batch_curiv_indio_ver01/data/sn85066387/0017504789A/1908061801/0353.pdf", "segment_count": 20, "url": "https://www.loc.gov/resource/sn85066387/1908-06-18/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/curiv/batch_curiv_indio_ver01/data/sn85066387/0017504789A/1908061801/0353.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85066387/1908-06-18/ed-1/?sp=11"], "batch": ["curiv_indio_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/california/", "2/united states/california/san francisco/", "3/united states/california/san francisco/san francisco/"], "contributor": ["university of california, riverside; riverside, ca"], "date": "1908-06-18", "dates": ["1908-06-18"], "description": ["SECOND SECTION VOLUME CIV NO 18 First Step Is Taken by City for Securing Hetch Hetchy Water Supply CALLS BARTNETT DIRTY DOG AND CRINGING CUR J Dalzell Brown Gives Vent to Passionate Hatred of Former Partner Blames Associate for Aiding in His Indictment for Em bezzlement Attorney Baits Convicted Banker Into Expression of Bitter Feeling I think the man that sits behind you is a dirty dog and if you want to know a cringing cur In these words bitter with a pas sionate hatred J Dalzell Brown the convict yesterday denounced his for mer colleague Walter J Bartnett who is on trial for embezzlement be fore Judge Conley of Madera sitting in Judge Cooks department of the su perior court The outburst of feeling came after days of constant meeting in the court room during which Bartnett r and Brown have ignored each others very existence Never before since the trial began have their eyes met and never have they exchanged a single word It was Attorney Geary of Bartnetfs legal staff who by his Questions to the witness opened the way for the ex coriation and once Brown was forced to speak he spoke plainly His face u25a0was"], "digitized": true, "extract_timestamp": "2025-09-02T13:55:58.156Z", "group": ["ndnp/curiv", "university-of-california-riverside-riverside-ca-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85066387/1908-06-18/ed-1/?sp=11", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_indio_ver01:data:sn85066387:0017504789A:1908061801:0353/full/pct:3.125/0/default.jpg#h=274&w=201", "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_indio_ver01:data:sn85066387:0017504789A:1908061801:0353/full/pct:6.25/0/default.jpg#h=548&w=403", "https://tile.loc.gov/image-services/iiif/service:ndnp:curiv:batch_curiv_indio_ver01:data:sn85066387:0017504789A:1908061801:0353/full/pct:12.5/0/default.jpg#h=1096&w=807", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/curiv/batch_curiv_indio_ver01/data/sn85066387/0017504789A/1908061801/0353.xml&format=alto_xml"], "index": 11, "language": ["english"], "location": ["san francisco", "united states", "san f