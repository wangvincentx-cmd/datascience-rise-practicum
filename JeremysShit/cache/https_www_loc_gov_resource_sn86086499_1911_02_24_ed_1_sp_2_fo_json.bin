asthead (Chroniclingamerica.loc.gov, viewed June 9, 2021). Latest issue consulted: Vol. XXIV, No. 47 (December 28, 1922) (Chroniclingamerica.loc.gov, viewed June 9, 2021). Wauwatosa times Wauwatosa news-times"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:00.190Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021270741/", "image_url": [], "index": 3, "language": ["english"], "location": ["united states", "wauwatosa", "wisconsin", "milwaukee"], "number": ["online resource", "2026-04-13t21:30:13", "2768-5179", "1255630479", "2021270741"], "original_format": ["newspaper"], "partof": ["wauwatosa news (wauwatosa, wis.) 1900-1948 [online resource]", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 50.15752, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["wauwatosa", "newspapers", "wauwatosa (wis.)", "wisconsin", "milwaukee", "united states"], "timestamp": "2026-05-26T21:02:54.346Z", "title": "Wauwatosa news", "type": ["title"], "url": "https://www.loc.gov/item/2021270741/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn86086499/1904-01-16/ed-1/", "http://www.loc.gov/resource/sn86086499/1904-01-16/ed-1/"], "batch": ["whi_grindylow_ver01"], "campaigns": [], "contributor": ["wisconsin historical society"], "date": "1904-01-16", "dates": ["1904-01-16"], "description": ["Wauwatosa, Wis."], "digitized": true, "extract_timestamp": "2023-08-22T16:20:27.630Z", "group": ["ndnp/whi", "wisconsin-historical-society-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn86086499/1904-01-16/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_grindylow_ver01:data:sn86086499:00414214502:1904011601:1227/full/pct:3.125/0/default.jpg#h=300&w=208", "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_grindylow_ver0