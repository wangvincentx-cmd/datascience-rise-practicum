8076526"], "number_reel": ["00295863869"], "numeric_shelf_id": 192101261, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//ndhi/batch_ndhi_isley_ver01/data/sn88076526/00295863869/1921012601/1921012601_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn88076526/marcxml"}], "partof": [{"count": 132, "title": "the devils lake world (devils lake, n.d.) 1920-1982", "url": "https://www.loc.gov/search/?fa=partof:the+devils+lake+world+%28devils+lake,+n.d.%29+1920-1982&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the devils lake world (devils lake, n.d.) 1920-1982"], "place_of_publication": "Devils Lake, N.D.", "publication_frequency": ["weekly"], "raw_lccn": "sn 88076526 ", "reel_numbers": ["00295863869"], "resources": [{"files": 12, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_isley_ver01:data:sn88076526:00295863869:1921012601:0538/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn88076526/1921-01-26/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.332207, "shard": "07", "shelf_id": "sn88076526, 1921-01-26, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ndhi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "north dakota", "ramsey", "devils lake (n.d.)", "united states", "devils lake"], "subject_headings": ["Devils Lake (N.D.)--Newspapers", "North Dakota--Devils Lake", "United States--North Dakota--Ramsey--Devils Lake"], "subjects": [{"devils lake": "https://www.loc.gov/search/?fa=subject:devils+lake&fo=json"}, {"devils lake (n.d.)": "https://www.loc.gov/search/?fa=subject:devils+lake+%28n.d.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"north dakota": "https://www.loc.gov/search/?fa=subject:north+dakota&fo=json"}, {"ramsey": "https://www.loc.gov/search/?fa=subject:ramsey&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2023-08-26T11:45:02.909Z", "title": "The Devils Lake world (Devils Lake, N.D.), January 26, 1921", "type": ["issue"], "url": "https://www.loc.gov/item/sn88076526/1921-01-26/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn88076526/", "http://lccn.loc.gov/sn88076526"], "batch": ["ndhi_isley_ver01"], "campaigns": [], "date": "1920", "description": ["Weekly Vol. 10, no. 27 (July 7, 1920)-v. 82, no. 49 (Dec. 1, 1982). \"Official paper of Ramsey County\", 1925-1974. \"Republican.\" Available on microfilm from the State Historical Society of North Dakota. Archived issues are available in digital format from the Library of Congress Chronicling America online collection."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:06.609Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-11", "catalog", "united-states-newspaper-directory", "main-catalog-split-11"], "hassegments": false, "id": "http://www.loc.gov/item/sn88076526/", "image_url": [], "index": 12, "language": ["english"], "latlong": [48.1178921, -98.8652897], "location": ["devils lake", "north dakota", "ramsey", "united states"], "location_str": "", "lonlat": [-98.8652897, 48.1178921], "number": ["18298428", "http://www.loc.gov/item/sn88076526/1920-07-07/ed-1/", "microfilm master", "http://www.loc.gov/item/sn88076526/1922-12-27/ed-1/", "sn88076525", "2023-08-22t07:32:24.084270", "state hist soc of n dakota", "sn88076526", "2026-04-13t21:30:13", "2025-06-25t14:24:30", "131", "online resource", "original", "2470-5527", "microfilm service copy"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "catalog", "the devils lake world (devils lake, n.d.) 1920-1982", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 58.941723, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "north dakota", "ramsey", "devils lake (n.d.)", "united states", "devils lake"], "timestamp": "2026-07-18T09:27:07.296Z", "title": "The Devils Lake world", "type": ["title"], "url": "https://www.loc.gov/item/sn88076526/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018218966/"], "campaigns": [], "date": "1906", "dates": ["[1906 TO 9999]"], "description": ["Weekly Began in 1906. \"Beiblatt zu der Pierce County tribune.\" Place of publication varies: <1906>-Nov. 23, 1911, Rugby, N.D.; Dec. 7, 1911-Apr. 25, 1912, Devils Lake, N.D.; May 2, 1912-July 13, 1945?, Bismarck, N.D.; <Nov. 27, 1945>-, with an office in Bismarck, which moved to Fredonia, N.D. <Feb. 9, 1968>. Description based on: 1. Jahrgang, no. 37 (11. April, 1907); title from masthead (Chroniclingamerica.loc.gov, viewed October 3, 2018). Latest issue consulted: 15. Jahrgang, no. 27 (19. Oktober 1920) (Chroniclingamerica.loc.gov, viewed October 3, 2018)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:44.751Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018218966/", "image_url": [], "index": 13, "language": ["german"], "location": ["omaha", "bismarck", "pierce", "fredonia", "north dakota", "ramsey", "united states", "douglas", "nebraska", "devils lake", "burleigh", "rugby", "logan"], "number": ["2639-5150", "online resource", "2018218966", "1055488809", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "der staats=anzeiger (rugby, north dakota) 1906-current [online resource]"], "publication_frequency": ["weekly"], "score": 49.700047, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["rugby (n.d.)", "omaha", "bismarck", "logan", "pierce", "newspapers", "fredonia", "north dakota", "bismarck (n.d.)", "ramsey", "fredonia (n.d.)", "devils lake (n.d.)", "united states", "douglas", "devils lake", "burleigh", "rugby", "nebr