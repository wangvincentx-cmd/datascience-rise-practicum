1930-11-21/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_hobson_ver01/data/sn86075250/00517178974/1930112101/0373.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_hobson_ver01:data:sn86075250:00517178974:1930112101:0373/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_hobson_ver01/data/sn86075250/00517178974/1930112101/0373.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn86075250/1930-11-21/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_hobson_ver01/data/sn86075250/00517178974/1930112101/0373.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn86075250/1930-11-21/ed-1/?sp=1"], "batch": ["mthi_hobson_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/blaine/", "3/united states/montana/blaine/harlem/"], "contributor": ["montana historical society; helena, mt"], "date": "1930-11-21", "dates": ["1930-11-21"], "description": ["A Constructive Newspaper TWENTYSEVENTH YEAR HARLEM HONS AGREE GET DATAON FLOOD AREAS OF DISTRICT Harlem Lions had as their guests at their regular Monday evening meeting a committee of Havre and Chinook businessmen who came down for the purpose of getting the club interested in cooperating with the Havre Chamber of Commerce in securing information rela tive to floods and flood damage in this vicinity E C Carruth Frank Cowan and Robert Lucke of Havre and Harry Brooks and R V Bottomly of Chinook formed the visiting committee Army engineers have been investi gating flood damage and flood control in this section of Montana and making survey relative to establishing a reser voir at the Chain Lakes west of Havre However the various communities must themselves secure data regarding dam ages of floods their frequency cause and retention to present to the engin eers when they meet at Havre some time in January The Harlem Lions agreed to put a committee to work at once to get information in the area extending from Madras to the Phillips county line Rov W B Nelson of Great Falls a member of the Lions of that city was also a guest Monday night"], "digitized": true, "extract_timestamp": "2023-09-02T23:05:19.774Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86075250/1930-11-21/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_hobson_ver01:data:sn86075250:00517178974:1930112101:0373/full/pct:6.25/0/default.jpg#h=367&w=267", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_hobson_ver01:data:sn86075250:00517178974:1930112101:0373/full/pct:12.5/0/default.jpg#h=734&w=534", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_hobson_ver01/data/sn86075250/00517178974/1930112101/0373.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["montana", "blaine", "united states", "harlem"], "location_city": ["harlem"], "location_country": ["united states"], "location_county": ["blaine"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000001", "0", "9", "8", "7", "sn86075250", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn86075250"], "number_page": ["0000000001"], "number_reel": ["0", "0", "5", "1", "7", "1", "7", "8", "9", "7", "4"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the harlem news (harlem, mont.) 1908-current", "serial a