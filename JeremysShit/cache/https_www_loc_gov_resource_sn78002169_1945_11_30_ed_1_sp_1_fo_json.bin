sclosed number of contracts 0W on hand Higgins would not 6 how many would be employed and shunned questions as to the amount of work that will be done by these men Only several minor outbreaks oc curred during this first day of re hiring at the multimillion dollar Higgins company which was plac ed in liquidation following a drawn out fight with the unions by its president A plumbing supply truck at tempted to cross the unions line I but the pickets halted the vehicle Police told the driver to disregard the pickets warning"], "digitized": true, "extract_timestamp": "2023-08-12T17:38:26.237Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn78002169/1945-11-30/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_lily_ver01:data:sn78002169:0027955887A:1945113001:0393/full/pct:6.25/0/default.jpg#h=424&w=318", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_lily_ver01:data:sn78002169:0027955887A:1945113001:0393/full/pct:12.5/0/default.jpg#h=849&w=637", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_lily_ver01/data/sn78002169/0027955887A/1945113001/0393.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["new hanover", "united states", "new hanover county", "wilmington", "north carolina"], "location_city": ["wilmington"], "location_country": ["united states"], "location_county": ["new hanover"], "location_state": ["north carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "5", "8", "sn78002169", "7", "a", "0000000001", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn78002169"], "number_page": ["0000000001"], "number_reel": ["0", "0", "2", "7", "9", "5", "5", "8", "8", "7", "a"], "online_format": ["image", "pdf", "online text"], "original_fo