": ["usnd"], "subject": ["clark", "las vegas", "nevada", "united states", "lincoln", "las vegas (nev.)", "newspapers"], "timestamp": "2026-05-26T21:02:54.346Z", "title": "Las Vegas age", "type": ["title"], "url": "https://www.loc.gov/item/2021270602/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2024271102/", "http://lccn.loc.gov/2024271102", "https://search.catalog.loc.gov/instances/cee4e994-2276-59a8-9d90-b979d2a2390a"], "campaigns": [], "contributor": ["thomson gale (firm)", "ebsco publishing (firm)", "dow jones reuters business interactive llc"], "date": "1949", "dates": ["[1949 TO 9999]"], "description": ["Daily Print began with vol. 41, no. 73 (Apr. 3, 1949). Undated issue in 1955 called: Las Vegas Golden Anniversary progress edition. The Las Vegas review-journal and the Las Vegas sun publish a combined edition on Saturday, Sunday and holidays, <Sept. 11, 2000> Volume 118, Number 154 (September 21, 2022) (surrogate); title from masthead. Volume 118, Number 154 (September 21, 2022) (surrogate)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:05.616Z", "group": ["ndnp/newspapers", "catalog-split-05", "catalog", "united-states-newspaper-directory", "main-catalog-split-05"], "hassegments": false, "id": "http://www.loc.gov/item/2024271102/", "image_url": [], "index": 12, "language": ["english"], "location": ["las vegas", "clark county", "nevada", "united states", "clark"], "number": ["2025-09-24t11:44:37", "2026-04-13t21:30:13", "2997-6057", "247430999", "2024271102", "online resource", "sn86076171"], "original_format": ["newspaper"], "other_title": ["Issues for Apr. 3, 1949-Apr. 10, 1949 published as: Las Vegas review-journal and Boulder City journal", "Review-journal"], "partof": ["las vegas review-journal (las vegas, nev.) 1949-current [online resource]", "serial and government publications division", "catalog", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 37.3742, "shelf_id":