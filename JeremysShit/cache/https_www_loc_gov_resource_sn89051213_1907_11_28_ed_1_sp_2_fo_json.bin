414213066/1907112801/0670.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89051213/1907-11-28/ed-1/?sp=2"], "batch": ["arhi_igglybuff_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arkansas/", "2/united states/arkansas/polk/", "3/united states/arkansas/polk/mena/"], "contributor": ["arkansas state archives"], "date": "1907-11-28", "dates": ["1907-11-28"], "description": ["WILL MENA SCHOOL DISTRICT GET 1 HENDRIX ACADEMY i Compromise Suggested by Inter ested Parties to Put an End to Litigation MANY INTERESTED HERE No Action Can Be Taken Without the Approval of the M E Church South Conference Which Meets November 27 m I Steps have been taken recently to bring order out of chaos in relation to the Mena Hendrix f Academy property to tbo end that it serve some good purpose to the city of Mena and at the same time render justice to all interests involved J Following are the terms of a j Compromise that has been sug gested which must come before the conference of the M E church South to be convened at if Little Rock on November 27 for its acceptance or rejection s Arkansas Townsite Company J S Kelly et at Plaintiffs vs 3 Hendrix College W W Martin Trust s ee et al Defendants R R Moore IntervenorIn Polk Chancery Court At a conference in the city of Little Rock between R M Quigley a citizen of Mena Ark J C Clark as attorney i for Hendrix College J E Wootton as lessee of the Mena Academy it was f"], "digitized": true, "extract_timestamp": "2024-12-03T00:16:08.099Z", "group": ["ndnp/arhi", "arkansas-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89051213/1907-11-28/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_igglybuff_ver01:data:sn89051213:00414213066:1907112801:0670/full/pct:6.25/0/default.jpg#h=466&w=327", "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_igglybuff_ver01:data:sn89051213:0