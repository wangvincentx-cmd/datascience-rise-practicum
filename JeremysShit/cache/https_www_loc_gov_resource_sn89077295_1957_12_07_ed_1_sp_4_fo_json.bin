df", "segment_count": 12, "url": "https://www.loc.gov/resource/sn89077295/1957-12-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010698/1957120701/0038.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010698:1957120701:0035/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010698/1957120701/0038.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn89077295/1957-12-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010698/1957120701/0038.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89077295/1957-12-07/ed-1/?sp=4"], "batch": ["gu_alicorn_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/georgia/", "2/united states/georgia/chatham/", "3/united states/georgia/chatham/savannah/"], "contributor": ["digital library of georgia, a project of galileo located at the university of georgia libraries"], "date": "1957-12-07", "dates": ["1957-12-07"], "description": ["Page 4 Hf r I Published Every Thuraday By Herald Publishing Co 808 Montgomery Street Telephone Dial AD 24505 Remittance must be made by Express Post Office Money Order or Registered Mail Second Class Mail Privilege authorized at Savannah Ga National Advertising Representative Interstate United Newspapers 545 Fifth Avenue New York 17 New York Branch Office 5 East Jackson Boulevard Chicago 111 No guarantee of publication of unsolicited material Letters to the editor on either side of any subject are welcomed but must be signed and confined to 250 words No letters can be returned FLOYD ADAMS Editor and Publisher MRS W A ADAMS Assistant to Publisher A A MASON Associate Editor LUCIUS Kelly BRYANT SR Advertising Manager SUBSCRIPTION RATEFIN ADVANCE Six Months 300 One Year 400 PRESIDENTS ILLNESS GETS STRENGTH FROM NIXON Today the nation and the world is focused on the illness of President Eisenhower A nation prayerfully hoping for recovery of its chief executive is concerned as to its status in world leadership while his health is im paired The world considering the nations decision which rest on the shoulders of a once virile leader that has shown a gradual decline in health over a long period"], "digitized": true, "extract_timestamp": "2025-04-20T03:17:49.254Z", "group": ["ndnp/gu", "digital-library-of-georgia-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89077295/1957-12-07/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010698:1957120701:0038/full/pct:3.125/0/default.jpg#h=288&w=184", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010698:1957120701:0038/full/pct:6.25/0/default.jpg#h=577&w=368", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010698:1957120701:0038/full/pct:12.5/0/default.jpg#h=1155&w=736", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010698/1957120701/0038.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["georgia", "chatham", "savannah", "united states"], "location_city": ["savannah"], "location_country": ["united states"], "location_county": ["chatham"], "location_state": ["georgia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "9", "0000000004", "6