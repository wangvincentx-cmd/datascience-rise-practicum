{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn89077295/?st=calendar", "cite_this": {"apa": "(1957, December 7)  <cite>The Herald</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn89077295/1957-12-07/ed-1/.", "chicago": "<cite>The Herald</cite>. (Savannah, GA), Dec. 7 1957. https://www.loc.gov/item/sn89077295/1957-12-07/ed-1/.", "mla": "<cite>The Herald</cite>. (Savannah, GA) 7 Dec. 1957, p. 4. Retrieved from the Library of Congress, www.loc.gov/item/sn89077295/1957-12-07/ed-1/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/gu/batch_gu_alicorn_ver02/data/sn89077295/00517010698/1957120701/0038.xml&format=alto_xml&full_text=1", "item": {"_version_": 1829894379325620224, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn89077295/1957-12-07/ed-1/", "http://www.loc.gov/resource/sn89077295/1957-12-07/ed-1/"], "batch": ["gu_alicorn_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/georgia/", "2/united states/georgia/chatham/", "3/united states/georgia/chatham/savannah/"], "contributor_names": ["Digital Library of Georgia, a project of GALILEO located at the University of Georgia Libraries"], "contributors": [{"digital library of georgia, a project of galileo located at the university of georgia libraries": "https://www.loc.gov/search/?fa=contributor:digital+library+of+georgia,+a+project+of+galileo+located+at+the+university+of+georgia+libraries&fo=json"}], "created_published": ["Savannah, Georgia, December 7, 1957"], "date": "1957-12-07", "date_issued": "1957-12-07", "dates": [{"1957-12-07": "https://www.loc.gov/search/?dates=1957-12-07/1957-12-07&fo=json"}], "dates_of_publication": "1945-1997", "description": ["Savannah, Georgia"], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2025-04-20T03:17:49.254Z", "extract_urls": ["file:/service/ndnp//gu/batch_gu_alicorn_ver02/data/sn89077295/00517010698/1957120701/1957120701_1.xml#ndnp/gu"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/gu", "digital-library-of-georgia-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn89077295/1957-12-07/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010698:1957120701:0035/full/pct:3.125/0/default.jpg#h=290&w=188", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010698:1957120701:0035/full/pct:6.25/0/default.jpg#h=580&w=377", "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010698:1957120701:0035/full/pct:12.5/0/default.jpg#h=1160&w=755"], "index": 4, "item": {"batch": ["gu_alicorn_ver02"], "contributor_names": ["Digital Library of Georgia, a project of GALILEO located at the University of Georgia Libraries"], "created_published": ["Savannah, Georgia, December 7, 1957"], "date": "1945", "date_issued": "1957-12-07", "dates": ["1957-12-07"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn89077295", "location": ["Georgia--Savannah"], "medium": "12 pages", "newspaper_title": ["The herald"], "notes": ["Weekly", "Began in 1945.", "-v. 51, no. 1 (Jan. 8, 1997).", "\"Savannah's Black voice.\"", "<Nov. 10. 1955-Nov. 24, 1956>, some issues contain a section with title: Pix parade. Pix parade carries its own numbering, but is described as \"Savannah's only complete pix section,\" and has at head of title: The herald, indicating it was likely unavailable as a standalone publication. The publication date of Pix parade is often the same as that of Herald (Savannah, Ga.).", "<Apr. 23-Aug. 27, 1955>, included as part of this title are some issues of: The national foto-news. This appears to have been a national pictorial weekly with its own numbering, published in Toledo, Ohio, but the issues included with Herald (Savannah, Ga.) have at head of title: The herald, indicating they are intended to be part of this newspaper. It is unclear whether The national foto-news ever appeared as a standalone publication, or whether it was always included as part of a newspaper title. The national foto-news is seldom if ever published on the same day as the regular issue of Herald (Savannah, Ga.).", "Occasional issues may include: Women's supplement--women in the news.", "Description based on: Vol. 3, no. 18 (Sept. 16, 1948).", "Latest issue consulted: Vol. 11, no. 30 (November 24, 1956).", "Also on microfilm: Athens, Ga. : University of Georgia Libraries.", "Savannah herald (DLC)sn 97046024 (OCoLC)36404952"], "other_formats": ["https://tile.loc.gov/storage-services/service/ndnp//gu/batch_gu_alicorn_ver02/data/sn89077295/00517010698/1957120701/1957120701_1.xml", "http://lccn.loc.gov/sn89077295/marcxml"], "place_of_publication": "Savannah, Georgia", "raw_lccn": "sn 89077295 ", "reel_numbers": ["00517010698"], "source_group": "ndnp/gu", "subjects": ["African Americans--Georgia--Savannah--Newspapers", "African Americans", "Georgia--Savannah", "United States--Georgia--Chatham--Savannah"], "title": "The herald (Savannah, Georgia), December 7, 1957"}, "language": ["english"], "languages": [{"english": "https://www.loc.gov/search/?fa=language:english&fo=json"}], "library_of_congress_control_number": "sn89077295", "location": ["georgia", "chatham", "savannah", "united states"], "location_city": ["savannah"], "location_country": ["united states"], "location_county": ["chatham"], "location_state": ["georgia"], "locations": [{"chatham": "https://www.loc.gov/search/?fa=location:chatham&fo=json"}, {"georgia": "https://www.loc.gov/search/?fa=location:georgia&fo=json"}, {"savannah": "https://www.loc.gov/search/?fa=location:savannah&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=location:united+states&fo=json"}], "locations_city": [{"savannah": "https://www.loc.gov/search/?fa=location_city:savannah&fo=json"}], "locations_country": [{"united states": "https://www.loc.gov/search/?fa=location_country:united+states&fo=json"}], "locations_county": [{"chatham": "https://www.loc.gov/search/?fa=location_county:chatham&fo=json"}], "locations_state": [{"georgia": "https://www.loc.gov/search/?fa=location_state:georgia&fo=json"}], "medium": "12 pages", "method": "mets_filesec", "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "newspaper_title": ["The herald"], "notes": ["Weekly", "Began in 1945.", "-v. 51, no. 1 (Jan. 8, 1997).", "\"Savannah's Black voice.\"", "<Nov. 10. 1955-Nov. 24, 1956>, some issues contain a section with title: Pix parade. Pix parade carries its own numbering, but is described as \"Savannah's only complete pix section,\" and has at head of title: The herald, indicating it was likely unavailable as a standalone publication. The publication date of Pix parade is often the same as that of Herald (Savannah, Ga.).", "<Apr. 23-Aug. 27, 1955>, included as part of this title are some issues of: The national foto-news. This appears to have been a national pictorial weekly with its own numbering, published in Toledo, Ohio, but the issues included with Herald (Savannah, Ga.) have at head of title: The herald, indicating they are intended to be part of this newspaper. It is unclear whether The national foto-news ever appeared as a standalone publication, or whether it was always included as part of a newspaper title. The national foto-news is seldom if ever published on the same day as the regular issue of Herald (Savannah, Ga.).", "Occasional issues may include: Women's supplement--women in the news.", "Description based on: Vol. 3, no. 18 (Sept. 16, 1948).", "Latest issue consulted: Vol. 11, no. 30 (November 24, 1956).", "Also on microfilm: Athens, Ga. : University of Georgia Libraries.", "Savannah herald (DLC)sn 97046024 (OCoLC)36404952"], "number": ["00517010698", "1", "sn89077295"], "number_edition": ["1"], "number_lccn": ["sn89077295"], "number_reel": ["00517010698"], "numeric_shelf_id": 195712071, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//gu/batch_gu_alicorn_ver02/data/sn89077295/00517010698/1957120701/1957120701_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn89077295/marcxml"}], "partof": [{"count": 590, "title": "the herald (savannah, georgia) 1945-1997", "url": "https://www.loc.gov/search/?fa=partof:the+herald+%28savannah,+georgia%29+1945-1997&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the herald (savannah, georgia) 1945-1997"], "place_of_publication": "Savannah, Georgia", "publication_frequency": ["weekly"], "raw_lccn": "sn 89077295 ", "reel_numbers": ["00517010698"], "resources": [{"files": 12, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:gu:batch_gu_alicorn_ver02:data:sn89077295:00517010698:1957120701:0035/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn89077295/1957-12-07/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn89077295, 1957-12-07, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/gu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["african american", "african americans", "savannah", "newspapers", "georgia", "chatham", "united states"], "subject_ethnicity": ["african american"], "subject_headings": ["African Americans--Georgia--Savannah--Newspapers", "African Americans", "Georgia--Savannah", "United States--Georgia--Chatham--Savannah"], "subjects": [{"african american": "https://www.loc.gov/search/?fa=subject:african+american&fo=json"}, {"african americans": "https://www.loc.gov/search/?fa=subject:african+americans&fo=json"}, {"chatham": "https://www.loc.gov/search/?fa=subject:chatham&fo=json"}, {"georgia": "https://www.loc.gov/search/?fa=subject:georgia&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"savannah": "https://www.loc.gov/search/?fa=subject:savannah&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "subjects_ethnicity": [{"african american": "https://www.loc.gov/search/?fa=subject_ethnicity:african+american&fo=json"}], "timestamp": "2025-04-20T04:27:48.284Z", "title": "The herald (Savannah, Georgia), December 7, 1957", "type": ["issue"], "url": "https://www.loc.gov/item/sn89077295/1957-12-07/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn89077295/"], "batch": ["gu_alicorn_ver02"], "campaigns": [], "date": "1945", "description": ["Weekly Began in 1945. -v. 51, no. 1 (Jan. 8, 1997). \"Savannah's Black voice.\" <Nov. 10. 1955-Nov. 24, 1956>, some issues contain a section with title: Pix parade. Pix parade carries its own numbering, but is described as \"Savannah's only complete pix section,\" and has at head of title: The herald, indicating it was likely unavailable as a standalone publication. The publication date of Pix parade is often the same as that of Herald (Savannah, Ga.). <Apr. 23-Aug. 27, 1955>, included as part of this title are some issues of: The national foto-news. This appears to have been a national pictorial weekly with its own numbering, published in Toledo, Ohio, but the issues included with Herald (Savannah, Ga.) have at head of title: The herald, indicating they are intended to be part of this newspaper. It is unclear whether The national foto-news ever appeared as a standalone publication, or whether it was always included as part of a newspaper title. The national foto-news is seldom if ever published on the same day as the regular issue of Herald (Savannah, Ga.). Occasional issues may include: Women's supplement--women in the news. Description based on: Vol. 3, no. 18 (Sept. 16, 1948). Latest issue consulted: Vol. 11, no. 30 (November 24, 1956). Also on microfilm: Athens, Ga. : University of Georgia Libraries. Savannah herald (DLC)sn 97046024 (OCoLC)36404952"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:13.325Z", "group": ["newspaper-titles", "ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn89077295/", "image_url": [], "index": 4, "language": ["english"], "latlong": [32.0806102, -81.0900966], "location": ["georgia", "chatham", "savannah", "united states"], "location_str": "", "lonlat": [-81.0900966, 32.0806102], "number": ["online resource", "589", "microfilm master", "2025-04-19t23:27:18.165195", "microfilm service copy", "sn97046024", "http://www.loc.gov/item/sn89077295/1946-04-24/ed-1/", "http://www.loc.gov/item/sn89077295/1963-12-14/ed-1/", "2261869", "univ of georgia", "2026-04-13t21:30:13", "sn89077295"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "chronicling america", "serial and government publications division", "the herald (savannah, georgia) 1945-1997"], "publication_frequency": ["weekly"], "score": 56.38749, "shelf_id": "http://lccn.loc.gov/sn89077295", "site": ["chroniclingamerica", "usnd"], "subject": ["african american", "african americans", "savannah", "newspapers", "georgia", "chatham", "united states"], "timestamp": "2026-07-18T09:29:44.638Z", "title": "The herald", "type": ["title"], "url": "https://www.loc.gov/item/sn89077295/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83016195/1883-08-26/ed-1/", "http://www.loc.gov/resource/sn83016195/1883-08-26/ed-1/"], "batch": ["dlc_fairview_ver01"], "campaigns": [], "contributor": ["library of congress, washington, dc"], "date": "1883-08-26", "dates": ["1883-08-26"], "description": ["Savannah, Ga."], "digitized": true, "extract_timestamp": "2023-08-07T20:31:23.113Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8"], "hassegments": true, "id": "http://www.loc.gov/item/sn83016195/1883-08-26/ed-1/", "image_url": ["http