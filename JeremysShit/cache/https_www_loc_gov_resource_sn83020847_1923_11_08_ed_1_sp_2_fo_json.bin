xt-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mb/batch_mb_allspice_ver01/data/sn83020847/00517171025/1923110801/0632.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mb:batch_mb_allspice_ver01:data:sn83020847:00517171025:1923110801:0631/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mb/batch_mb_allspice_ver01/data/sn83020847/00517171025/1923110801/0632.pdf", "segment_count": 14, "url": "https://www.loc.gov/resource/sn83020847/1923-11-08/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mb/batch_mb_allspice_ver01/data/sn83020847/00517171025/1923110801/0632.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83020847/1923-11-08/ed-1/?sp=2"], "batch": ["mb_allspice_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/massachusetts/", "2/united states/massachusetts/hampden/", "3/united states/massachusetts/hampden/springfield/"], "contributor": ["boston public library"], "date": "1923-11-08", "dates": ["1923-11-08"], "description": ["2 National Editorial Discussion International Poincares Isolation A conquerable change the impor tance of which it is as yet difficult to appraise is made by the reported decision of Belgium and Italy not tc support Premier Poincare in the re trictions which he seeks to impose Upon the inquiry into Germanys Mity to pay The formula sug gested at Brussels is to examine Germanys capacity to matte repa rations and it is understood that this satisfies both Italy and Great Britain there is no reason why it should not also satisfy the United States which is acquiring a direct interest in Getenys economic and financial condition not only through the claims for war damages which were advanced another stage yes terday by the mixed claims commis sion but through the prospect em phasized yesterday at Washington that it will soon be necessary to ar range for the sale of foodstuffs to Germany to avert famine At Wash ington the news of the decision of Italy and Belgium to support what is in effect the American view was received with gratification though caution was shown in discussing the probable effects of this new align ment In Paris this new shift has"], "digitized": true, "extract_timestamp": "2024-08-17T23:59:53.854Z", "group": ["ndnp/mb", "massachusetts-boston-public-library"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83020847/1923-11-08/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mb:batch_mb_allspice_ver01:data:sn83020847:00517171025:1923110801:0632/full/pct:3.125/0/default.jpg#h=268&w=207", "https://tile.loc.gov/image-services/iiif/service:ndnp:mb:batch_mb_allspice_ver01:data:sn83020847:00517171025:1923110801:0632/full/pct:6.25/0/default.jpg#h=536&w=414", "https://tile.loc.gov/image-services/iiif/service:ndnp:mb:batch_mb_allspice_ver01:data:sn83020847:00517171025:1923110801:0632/full/pct:12.5/0/default.jpg#h=1073&w=829", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mb/batch_mb_allspice_ver01/data/sn83020847/00517171025/1923110801/0632.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["united states", "massachusetts", "hampden", "springfield"], "location_city": ["springfield"], "location_country": ["united states"], "location_county": ["hampden"], "location_state": ["massachusetts"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["1", "0", "sn83020847", "7", "2", "5", "0000000002"], "number_edition": ["1"], "number_lccn": ["sn83020847"], "number_page": ["0000000002"], "number_reel": ["0", "0", "5", "1", "7", "1", "7", "1", "0", "2", "5"], "online_format": ["imag