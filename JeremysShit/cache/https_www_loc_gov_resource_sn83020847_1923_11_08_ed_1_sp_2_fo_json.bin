-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2024271103/", "image_url": [], "index": 4, "language": ["english"], "location": ["hampden county", "springfield", "united states", "massachusetts", "hampden"], "number": ["online resource", "2026-04-13t21:30:13", "2024271103", "2997-7673", "1433132957", "2024271036"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "springfield republican (springfield, mass.) 1838-1851 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 45.212814, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["springfield (mass.)", "newspapers", "hampden county", "springfield", "united states", "hampden county (mass.)", "massachusetts", "hampden"], "timestamp": "2026-05-26T21:13:38.179Z", "title": "Springfield republican", "type": ["title"], "url": "https://www.loc.gov/item/2024271103/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019218555/", "http://lccn.loc.gov/2019218555", "https://search.catalog.loc.gov/instances/b85d790b-807d-5a74-b365-c4c2b1847066"], "campaigns": [], "date": "2003", "dates": ["[2003 TO 9999]"], "description": ["Daily Began April 7, 2003. Print ed. published in several regional eds. Description based on: June 1, 2018 (surrogate); title from masthead. Latest issue consulted: June 1, 2018 (surrogate)."], "digitized": true, "extract_timestamp": "2026-05-19T21:36:42.266Z", "group": ["ndnp/newspapers", "catalog-split-06", "catalog", "united-states-newspaper-directory", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/2019218555/", "image_url": [], "index": 5, "language": ["english"], "location": ["franklin county", "hampshire county", "springfield", "united states", "massachusetts", "hampden"], "number": ["52000893", "2026-04-13t21:30:13", "online resource", "2019218555", "2025-10-22t10:48:02.100000", "2641-2829"], "original_for