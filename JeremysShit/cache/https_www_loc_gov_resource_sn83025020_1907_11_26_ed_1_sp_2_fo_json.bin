 leader (DLC)sn 96064131 (OCoLC)13646071"], "digitized": true, "extract_timestamp": "2026-06-05T18:24:58.411Z", "group": ["newspaper-titles", "catalog-split-05", "catalog", "ndnp/newspapers", "main-catalog-split-05", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn83025020/", "image_url": [], "index": 2, "language": ["english"], "latlong": [36.6387618, -95.1544373], "location": ["indian territory", "craig", "craig county", "united states", "vinita", "oklahoma"], "location_str": "", "lonlat": [-95.1544373, 36.6387618], "number": ["microfilm master", "sn96064131", "microfilm service copy", "sn83025020", "oklahoma hist soc res libr", "9216823", "2025-06-27t06:57:56", "sn93050700", "2472-2979", "sn86064149", "http://www.loc.gov/item/sn83025020/1902-12-16/ed-1/", "2026-04-13t21:30:13", "1", "northeastern state univ", "http://www.loc.gov/item/sn83025020/1913-01-31/ed-1/", "2020-05-29t09:29:54.540398", "2333", "univ of arkansas, little rock", "online resource", "wisconsin hist soc, newsp proj", "sn83025010", "sn95054119"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the vinita daily chieftain (vinita, indian territory [okla.]) 1902-1913", "serial and government publications division", "catalog", "chronicling america"], "publication_frequency": ["daily"], "score": 100.00214, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "catalog", "usnd"], "subject": ["indian territory", "vinita (okla.)", "craig county", "craig", "united states", "indians of north america", "newspapers", "craig county (okla.)", "vinita", "oklahoma"], "timestamp": "2026-07-18T09:05:22.105Z", "title": "The Vinita daily chieftain.", "type": ["title"], "url": "https://www.loc.gov/item/sn83025020/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021220254/"], "campaigns": [], "contributor": ["ivey, gus", "ross, william p.,", "milford, m. e.,", "owen, robert l.,", "adair, john l. (john lynch),", "scroggs, j. w. (joseph whitefield),", "marrs, d. m.,"], "date": "1882", "dates": ["[1882 TO 1902]"], "description": ["Weekly Print began with issue for Sep. 22, 1882; print ceased with Vol. XXI, No. 17 (Dec. 18, 1902). Editors: Gus Ivey, <September 29-December 22, 1882>; Robert L. Owen, January 5-September 7, 1883; Wm. P. Ross, September 14, 1883-June 26, 1884; J.W. Scroggs, September 14, 1883-April 10, 1884; M.E. Milford, July 3, 1884-December 17, 1885; John L. Adair, December 24, 1885-<October 17, 1889>; D.M. Marrs, <May 14, 1891>-December 18, 1902. \"Devoted to the interests of the Cherokees, Choctaws, Chickasaws, Seminoles, Creeks, and all other Indians of the Indian Territory.\" Daily eds.: Daily Indian chieftain, Sep. 25, 1891-Oct. 6, 1892, and: Daily chieftain, Oct. 3, 1898-Dec. 15, 1902. Vol. 1, No. 2 (September 29, 1882); title from caption (Chronicling America's website, viewed Apr. 6, 2021). Vol. XXI, No. 17 (Dec. 18, 1902) (Chronicling America's website, viewed Apr. 6, 2021). Vinita weekly chieftain"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:30.200Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021220254/", "image_url": [], "index": 3, "language": ["english"], "location": ["indian territory", "craig", "craig county", "united states", "vinita", "oklahoma"], "number": ["online resource", "904432951", "2767-8466", "2021220254", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["indian chieftain (vinita, indian territory [okla.]) 1882-1902 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 90.9161, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["indian territory", "vinita (okla.)", "electronic journals", "craig county", "craig", "periodicals", "united states", "indians of north america", "newspapers", "craig county (okla.)", "vinita", "oklahoma"], "timestamp": "2026-05-26T21:02:05.412Z", "title": "Indian chieftain", "type": ["title"], "url": "https://www.loc.gov/item/2021220254/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271074/"], "campaigns": [], "contributor": ["marrs, d. m."], "date": "1902", "dates": ["[1902 TO 1913]"], "description": ["Daily (except Sunday) Began with vol. 5, no. 57 (December 16, 1902); ceased in 1913. Weekly eds.: Indian Chieftain, Dec 18, 1902, and: Vinita Weekly Chieftain, Dec 25, 1902-Aug 31, 1905, and: Weekly Chieftain, [Sep. 7, 1905]-Dec 27, 1912. Description based on: Vol. 5, no. 57 (December 16, 1902); title from masthead (Chroniclingamerica.loc.gov, viewed May 4, 2016). Latest issue consulted: Vol. XVI, no. 235 (January 31, 1913) (Chroniclingamerica.loc.gov, viewed May 4, 2016). Vinita leader"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:34.895Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271074/", "image_url": [], "index": 4, "language": ["english"], "location": ["indian territory", "craig", "craig county", "united states", "vinita", "oklahoma"], "number": ["2016271074", "online resource", "2472-2987", "948681326", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the vinita daily chieftain (vinita, indian territory [okla.]) 1902-1913 [online resource]"], "publication_frequency": ["daily"], "score": 90.9161, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["indian territory", "vinita (okla.)", "craig county", "craig", "united states", "indians of north america", "newspapers", "craig county (okla.)", "vinita", "oklahoma"], "timestamp": "2026-05-26T20:53:59.281Z", "title": "The Vinita daily chieftain", "type": ["title"], "url": "https://www.loc.gov/item/2016271074/"}, {"access_restricted": false