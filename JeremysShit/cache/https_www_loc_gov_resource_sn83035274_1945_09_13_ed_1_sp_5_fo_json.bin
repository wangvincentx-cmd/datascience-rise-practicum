131, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//ohi/batch_ohi_gatsby_ver01/data/sn83035274/00279555727/1945091301/1945091301_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn83035274/marcxml"}], "other_title": ["Transylvania-American peoples journal"], "partof": [{"count": 771, "title": "siebenb\u00fcrgisch-amerikanisches volksblatt (cleveland, ohio) 1917-1971", "url": "https://www.loc.gov/search/?fa=partof:siebenb%C3%BCrgisch-amerikanisches+volksblatt+%28cleveland,+ohio%29+1917-1971&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["siebenb\u00fcrgisch-amerikanisches volksblatt (cleveland, ohio) 1917-1971"], "place_of_publication": "Cleveland, Ohio", "publication_frequency": ["weekly"], "raw_lccn": "sn 83035274 ", "reel_numbers": ["00279555727"], "resources": [{"files": 8, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_gatsby_ver01:data:sn83035274:00279555727:1945091301:0508/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn83035274/1945-09-13/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.45633, "shard": "04", "shelf_id": "sn83035274, 1945-09-13, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ohi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "wayne", "german", "michigan", "cuyahoga", "cleveland (ohio)", "detroit", "ohio", "germans", "united states", "cleveland"], "subject_ethnicity": ["german"], "subject_headings": ["Germans--Ohio--Newspapers", "Germans--Michigan--Newspapers", "Cleveland (Ohio)--Newspapers", "Germans", "Ohio--Cleveland", "Michigan", "Ohio", "United States--Ohio--Cuyahoga--Cleveland", "United States--Michigan--Wayne--Detroit"], "subjects": [{"cleveland": "https://www.loc.gov/search/?fa=subject:cleveland&fo=json"}, {"cleveland (ohio)": "https://www.loc.gov/search/?fa=subject:cleveland+%28ohio%29&fo=json"}, {"cuyahoga": "https://www.loc.gov/search/?fa=subject:cuyahoga&fo=json"}, {"detroit": "https://www.loc.gov/search/?fa=subject:detroit&fo=json"}, {"german": "https://www.loc.gov/search/?fa=subject:german&fo=json"}, {"germans": "https://www.loc.gov/search/?fa=subject:germans&fo=json"}, {"michigan": "https://www.loc.gov/search/?fa=subject:michigan&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"ohio": "https://www.loc.gov/search/?fa=subject:ohio&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"wayne": "https://www.loc.gov/search/?fa=subject:wayne&fo=json"}], "subjects_ethnicity": [{"german": "https://www.loc.gov/search/?fa=subject_ethnicity:german&fo=json"}], "timestamp": "2023-09-05T16:46:46.587Z", "title": "Siebenbu\u0308rgisch-Amerikanisches Volksblatt (Cleveland, Ohio), September 13, 1945", "type": ["issue"], "url": "https://www.loc.gov/item/sn83035274/1945-09-13/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83035274/", "http://lccn.loc.gov/sn83035274", "https://search.catalog.loc.gov/instances/a5194ffc-5868-503b-bf0d-350c246d440b"], "batch": ["ohi_gatsby_ver01"], "campaigns": [], "contributor": ["eckstein, walter", "schneider, georg"], "date": "1917", "description": ["Weekly Jahrg. 12, no. 29 (Juni 14, 1917)-Jahrg. 60, no. 19 (May 12, 1971). Beginning in May 1954, published in Detroit, Michigan. Cf. Gutgesell, S. Guide to Ohio newspapers, 1974. Publishers: Siebenbu\u0308rgisch-Amerikanisches Volksblatt Pub. Co., June 14, 1917-June 6, 1935; The Saxon Pub. & Print. Co. Inc., June 13, 1935-Sept. 28, 1950; Press & Plate Co., Oct. 5, 1950-<May 6, 1954>. Editors: Georg Schneider, June 14, 1917-Sept. 28, 1950; Walter Eckstein, Oct. 5, 1950-<May 6, 1954>. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. In German with some columns in English. Officiales Organ des Zentral-Verbandes der Siebenbu\u0308rger-Sachsen in Amerika. Saxon news Volksblatt 0894-1165 (DLC)sn 83035423 (OCoLC)9849161"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:06.990Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-01", "catalog", "united-states-newspaper-directory", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/sn83035274/", "image_url": [], "index": 5, "language": ["english", "german"], "latlong": [42.3329407, -83.0478365], "location": ["wayne", "michigan", "cuyahoga", "detroit", "ohio", "cuyahoga county", "united states", "cleveland"], "location_str": "", "lonlat": [-83.0478365, 42.3329407], "number": ["sn83035423", "2689-0658", "9659075", "online resource", "2025-11-04t10:47:07", "western rsv hist soc, newsp proj", "unspecified", "sn83035274", "sn83035273", "http://www.loc.gov/item/sn83035274/1954-04-29/ed-1/", "1", "microfilm service copy", "http://www.loc.gov/item/sn83035274/1939-07-06/ed-1/", "original", "ohio hist soc", "2023-08-23t21:16:26.600330", "770", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Transylvania-American peoples journal"], "partof": ["chronicling america", "siebenb\u00fcrgisch-amerikanisches volksblatt (cleveland, ohio) 1917-1971", "catalog", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 93.73064, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "cuyahoga county (ohio)", "wayne", "german", "michigan", "cuyahoga", "cleveland (ohio)", "detroit (mich.)", "german americans", "detroit", "ohio", "germans", "united states", "cleveland"], "timestamp": "2026-07-18T09:06:59.736Z", "title": "Siebenbu\u0308rgisch-Amerikanisches Volksblatt", "type": ["title"], "url": "https://www.loc.gov/item/sn83035274/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2019271325/"], "campaigns": [], "contributor": ["eckstein, walter", "schneider, georg"], "date": "1917", "dates": ["[1917 TO 1971]"], "description": ["Weekly Began June 14, 1917; ceased May 12, 1971. Beginning in May 1954, published in Detroit, Michigan. Publisher: Press & Plate Co., Oct. 5, 1950-<May 6, 1954>. Editors: Georg Schneider, June 14, 1917-Sept. 28, 1950; Walter Eckstein, Oct. 5, 1950-<May 6, 1954>. In German with some columns in English. Officiales Organ des Zentral-Verbandes der Siebenbu\u0308rger-Sachsen in Amerika. Description based on: Jahrgang 34, No. 35 (6. Juli 1939); title from masthead (Chroniclingamerica.loc.gov, viewed September 26, 2019). Latest issue consulted: Jahrgang 45 (29. April 1954) (Chroniclingamerica.loc.gov, viewed September 26, 2019). Saxon news Volksblatt"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:49.584Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019271325/", "image_url": [], "index": 6, "language": ["english", "german"], "location": ["wayne", "michigan", "cuyahoga", "detroit", "ohio", "united states", "cleveland"], "number": ["online resource", "2019271325", "1121045750", "2689-0666", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Transylvania-American peoples journal"], "partof": ["directory of u.s. newspapers in american libraries", "siebenb\u00fcrgisch-amerikanisches volksblatt (cleveland, ohio) 1917-1971 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 84.58684, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "wayne", "german", "michigan", "cuyahoga", "cleveland (ohio)", "detroit", "ohio", "germans", "united states", "cleveland"], "timestamp": "2026-05-26T20:58:47.437Z", "title": "Siebenbu\u0308rgisch-Amerikanisches Volksblatt", "type": ["title"], "url": "https://www.loc.gov/item/2019271325/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2018270596/"], "campaigns": [], "contributor": ["south slavic socialist labor party federation", "slepcevich, peter", "petrovich, lazar"], "date": "1907", "dates": ["[1907 TO 1970]"], "description": ["Semimonthly, July 14, 1966-1970 Began with Sept. 19, 1907 issue; ceased Oct. 8, 1970. Imprint varies: 1907-1910 published in New York; 1910-1943 published in Cleveland; 1943-1970 published in Detroit. Editors: Lazar Petrovich, <1919>-1926, 1948-1957; Peter Slepcevich, <1958-1967>. Also issued on microfilm from the Library of Congress Photoduplication Service and the New York Public Library. In Serbo-Croatian (Roman) with some columns in English. Official organ of the: South Slavic Socialist Labor Party Federation. Description based on: Vol. XXXIV, No. 3 (January 16, 1941); title from masthead (Chroniclingamerica.loc.gov, viewed December 19, 2018). Latest issue consulted: Vol. XXXIX, No. 3 (January 17, 1946) (Chroniclingamerica.loc.gov, viewed December 19, 2018)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:46.349Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2018270596/", "image_url": [], "index": 7, "language": ["english", "croatian"], "location": ["wayne", "michigan", "cuyahoga", "new york", "detroit", "ohio", "united states", "cleveland", "new york city"], "number": ["1079422283", "2018270596", "online resource", "2641-0168", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Workers' struggle"], "partof": ["radni\u010dka borba = workers' struggle (cleveland, o.) 1907-1970 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["semimonthly"], "score": 73.302246, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "wayne", "michigan", "new york (state)", "cuyahoga", "new york (n.y.)", "cleveland (ohio)", "detroit (mich.)", "new york", "yugoslavian", "yugoslavs", "detroit", "ohio", "united states", "cleveland"], "timestamp": "2026-05-26T20:57:39.303Z", "title": "Radnic\u030cka borba = Workers' struggle", "type": ["title"], "url": "https://www.loc.gov/item/2018270596/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83035526/", "http://lccn.loc.gov/sn83035526", "https://search.catalog.loc.gov/instances/f6cc1b23-af84-5d5d-9956-5bedb4d981f9"], "batch": ["ohi_frederick_ver02"], "campaigns": [], "contributor": ["south slavic socialist labor party federation", "slepcevich, peter", "petrovich, lazar"], "date": "1907", "description": ["Semimonthly, July 14, 1966-1970 Began with Sept. 19, 1907 issue. -v. 63, no. 19 (Oct. 8, 1970). Publisher: The South Slavic S.L.P. Federation. Imprint varies: 1907-1910 published in New York; 1910-1943 published in Cleveland; 1943-1970 published in Detroit. Editors: Lazar Petrovich, <1919>-1926, 1948-1957; Peter Slepcevich, <1958-1967>. Also issued on microfilm from the Library of Congress Photoduplication Service and the New York Public Library. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. In Serbo-Croatian (Roman) with some columns in English. Official organ of the: South Slavic Socialist Labor Party Federation. Description based on: Vol. 10, no. 2 (Jan. 11, 1917)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:06.990Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-01", "catalog", "united-states-newspaper-directory", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/sn83035526/", "image_url": [], "index": 8, "language": ["english", "croatian"], "latlong": [41.5051414, -81.6914575], "location": ["wayne", "michigan", "cuyahoga", "new york", "detroit", "ohio", "united states", "cleveland", "new york city"], "location_str": "", "lonlat": [-81.6914575, 41.5051414], "number": ["new york pub libr res libr", "microfilm master", "sn83035526", "online resource", "http://www.loc.gov/item/sn83035526/1941-01-16/ed-1/", "2025-07-01t13:27:20.200000", "http://www.loc.gov/item/sn83035526/1946-01-17/ed-1/", "258", "1", "microfilm service copy", "wisconsin hist soc, newsp proj", "original", "10001933", "2641-015x", "2023-08-23t21:16:26.600330", "western rsv hist soc, newsp proj", "library of congress", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Workers' struggle"], "partof": ["catalog", "chronicling america", "radni\u010dka borba = workers' struggle ([new york, n.y.]) 1907-1970", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["semimonthly"], "score": 73.302246, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "wayne", "michigan", "new york (state)", "cuyahoga", "new york (n.y.)", "cleveland (ohio)", "detroit (mich.)", "new york", "yugoslavian", "yugoslavs", "detroit", "ohio", "united states", "cleveland"], "timestamp": "2026-07-18T09:07:48.184Z", "title": "Radnic\u030cka borba = Workers' struggle", "type": ["title"], "url": "https://www.loc.gov/item/sn83035526/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83035644/", "http://lccn.loc.gov/sn83035644", "https://search.catalog.loc.gov/instances/ae9dbbeb-8808-5151-9ce9-02b6e6df846a"], "batch": ["ohi_kino_ver04"], "campaigns": [], "contributor": ["union of roum. beneficial and cultural soc. of america", "union of roumanian beneficial societies of america"], "date": "1905", "description": ["Triweekly, <Jan. 15, 1998> Began in 1905. Cf. Gutgesell, S. Guide to Ohio newspapers, 1974. \"Organ al Roma\u0302nilor den Statele Unite s\u0326i in special al Bisericilor Gr-Orientale.\" Published in: Cleveland, Ohio, Sept. 1905-Oct. 1969; and: Detroit, Mich., Oct. 1969-Oct. 1976; and: Cleveland, Ohio, Oct. 1976- Editor: Peter Lucaci, <1976>- Includes news and notices of the various branches of the Romanian-American alliance for democracy, 1942-1959. Also issued on microfilm from Center for Research Libraries and Library of Congress Photoduplication Service. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. In Romanian and English. Organ of: Union of Roumanian Beneficial Societies of America, <Dec. 20, 1908>-June 25, 1911; Roumanian Beneficial and Cultural Societies of America, Feb. 12, 1914-Jan. 23, 1927; Union of Roum. Beneficial and Cultural Soc. of America, Jan. 24, 1927-May 21, 1928; Union & League of Roumanian Beneficial and Cultural Societies of America, May 22, 1928-<>; Union and League of Romanian Societies of America, <Dec. 16, 2001>. Absorbed: Roma\u0302nul, in Apr. 1928; accompanied by weekly suppl. called Roma\u0302nul thereafter. Cf. The immigrant labor press in North America, 1840s-1970s. Description based on: Anul 1, no. 2 (28 sept. 1906). Latest issue consulted: Anul 92, no. 1 (Jan. 15, 1998)."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:06.990Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-02", "catalog", "united-states-newspaper-directory", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/sn83035644/", "image_url": [], "index": 9, "language": ["romanian", "english"], "latlong": [42.3329407, -83.0478365], "location": ["wayne", "michigan", "cuyahoga", "canada", "detroit", "ohio", "united states", "cleveland"], "location_str": "", "lonlat": [-83.0478365, 42.3329407], "number": ["new york pub libr res libr", "microfilm master", "sn83035644", "online resource", "center for res libr, newsp proj", "1", "microfilm service copy", "sn83045482", "2025-11-07t12:36:46.900000", "ohio hist soc", "library of congress", "2023-08-23t21:16:26.600330", "1270", "10208533", "wisconsin hist soc, newsp proj", "original", "http://www.loc.gov/item/sn83035644/1922-11-02/ed-1/", "unspecified", "detroit public library", "franklin d roosevelt libr", "1041-0732", "http://www.loc.gov/item/sn83035644/1918-03-05/ed-1/", "western rsv hist soc, newsp proj", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["America Romanian news", "America Roumanian News", "Roumanian News", "Romanian News", "Ziarul Rom\u00e2nesc"], "partof": ["america (cleveland, ohio) 1905-current", "catalog", "chronicling america", "serial and government publications division", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["triweekly"], "score": 73.302246, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "wayne", "michigan", "cuyahoga", "canada", "cleveland (ohio)", "detroit (mich.)", "romanian", "romanian americans", "detroit", "labor", "ohio", "romanians", "united states", "cleveland", "romanian orthodox episcopate of america"], "timestamp": "2026-07-18T09:07:48.184Z", "title": "America", "type": ["title"], "url": "https://www.loc.gov/item/sn83035644/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83035337/", "http://lccn.loc.gov/sn83035337", "https://search.catalog.loc.gov/instances/fb4037ac-3bd3-519a-9d24-ec46f40463d1"], "batch": ["ohi_atticus_ver01"], "campaigns": [], "contributor": ["mosler, joseph", "jodlbauer, joseph", "frebe, fritz", "haupt, herman g.", "rosenberg, w. l."], "date": "1911", "description": ["Weekly Vol. 1, no. 1 (Apr. 29, 1911)-v. 9, no. 52 (Apr. 17, 1920). Published on Saturday. Publishers: Vereinigten Deutschen Socialisten der S.B. Clevelands, Apr. 29, 1911-Feb. 1, 1913; Deutsche Staats-Agitations-Komitee fu\u0308r Ohio, Feb. 8, 1913-Apr. 17, 1920. Editors: W.L. Rosenberg, Apr. 29, 1911-Mar. 10, 1912; Jos. Jodlbauer, Mar. 16, 1912-Aug. 28, 1915; Jos. Mosler, Sept. 4, 1915-<Apr. 27, 1917>; Fritz Frebe, <Dec. 21, 1918-Oct. 25, 1919>; Herman G. Haupt, <Dec. 13, 1919>-Apr. 17, 1920. With Feb. 8, 1913 issue, the subtitle changed to: Wochenblatt des Deutschen Socialisten des Staates Ohio. \"Socialist.\" Cf. Gutgesell, S. Guide to Ohio newspapers, 1974. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. In German. Officialles Organ der Deutschen Branches der Socialist Partei des Staates Ohio."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:06.609Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-01", "catalog", "united-states-newspaper-directory", "main-catalog-split-01"], "hassegments": false, "id": "http://www.loc.gov/item/sn83035337/", "image_url": [], "index": 10, "language": ["german"], "latlong": [41.5051414, -81.6914575], "location": ["cuyahoga", "ohio", "cuyahoga county", "united states", "cleveland"], "location_str": "", "lonlat": [-81.6914575, 41.5051414], "number": ["2577-4190", "9702202", "online resource", "http://www.loc.gov/item/sn83035337/1920-04-17/ed-1/", "unspecified", "1", "microfilm service copy", "http://www.loc.gov/item/sn83035337/1911-04-29/ed-1/", "2025-12-04t10:47:20.500000", "343", "ohio hist soc", "2023-08-23t21:16:26.600330", "western rsv hist soc, newsp proj", "sn83035337", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Echo : weekly journal of the United German Socialists of Cleveland", "Echo : wochenblatt des Deutschen Socialisten des Staates Ohio"], "partof": ["chronicling america", "catalog", "serial and government publications division", "directory of u.s. newspapers in american libraries", "echo : wochenblatt der vereinigten deutschen socialisten clevelands (cleveland, o. [ohio]) 1911-1920"], "publication_frequency": ["weekly"], "score": 53.53462, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["newspapers", "cuyahoga county (ohio)", "german", "cuyahoga", "cleveland (ohio)", "socialism", "german americans", "ohio", "germans", "united states", "cleveland"], "timestamp": "2026-07-18T09:06:59.736Z", "title": "Echo : Wochenblatt der Vereinigten Deutschen Socialisten Clevelands", "type": ["title"], "url": "https://www.loc.gov/item/sn83035337/"}], "next_resource