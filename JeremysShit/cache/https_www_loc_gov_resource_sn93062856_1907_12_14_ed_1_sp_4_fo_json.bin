kes peak", "colorado springs", "denver", "utah", "leadville"], "mime_type": ["image/jpg"], "number": ["http://www.loc.gov/item/87707842", "87707842", "http://www.loc.gov/item/11511644", "2025-05-01t16:23:54"], "online_format": ["image"], "original_format": ["photo, print, drawing", "collection"], "partof": ["groups of images (lots)", "prints and photographs division", "lot 12685", "catalog"], "score": 40.554684, "shelf_id": "LOT 12685 (H) (OSF) and (SOS) [P&P]", "site": ["pictures", "catalog"], "subject": ["valleys", "ice sculpture", "mormon churches", "hotels & taverns", "albumen prints", "cyanotypes", "mountains", "salt lake city", "panoramic photographs", "denver", "railroads", "tourists", "waterfalls", "mammoth plates", "cityscape photographs", "denver (colo.)", "colorado", "landscape photographs", "lakes & ponds", "colorado springs", "utah", "pikes peak (colo.)", "gelatin silver prints", "leadville"], "timestamp": "2026-03-07T14:22:00.661Z", "title": "Colorado and Utah views", "type": ["still image"], "url": "https://www.loc.gov/item/87707842/"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2013646211/", "http://www.loc.gov/item/2013646211/", "http://www.loc.gov/pictures/item/2013646211/", "https://www.loc.gov/pictures/collection/cph/item/2013646211/", "http://www.loc.gov/pictures/collection/cph/item/2013646211/", "http://www.loc.gov/resource/ds.02677/", "https://hdl.loc.gov/loc.pnp/ds.02677", "http://lccn.loc.gov/2013646211"], "campaigns": [], "date": "1908-01-01", "dates": ["1908"], "description": ["1 photomechanical print (postcard) ; 9 x 55 cm | Postcard showing a view of  buildings in Salt Lake City, Utah."], "digitized": true, "extract_timestamp": "2021-08-24T20:14:43.538Z", "group": ["cph", "catalog-split-10", "catalog", "miscellaneous-items-high-demand", "main-catalog-split-10", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2013646211/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/ds/02600/02677_150px.jpg#h=27&w=150", "https://tile.loc.gov/storage-services/service/pnp/ds/02600/02677r.jpg#h=117&w=640", "https://tile.loc.gov/storage-services/service/pnp/ds/02600/02677v.jpg#h=187&w=1024"], "index": 5, "language": ["english"], "location": ["utah", "united states", "salt lake city"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2015-03-02t15:14:34", "http://www.loc.gov/item/17635127", "2013646211"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["miscellaneous items in high demand", "prints and photographs division", "prints & photographs online catalog (library of congress)", "catalog", "lot 14058"], "score": 30.68325, "shelf_id": "LOT 14058, no. 404 [P&P]", "site": ["pictures", "catalog"], "subject": ["photomechanical prints", "stores & shops", "buildings", "salt lake city", "salt lake city (utah)", "panoramic postcards", "utah", "streets", "united states"], "timestamp": "2022-05-02T06:17:11.461Z", "title": "Panoramic view of Salt Lake City, from top of Boston block", "url": "https://www.loc.gov/item/2013646211/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017587026", "http://www.loc.gov/item/2017587026/", "https://search.catalog.loc.gov/instances/08e59c5a-661e-5d0e-9b3b-c841b758b67d", "https://hdl.loc.gov/loc.gmd/g4344s.ct011426", "http://www.loc.gov/resource/g4344s.ct011426/", "https://hdl.loc.gov/loc.gmd/g4344s.ct011427", "http://www.loc.gov/resource/g4344s.ct011427/"], "campaigns": [], "contributor": ["pratt, orson", "sherwood, henry garlick"], "date": "1847", "dates": ["1847"], "description": ["Manuscript plat map, pen-and-ink on thick flexible sheepskin, signed and inscribed by H.G. Sherwood, nailed at the top to its original wooden roller. This manuscript plat map is believed to be the first map of Salt Lake City, Utah. Title supplied by acquisition specialist. Sherwood retained ownership of the plat while the city was being constructed. In 1852, it passed into the hands of Jesse William Fox, Sr., Sherwood's successor as Territory Surveyor General of Utah. Accompanied by text (property of Jesse W. Fox): Engineer's field book / by C.S. Cross. New York : Baptist & Taylor Book, 1855. 43 pages ; 19 cm. Includes notes and diagrams. Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:11.686Z", "group": ["gmd.mar", "catalog-split-06", "catalog", "general-maps", "main-catalog-split-06"], "hassegments": false, "id": "http://www.loc.gov/item/2017587026/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd434/g4344/g4344s/ct011426.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd434/g4344/g4344s/ct011426.gif#h=150&w=100", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd434:g4344:g4344s:ct011426/full/pct:12.5/0/default.jpg#h=812&w=541", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd434:g4344:g4344s:ct011426/full/pct:25/0/default.jpg#h=1625&w=1082"], "index": 6, "language": ["english"], "location": ["utah", "united states", "salt lake city"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2025-06-07t07:40:57.700000", "2017587026", "2019-09-30t10:59:53"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "cities and towns", "catalog"], "score": 30.05308, "shelf_id": "G4344.S3 1847 .S4", "site": ["catalog"], "subject": ["cadastral maps", "maps", "historical geography", "surveys", "salt lake city", "salt lake city (utah)", "real property", "demographic surveys", "manuscript maps", "history", "utah", "united states"], "timestamp": "2026-04-29T16:10:14.418Z", "title": "[Plat of the Great City of the Valley of the Great Salt Lake]", "type": ["cartographic"], "url": "https://www.loc.gov/item/2017587026/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/75696611", "http://www.loc.gov/item/75696611/", "https://search.