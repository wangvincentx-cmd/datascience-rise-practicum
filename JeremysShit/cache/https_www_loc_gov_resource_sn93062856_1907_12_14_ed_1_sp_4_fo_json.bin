", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn93062856/1907-12-14/ed-1/?sp=4"], "batch": ["uuml_kirilenko_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/utah/", "2/united states/utah/salt lake/", "3/united states/utah/salt lake/salt lake city/", "1/united states/colorado/", "2/united states/colorado/denver/", "3/united states/colorado/denver/denver/"], "contributor": ["university of utah, marriott library"], "date": "1907-12-14", "dates": ["1907-12-14"], "description": ["g I 1 J j T THE rcFTtRMOUlTTAIN AND COLORADO CATHOLIC DECEMBER 14 1907 0 P ili 1 fl c ESTABLISHED 1899 k F THE COLORADO CATHOLIC 1 ESTABLISHED 1884 4 CONSOLIDATED OCTOBER 2 1899 L j I 200 A YEAR IN ADVANCE Published Every Saturday by the Intermountain I Catholic Publishing Company 424 Atlas Block West Second South Salt Lake City Utah Telephone 567 j REMITTANCES Remittances should be made by postofflce or ex press money orders drafts or registered letters CHANGING ADDRESSES Subscribers removing from one place to another and desiring papers changed should always give for f mer as well as present address r i CORRESPONDENCE SOLICITED The Reverend Clergy are requested to send to THE INTERMOUNTAIN CATHOLIC news contributions i of Interest to their respective parishes Entered in the Postofilce at Salt Lake as Second Class Matter CARD FROM BISHOP SCANLAN I feel it my duty to protect Catholics and the pub t lic generally from fraud and Imposition by notifying them from time to time that no person bearing the name and garb of a priest or sister or anyone else Is authorized or permitted to solicit or collect In this I diocese ror any"], "digitized": true, "extract_timestamp": "2020-09-15T16:02:01.814Z", "group": ["ndnp/uuml", "university-of-utah-marriott-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn93062856/1907-12-14/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:uum