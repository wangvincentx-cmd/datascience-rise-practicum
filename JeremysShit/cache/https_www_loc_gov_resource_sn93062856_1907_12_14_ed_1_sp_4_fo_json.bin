e image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.331948, "shard": "06", "shelf_id": "sn93062856, 1907-12-14, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/uuml", "subject": ["colorado", "catholic church", "catholics", "salt lake city", "salt lake city (utah)", "salt lake", "newspapers", "denver", "utah", "united states"], "subject_headings": ["Catholics--Newspapers", "Salt Lake City (Utah)--Newspapers", "Catholic Church--Newspapers", "Catholic Church", "Catholics", "Utah--Salt Lake City", "United States--Utah--Salt Lake--Salt Lake City", "United States--Colorado--Denver--Denver"], "subjects": [{"catholic church": "https://www.loc.gov/search/?fa=subject:catholic+church&fo=json"}, {"catholics": "https://www.loc.gov/search/?fa=subject:catholics&fo=json"}, {"colorado": "https://www.loc.gov/search/?fa=subject:colorado&fo=json"}, {"denver": "https://www.loc.gov/search/?fa=subject:denver&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"salt lake": "https://www.loc.gov/search/?fa=subject:salt+lake&fo=json"}, {"salt lake city": "https://www.loc.gov/search/?fa=subject:salt+lake+city&fo=json"}, {"salt lake city (utah)": "https://www.loc.gov/search/?fa=subject:salt+lake+city+%28utah%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"utah": "https://www.loc.gov/search/?fa=subject:utah&fo=json"}], "timestamp": "2022-11-28T15:26:42.764Z", "title": "The Intermountain Catholic (Salt Lake City [Utah] ; Denver [Colo.]), December 14, 1907", "type": ["issue"], "url": "https://www.loc.go