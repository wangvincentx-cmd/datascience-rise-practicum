35:1949022501:0057/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949022501/0060.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn85053044/1949-02-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949022501/0060.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_anaconda_ver01:data:sn85053044:00517178135:1949022501:0057/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949022501/0060.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn85053044/1949-02-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949022501/0060.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85053044/1949-02-25/ed-1/?sp=4"], "batch": ["mthi_anaconda_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/glacier/", "3/united states/montana/glacier/browning/"], "contributor": ["montana historical society; helena, mt"], "date": "1949-02-25", "dates": ["1949-02-25"], "description": ["THE BROWIHNG CHIF John E Davies Editor and Owner A weekly newspaper published every Friday at Browning Glacier County Montana Entered as 2nd class matter July 15 1931 at the postoffice at Browning Montana under act of March 3 1879 Subscription 200 year in advance liKwfiriwt i\u00dfsmct The break in commodity and stock markets plus the laying off of worker in various indust ries is causing Americans to ask Is this it More tensely than ever busi ness and government are tryng to guess whether the boom has ended More closely than ever they are examining the bulwarks against a bust The majority of economists be lieve there will be a recession not a depression A minority hold that many parts of the econ omy are still on the inflationary side They support President Trumans view that controls and taxes are needed The majority declare there is now more need for insurance against a slump and would support Senator Georges view that new taxes should wait at least until it is ap parent whether the economy is going up or down He is a wise man who can tell where political opinion leaves off and economic statistics begin Labor leaders"], "digitized": true, "extract_timestamp": "2023-07-03T13:49:30.714Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85053044/1949-02-25/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_anaconda_ver01:data:sn85053044:00517178135:1949022501:0060/full/pct:6.25/0/default.jpg#h=318&w=226", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_anaconda_ver01:data:sn85053044:00517178135:1949022501:0060/full/pct:12.5/0/default.jpg#h=637&w=453", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949022501/0060.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["montana", "glacier", "united states", "browning"], "location_city": ["browning"], "location_country": ["united states"], "location_county": ["glacier"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["3", "0000000004", "8", "0", "sn85053044", "5", "7", "1"], "number_edition": ["1"], "number_lccn": ["sn85