{"articles_and_essays": null, "calendar_url": "https://www.loc.gov/item/sn84027621/?st=calendar", "cite_this": {"apa": "(1920, December 17)  <cite>The Ocala evening star</cite>. Retrieved from the Library of Congress, https://www.loc.gov/item/sn84027621/1920-12-17/ed-1/.", "chicago": "<cite>The Ocala evening star</cite>. (Ocala, FL), Dec. 17 1920. https://www.loc.gov/item/sn84027621/1920-12-17/ed-1/.", "mla": "<cite>The Ocala evening star</cite>. (Ocala, FL) 17 Dec. 1920, p. 7. Retrieved from the Library of Congress, www.loc.gov/item/sn84027621/1920-12-17/ed-1/."}, "fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/fu/batch_fu_criser_ver02/data/sn84027621/00295865659/1920121701/0639.xml&format=alto_xml&full_text=1", "item": {"_version_": 1855511997840359424, "access_restricted": false, "aka": ["http://www.loc.gov/item/sn84027621/1920-12-17/ed-1/", "http://www.loc.gov/resource/sn84027621/1920-12-17/ed-1/"], "batch": ["fu_criser_ver02"], "call_number": ["Newspaper"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/florida/", "2/united states/florida/marion/", "3/united states/florida/marion/ocala/"], "contributor_names": ["University of Florida"], "contributors": [{"university of florida": "https://www.loc.gov/search/?fa=contributor:university+of+florida&fo=json"}], "created_published": ["Ocala, Fla., December 17, 1920"], "date": "1920-12-17", "date_issued": "1920-12-17", "dates": [{"1920-12-17": "https://www.loc.gov/search/?dates=1920-12-17/1920-12-17&fo=json"}], "dates_of_publication": "1895-1943", "description": ["Ocala, Fla."], "digital_id": ["https://www.loc.gov/chroniclingamerica/lccn/sn84027621/issues", "http://ufdc.ufl.edu/UF00075908"], "digitized": true, "digitized_label": "Present", "display_offsite": true, "extract_timestamp": "2026-01-27T16:59:07.357Z", "extract_urls": ["file:/service/ndnp//fu/batch_fu_criser_ver02/data/sn84027621/00295865659/1920121701/1920121701_1.xml#ndnp/fu"], "format": [{"newspaper": "https://www.loc.gov/search/?fa=original_format:newspaper&fo=json"}], "genre": ["Newspapers"], "group": ["ndnp/fu", "university-of-florida-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn84027621/1920-12-17/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_criser_ver02:data:sn84027621:00295865659:1920121701:0633/full/pct:3.125/0/default.jpg#h=286&w=202", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_criser_ver02:data:sn84027621:00295865659:1920121701:0633/full/pct:6.25/0/default.jpg#h=573&w=404", "https://tile.loc.gov/image-services/iiif/service:ndnp:fu:batch_fu_criser_ver02:data:sn84027621:00295865659:1920121701:0633/full/pct:12.5/0/default.jpg#h=1147&w=809"], "index": 7, "item": {"batch": ["fu_criser_ver02"], "call_number": ["Newspaper"], "contributor_names": ["University of Florida"], "created_published": ["Ocala, Fla., December 17, 1920"], "date": "1895", "date_issued": "1920-12-17", "dates": ["1920-12-17"], "digital_id": ["https://www.loc.gov/chroniclingamerica/lccn/sn84027621/issues", "http://ufdc.ufl.edu/UF00075908"], "digitized_label": "Present", "format": ["newspaper"], "genre": ["Newspapers"], "language": ["eng"], "library_of_congress_control_number": "sn84027621", "location": ["Ocala (Fla.)", "Marion County (Fla.)", "Florida--Marion County", "Florida--Ocala"], "medium": "8 pages", "newspaper_title": ["The Ocala evening star"], "notes": ["Daily (except Sunday)", "Began in 1895; ceased in 1943.", "Archived issues are available in digital format from the Library of Congress Chronicling America online collection.", "Description based on: Vol. 1, no. 5 (June 24, 1895).", "Latest issue consulted: Vol. no. 46 (Aug. 28, 1943)."], "other_formats": ["https://tile.loc.gov/storage-services/service/ndnp//fu/batch_fu_criser_ver02/data/sn84027621/00295865659/1920121701/1920121701_1.xml", "http://lccn.loc.gov/sn84027621/marcxml"], "other_title": ["Evening star", "Star"], "place_of_publication": "Ocala, Fla.", "raw_lccn": "sn 84027621 ", "reel_numbers": ["00295865659"], "source_group": "ndnp/fu", "subjects": ["Ocala (Fla.)--Newspapers", "Marion County (Fla.)--Newspapers", "Florida--Marion County", "Florida--Ocala", "United States--Florida--Marion--Ocala"], "summary": ["In 1895, the Ocala (FL) Evening Star [LCCN: sn84027621] surfaced as a rival publication to the Ocala (FL) Banner [LCCN: sn88074815]. These two titles subsequently merged into one publication on September 1, 1943. The resulting Ocala (FL) Star-Banner [LCCN: sn78002071] has remained the daily newspaper in Marion County (FL) since that time. The Ocala Evening Star was also published from 1897 in a weekly edition, the Ocala (FL) Weekly Star [LCCN: sn84027622]. R.N. Dosh, editor of the Ocala Evening Star in the 1920s and 1930s, gave an address to the Ocala Rotary Club, recalling by-gone editors and rival publications, chiefest of whom was Col. Frank E. Harris of the Ocala Banner in the 1890s. He also remembered that the \"Star first saw the light of day in the press room of the Florida Baptist Witness ... the first editor was A.H. Harding ...\" The Florida Baptist Witness (Ocala, FL) LCCN sn95026767], which began publishing in 1884, was the weekly newspaper of the Florida Baptist Convention, an organ of the Southern Baptist Convention. A variant edition of the same title continues (ca. 2008) to publish. Ocala (FL) is the seat of Marion County (FL) government. The Freeze of 1894 dramatically changed the Ocala into which the Ocala Evening Star was born. The Freeze devastated the citrus industry in Marion County. Between 1895 and 1943, other forms of agriculture took the place of citrus while tourism in the area grew. The Silver Springs theme park, known for its crystal clear waters, would do its part like no other attraction in pre-World War II Marion County. The County remained primarily agricultural until after the war, when its character would again change dramatically.--E. Kesse, University of Florida Digital Library Center."], "title": "The Ocala evening star (Ocala, Fla.), December 17, 1920"}, "language": ["english"], "languages": [{"english": "https://www.loc.gov/search/?fa=language:english&fo=json"}], "library_of_congress_control_number": "sn84027621", "location": ["marion", "florida", "ocala", "united states", "marion county"], "location_city": ["ocala"], "location_country": ["united states"], "location_county": ["marion"], "location_state": ["florida"], "locations": [{"florida": "https://www.loc.gov/search/?fa=location:florida&fo=json"}, {"marion": "https://www.loc.gov/search/?fa=location:marion&fo=json"}, {"marion county": "https://www.loc.gov/search/?fa=location:marion+county&fo=json"}, {"ocala": "https://www.loc.gov/search/?fa=location:ocala&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=location:united+states&fo=json"}], "locations_city": [{"ocala": "https://www.loc.gov/search/?fa=location_city:ocala&fo=json"}], "locations_country": [{"united states": "https://www.loc.gov/search/?fa=location_country:united+states&fo=json"}], "locations_county": [{"marion": "https://www.loc.gov/search/?fa=location_county:marion&fo=json"}], "locations_state": [{"florida": "https://www.loc.gov/search/?fa=location_state:florida&fo=json"}], "medium": "8 pages", "method": "mets_filesec", "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "newspaper_title": ["The Ocala evening star"], "notes": ["Daily (except Sunday)", "Began in 1895; ceased in 1943.", "Archived issues are available in digital format from the Library of Congress Chronicling America online collection.", "Description based on: Vol. 1, no. 5 (June 24, 1895).", "Latest issue consulted: Vol. no. 46 (Aug. 28, 1943)."], "number": ["sn84027621", "00295865659", "1"], "number_edition": ["1"], "number_lccn": ["sn84027621"], "number_reel": ["00295865659"], "numeric_shelf_id": 192012171, "online_format": ["image", "pdf", "online text"], "original_form