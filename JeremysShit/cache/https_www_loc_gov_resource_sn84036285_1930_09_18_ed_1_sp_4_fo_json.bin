 ["mthi_goosefoot_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/carbon/", "3/united states/montana/carbon/red lodge/"], "contributor": ["montana historical society; helena, mt"], "date": "1930-09-18", "dates": ["1930-09-18"], "description": ["Carbon County News I Published every Thursday at Rod Lodge Carbon Co Montana OFFICIAL PAPER OF CARBON COUNTY j OFFICIAL PAPER OF THE CITY OF RED LODGE MONT O H P SHELLEY Editor and Owner Subscription Per year 250 six months fl50 three months 1 All sub scriptions payable in advance Entered at the Postoffice at Red Lodge Montana as Mat ter of the Second Class Un der the Act of Congress of March 5 1879 Mem r i National Editorial Association I Advertising rates based on guaranteed circulation and furnished I upon application Discount given on contracts fry 4 Alto TELEPHONE NUMBER NINE GALEN FOR THE SENATE JUDGE ALBERT J GALEN as the candidate on the republican ticket in Montana for the United St ates senatorship is a straightforward citizen stand ing ace high in the estimation of his fellowmen His record as an official is like an open book that anyone running through may read with profit His useful ness as a public official has been proven His con tinued service in behalf of the state is demanded by his party That opportunity is afforded in his nomin ation by the republican party as its candidate for the"], "digitized": true, "extract_timestamp": "2023-07-03T13:46:55.333Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84036285/1930-09-18/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_goosefoot_ver01:data:sn84036285:00340581829:1930091801:0703/full/pct:6.25/0/default.jpg#h=450&w=330", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_goosefoot_ver01:data:sn84036285:00340581829:1930091801:0703/full/pct:1