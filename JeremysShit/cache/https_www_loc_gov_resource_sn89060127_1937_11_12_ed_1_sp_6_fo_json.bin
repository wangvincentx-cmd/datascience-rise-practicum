urce/sn89060127/1937-11-12/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522023/1937111201/0524.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_frederick_ver03:data:sn89060127:00279522023:1937111201:0519/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522023/1937111201/0524.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn89060127/1937-11-12/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522023/1937111201/0524.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89060127/1937-11-12/ed-1/?sp=6"], "batch": ["mdu_frederick_ver03"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/maryland/", "2/united states/maryland/worcester/", "3/united states/maryland/worcester/pocomoke city/"], "contributor": ["university of maryland, college park, md"], "date": "1937-11-12", "dates": ["1937-11-12"], "description": ["Page 6 WORCESTER DEMOCRAT AND THE LEDGERENTERPRISE Published Every Friday at Pocomoke City Maryland EDWARD J CLARKE Editor and Owner 150 The Year In Advance Entered at the Postoffice at Pocomoke City Maryland as Second Class Matter iggg NATIONAL EDITORIAL ASSOCIATION FRIDAY NOVEMBER 12 1937 THE BUSINESS OUTLOOK To put it mildiy the business outlook today is extremely con fused One one hand it is predicted that this winters domestic commerce will be the best since 1929 with retail sales in some lines perhaps exceeding the boomtime figure On the other busi ness leaders are seriously disturbedand many of them are plain ly pessimistic as to the trend of future events This anomaly is easily explained For in the view of execu tives the shortterm outlook is favorable and the longterm is bad Purchasing power is tied up farm income is at a sixyear high consumer goods are moving rapidly Yet the unrest in Europe the tangled political situation at home including the threat of more government in business the apparent certainty of higher taxes the prospect of still more serious labor disturbances and the nervousness of security investors and speculators are retarding factors As everyone knows the stock market"], "digitized": true, "extract_timestamp": "2023-03-01T18:25:24.776Z", "group": ["ndnp/mdu", "university-of-maryland-college-park-college-park-md-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89060127/1937-11-12/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_frederick_ver03:data:sn89060127:00279522023:1937111201:0524/full/pct:6.25/0/default.jpg#h=488&w=404", "https://tile.loc.gov/image-services/iiif/service:ndnp:mdu:batch_mdu_frederick_ver03:data:sn89060127:00279522023:1937111201:0524/full/pct:12.5/0/default.jpg#h=976&w=809", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mdu/batch_mdu_frederick_ver03/data/sn89060127/00279522023/1937111201/0524.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["worcester county", "pocomoke city", "united states", "maryland", "worcester"], "location_city": ["pocomoke city"], "location_country": ["united states"], "location_county": ["worcester"], "location_state": ["maryland"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["sn89060127", "9", "0", "5", "3", "0000000006", "7", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn89060127"], "number_page": ["0000000006"], "number_reel": ["0", "0", "2", "7", "9", "5", "2", "2", "0"