 "https://tile.loc.gov/image-services/iiif/service:gmd:gmd383:g3833:g3833k:la000069/full/pct:12.5/0/default.jpg#h=2248&w=2005", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd383:g3833:g3833k:la000069/full/pct:25/0/default.jpg#h=4496&w=4010"], "index": 7, "language": ["english"], "location": ["dover", "delaware", "united states", "frederica", "milford", "smyrna", "kent county", "camden"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["sheet", "2013593082", "2025-06-07t05:29:43.500000", "2013-06-01t16:02:58"], "online_format": ["image"], "original_format": ["map"], "partof": ["cultural landscapes", "county landownership maps", "geography and map division", "catalog"], "score": 34.647514, "shelf_id": "G3833.K4 1859 .F7 G3833.K4 1859 .F7 Copy 2", "site": ["catalog"], "subject": ["milford (del.)", "camden", "cadastral maps", "delaware", "kent county", "landowners", "frederica", "kent county (del.)", "smyrna (del.)", "villages", "frederica (del.)", "dover (del.)", "cities and towns", "united states", "dover", "maps", "camden (del.)", "real property", "milford", "smyrna"], "timestamp": "2026-04-29T16:08:01.898Z", "title": "Map of Kent County, Delaware : from actual surveys", "type": ["cartographic"], "url": "https://www.loc.gov/item/2013593082/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2021756482", "http://www.loc.gov/item/2021756482/", "https://hdl.loc.gov/loc.pnp/highsm.68261", "http://www.loc.gov/resource/highsm.68261/", "https://www.loc.gov/pictures/item/2021756482/", "http://www.loc.gov/pictures/item/2021756482/", "https://www.loc.gov/pictures/collection/highsm/item/2021756482/", "http://www.loc.gov/pictures/collection/highsm/item/2021756482/", "https://hdl.loc.gov/loc.pnp/highsm.68261"], "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2021-01-01", "dates": ["2021"], "description": ["Title, date, and keywords based on information provided by the photographer. The leather-goods store does