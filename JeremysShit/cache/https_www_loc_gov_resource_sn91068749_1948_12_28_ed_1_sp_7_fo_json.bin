ttp://www.loc.gov/item/2018674726/", "http://www.loc.gov/pictures/item/2018674726/", "http://www.loc.gov/resource/nclc.02972/", "http://lccn.loc.gov/2018674726"], "campaigns": [], "contributor": ["hine, lewis wickes"], "date": "1914-01-01", "dates": ["1914"], "description": ["1 photographic print."], "digitized": true, "extract_timestamp": "2021-09-01T22:53:35.709Z", "group": ["nclc", "catalog-split-11", "catalog", "national-child-labor-committee", "main-catalog-split-11", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2018674726/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02972_150px.jpg#h=106&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02972t.gif#h=106&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02972r.jpg#h=453&w=640", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02972v.jpg#h=725&w=1024"], "index": 7, "language": ["english"], "location": ["roanoke rapids", "united states", "north carolina"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/ncl2004001115/pp", "http://www.loc.gov/item/20685295", "2018-11-02t16:09:13", "2018674726", "http://www.loc.gov/item/2018674726"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 7479", "prints and photographs division", "prints & photographs online catalog (library of congress)", "national child labor committee collection", "catalog"], "score": 26.80526, "shelf_id": "LOT 7479, v. 6, no. 3879 [P&P]", "site": ["pictures", "catalog"], "subject": ["textile mill workers", "boys", "photographic prints", "north carolina", "girls", "roanoke rapids", "united states"], "timestamp": "2022-04-30T18:36:00.406Z", "title": "Rosemary Mfg. Co. Uriah and Eva Westbrook. Both violations. Uriah is 12 years old now (Bible record said born May 24, 1903) and he has been working there 2 months. Eva began at 12 years; been working there 1 year. Born May 4, 1901. The real need for the work of the children is not apparent, although the father is sick, for there are 6 children in the mill. The mother said: \"We kin go back to the farm any time, and I wisht we would. It's a heap easier living there than in the mill.\" Some of the children agreed with her.  Location: Roanoke Rapids, North Carolina.", "url": "https://www.loc.gov/item/2018674726/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/pictures/collection/nclc/item/2018674728/", "https://hdl.loc.gov/loc.pnp/nclc.02974", "http://www.loc.gov/item/2018674728/", "http://www.loc.gov/pictures/item/2018674728/", "http://www.loc.gov/resource/nclc.02974/", "http://lccn.loc.gov/2018674728"], "campaigns": [], "contributor": ["hine, lewis wickes"], "date": "1914-01-01", "dates": ["1914"], "description": ["1 photographic print."], "digitized": true, "extract_timestamp": "2021-09-01T22:53:35.709Z", "group": ["nclc", "catalog-split-13", "catalog", "national-child-labor-committee", "main-catalog-split-13", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2018674728/", "image_url": ["https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02974_150px.jpg#h=106&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02974t.gif#h=105&w=150", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02974r.jpg#h=450&w=640", "https://tile.loc.gov/storage-services/service/pnp/nclc/02900/02974v.jpg#h=720&w=1024"], "index": 8, "language": ["english"], "location": ["roanoke rapids", "united states", "north carolina"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["http://www.loc.gov/item/20685297", "http://www.loc.gov/item/2018674728", "http://www.loc.gov/item/ncl2004001117/pp", "2018674728", "2018-11-02t16:09:15"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["lot 7479", "prints and photographs division", "prints & photographs online catalog (library of congress)", "national child labor committee collection", "catalog"], "score": 26.80526, "shelf_id": "LOT 7479, v. 6, no. 3881 [P&P]", "site": ["pictures", "catalog"], "subject": ["textile mill workers", "boys", "cotton industry", "photographic prints", "north carolina", "roanoke rapids", "united states"], "timestamp": "2022-04-30T18:36:00.406Z", "title": "2 violations. Simon Birdsong (left hand boy) said: \"I'm about 12.\" His mother said: \"He's old enough to work all right,\" but the boy admitted that she had to sign up that he was older than he was. He appears to be 10. Has had job doffing for several weeks. Could not write his own name. Has had no schooling after the 1st grade. Wylie Haw (right hand boy). Mother says he is 12 years old now. Been working 1 year. She is a widow.  Location: Roanoke Rapids, North Carolina.", "url": "https://www.loc.gov/item/2018674728/"}, {"access_restricted": false, "aka": ["http://memory.loc.gov/cgi-bin/query/r?ammem/AMALL:@field(NUMBER+@band(rbpe+13500500))", "http://www.loc.gov/item/rbpe.13500500/", "http://www.loc.gov/resource/rbpe.13500500/", "https://hdl.loc.gov/loc.rbc/rbpe.13500500", "https://hdl.loc.gov/loc.rbc/rbpe.13500500", "http://www.loc.gov/item/2020767979/", "http://lccn.loc.gov/2020767979"], "campaigns": [], "contributor": ["davie, allen j. (allen jones)", "printed ephemera collection (library of congress)", "sir archie"], "date": "1810", "dates": ["1810"], "description": ["Imprint 2.; Horses. Available also through the Library of Congress web site in two forms: as facsimile page images and as full text in SGML. Printed Ephemera Collection; Portfolio 135, Folder 5."], "digitized": true, "extract_timestamp": "2020-09-17T08:42:55.069Z", "group": ["rbpebib.mar", "catalog-split-01", "catalog", "broadsides-and-printed-ephemera", "main-catalog-split-01", "main-catalog"], "hassegments": true, "id": "http://www.loc.gov/item/2020767979/", "image_url": ["https://tile.loc.gov/storage-services/service/rbc/rbpe/rbpe13/rbpe135/13500500/001dq