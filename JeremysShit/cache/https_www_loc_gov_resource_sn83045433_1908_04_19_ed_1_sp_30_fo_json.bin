estricted": false, "aka": ["http://www.loc.gov/resource/sn83045433/1908-04-19/ed-1/?sp=30"], "batch": ["dlc_india_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/district of columbia/", "3/united states/district of columbia/washington/"], "contributor": ["library of congress, washington, dc"], "date": "1908-04-19", "dates": ["1908-04-19"], "description": ["BRAZIL A RICH LAND 2 Controls Rubber Industry of Entire World SUGAR CANE ALONG COAST Republic Produces One Hundred and Thirviyfive Million Dellars Werth of Coffee for ExportCattle Rals ing Profitable in South Brasil Mineral Resources Abundant The following article upon Brasil its _ rubber production coffee plantations rail ways and varied riches was prepared specially for The Washington Herald under the supervision of John Barrett director of the Bureau of American Re publics from data furnished by the bu reau Brazil is a wonderland Trees in that lucky republic yield a substance most easily changed into gold This is rubber The United States imported last year 136 000000 pounds of rubber valued at over 60000000 This product is today one of the greatest necessities to industrial prog ress Stop its influx to any country for a month and clvilization would halt Rapid transit the telephone and other developments of our era including auto mobiles depend upon rubber and ex cepting a few plantations in Africa and Asia Brazil controls the rubber crop of tha world Up the Amazon 1000 miles to Manaos 1000 miles further to Iquitos in Peru stretch the forests that are part of Bra gils riches"], "digitized": true, "extract_timestamp": "2026-06-16T10:00:06.897Z", "group": ["ndnp/dlc-2004_2006", "library-of-congress-washington-dc-awardee-1"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045433/1908-04-19/ed-1/?sp=30", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_india_ver02:data:sn83045433:100493445:1908041901:0242/full/pct:3.125/0/default.j