ial national flower of the United Slates in a bill introduced in the house at Washington by Representa tive Kinkead of New York President Wilson has taken more cold and canceled all his engagements by order of his physician Chief Jus tice White and Justice Lurton also are confined to their homes In Washington suffering with colds The house at Washington was turned Into a circus for"], "digitized": true, "extract_timestamp": "2023-08-22T16:21:58.851Z", "group": ["ndnp/whi", "wisconsin-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85040245/1913-12-19/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_knarl_ver02:data:sn85040245:00414215440:1913121901:0297/full/pct:3.125/0/default.jpg#h=287&w=227", "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_knarl_ver02:data:sn85040245:00414215440:1913121901:0297/full/pct:6.25/0/default.jpg#h=574&w=454", "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_knarl_ver02:data:sn85040245:00414215440:1913121901:0297/full/pct:12.5/0/default.jpg#h=1148&w=909", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/whi/batch_whi_knarl_ver02/data/sn85040245/00414215440/1913121901/0297.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["united states", "wisconsin", "ladysmith", "rusk"], "location_city": ["ladysmith"], "location_country": ["united states"], "location_county": ["rusk"], "location_state": ["wisconsin"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000004", "1", "2", "4", "sn85040245", "0", "5"], "number_edition": ["1"], "number_lccn": ["sn85040245"], "number_page": ["0000000004"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "5", "4", "4", "0"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial