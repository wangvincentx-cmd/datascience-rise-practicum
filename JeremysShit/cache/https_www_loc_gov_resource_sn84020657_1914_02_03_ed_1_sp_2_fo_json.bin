4A/1914020301/0116.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_albatross_ver01:data:sn84020657:0027955064A:1914020301:0115/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ak/batch_ak_albatross_ver01/data/sn84020657/0027955064A/1914020301/0116.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn84020657/1914-02-03/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ak/batch_ak_albatross_ver01/data/sn84020657/0027955064A/1914020301/0116.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020657/1914-02-03/ed-1/?sp=2"], "batch": ["ak_albatross_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/alaska/", "3/united states/alaska/juneau/"], "contributor": ["alaska state library historical collections"], "date": "1914-02-03", "dates": ["1914-02-03"], "description": ["ALASKA DAILY EMPIRE Published by the EMPIRE PRINTING COMPANY JOHN W TROY Editor and Manager Telephone No 374 Entered as secondclass matter November 7 1912 at the postofilre at Ju neau Alaska under the Act of March 3 1S79 SUBSCRIPTION RATES Ore year by mail 31000 Six months by mail 500 Per month delivered 100 ONE YEARS ACCOMPLISH MENT WHEN Speaker Clark said in that Iowa speech the other night that the best years work that has been per formed at Washington in a gen eration is nearing its end he did not speak idly Before the first twelve months of Wilsons ad ministration shall have been completed the Alaska railroad legislation will probably have been added to the tariff and cur rency laws It has not been of ten that so much constructive legislation has been accomplish ed in one year by any Nation any where at any time But even that does not include all that the administration has done in the line of progress It has abolished dollar diplomacy It has established a wider bet ter and more enlightened mean ing for the Monroe doctrine It has increased the influ ence of the United States for peace"], "digitized": true, "extract_timestamp": "2024-05-22T12:56:32.767Z", "group": ["ndnp/ak", "alaska-state-library-historical-collections-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020657/1914-02-03/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_albatross_ver01:data:sn84020657:0027955064A:1914020301:0116/full/pct:3.125/0/default.jpg#h=262&w=191", "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_albatross_ver01:data:sn84020657:0027955064A:1914020301:0116/full/pct:6.25/0/default.jpg#h=525&w=383", "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_albatross_ver01:data:sn84020657:0027955064A:1914020301:0116/full/pct:12.5/0/default.jpg#h=1050&w=767", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_albatross_ver01/data/sn84020657/0027955064A/1914020301/0116.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["juneau", "united states", "alaska"], "location_city": ["juneau"], "location_country": ["united states"], "location_state": ["alaska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["a", "4", "6", "sn84020657", "1", "0000000002", "0", "5", "9", "7", "2"], "number_edition": ["1"], "number_lccn": ["sn84020657"], "number_page": ["0000000002"], "number_reel": ["0", "0", "2", "7", "9", "5", "5", "0", "6", "4", "a"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the alaska daily empire (juneau, alaska) 1912-1926"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["t