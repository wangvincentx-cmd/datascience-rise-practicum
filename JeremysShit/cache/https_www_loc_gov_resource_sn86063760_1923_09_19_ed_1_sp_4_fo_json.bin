The success of the hog cow and hen program will de pend on the cooperation of every citizen of Clarendon County It can be put across but it will take work to do it There is no such a thing as getting rich the first year nor the"], "digitized": true, "extract_timestamp": "2025-04-13T08:07:59.452Z", "group": ["ndnp/scu", "university-of-south-carolina-columbia-sc-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn86063760/1923-09-19/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_kiwi_ver03:data:sn86063760:00529041263:1923091901:0328/full/pct:6.25/0/default.jpg#h=391&w=275", "https://tile.loc.gov/image-services/iiif/service:ndnp:scu:batch_scu_kiwi_ver03:data:sn86063760:00529041263:1923091901:0328/full/pct:12.5/0/default.jpg#h=782&w=550", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/scu/batch_scu_kiwi_ver03/data/sn86063760/00529041263/1923091901/0328.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["south carolina", "united states", "clarendon county", "clarendon", "manning"], "location_city": ["manning"], "location_country": ["united states"], "location_county": ["clarendon"], "location_state": ["south carolina"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["1", "3", "0", "sn86063760", "9", "6", "0000000004", "5", "2", "4"], "number_edition": ["1"], "number_lccn": ["sn86063760"], "number_page": ["0000000004"], "number_reel": ["0", "0", "5", "2", "9", "0", "4", "1", "2", "6", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the manning times (manning, clarendon county, s.c.) 1884-current", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the manning time