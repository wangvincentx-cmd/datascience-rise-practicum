.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949052701/0164.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn85053044/1949-05-27/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949052701/0164.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_anaconda_ver01:data:sn85053044:00517178135:1949052701:0161/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949052701/0164.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn85053044/1949-05-27/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949052701/0164.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85053044/1949-05-27/ed-1/?sp=4"], "batch": ["mthi_anaconda_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/glacier/", "3/united states/montana/glacier/browning/"], "contributor": ["montana historical society; helena, mt"], "date": "1949-05-27", "dates": ["1949-05-27"], "description": ["THE BROWNING CHIEF John E Davies Editor and Owner A weekly newspaper published every Friday at Browning Glacier County Montana Entered as 2nd class matter July 15 1931 at the postoffice at Browning Montana under act of March 3 1879 Subscription 200 year in advance FACING FISCAL FACTS Neither President Truman nor Congress is facing up to the act ual financial position of the United States The President has just declared that he stands on his January proposal for 4000000000 in new taxes In his pre s s conference Mr Truman put the emphasis on debt payments and at first only said that the amount of taxes would depend on how things worked out But when pressed he refused to retreat from the 4000000000 figure In doing so it seems to us he fails to recognize the danger in piling on taxes at a time when business is declin ing His own economic advisers are reported in favor of some tax cuts For its part Congress blithely goes ahead adding to the costs of government The Senate has just voted a 3000000000 appropria tions bill for the Treasury and Post Office not merely rejecting pleas for a 5 per cent"], "digitized": true, "extract_timestamp": "2023-07-03T13:49:31.374Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85053044/1949-05-27/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_anaconda_ver01:data:sn85053044:00517178135:1949052701:0164/full/pct:6.25/0/default.jpg#h=318&w=231", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_anaconda_ver01:data:sn85053044:00517178135:1949052701:0164/full/pct:12.5/0/default.jpg#h=637&w=462", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_anaconda_ver01/data/sn85053044/00517178135/1949052701/0164.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["glacier", "browning", "united states", "montana"], "location_city": ["browning"], "location_country": ["united states"], "location_county": ["glacier"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "sn85053044", "8", "3", "0000000004", "7", "1"], "number_edition": ["1"], "number_lccn": ["sn85053044"], "number_page": ["0000000004"], "number_reel": ["0