 Wednesday morning at the weekly bridge luncheon for mem bers and their guests Bridge was in play at 15 tables during the morning followed by luncheon al 130 oclock Hostesses for the day were Mrs Fred Burr and Mrs Eu gene Hicks High scorer of the game was Mrs John A Elmore while low scorer was Mrs O L Browne Hostesses for next Wednesday will be Mrs B R Morrison and Mrs Alice Andrews Among those attending were Mrs Lynn B Tillery Mrs W S Baker Mrs Robert W Marye Miss Lois Toomer Mrs Walker Taylor Mrs Oscar Peck Mrs William Emerson Mrs David H Scott Mrs W L Beery Mrs Frank Park of Greenville Mrs John A El more Mrs R J Griffith of At lanta Ga Mrs George Thomas Mrs Horace Emerson Mrs George Clark Mrs Hazel Powell of Lum berton Mrs I J Sutton Mrs O L Browne Mrs Horace Pearsall Mrs Fred Pearsall Mrs Van Toomer Mrs C Wayne Spencer Mrs John Ryssey Mrs Robert Murphy Mrs T K Lynch Mrs T D Love Jr Mrs C M Wade Mrs Emsley A Laney"], "digitized": true, "extract_timestamp": "2023-08-12T17:38:24.992Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn78002169/1945-08-17/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_lily_ver01:data:sn78002169:00279558856:1945081701:0551/full/pct:6.25/0/default.jpg#h=424&w=320", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_lily_ver01:data:sn78002169:00279558856:1945081701:0551/full/pct:12.5/0/default.jpg#h=849&w=640", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ncu/batch_ncu_lily_ver01/data/sn78002169/00279558856/1945081701/0551.xml&format=alto_xml"], "index": 7, "language": ["english"], "location": ["new hanover county", "new hanover", "wilmington", "north carolina", "united states"], "location_city": ["wilmington"], "location_country": ["united states"], "location_county": ["new hanover"], "location_state": ["north carolina"], "mime_type": ["imag