e <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.331948, "shard": "06", "shelf_id": "sn88085947, 1908-01-14, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/wa", "source_modified": "2000-01-01T12:00:00Z", "subject": ["spokane (wash.)", "washington (state)", "washington", "spokane", "newspapers", "united states"], "subject_headings": ["Spokane (Wash.)--Newspapers", "Washington (State)--Spokane", "United States--Washington--Spokane--Spokane"], "subjects": [{"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"spokane": "https://www.loc.gov/search/?fa=subject:spokane&fo=json"}, {"spokane (wash.)": "https://www.loc.gov/search/?fa=subject:spokane+%28wash.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"washington": "https://www.loc.gov/search/?fa=subject:washington&fo=json"}, {"washington (state)": "https://www.loc.gov/search/?fa=subject:washington+%28state%29&fo=json"}], "timestamp": "2024-04-26T16:33:02.603Z", "title": "The Spokane press (Spokane, Wash.), January 14, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn88085947/1908-01-14/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn88085947/", "http://lccn.loc.gov/sn88085947"], "batch": ["wa_american_ver02"], "campaigns": [], "date": "1902", "description": ["Daily (except Sunday) No. 1 (Nov. 7, 1902)- ; -37th year, no. 119 (Mar. 18, 1939). Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:10.544Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-02", "catalog", "united-states-newspaper-directory", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/sn88085947/", "image_url": [], "index": 4, "language": ["english"], "latlong": [47.6589989, -117.4250224], "location": ["washington", "united states", "spokane"], "location_str": "", "lonlat": [-117.4250224, 47.6589989], "number": ["online resource", "2025-06-25t14:24:32", "sn88085947", "2024-04-18t09:34:01.476550", "http://www.loc.gov/item/sn88085947/1902-11-07/ed-1/", "http://www.loc.gov/item/sn88085947/1910-12-31/ed-2/", "18446894", "2328-5710", "2026-04-13t21:30:13", "1", "2793"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the spokane press (spokane, wash.) 1902-1939", "catalog", "chronicling america"], "publication_frequency": ["daily"], "score": 49.216022, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["spokane (wash.)", "washington (state)", "washington", "spokane", "newspapers", "united states"], "timestamp": "2026-07-18T09:27:58.371Z", "title": "The Spokane press", "type": ["title"], "url": "https://www.loc.gov/item/sn88085947/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021220341/"], "campaigns": [], "date": "1914", "dates": ["[1914 TO 1971]"], "description": ["Biweekly, Jan. 26, 1933-June 17, 1971 Print began with v. 35, no. 12 (June 15, 1914); ceased with v. 96, no. 12 (June 17, 1971). Continues the numbering of Ranch (Seattle, Wash.). Two volumes per year, 1914-1932; one volume per year, 1933-1971. Volume numbers 60-69 published 1929-1934; volume numbering 60-69 repeated 1935-1944.. Master and use copy. Digital master created according to Benchmark for Faithful Digital Reproductions of Monographs and Serials, Version 1. Digital Library Federation, December 2002. http://purl.oclc.org/DLF/benchrepro0212 digitized HathiTrust Digital Library committed to preserve pda Vol. XXXV, No. 12 (June 15, 1914); title from caption (Chronicling America's website, viewed May 18, 2021). Vol. XXXV, No. 12 (June 15, 1914) (Chronicling America's website, viewed May 18, 2021). Washington farmer-stockman"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:13.555Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021220341/", "image_url": [], "index": 5, "language": ["english"], "location": ["washington", "\u00e9tat", "united states", "spokane"], "number": ["online resource", "2768-4210", "2021220340", "2021220341", "2026-04-13t21:30:13", "701515085"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "washington farmer (spokane, wash.) 1914-1971 [online resource]", "serial and government publications division"], "publication_frequency": ["biweekly"], "score": 39.974396, "shelf_id": "ISSN RECORD S449.W2 R36", "site": ["usnd"], "subject": ["spokane (wash.)", "livestock", "washington (\u00e9tat)", "washington (state)", "washington", "agriculture", "newspapers", "spokane", "journaux", "united states"], "timestamp": "2026-05-26T21:02:05.412Z", "title": "Washington farmer", "type": ["title"], "url": "https://www.loc.gov/item/2021220341/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020218544/", "http://lccn.loc.gov/2020218544", "https://search.catalog.loc.gov/instances/57467847-0d77-5431-bafd-09549fb59d1c"], "campaigns": [], "date": "1894", "dates": ["[1894 TO 9999]"], "description": ["Daily Began with Vol. 11, No. 53 (June 29, 1894). Semi-weekly eds.: Weekly Spokesman-review, 1894-1896, and: Twice-a-week Spokesman-review, Oct.-Nov. 1896, and: Spokesman-review (Spokane, Wash. : 1896), 1896-1929. Saturday and Sunday ed.: The Spokesman-review, Spokane chronicle, Oct. 1985-July 1992. Vol. 11, No. 53 (June 29, 1894); title from PDF masthead (ProQuest Historical Newspapers, viewed May 25, 2023). 141st Vol., Issue 3 (May 21, 2023) (viewed May 25, 2023)."], "digitized": true, "extract_timestamp": "2026-05-19T21:36:55.358Z", "group": ["ndnp/newspapers", "catalog-split-12", "catalog", "united-states-newspaper-directory", "main-catalog-split-12"], "hassegments": false, "id": "http://www.loc.gov/item/2020218544/", "image_url": [], "index": 6, "language": ["english"], "location": ["washington", "united states", "spokane"], "number": ["2023240320", "online resource", "2020218544", "2023240318", "2023240319", "2023240316", "2025-08-29t10:49:32.300000", "2026-04-13t21:30:13", "2690-7178", "61313128"], "original_format": ["newspaper"], "partof": ["the spokesman-review (spokane, washington;spokane, wash.;spokane, wa) 1894-current [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division", "catalog"], "publication_frequency": ["daily"], "score": 39.974396, "shelf_id": "Newspaper AN", "site": ["usnd", "catalog"], "subject": ["serial publications", "electronic journals", "spokane (wash.)", "washington (state)", "washington", "spokane", "newspapers", "united states"], "timestamp": "2026-05-26T20:59:11.488Z", "title": "The Spokesman-review", "type": ["title"], "url": "https://www.loc.gov/item/2020218544/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2009252218/"], "campaigns": [], "date": "1883", "dates": ["[1883 TO 1890]"], "description": ["Weekly Began with vol. 1, no. 1 (May 19, 1883); print ceased with Feb. 27, 1890. Also issued on microfilm from Bell & Howell, Micro Photo Div. Daily editions: Spokane Falls Evening Review, 1884; Spokane Evening Review, 1884-1885; Morning Review, 1885-1889; Spokane Falls Review (Spokane Falls, Wash. : 1889), 1889-1891. Description based on: Vol. 1, no. 1 (May 19, 1883); title from masthead. Latest issue consulted: Vol. 3, no. 44 (Mar. 6, 1886). Spokane Falls weekly review"], "digitized": true, "extract_timestamp": "2026-0