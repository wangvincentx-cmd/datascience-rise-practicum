gov/image-services/iiif/service:ndnp:ncu:batch_ncu_mitchell_ver01:data:sn92073908:00416156578:1920110201:0426/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn92073908/1920-11-02/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.331948, "shard": "06", "shelf_id": "sn92073908, 1920-11-02, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ncu", "source_modified": "2000-01-01T12:00:00Z", "subject": ["newspapers", "halifax", "united states", "scotland neck (n.c.)", "scotland neck", "north carolina"], "subject_headings": ["Scotland Neck (N.C.)--Newspapers", "North Carolina--Scotland Neck", "United States--North Carolina--Halifax--Scotland Neck"], "subjects": [{"halifax": "https://www.loc.gov/search/?fa=subject:halifax&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"north carolina": "https://www.loc.gov/search/?fa=subject:north+carolina&fo=json"}, {"scotland neck": "https://www.loc.gov/search/?fa=subject:scotland+neck&fo=json"}, {"scotland neck (n.c.)": "https://www.loc.gov/search/?fa=subject:scotland+neck+%28n.c.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2023-08-13T14:09:48.612Z", "title": "The commonwealth (Scotland Neck, N.C.), November 2, 1920, (FOUR O'CLOCK EDITION)", "type": ["issue"], "url": "https://www.loc.gov/item/sn92073908/1920-11-02/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn92073908/", "http://lccn.loc.gov/sn92073908"], "batch": ["ncu_mitchell_ver01"], "campaigns": [], "date": "1896", "description": ["Weekly, Jan. 31, 1929-Feb. 7, 1929 Vol. 12, no. 27, new ser. v. 1, (June 18, 1896)-v. 30, no. 30 (Feb. 7, 1929). The Scotland Neck news revived the Commonwealth title when it changed its name to the Scotland Neck News and the commonwealth on May 3, 1929. Suspended with Jan. 12, 1929 issue; resumed with Jan. 31, 1929 issue. Numbering is erratic. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Scotland Neck news and the commonwealth (DLC)sn 92073909 (OCoLC)25107353"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:06.216Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-07", "catalog", "united-states-newspaper-directory", "main-catalog-split-07"], "hassegments": false, "id": "http://www.loc.gov/item/sn92073908/", "image_url": [], "index": 2, "language": ["english"], "latlong": [36.131399, -77.423183], "location": ["halifax", "united states", "halifax county", "scotland neck", "north carolina"], "location_str": "", "lonlat": [-77.423183, 36.131399], "number": ["http://www.loc.gov/item/sn92073908/1922-12-28/ed-1/", "2025-06-25t14:25:06", "microfilm master", "1618", "2474-9931", "east carolina univ", "scotland neck mem libr", "sn92073908", "sn92073907", "2026-04-13t21:30:13", "sn92073909", "north carolina div of archives & hist", "25107331", "halifax cnty libr", "http://www.loc.gov/item/sn92073908/1896-06-18/ed-1/", "2023-08-09t16:16:15.715047", "online resource", "microfilm service copy"], "original_format": ["newspaper"], "other_title": ["Daily commonwealth"], "partof": ["serial and government publications division", "chronicling america", "catalog", "the commonwealth (scotland neck, n.c.) 1896-1929", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 62.00483, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["halifax county (n.c.)", "newspapers", "halifax", "united states", "scotland neck (n.c.)", "scotland neck", "north carolina"], "timestamp": "2026-07-18T09:33:58.694Z", "title": "The commonwealth", "type": ["title"], "url": "https://www.loc.gov/item/sn92073908/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271224/"], "campaigns": [], "date": "1882", "dates": ["[1882 TO 1884]"], "description": ["Weekly (except at Christmas) Began in Aug. 1882; ceased in 1884. Publisher: E. E. Hilliard, <October 4, 1883>. Suspended with Nov. 2, 1882 issue; resumed with Dec. 7, 1882 issue. Description based on: Vol. I, no. 4 (August 24, 1882); title from masthead (Chroniclingamerica.loc.gov, viewed November 16, 2016). Latest issue consulted: Vol. II, no. 5 (October 4, 1883) (Chroniclingamerica.loc.gov, viewed November 16, 2016). Democrat (Scotland Neck, N.C.) 2474-9923 (DLC) 2016271225 (OCoLC)962749735"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:37.472Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271224/", "image_url": [], "index": 3, "language": ["english"], "location": ["scotland neck", "halifax", "united states", "north carolina"], "number": ["online resource", "2016271225", "2016271224", "962749141", "2026-04-13t21:30:13", "2474-9907"], "original_format": ["newspaper"], "partof": ["the commonwealth (scotland neck, n. c.) 1882-1884 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 52.797554, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "halifax", "united states", "scotland neck (n.c.)", "scotland neck", "north carolina"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "The commonwealth", "type": ["title"], "url": "https://www.loc.gov/item/2016271224/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271225/"], "campaigns": [], "date": "1884", "dates": ["[1884 TO 1896]"], "description": ["Weekly (except at Christmas) Began in 1884; ceased with vol. XII, no. 26 (June 11, 1896). Description based on: Volume I, number 13 (February 19, 1885); title from masthead (Chroniclingamerica.loc.gov, viewed November 16, 2016). Latest issue consulted: Vol. XII, no. 26 (June 11, 1896) (Chroniclingamerica.loc.gov, viewed November 16, 2016). Commonwealth (Scotland Neck, N.C. : 1896) 2474-994X (DLC) 2016271226 (OCoLC)962750592"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:37.472Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271225/", "image_url": [], "index": 4, "language": ["english"], "location": ["scotland neck", "halifax", "united states", "north carolina"], "number": ["2016271226", "online resource", "2016271225", "2016271224", "962749735", "2474-9923", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the democrat (scotland neck, halifax co., n. c.) 1884-1896 [online resource]"], "publication_frequency": ["weekly"], "score": 52.797554, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["newspapers", "halifax", "united states", "scotland neck (n.c.)", "scotland neck", "north carolina"], "timestamp": "2026-05-26T20:54:14.600Z", "title": "The Democrat", "type": ["title"], "url": "https://www.loc.gov/item/2016271225/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2016271226/"], "campaigns": [], "date": "1896", "dates": ["[1896 TO 1929]"], "description": ["Weekly, Jan. 31, 1929-Feb. 7, 1929 Began with Vol. XII. New Series--Vol. 1, no. 27 (June 18, 1896); ceased February 7, 1929. The Scotland Neck news revived the Commonwealth title when it changed its name to the Scotland Neck News and the commonwealth on May 3, 1929. Publisher: Clee Vaughan, <January 3-December 28, 1922>. Suspended with Jan. 12, 1929 issue; resumed with Jan. 31, 1929 issue. Numbering is erratic. Description based on: Vol. XII. New Series--Vol. 1, no. 27 (June 18, 1896); title from masthead (Chroniclingamerica.loc.gov, viewed November 16, 2016). Latest issue consulted: Vol. XVII, number 58 (December 28, 1922) (Chroniclingamerica.loc.gov, viewed November 16, 2016). Scotland Neck news and the commonwealth"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:37.472Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2016271226/", "image_url": [], "index": 5, "language": ["english"], "location": ["scotland neck", "halifax", "united states", "north carolina"], "number": ["online resource", "2016271225", "2016271226", "2474-994x", "2026-04-13t21:30:13", "962750592"], "original_format": ["newspaper"], "other_title": ["Daily commonwealth"], "parto