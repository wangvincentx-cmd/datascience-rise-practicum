02/1908011701/0183.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn88068010/1908-01-17/ed-1/?sp=4"], "batch": ["mohi_beetlebailey_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/missouri/", "2/united states/missouri/chariton/", "3/united states/missouri/chariton/keytesville/"], "contributor": ["state historical society of missouri; columbia, mo"], "date": "1908-01-17", "dates": ["1908-01-17"], "description": ["1 A Great Reduced Price Sale for w fE are going to offer the people of KEYTESVILLE AND CHARITON COUNTY a Great Opportunity to Save Money on Dependable Merchandise Last fall we bought much heavier than usual the warm weather which we have had and the brief financial panic causes us to be overstocked for this season of the year In order to meet our obligations we have got to have money and in order to get money we are offer ingeverything in this stock at Greatly Reduced Prices in some cases less than the goods cost us laid down at Keytesville depot This is no hot air talkbut a straight business proposition and a call at our store will convince you that we are doing just what we say we are AW mm u cH3g ENDING SATURDAY FEBRUARY 1 1908 We will offer for sale every article of merchandise in this store at prices you cannot match anywhere Nothing will be reserved but the knife has gone into the price of every article we carry Wc pledge you our word tuat not one article of bankrupt stock has been brought in for this sale but it is just what"], "digitized": true, "extract_timestamp": "2020-09-15T11:48:29.678Z", "group": ["ndnp/mohi", "state-historical-society-of-missouri-columbia-mo-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88068010/1908-01-17/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_beetlebailey_ver01:data:sn88068010:00294556102:1908011701:0183/full/pct:3.125/0/default.jpg#h=259&w=188", "https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_beetlebailey_ver01:data:sn88068010:00294556102:1908011701:0183/full/pct:6.25/0/default.jpg#h=519&w=376", "https://tile.loc.gov/image-services/iiif/service:ndnp:mohi:batch_mohi_beetlebailey_ver01:data:sn88068010:00294556102:1908011701:0183/full/pct:12.5/0/default.jpg#h=1038&w=753", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mohi/batch_mohi_beetlebailey_ver01/data/sn88068010/00294556102/1908011701/0183.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["chariton county", "keytesville", "united states", "missouri", "chariton"], "location_city": ["keytesville"], "location_country": ["united states"], "location_county": ["chariton"], "location_state": ["missouri"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000004", "5", "0", "2", "1", "4", "sn88068010", "9", "6"], "number_edition": ["1"], "number_lccn": ["sn88068010"], "number_page": ["0000000004"], "number_reel": ["0", "0", "2", "9", "4", "5", "5", "6", "1", "0", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "chariton courier (keytesville, chariton county, mo.) 1878-current"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["chariton courier (keytesville, chariton county, mo.) 1878-current"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn88068010/1908-01-17/ed-1/?sp=4"}], "segmentof": ["http://www.loc.gov/resource/sn88068010/1908-01-17/ed-1/"], "shelf_id": "04", "site": ["chroniclingamerica"], "subject": ["chariton county", "keytesville", "chariton county (mo.)", "united states", "missouri", "keytesville (mo.)", "newspapers", "chariton"], "times