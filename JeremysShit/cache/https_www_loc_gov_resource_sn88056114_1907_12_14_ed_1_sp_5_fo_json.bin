ge display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn88056114, 1907-12-14, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/idhi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["church and state", "ada", "newspapers", "boise (idaho)", "united states", "boise", "idaho", "mormon church"], "subject_headings": ["Church and state--Mormon Church--Newspapers", "Boise (Idaho)--Newspapers", "Church and state--Mormon Church", "Idaho--Boise", "United States--Idaho--Ada--Boise"], "subjects": [{"ada": "https://www.loc.gov/search/?fa=subject:ada&fo=json"}, {"boise": "https://www.loc.gov/search/?fa=subject:boise&fo=json"}, {"boise (idaho)": "https://www.loc.gov/search/?fa=subject:boise+%28idaho%29&fo=json"}, {"church and state": "https://www.loc.gov/search/?fa=subject:church+and+state&fo=json"}, {"idaho": "https://www.loc.gov/search/?fa=subject:idaho&fo=json"}, {"mormon church": "https://www.loc.gov/search/?fa=subject:mormon+church&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2023-07-06T19:32:32.683Z", "title": "The Idaho scimitar (Boise, Idaho), December 14, 1907", "type": ["issue"], "url": "https://www.loc.gov/item/sn88056114/1907-12-14/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn88056114/", "http://lccn.loc.gov/sn88056114", "https://search.catalog.loc.gov/instances/e23d4c