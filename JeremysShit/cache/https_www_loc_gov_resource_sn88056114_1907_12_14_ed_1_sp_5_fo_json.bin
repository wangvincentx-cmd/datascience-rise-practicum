_everglades_ver01/data/sn88056114/0041421194A/1907121401/0104.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn88056114/1907-12-14/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/idhi/batch_idhi_everglades_ver01/data/sn88056114/0041421194A/1907121401/0104.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_everglades_ver01:data:sn88056114:0041421194A:1907121401:0100/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/idhi/batch_idhi_everglades_ver01/data/sn88056114/0041421194A/1907121401/0104.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn88056114/1907-12-14/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/idhi/batch_idhi_everglades_ver01/data/sn88056114/0041421194A/1907121401/0104.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn88056114/1907-12-14/ed-1/?sp=5"], "batch": ["idhi_everglades_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/idaho/", "2/united states/idaho/ada/", "3/united states/idaho/ada/boise/"], "contributor": ["idaho state historical society"], "date": "1907-12-14", "dates": ["1907-12-14"], "description": ["A Tariff Created Trust The persuasive force behind 278 newspapers of all shades of political opinion organized for vigorous warfare is to be employed against the tariff which enables the manufacturers of paper to levy unearned tribute on the publishers of newspapers These publishers charge through their committee that unlawful combinations of paper makers have been organized recently that artificial stimulation of prices has been accomplished and that judicial pro hibition of such efforts has been disobeyed A resolution adopted by the organization states that it is the sense of the associated publishers that the duty on printing paper wood pulp and all ma terial entering into the manufacture of printing pa per should be immediately repealed The President of the United States is asked to give attention to the existence of a trade conspiracy by which the makers of paper arranged for an ad vance of 12 a ton upon paper supplied during the current year and an announced advance of an addi tional 10 per ton for the next year These advances will net the paper combine 10000000 for the first year and 19000000 for the second year The combination that is able to impose its own prices"], "digitized": true, "extract_timestamp": "2023-07-06T12:34:47.049Z", "group": ["ndnp/idhi", "idaho-state-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn88056114/1907-12-14/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_everglades_ver01:data:sn88056114:0041421194A:1907121401:0104/full/pct:6.25/0/default.jpg#h=403&w=312", "https://tile.loc.gov/image-services/iiif/service:ndnp:idhi:batch_idhi_everglades_ver01:data:sn88056114:0041421194A:1907121401:0104/full/pct:12.5/0/default.jpg#h=806&w=624", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/idhi/batch_idhi_everglades_ver01/data/sn88056114/0041421194A/1907121401/0104.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["boise", "idaho", "united states", "ada"], "location_city": ["boise"], "location_country": ["united states"], "location_county": ["ada"], "location_state": ["idaho"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "0000000005", "sn88056114", "4", "a", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn88056114"], "number_page": ["0000000005"], "number_reel": ["0", "0", "4", "1", "4", "2", "1", "1", "