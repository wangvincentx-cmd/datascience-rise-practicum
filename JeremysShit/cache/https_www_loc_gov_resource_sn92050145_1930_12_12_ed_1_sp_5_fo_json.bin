rial and government publications division", "catalog"], "publication_frequency": ["daily"], "score": 37.32358, "shelf_id": "Newspaper", "site": ["usnd", "catalog"], "subject": ["little rock (ark.)", "arkansas", "pulaski", "electronic journals", "periodicals", "little rock", "newspapers", "united states"], "timestamp": "2026-05-26T20:58:32.070Z", "title": "Arkansas Democrat gazette", "type": ["title"], "url": "https://www.loc.gov/item/2019271069/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271994/"], "campaigns": [], "date": "1852", "dates": ["[1852 TO 1857]"], "description": ["Weekly Began September 7, 1852; ceased with old series, vol. XIV, new series, vol. V, no. 34 (June 2, 1857). Suspended Feb. 28-Apr. 4, 1854. Description based on: Old Series, Vol. XI, New Series, Vol. II, No. 27 (April 18, 1854); title from masthead (Chroniclingamerica.loc.gov, viewed July 7, 2020). Latest issue consulted: Old Series, Vol. XIV, New Series, Vol. V, No. 34 (June 2, 1857) (Chroniclingamerica.loc.gov, viewed July 7, 2020). Arkansas true Democrat 2692-8663 (DLC) 2020271995 (OCoLC)1163857394"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:53.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271994/", "image_url": [], "index": 9, "language": ["english"], "location": ["arkansas", "pulaski", "pulaski county", "little rock", "united states"], "number": ["2692-8647", "online resource", "2020271995", "2022270709", "1163802314", "2026-04-13t21:30:13", "2020271994"], "original_format": ["newspaper"], "partof": ["directory of u.s. newspapers in american libraries", "the true democrat (little rock, arkansas) 1852-1857 [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 37.32358, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["little rock (ark.)", "pulaski county (ark.)", "arkansas", "pulaski county", "pulaski", "little rock", "newspapers", "united states"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The true Democrat", "type": ["title"], "url": "https://www.loc.gov/item/2020271994/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271995/"], "campaigns": [], "date": "1857", "dates": ["[1857 TO 1862]"], "description": ["Weekly Began with old series, vol. XIV, new series, vol. V, no. 35 (June 9, 1857); ceased with volume 19, number 36 (June 5, 1862). Issued on half sheet with title: True Democrat, Apr. 3-May 1, 1862, and May 15-29, 1862. Issues for June 9, 1857-July 14, 1858 called also new ser., v. 5, no. 35-v. 6, no. 40. Triweekly ed.: Tri-weekly true Democrat (non-extant), 1860. Daily eds.: Daily true Democrat (Little Rock, Ark.), <1861>, and: True Democrat bulletin, 1862. Description based on: Old Series, Vol. XIV, New Series, Vol. V, No. 35 (June 9, 1857); title from masthead (Chroniclingamerica.loc.gov, viewed July 7, 2020). Latest issue consulted: Volume 19, Number 36 (June 5, 1862) (Chroniclingamerica.loc.gov, viewed July 7, 2020). True Democrat (Little Rock, Ark. : 1862)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:53.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271995/", "image_url": [], "index": 10, "language": ["english"], "location": ["arkansas", "pulaski", "pulaski county", "little rock", "united states"], "number": ["1163857394", "online resource", "2020271995", "2692-8663", "2020271994", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["True Democrat"], "partof": ["arkansas true democrat (little rock, arkansas) 1857-1862 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 37.32358, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["little rock (ark.)", "pulaski county (ark.)", "ar