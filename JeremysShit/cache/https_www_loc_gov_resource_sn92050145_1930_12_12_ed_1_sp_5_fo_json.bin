lls around see to it that you have sufficient money to insure a HAPPY Christmas A Club for every member of the family Come in join with us today Save Any AmountFrom 25c to 100 Weekly 4 Per Cfcnt Interest 200 Main North Little Reck reduced October production to 157000 cars the lowest since 1921 and less than half last years Oc tober production The steel indus try finds demands very low be cause of this automobile slack and also because orders for rails have been less than onethird the aver age for recent years pipe line business is tapering off as winter approaches"], "digitized": true, "extract_timestamp": "2025-01-19T03:38:45.315Z", "group": ["ndnp/arhi", "arkansas-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92050145/1930-12-12/ed-1/?sp=5", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_dioptase_ver02:data:sn92050145:00516990351:1930121201:0764/full/pct:6.25/0/default.jpg#h=329&w=274", "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_dioptase_ver02:data:sn92050145:00516990351:1930121201:0764/full/pct:12.5/0/default.jpg#h=659&w=548", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_dioptase_ver02/data/sn92050145/00516990351/1930121201/0764.xml&format=alto_xml"], "index": 5, "language": ["english"], "location": ["pulaski", "little rock", "arkansas", "united states"], "location_city": ["little rock"], "location_country": ["united states"], "location_county": ["pulaski"], "location_state": ["arkansas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0000000005", "0", "3", "9", "sn92050145", "6", "1", "5"], "number_edition": ["1"], "number_lccn": ["sn92050145"], "number_page": ["0000000005"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "0", "3", "5", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["news