ch & pub records", "sn83025465", "sn84020558", "the autry museum of the american west", "10727", "arizona hist soc, s arizona div", "sharlot hall mus arch & libr", "sn89077831", "microfilm master", "sn99068151", "sn83025466", "sn83025464", "http://www.loc.gov/item/sn84020558/1890-05-19/ed-1/", "2157-135x", "2026-06-11t10:47:24.100000", "online resource", "original", "2612512", "univ of texas at austin", "el paso pub libr", "arizona newsp proj, counties", "sn89077832", "library of congress", "2023-12-21t07:55:00.444837", "city of mesa libr", "2026-04-13t21:30:13", "microfilm service copy"], "original_format": ["newspaper"], "other_title": ["Daily republican"], "partof": ["serial and government publications division", "chronicling america", "catalog", "arizona republican (phoenix, ariz.) 1890-1930", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["daily"], "score": 73.54317, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["maricopa", "maricopa county (ariz.)", "newspapers", "maricopa county", "phoenix (ariz.)", "united states", "arizona", "phoenix"], "timestamp": "2026-07-18T09:08:35.698Z", "title": "Arizona republican", "type": ["title"], "url": "https://www.loc.gov/item/sn84020558/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2024271093/"], "campaigns": [], "date": "1955", "dates": ["[1955 TO 1965]"], "description": ["Weekly Began with volume III, number 1 (July 14, 1955); ceased with vol. XIII, no. 26 (February 3, 1965). Merged with: Westside citizen, to form: Westsider (Goodyear, Ariz.). Volume III, Number 1 (July 14, 1955); title from masthead (Chroniclingamerica.loc.gov, viewed April 21, 2024). Vol. XII, Number 23 (December 19, 1963) (Chroniclingamerica.loc.gov, viewed April 21, 2024). Westside citizen Westsider (Goodyear, Ariz.)"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:15Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2024271093/", "image_url": [], "index": 13, "language": ["english"], "location": ["maricopa", "maricopa county", "goodyear", "united states", "arizona", "tolleson", "litchfield park", "phoenix"], "number": ["2997-4690", "1430728187", "2026-04-13t21:30:13", "2024271093", "online resource"], "original_format": ["newspaper"], "other_title": ["Westside"], "partof": ["serial and government publications division", "westside enterprise (goodyear, arizona) 1955-1965 [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 64.428986, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["maricopa", "litchfield park (ariz.)", "goodyear (ariz.)", "maricopa county (ariz.)", "newspapers", "maricopa county", "phoenix (ariz.)", "goodyear", "united states", "arizona", "litchfield park", "tolleson", "tolleson (ariz.)", "phoenix"], "timestamp": "2026-05-26T21:13:38.179Z", "title": "Westside enterprise", "type": ["title"], "url": "https://www.loc.gov/item/2024271093/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271984/"], "campaigns": [], "date": "1925", "dates": ["[1925 TO 1945]"], "description": ["Monthly, <Sept. 1943>- Began in 1925; ceased in 1945. Official organ of the C.A.I.S., <1943-1945>. Publishers: J.M. Melendrez, <1925>-1939; C.B. Bautista, 1939-<1942>; C.J. Carreon, 1943- Available on microfilm from the Dept. of Library, Archives & Public Records, Phoenix, Ariz. Text in Spanish, <1925-Aug. 1943>; in English and Spanish, <Sept. 3, 1943- Published as 2da e\u0301poca [second series], <1925>-1943; first series published 1900-1916 became English language title The Messenger, 1916-1955. Description based on: Vol. X 2da E\u0301poca, No. 22 (12 de agosto de 1933); title from masthead (Chroniclingamerica.loc.gov, viewed June 30, 2020). Latest issue consulted: Ano XIX, Num 11 (January, 1945) (Chroniclingamerica.loc.gov, viewed June 30, 2020)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:53.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271984/", "image_url": [], "index": 14, "language": ["spanish", "english"], "location": ["maricopa", "maricopa county", "united states", "arizona", "phoenix"], "number": ["online resource", "2020271984", "2692-7322", "2026-04-13t21:30:13", "1160207900"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "el mensajero (phoenix, arizona) 1925-1945 [online resource]"], "publication_frequency": ["monthly"], "score": 64.428986, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["maricopa", "maricopa county (ariz.)", "committee for americanism and inter-american solidarity", "newspapers", "maricopa county", "phoenix (ariz.)", "latin american", "united states", "arizona", "hispanic americans", "phoenix"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "El mensajero", "type": ["title"], "url": "https://www.loc.gov/item/2020271984/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271989/"], "campaigns": [], "date": "193?", "dates": ["[1930 TO 1999]"], "description": ["Weekly Volume 3, Number 19 (August 12, 1939); title from masthead (Chroniclingamerica.loc.gov, viewed July 1, 2020). August 29, 1942 (Chroniclingamerica.loc.gov, viewed July 1, 2020)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:53.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271989/", "image_url": [], "index": 15, "language": ["english"], "location": ["maricopa", "maricopa county", "united states", "arizona", "phoenix"], "number": ["online resource", "1161991053", "2020271989", "2026-04-13t21:30:13", "2692-7713"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "the phoenix index (phoenix, arizona) 193?-19?? [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 64.428986, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["maricopa", "maricopa county (ariz.)", "newspapers", "african americans", "maricopa county", "phoenix (ariz.)", "united states", "arizona", "african american", "phoenix"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The Phoenix index", "type": ["title"], "url": "https://www.loc.gov/item/2020271989/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271990/"], "campaigns": [], "contributor": ["smith, a. r. (arthur randolph),", "vance, helen harper"], "date": "1918", "dates": ["[1918 TO 1939]"], "description": ["Monthly, <Dec. 19, 1925>- Began in 1918? Includes supplement: Arizona American, Booster ed. <1925>. Editors: A. R. Smith, <August 3, 1918-March 1, 931>; Helen Harper Vance, <August 3-October 26, 1918>. Description based on: Vol. 1, No. 21 (August 10, 1918); title from masthead (Chroniclingamerica.loc.gov, viewed July 1, 2020). Latest issue consulted: Vol. XII, No. 397 (March, 1931) (Chroniclingamerica.loc.gov, viewed July 1, 2020)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:53.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271990/", "image_url": [], "index": 16, "language": ["english"], "location": ["maricopa", "maricopa county", "united states", "arizona", "phoenix"], "number": ["online resource", "2020271990", "2692-7748", "1161988423", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "phoenix tribune (phoenix, arizona) 1918-193? [online resource]"], "publication_frequency": ["monthly"], "score": 64.428986, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["maricopa", "maricopa county (ariz.)", "newspapers", "african americans", "maricopa county", "phoenix (ariz.)", "united states", "arizona", "african american", "phoenix"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "Phoenix tribune", "type": ["title"], "url": "https://www.loc.gov/item/2020271990/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2021270763/"], "campaigns": [], "contributor": ["phoenix indian school"], "date": "1943", "dates": ["[1943 TO 1957]"], "description": ["Appearing between 1943 and 1957, Adahooni\u0142igii was something of a predecessor to later publication, the Navajo Times. Written predominantly in the Navajo language (Dine\u0301 bizaad) and published monthly, the publication was produced by the Navajo Agency of the Bureau of Indian Affairs (BIA) and distributed to the residents of the Window Rock reservation in Arizona. With relatively few publications (other than religious texts) written in the language up to this point, the paper is often credited with contributing to the standardisation of Navajo orthography. From 1947 onwards, articles began to be published bilingually. Notable editors include Robert W. Young and William Morgan, Sr, both of whom were known for The Navajo Language, a major Navajo dictionary also published in 1943. Towards the end of its run, the government's Indian Termination Policy would result in the withdrawal of BIA funds and the eventual closure of Adahooni\u0142igii."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:48.715Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2021270763/", "image_url": [], "index": 17, "language": ["navaho", "english", "navajo"], "location": ["maricopa", "maricopa county", "chinle", "united states", "arizona", "phoenix"], "number": ["online resource", "2021270763", "2768-7287", "1102218139", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "partof": ["serial and government publications d