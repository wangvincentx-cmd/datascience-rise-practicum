"pulaski county", "little rock", "pulaski"], "timestamp": "2026-05-26T21:01:34.100Z", "title": "The true Democrat", "type": ["title"], "url": "https://www.loc.gov/item/2020271994/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2020271995/"], "campaigns": [], "date": "1857", "dates": ["[1857 TO 1862]"], "description": ["Weekly Began with old series, vol. XIV, new series, vol. V, no. 35 (June 9, 1857); ceased with volume 19, number 36 (June 5, 1862). Issued on half sheet with title: True Democrat, Apr. 3-May 1, 1862, and May 15-29, 1862. Issues for June 9, 1857-July 14, 1858 called also new ser., v. 5, no. 35-v. 6, no. 40. Triweekly ed.: Tri-weekly true Democrat (non-extant), 1860. Daily eds.: Daily true Democrat (Little Rock, Ark.), <1861>, and: True Democrat bulletin, 1862. Description based on: Old Series, Vol. XIV, New Series, Vol. V, No. 35 (June 9, 1857); title from masthead (Chroniclingamerica.loc.gov, viewed July 7, 2020). Latest issue consulted: Volume 19, Number 36 (June 5, 1862) (Chroniclingamerica.loc.gov, viewed July 7, 2020). True Democrat (Little Rock, Ark. : 1862)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:53.248Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2020271995/", "image_url": [], "index": 6, "language": ["english"], "location": ["arkansas", "united states", "pulaski county", "little rock", "pulaski"], "number": ["2020271995", "online resource", "2692-8663", "2020271994", "2026-04-13t21:30:13", "1163857394"], "original_format": ["newspaper"], "other_title": ["True Democrat"], "partof": ["arkansas true democrat (little rock, arkansas) 1857-1862 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 37.32355, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["little rock (ark.)", "arkansas", "newspapers", "pulaski cou