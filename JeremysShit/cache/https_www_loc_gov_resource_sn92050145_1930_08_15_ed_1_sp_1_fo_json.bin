ervices/iiif/service:ndnp:arhi:batch_arhi_dioptase_ver02:data:sn92050145:00516990351:1930081501:0682/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/arhi/batch_arhi_dioptase_ver02/data/sn92050145/00516990351/1930081501/0682.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn92050145/1930-08-15/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/arhi/batch_arhi_dioptase_ver02/data/sn92050145/00516990351/1930081501/0682.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn92050145/1930-08-15/ed-1/?sp=1"], "batch": ["arhi_dioptase_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/arkansas/", "2/united states/arkansas/pulaski/", "3/united states/arkansas/pulaski/little rock/"], "contributor": ["arkansas state archives"], "date": "1930-08-15", "dates": ["1930-08-15"], "description": ["HEADS OF BIG TEN INDUSTRIES AGAINST WAGE CUTS New York CityTen big industrial leaders declared against wage cuts in an article written by Roy Dickinson assisant editor and member of the Harding Unemploy ment Conference Extracts from the statements of the ten employers follow GEORGE F JOHNSON president Endicott Johnson Cor porationReducing income of labor la not a remedy for business depression it is a direct and contributing cause R 8 SSAINWALD president Paraffine Companies Inc The Paraffine Companies Inc believes such reduction can and should be avoided C R PALMER president Cluett Peabody CoIn my opinion a general reduction of wages and salaries at this time is entirely unwarranted W A SHEAFFER president W A Sheaffer Pen Company Believe it would be serious mistake to reduce wages A K ERSK1NE president Studebaker CompanyHave not even considered reducing wages or salaries A C LOKING president Pillsbury Flour Mills Company The new spirit in industry starts a virtuous and not a vicious circle in motion HERBERT V KOHLER executive vice president Kohler Company Kohler Company is maintaining its organization and its wage scale HOWARD COOXLEY president Walworth CompanyThe Walworth Company has no thought of reducing salaries or wages HAROLD C KEITH"], "digitized": true, "extract_timestamp": "2025-01-19T03:38:45.315Z", "group": ["ndnp/arhi", "arkansas-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92050145/1930-08-15/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_dioptase_ver02:data:sn92050145:00516990351:1930081501:0682/full/pct:6.25/0/default.jpg#h=331&w=272", "https://tile.loc.gov/image-services/iiif/service:ndnp:arhi:batch_arhi_dioptase_ver02:data:sn92050145:00516990351:1930081501:0682/full/pct:12.5/0/default.jpg#h=663&w=544", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/arhi/batch_arhi_dioptase_ver02/data/sn92050145/00516990351/1930081501/0682.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["united states", "little rock", "pulaski", "arkansas"], "location_city": ["little rock"], "location_country": ["united states"], "location_county": ["pulaski"], "location_state": ["arkansas"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "0", "9", "3", "sn92050145", "0000000001", "6", "1"], "number_edition": ["1"], "number_lccn": ["sn92050145"], "number_page": ["0000000001"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "0", "3", "5", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "union labor bulletin (little rock, ark.) 191?-1957"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["union labor bulletin (little rock, ark.) 191?-19