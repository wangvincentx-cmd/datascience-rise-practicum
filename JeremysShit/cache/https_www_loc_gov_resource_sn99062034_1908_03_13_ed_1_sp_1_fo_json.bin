n": ["0/united states/", "1/united states/south dakota/", "2/united states/south dakota/lake/", "3/united states/south dakota/lake/madison/"], "contributor": ["south dakota state historical society \u2013 state archives"], "date": "1908-03-13", "dates": ["1908-03-13"], "description": ["ij 3 Big Battleship Fleet It has been known for some weeks past that the big sixteen would ar rive at Its practicing ground ahead of time but it was never suspected that such an excellent showing as this would be made The important fact about it is that most of the four days gain in time was made on the last stretch of the voyage from Callao South America Previous to the visit at that port the fleet was kept on schedule making the various stops the full length called for In the itin erary Fleet in Perfect Condition An ofllcial message was also re ceived from Rear Admiral Evans him self by the local wireless station to be transmitted to Washington It was to the effect that Admiral Evans report ed to Washington that he arrived at the bay with all of the ships of the fleet in even better condition than at the time when It sailed from Hamu ton Ruads and that he is even now ready for any unforeseen emergency that may arise and that the entire fleet is prepared to sail for any des tination at an hours notice The importance of this I"], "digitized": true, "extract_timestamp": "2023-06-25T23:47:50.796Z", "group": ["ndnp/sdhi", "south-dakota-state-historical-society-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn99062034/1908-03-13/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_grenada_ver01:data:sn99062034:00279523246:1908031301:0606/full/pct:3.125/0/default.jpg#h=264&w=207", "https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_grenada_ver01:data:sn99062034:00279523246:1908031301:0606/full/pct:6.25/0/default.jpg#h=529&w=414", "https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:ba