", "catalog", "panoramic maps"], "score": 29.906975, "shelf_id": "G4194.O4A3 1868 .R8", "site": ["catalog"], "subject": ["nebraska", "omaha (neb.)", "omaha", "aerial views", "united states"], "timestamp": "2026-04-29T16:12:42.091Z", "title": "Bird's eye view of the city of Omaha, Nebraska 1868", "type": ["cartographic"], "url": "https://www.loc.gov/item/73693495/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_fourtusker_ver01/data/sn93062828/00332899491/1945082501/0266.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_fourtusker_ver01:data:sn93062828:00332899491:1945082501:0260/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/nbu/batch_nbu_fourtusker_ver01/data/sn93062828/00332899491/1945082501/0266.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn93062828/1945-08-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_fourtusker_ver01/data/sn93062828/00332899491/1945082501/0266.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_fourtusker_ver01:data:sn93062828:00332899491:1945082501:0260/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/nbu/batch_nbu_fourtusker_ver01/data/sn93062828/00332899491/1945082501/0266.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn93062828/1945-08-25/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/nbu/batch_nbu_fourtusker_ver01/data/sn93062828/00332899491/1945082501/0266.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn93062828/1945-08-25/ed-1/?sp=7"], "batch": ["nbu_fourtusker_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/nebraska/", "2/united states/nebraska/douglas/", "3/united states/nebraska/douglas/omaha/"], "contributor": ["university of nebraska-lincoln libraries, lincoln, ne"], "date": "1945-08-25", "dates": ["1945-08-25"], "description": ["EDITORIAL COMMENT j POOR RECOMMENDATION Reviewing the American economic policies in the 1930s R C Leffingwell writes in the Yale Review Restrictions on the hours and days of labor and on output and restrictions on farm production were part of a planned economy of permanent depression and artificial shortages We were producing more food than world markets would take and our gov ernment paid marginal farmers to stay in the farm business instead of turning to something else and paid them not to produce so much plow under crops and kill little pigs The business of not raising hogs was a highly flourishing industry says the Statist The planners seemed to have lost faith in America They sought to benefit organized labor and farmers at the expense of the general public They could not see that neither farmers nor laborers could prosper long in an impoverished community They could not believe in the economy of abundance and were con cerned more with changing each mans share of pov erty than with sharing wealth Commenting on the foregoing the New York Times says it is a harsh but basically true judgment of our planned economy of the 30s Is there any"], "digitized": true, "extract_timestamp": "2025-12-01T12:40:20.733Z", "group": ["ndnp/nbu", "university-of-nebraska-of-nebraska-lincoln-libraries-lincoln-ne-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn93062828/1945-08-25/ed-1/?sp=7", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_fourtusker_ver01:data:sn93062828:00332899491:1945082501:0266/full/pct:6.25/0/default.jpg#h=494&w=375", "https://tile.loc.gov/image-services/iiif/service:ndnp:nbu:batch_nbu_fourtusker_ver01:data:sn93062828:00332899491:1945082501:0266/full/pct:12.5/0/default.jpg#h=989&w=751", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/nbu/batch_nbu_fourtusker_ver01/data/sn93062828/00332899491/1945082501/0266.xml&format=alto_xml"], "index": 7, "language": ["english"], "location": ["nebraska", "omaha", "douglas", "united states"], "location_city": ["omaha"], "location_country": ["united states"], "location_county": ["douglas"], "location_state": ["nebraska"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "3", "9", "8", "sn93062828", "1", "0000000007", "4"], "number_edition": ["1"], "number_lccn": ["sn93062828"], "number_page": ["0000000007"], "number_reel": ["0", "0", "3", "3", "2", "8", "9", "9", "4", "9", "1"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Guide Omaha", "Greater Omaha guide"], "partof": ["the omaha guide (omaha, neb.) 1927-19??", "serial and government publications division", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the omaha guide (omaha, neb.) 1927-19??"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn93062828/1945-08-25/ed-1/?sp=7"}], "segmentof": ["http://www.loc.gov/resource/sn93062828/1945-08-25/ed-1/"], "shelf_id": "7", "site": ["chroniclingamerica"], "subject": ["nebraska", "african american", "omaha (neb.)", "african americans", "omaha", "douglas", "newspapers", "african american newspapers", "united states"], "subject_ethnicity": ["african american"], "timestamp": "2025-12-14T23:49:35.403Z", "title": "Image 7 of The Omaha guide (Omaha, Neb.), August 25, 1945", "type": ["segment"], "url": "https://www.loc.gov/resource/sn93062828/1945-08-25/ed-1/?sp=7"}]