cription": ["Weekly Ceased 10 Settembre 1948. Suspended Mar. 1, 1924; resumed Apr. 19, 1924. Available on microfilm from Library of Congress, Photoduplication Service, and Connecticut State Library. Text in Italian and English. Description based on: Anno. VII, No. 15 (April 17, 1920); title from masthead (Chroniclingamerica.loc.gov, viewed May 1, 2019). Latest issue consulted: Anno XVII, No. 51 (20 Dicembre 1930) (Chroniclingamerica.loc.gov, viewed May 1, 2019)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:47.120Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2019271083/", "image_url": [], "index": 2, "language": ["italian", "english"], "location": ["bridgeport", "fairfield", "connecticut", "fairfield county", "united states"], "number": ["online resource", "2643-5101", "1099570284", "2026-04-13t21:30:13", "2019271083"], "original_format": ["newspaper"], "other_title": ["Sentinel"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "la sentinella = the sentinel (bridgeport, conn.) 191?-1948 [online resource]"], "publication_frequency": ["weekly"], "score": 79.625046, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["fairfield county (conn.)", "bridgeport", "fairfield", "italians", "connecticut", "newspapers", "fairfield county", "united states", "italian", "bridgeport (conn.)"], "timestamp": "2026-05-26T20:58:32.070Z", "title": "La sentinella = The sentinel", "type": ["title"], "url": "https://www.loc.gov/item/2019271083/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2015218855/"], "campaigns": [], "date": "1803", "dates": ["[1803 TO 1929]"], "description": ["Weekly Began November 16, 1803. Published in Danbury, Conn., <November 16, 1803->;Bridgeport, Conn. <May 23, 1810->. Publishers: T. Rowe & Co., <November 16, 1803->; Stiles Nichols & Son <July 12, 1815->. Issues for <May 9, 1843-July 19, 1861> called also <new ser., v. 2, no. 71-new ser., v. 19, no. 1020>. Daily eds.: Daily advertiser and farmer, Sept. 8, 1856-186, and: Evening farmer, 186 -18, and: Bridgeport evening farmer, 18 -1917, and: Bridgeport times and evening farmer, 1918-192. New series vol. CXVII, no. 5107 (title from masthead) (Chroniclingamerica.loc.gov, viewed September 23, 2015). New series vol. CXXVIII, no. 5729 (August 13, 1920) (Chroniclingamerica.loc.gov, viewed September 23, 2015)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:03.421Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2015218855/", "image_url": [], "index": 3, "language": ["english"], "location": ["bridgeport", "fairfield", "connecticut", "fairfield county", "united states", "danbury"], "number": ["2381-0114", "2015218853", "2026-04-13t21:30:13", "192107503", "online resource", "2015218854", "2015218855"], "original_format": ["newspaper"], "other_title": ["Issues for <Aug. 12, 1864-Feb. 1865> published as: Bridgeport Republican farmer", "Issue for <Aug. 24, 1866> published as: Weekly Republican farmer", "Issue for <May 21, 1897> published as: Weekly farmer"], "partof": ["serial and government publications division", "republican farmer (bridgeport, conn.) 1803-192? [online resource]", "directory of u.s. newspapers in american libraries"], "publication_frequency": ["weekly"], "score": 66.9179, "shelf_id": "ISSN RECORD AN1 .A15", "site": ["usnd"], "subject": ["fairfield county (conn.)", "bridgeport", "danbury", "fairfield", "connecticut", "agricultural newspapers", "newspapers", "fairfield county", "united states", "bridgeport (conn.)", "danbury (conn.)"], "timestamp": "2026-05-26T20:52:06.072Z", "title": "Republican farmer", "type": ["title"], "url": "https://www.loc.gov/item/2015218855/"}, {"access_restricted": false, "aka": ["http://infoweb.newsbank.com/?db=EANX&s_browseRef=decades/14DE99CA2A23A1A6/all.xml", "http://www.loc.gov/item/sn82015536/", "http://lccn.loc.gov/sn82015536", "http://infoweb.newsbank.com/?db=EANX&s_browseRef=decades/10F19F342FFB91C0/all.xml"], "batch": ["ct_haddam_ver01"], "campaigns": [], "date": "1803", "description": ["Weekly Vol. 1, no. 1 (Nov. 16, 1803)- Published in Bridgeport, Conn., <May 23, 1810-> Publisher: Stiles Nichols & Son <July 12, 1815-> Issues for <May 9, 1843-July 19, 1861> called also <new ser., v. 2, no. 71-new ser., v. 19, no. 1020>. Available on microfilm from Recordak, Readex Microprint Corp., and the Library of Congress, Photoduplication Service. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Daily eds.: Daily advertiser and farmer, Sept. 8, 1856-186, and: Evening farmer, 186 -18, and: Bridgeport evening farmer, 18 -1917, and: Bridgeport times and evening farmer, 1918-192."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:01.070Z", "group": ["newspaper-titles", "catalog-split-15", "catalog", "ndnp/newspapers", "main-catalog-split-15", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn82015536/", "image_url": [], "index": 4, "language": ["english"], "latlong": [41.179195, -73.189476], "location": ["bridgeport", "fairfield", "connecticut", "fairfield county", "united states", "danbury"], "location_str": "", "lonlat": [-73.189476, 41.179195], "number": ["connecticut state libr", "univ of tennessee", "sn82014093", "northwestern univ", "boston pub libr", "danbury scott fanton mus & hist soc", "univ of oklahoma", "huntington libr art gallery & gardens", "1", "new york hist soc, newsp proj", "central connecticut state univ", "syracuse univ", "mattatuck hist soc libr", "sn84022472", "univ of kentucky libr", "american antiquarian soc, newsp proj", "plumb mem libr", "2020-12-07t13:02:06.271773", "wisconsin hist soc, newsp proj", "131", "sn92051227", "pequot libr", "new york univ", "new york state - vx6", "2381-0106", "peabody e