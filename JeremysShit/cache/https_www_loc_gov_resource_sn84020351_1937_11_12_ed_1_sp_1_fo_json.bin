, "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-06t18:48:32", "2002-12-14t20:44:34", "sheet", "2001620483"], "online_format": ["image"], "original_format": ["map"], "partof": ["catalog", "county landownership maps", "geography and map division", "cultural landscapes"], "score": 31.030714, "shelf_id": "G3783.F3 1856 .C5 TIL", "site": ["catalog"], "subject": ["real property", "fairfield county (conn.)", "connecticut", "fairfield county", "united states", "maps"], "timestamp": "2026-04-29T15:42:50.105Z", "title": "Clark's map of Fairfield County, Connecticut", "type": ["cartographic"], "url": "https://www.loc.gov/item/2001620483/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_arnold_ver02/data/sn84020351/00414183189/1937111201/0465.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_arnold_ver02:data:sn84020351:00414183189:1937111201:0465/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_arnold_ver02/data/sn84020351/00414183189/1937111201/0465.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn84020351/1937-11-12/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_arnold_ver02/data/sn84020351/00414183189/1937111201/0465.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_arnold_ver02:data:sn84020351:00414183189:1937111201:0465/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ct/batch_ct_arnold_ver02/data/sn84020351/00414183189/1937111201/0465.pdf", "segment_count": 4, "url": "https://www.loc.gov/resource/sn84020351/1937-11-12/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ct/batch_ct_arnold_ver02/data/sn84020351/00414183189/1937111201/0465.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn84020351/1937-11-12/ed-1/?sp=1"], "batch": ["ct_arnold_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/fairfield/", "3/united states/connecticut/fairfield/bridgeport/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1937-11-12", "dates": ["1937-11-12"], "description": ["Founded by P Altieri Office 641 East Washington Avenue BRIDGEPORT CONN VENERD\u00cc 12 NOVEMBRE 1937 Subscription 200 per Year No 44 ANNO XXIV Fatti e Parole H Il Fiasco di Bruxelles Decisamente nonostante il tanto ambito appoggio mo rale di Washington il Mighty Empire e la verbosa nostra sorellastra hanno diportato nella capitale Belga un clamoroso fiasco le cui conseguenze non torna facile predire al momento Le tante artificiose montature truccature e turlupinature sono valse un semplice zero per quanto si riferisce allo scopo del convegno indetto allo scopo di pacificare la Cina ed il Giappone ed il cui unico importante risultato \u00e8 stato quello di dimostrare ancora una volta ed inconfutabilmente che i tempi in cui Berta filava furono e torneranno mai pi\u00f9 disgraziatamente per il vecchio raucoso John Bull e la debusciata Marianna ma fortuna tamente per il resto del mondo che fino a pochi anni addietro fu vittima dei capricci e dellavidit\u00e0 dei predatori di Londra e di Parigi Nellera presente lEra Fascista non \u00e8 possibile lege monia a base di forza od o base di demagogia criminale Poich\u00e9 il Fascismo non riconosce altro diritto che quello della ragione c non permette la continuazione dei sistemi politici"], "digitized": true, "extract_timestamp": "2023-06-01T13:38:26.488Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84020351/1937-11-12/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_arnold_ver02:data:sn84020351:00414183189:1937111201:0465/full/pct:3.125/0/default.jpg#h=301&w=224", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_arnold_ver02:data:sn84020351:00414183189:1937111201:0465/full/pct:6.25/0/default.jpg#h=602&w=449", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_arnold_ver02/data/sn84020351/00414183189/1937111201/0465.xml&format=alto_xml"], "index": 1, "language": ["italian", "english"], "location": ["bridgeport", "fairfield", "connecticut", "fairfield county", "united states"], "location_city": ["bridgeport"], "location_country": ["united states"], "location_county": ["fairfield"], "location_state": ["connecticut"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "0", "8", "3", "sn84020351", "4", "0000000001", "1"], "number_edition": ["1"], "number_lccn": ["sn84020351"], "number_page": ["0000000001"], "number_reel": ["0", "0", "4", "1", "4", "1", "8", "3", "1", "8", "9"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Sentinel"], "partof": ["serial and government publications division", "la sentinella = the sentinel (bridgeport, conn.) 191?-1948", "chronicling america"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["la sentinella = the sentinel (bridgeport, conn.) 191?-1948"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn84020351/1937-11-12/ed-1/?sp=1"}], "segmentof": ["http://www.loc.gov/resource/sn84020351/1937-11-12/ed-1/"], "shelf_id": "1", "site": ["chroniclingamerica"], "subject": ["fairfield county (conn.)