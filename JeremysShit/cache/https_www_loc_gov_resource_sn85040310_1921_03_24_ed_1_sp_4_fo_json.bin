er"], "other_formats": [{"label": "MODSXML Record", "link": "//tile.loc.gov/storage-services/service/ndnp//whi/batch_whi_fanny_ver01/data/sn85040310/00514152305/1921032401/1921032401_1.xml"}, {"label": "MARCXML Record", "link": "//lccn.loc.gov/sn85040310/marcxml"}], "partof": [{"count": 1771, "title": "the telegraph-courier (kenosha, wis.) 1888-1946", "url": "https://www.loc.gov/search/?fa=partof:the+telegraph-courier+%28kenosha,+wis.%29+1888-1946&fo=json"}, {"count": 3203926, "title": "chronicling america", "url": "https://www.loc.gov/collections/chronicling-america/?fo=json"}, {"count": 3225157, "title": "serial and government publications division", "url": "https://www.loc.gov/search/?fa=partof:serial+and+government+publications+division&fo=json"}], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the telegraph-courier (kenosha, wis.) 1888-1946"], "place_of_publication": "Kenosha, Wis.", "publication_frequency": ["weekly"], "raw_lccn": "sn 85040310 ", "reel_numbers": ["00514152305"], "resources": [{"files": 8, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_fanny_ver01:data:sn85040310:00514152305:1921032401:0613/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn85040310/1921-03-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.331948, "shard": "06", "shelf_id": "sn85040310, 1921-03-24, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/whi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["kenosha", "wisconsin", "kenosha (wis.)", "newspapers", "united states"], "subject_headings": ["Kenosha (Wis.)--Newspapers", "Wisconsin--Kenosha", "United States--Wisconsin--Kenosha--Kenosha"], "subjects": [{"kenosha": "https://www.loc.gov/search/?fa=subject:kenosha&fo=json"}, {"kenosha (wis.)": "https://www.loc.gov/search/?fa=subject:kenosha+%28wis.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"wisconsin": "https://www.loc.gov/search/?fa=subject:wisconsin&fo=json"}], "timestamp": "2023-08-23T01:30:14.670Z", "title": "The Telegraph-courier (Kenosha, Wis.), March 24, 1921", "type": ["issue"], "url": "https://www.loc.gov/item/sn85040310/1921-03-24/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/sn85040310", "http://www.loc.gov/item/sn85040310/", "https://search.catalog.loc.gov/instances/1e58d381-a245-5e42-b0bd-b175f26b379b"], "batch": ["whi_engledinger_ver02"], "campaigns": [], "date": "1888", "description": ["Weekly Vol. 49, no. 19 (Oct. 4, 1888)- Ceased in 1946 or 1947. Cf. Ayer's 1947. Publisher varies. Editor: M. Frank, L.A. Cass, 1888-Aug. 7, 1890.--L.A. Cass, Aug. 14, 1890-Aug. 13, 1891.--F.H. Hall, Aug. 20, 1891-Oct. 1, 1896.--G.P. Hewitt, Nov. 4, 1897-Aug. 29, 1901.--S.S. Simmons, Sept. 5, 1901-<1915>.--W.T. Marlatt, <1915>-Apr. 16, 1925. Available on microfilm from The State Historical Society of Wisconsin."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:02.120Z", "group": ["newspaper-titles", "catalog-split-06", "catalog", "ndnp/newspapers", "main-catalog-split-06", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn85040310/", "image_url": [], "index": 4, "language": ["english"], "latlong": [42.588079, -87.822877], "location": ["wisconsin", "kenosha", "united states"], "location_str": "", "lonlat": [-87.822877, 42.588079], "number": ["online resource", "2025-07-01t13:27:25.800000", "sn85040029", "wisconsin hist soc, newsp proj", "microfilm service copy", "1770", "sn85033123", "2022-10-19t13:11:23.724279", "http://www.loc.gov/item/sn85040310/1925-12-31/ed-1/", "11802001", "2837-2743", "http://www.loc.gov/item/sn85040310/1888-10-04/ed-1/", "2026-04-13t21:30:13", "sn85040310", "1"], "original_format": ["newspaper"], "partof": ["the telegraph-courier (kenosha, wis.) 1888-1946", "directory of u.s. newspapers in american libraries", "serial and government publications division", "catalog", "chronicling america"], "publication_frequency": ["weekly"], "score": 44.03167, "shelf_id": "http://lccn.loc.gov/sn85040310", "site": ["chroniclingamerica", "catalog", "usnd"], "subject": ["kenosha", "wisconsin", "kenosha (wis.)", "newspapers", "united states"], "timestamp": "2026-07-18T09:15:53.161Z", "title": "The Telegraph-courier", "type": ["title"], "url": "https://www.loc.gov/item/sn85040310/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270563/"], "campaigns": [], "date": "1860", "dates": ["[1860 TO 1888]"], "description": ["Weekly Began with vol. 21, no. 1 (June 14, 1860); ceased with volume XLIX, number 18 (September 28, 1888). Publisher varies. Published every Thursday. Editor: L. Stone, S.C. Winegar, D.C. McVean, June 14-Oct. 4, 1860.--S.C. Winegar & D.C. McVean, Oct. 11-18, 1860.--S.S. Schoff & S.C. Winegar, Oct. 25, 1860-Mar. 5, 1861.--S.S. Schoff, S.C. Winegar & H.F. Schoff, Mar. 12, 1863-Aug. 29, 1867.--M. Frank, Sept. 5, 1867-Dec. 3, 1868.--H. McKinley, 1869-Jan. 1880.--H. Barns, May 6-Sept. 10, 1880.--R.F. Roberts, Oct. 8, 1880-Mar. 25, 1881.--M. Frank, Sept. 8, 1882-1888. Available on microfilm from The State Historical Society of Wisconsin. Vol. 21, No. 1 (June 14, 1860); title from masthead (Chroniclingamerica.loc.gov, viewed April 7, 2023). Volume XLIX, number 18 (September 28, 1888) (Chroniclingamerica.loc.gov, viewed April 7, 2023). Kenosha courier Telegraph-courier 2837-276X (DLC) 2023270584 (OCoLC)1376434696"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:09.301Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2023270563/", "image_url": [], "index": 5, "language": ["english"], "location": ["wisconsin", "kenosha", "united states"], "number": ["online resource", "1375231915", "2023270584", "2837-0546", "2026-04-13t21:30:13", "2023270563", "2023270583"], "original_format": ["newspaper"], "other_title": ["Kenosha telegraph and tribune"], "partof": ["directory of u.s. newspapers in american libraries", "serial and government publications division", "the kenosha telegraph (kenosha, wis.;kenosha, wisconsin) 1860-1888 [online resource]"], "publication_frequency": ["weekly"], "score": 34.888, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["kenosha", "united states", "sources", "kenosha (wis.)", "newspapers", "history", "wisconsin"], "timestamp": "2026-05-26T21:08:46.277Z", "title": "The Kenosha telegraph", "type": ["title"], "url": "https://www.loc.gov/item/2023270563/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270570/"], "campaigns": [], "date": "1840", "dates": ["[1840 TO 1850]"], "description": ["Weekly Began with Volume I, number 1 (June 16, 1840); ceased with vol. X, no. 40 (March 29, 1850). Publisher varies. Available on microfilm from The State Historical Society of Wisconsin. Volume I, Number 1 (June 16, 1840); title from masthead (Chroniclingamerica.loc.gov, viewed April 13, 2023). Vol. X, No. 40 (March 29, 1850) (Chroniclingamerica.loc.gov, viewed April 13, 2023). Kenosha telegraph (Kenosha, Wis. : 1850) 2837-2433 (DLC) 2023270579 (OCoLC)1376353229"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:09.301Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2023270570/", "image_url": [], "index": 6, "language": ["english"], "location": ["wisconsin", "kenosha", "southport", "united states"], "number": ["2023270579", "online resource", "2837-1860", "1375686137", "2023270570", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Telegraph"], "partof": ["southport telegraph (southport, w.t. [kenosha, wis.]) 1840-1850 [online resource]", "directory of u.s. newspapers in american libraries", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 34.888, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["kenosha", "southport (wis.)", "southport", "united states", "kenosha (wis.)", "newspapers", "wisconsin"], "timestamp": "2026-05-26T21:08:46.277Z", "title": "Southport telegraph", "type": ["title"], "url": "https://www.loc.gov/item/2023270570/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270579/"], "campaigns": [], "date": "1850", "dates": ["[1850 TO 1854]"], "descripti