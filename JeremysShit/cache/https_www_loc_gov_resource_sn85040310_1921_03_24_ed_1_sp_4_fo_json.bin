ttps://www.loc.gov/resource/sn85040310/1921-03-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/whi/batch_whi_fanny_ver01/data/sn85040310/00514152305/1921032401/0616.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_fanny_ver01:data:sn85040310:00514152305:1921032401:0613/full/pct:3.125/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/whi/batch_whi_fanny_ver01/data/sn85040310/00514152305/1921032401/0616.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn85040310/1921-03-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/whi/batch_whi_fanny_ver01/data/sn85040310/00514152305/1921032401/0616.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn85040310/1921-03-24/ed-1/?sp=4"], "batch": ["whi_fanny_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/wisconsin/", "2/united states/wisconsin/kenosha/", "3/united states/wisconsin/kenosha/kenosha/"], "contributor": ["wisconsin historical society"], "date": "1921-03-24", "dates": ["1921-03-24"], "description": ["PAGE FOUR The Telegraph Courier PUBLISHED WEEKLY AT KENOSHA WIS W T Marlatt Editor and Publisher The Oldest Newspaper of Continuous Publication in Wisconsin SUBSCRIPTION ONE DOLLAR A YEAR IN ADVANCE Entered as Second Class Matter at the Post Office at Kenosha Under Act of Marfh 3 1873 VOLUME LXXXI NO 49 THURSDAY MARCH 241921 PHILIPPINES AS COMMERCIAL BASE The desire of President Harding to have a firsthand report on the Philippine situation is taken in quarters where such an eventuality is hoped for as an augury of granting of independ ence says the Christian Science Monitor in commenting on the assignment of General Wood to the Philippine Islands on k general mis sion Just who is hoping for such an event uality outside of a few Filipina malcontents who would like to introduce an Orientalized Tweed system in those islands is not stated Certainly as the educated Filipinos witness the avidness of Japan in sweeping the Pacific is lands into her basket their thoughts must be turned to the safety which American control of their territory assures The Filipinos are not so far from Korea but what they appreciate what Japanese imperialism would mean to them The Democratic Administration"], "digitized": true, "extract_timestamp": "2023-08-22T16:19:42.609Z", "group": ["ndnp/whi", "wisconsin-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85040310/1921-03-24/ed-1/?sp=4", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_fanny_ver01:data:sn85040310:00514152305:1921032401:0616/full/pct:3.125/0/default.jpg#h=265&w=214", "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_fanny_ver01:data:sn85040310:00514152305:1921032401:0616/full/pct:6.25/0/default.jpg#h=531&w=429", "https://tile.loc.gov/image-services/iiif/service:ndnp:whi:batch_whi_fanny_ver01:data:sn85040310:00514152305:1921032401:0616/full/pct:12.5/0/default.jpg#h=1063&w=858", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/whi/batch_whi_fanny_ver01/data/sn85040310/00514152305/1921032401/0616.xml&format=alto_xml"], "index": 4, "language": ["english"], "location": ["kenosha", "united states", "wisconsin"], "location_city": ["kenosha"], "location_country": ["united states"], "location_county": ["kenosha"], "location_state": ["wisconsin"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "3", "0000000004", "sn85040310", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn85040310"], "number_page": ["000000000