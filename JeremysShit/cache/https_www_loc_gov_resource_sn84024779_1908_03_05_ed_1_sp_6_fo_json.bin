blication": "Wahpeton, Richland County, Dakota [N.D.]", "publication_frequency": ["weekly"], "raw_lccn": "sn 84024779 ", "reel_numbers": ["00295863742"], "resources": [{"files": 8, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_colfax_ver01:data:sn84024779:00295863742:1908030501:0527/full/pct:3.125/0/default.jpg", "url": "https://www.loc.gov/resource/sn84024779/1908-03-05/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.332207, "shard": "07", "shelf_id": "sn84024779, 1908-03-05, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ndhi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["wahpeton (n.d.)", "newspapers", "north dakota", "united states", "wahpeton", "richland"], "subject_headings": ["Wahpeton (N.D.)--Newspapers", "North Dakota--Wahpeton", "United States--North Dakota--Richland--Wahpeton"], "subjects": [{"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"north dakota": "https://www.loc.gov/search/?fa=subject:north+dakota&fo=json"}, {"richland": "https://www.loc.gov/search/?fa=subject:richland&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}, {"wahpeton": "https://www.loc.gov/search/?fa=subject:wahpeton&fo=json"}, {"wahpeton (n.d.)": "https://www.loc.gov/search/?fa=subject:wahpeton+%28n.d.%29&fo=json"}], "timestamp": "2023-08-26T00:30:59.155Z", "title": "The Wahpeton times (Wahpeton, Richland County, Dakota [N.D.]), March 5, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn84024779/1908-03-05/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn84024779/", "http://lccn.loc.gov/sn84024779"], "batch": ["ndhi_bowbells_ver01"], "campaigns": [], "date": "1879", "description": ["Weekly Began in 1879. -v. 43, no. 36 (Jan. 9, 1919). Published as: Times, Nov. 1884-May 1885. Official County Paper, 1884, 1887-1889, 1903. Official City Paper, 1884, 1887-1888, 1903, 1910-1911, 1913-1915, 1918-1919. Includes Richland County Fair herald, vol. 1, no. 1-v. 1, no. 3 (July 24-Sept. 25, 1913). Available on microfilm from the State Historical Society of North Dakota. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Description based on: Vol. 6, no. 17 (Aug. 1, 1884). Independent press (Wahpeton, N.D. : 1919) (DLC)sn 88076486 (OCoLC)18241468"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:06.216Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-10", "catalog", "united-states-newspaper-directory", "main-catalog-split-10"], "hassegments": false, "id": "http://www.loc.gov/item/sn84024779/", "image_url": [], "index": 6, "language": ["english"], "latlong": [46.263918, -96.605505], "location": ["wahpeton", "north dakota", "richland", "united states"], "location_str": "", "lonlat": [-96.605505, 46.263918], "number": ["2251045", "microfilm master", "2379-1306", "http://www.loc.gov/item/sn84024779/1884-04-11/ed-1/", "2023-08-22t07:32:24.084270", "1258", "state hist soc of n dakota", "sn84024779", "2026-04-13t21:30:13", "wisconsin hist soc, newsp proj", "2025-06-25t14:21:31", "sn88076486", "http://www.loc.gov/item/sn84024779/1919-01-09/ed-1/", "online resource", "original", "1", "microfilm service copy"], "original_format": ["newspaper"], "other_title": ["Times (Wahpeton, N.D.)"], "partof": ["serial and government publications division", "chronicling america", "directory of u.s. newspapers in american libraries", "catalog", "the wahpeton times (wahpeton, richland county, dakota [n.d.]) 1879-1919"], "publication_frequency": ["weekly"], "score": 63.258038, "shelf_id": "Newspaper AN2 .W24x", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["wahpeton (n.d.)", "newspapers", "north dakota", "united states", "wahpeton", "richland"], "timestamp": "2026-07-18T09:10:05.966Z", "title": "The Wahpeton times", "type": ["title"], "url": "https://www.loc.gov/item/sn84024779/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2015218762/"], "campaigns": [], "date": "1879", "dates": ["[1879 TO 1919]"], "description": ["Weekly Began in 1879. Ceased with volume XLIII, number 36 (January 9, 1919). Published as: Times, Nov. 1884-May 1885. Official County Paper, 1884, 1887-1889, 1903. Official City Paper, 1884, 1887-1888, 1903, 1910-1911, 1913-1915, 1918-1919. Includes Richland County Fair herald, vol. 1, no. 1-v. 1, no. 3 (July 24-Sept. 25, 1913). Available on microfilm from the State Historical Society of North Dakota. Archived issues are available in digital format from the Library of Congress Chronicling America online collection. Description based on: Vol. 5, no. 1 (April 11, 1884); title from masthead (Chroniclingamerica.loc.gov, viewed May 13, 2015). Latest issue consulted: Volume XLIII, number 36 (January 9, 1919) (Chroniclingamerica.loc.gov, viewed May 13, 2015). Independent press (Wahpeton, N.D. : 1919)"], "digitized": true, "extract_timestamp": "2026-05-19T21:37:31.065Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2015218762/", "image_url": [], "index": 7, "language": ["english"], "location": ["wahpeton", "north dakota", "richland", "united states"], "number": ["online resource", "2015218762", "908848634", "2379-1314", "2026-04-13t21:30:13"], "original_format": ["newspaper"], "other_title": ["Times (Wahpeton, N.D.)"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the wahpeton times (wahpeton, richland county, dakota [n.d.]) 1879-1919 [online resource]"], "publication_frequency": ["weekly"], "score": 54.11437, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["wahpeton (n.d.)", "newspapers", "north dakota", "united states", "wahpeton", "richland"], "timestamp": "2026-05-26T20:52:06.072Z", "title": "The Wahpeton times", "type": ["title"], "url": "https://www.loc.gov/item/2015218762/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn84024779/1884-07-25/ed-1/", "http://www.loc.gov/resource/sn84024779/1884-07-25/ed-1/"], "batch": ["ndhi_bowbells_ver01"], "campaigns": [], "contributor": ["state historical society of north dakota"], "date": "1884-07-25", "dates": ["1884-07-25"], "description": ["Wahpeton, Richland County, Dakota [N.D.]"], "digitized": true, "extract_timestamp": "2023-08-25T19:25:04.365Z", "group": ["ndnp/ndhi", "state-histrorical-society-of-north-dako