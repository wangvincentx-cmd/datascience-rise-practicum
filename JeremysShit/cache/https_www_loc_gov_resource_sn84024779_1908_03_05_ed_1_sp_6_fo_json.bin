 sev enty years is provided in a bill intro duced by Senator Knox which haB been reported favorably by the senate committee on Judiciary The case of the Duluth and Superior Bridge company vs the Steamer Troy a suit for damages growing"], "digitized": true, "extract_timestamp": "2023-08-25T19:25:35.937Z", "group": ["ndnp/ndhi", "state-histrorical-society-of-north-dakota-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn84024779/1908-03-05/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_colfax_ver01:data:sn84024779:00295863742:1908030501:0532/full/pct:3.125/0/default.jpg#h=275&w=194", "https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_colfax_ver01:data:sn84024779:00295863742:1908030501:0532/full/pct:6.25/0/default.jpg#h=550&w=388", "https://tile.loc.gov/image-services/iiif/service:ndnp:ndhi:batch_ndhi_colfax_ver01:data:sn84024779:00295863742:1908030501:0532/full/pct:12.5/0/default.jpg#h=1100&w=777", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ndhi/batch_ndhi_colfax_ver01/data/sn84024779/00295863742/1908030501/0532.xml&format=alto_xml"], "index": 6, "language": ["english"], "location": ["wahpeton", "north dakota", "richland", "united states"], "location_city": ["wahpeton"], "location_country": ["united states"], "location_county": ["richland"], "location_state": ["north dakota"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "9", "0", "8", "3", "sn84024779", "4", "0000000006", "7", "6", "2", "1"], "number_edition": ["1"], "number_lccn": ["sn84024779"], "number_page": ["0000000006"], "number_reel": ["0", "0", "2", "9", "5", "8", "6", "3", "7", "4", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Times (Wahpeton, N.D.)"], "partof": ["serial and government publications division", "the