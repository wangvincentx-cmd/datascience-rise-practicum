timestamp": 1784400800.762701, "tz_aware": null, "unionFacets": "", "webcast_permalink": null}, "page": [{"height": 5749, "info": "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_flatheadsole_ver01:data:sn95063172:00414185733:1930120601:0554/info.json", "mimetype": "image/jp2", "size": 3010245, "url": "https://tile.loc.gov/storage-services/service/ndnp/ak/batch_ak_flatheadsole_ver01/data/sn95063172/00414185733/1930120601/0554.jp2", "use": "", "width": 4189}, {"mimetype": "application/pdf", "url": "https://tile.loc.gov/storage-services/service/ndnp/ak/batch_ak_flatheadsole_ver01/data/sn95063172/00414185733/1930120601/0554.pdf", "use": ""}, {"mimetype": "text/xml", "url": "https://tile.loc.gov/storage-services/service/ndnp/ak/batch_ak_flatheadsole_ver01/data/sn95063172/00414185733/1930120601/0554.xml", "use": ""}, {"height": 359, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_flatheadsole_ver01:data:sn95063172:00414185733:1930120601:0554/full/pct:6.25/0/default.jpg", "width": 261}, {"height": 718, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_flatheadsole_ver01:data:sn95063172:00414185733:1930120601:0554/full/pct:12.5/0/default.jpg", "width": 523}, {"height": 5749, "info": "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_flatheadsole_ver01:data:sn95063172:00414185733:1930120601:0554/info.json", "language": ["english"], "mimetype": "application/json", "reel_number": "00414185733", "section_label": null, "size": 3010245, "title": "Image 1 of The Kusko times (McGrath, Alaska), December 6, 1930", "width": 4189}, {"fulltext_service": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_flatheadsole_ver01/data/sn95063172/00414185733/1930120601/0554.xml&format=alto_xml&full_text=1", "mimetype": "text/plain", "use": "text"}], "pagination": {"current": 1, "first": null, "from": 1, "last": "https://www.loc.gov/resource/sn95063172/1930-12-06/ed-1/?fo=json&sp=3", "next": "https://www.loc.gov/resource/sn95063172/1930-12-06/ed-1/?fo=json&sp=2", "of": 4, "page_list": [{"number": 1, "url": null}, {"number": 2, "url": "https://www.loc.gov/resource/sn95063172/1930-12-06/ed-1/?fo=json&sp=2"}, {"number": 3, "url": "https://www.loc.gov/resource/sn95063172/1930-12-06/ed-1/?fo=json&sp=3"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": null, "results": "1 - 1", "to": 1, "total": 4}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn95063172/1930-11-29/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://library.alaska.gov/asp/edocs/2019/08/on1111581712.pdf", "http://www.loc.gov/item/2019401615/", "http://lccn.loc.gov/2019401615", "https://www.arlis.org/docs/vol1/O/1111581712.pdf"], "campaigns": [], "contributor": ["mikow, elizabeth", "runfola, david michael", "alaska. department of fish and game. division of subsistence", "gonzalez, daniel", "retherford, brittany"], "date": "2019", "dates": ["2019"], "description": ["\"Chinook salmon Oncorhynchus tshawytscha are an integral part of the subsistence diet of residents of the Kuskokwim River. Sharp declines in Chinook salmon abundance began in 2010 and brought severe hardship and unprecedented restrictions to Kuskokwim River fish-dependent communities. This report summarizes local and traditional knowledge (LTK) provided by residents of the communities of Aniak, Sleetmute, Stony River, McGrath, and Nikolai. Ethnographic interviews focused on respondent knowledge of freshwater systems, salmon spawning grounds, juvenile rearing habitats, and other environmental factors that affect salmon spawning migration and reproduction. Researchers worked with respondents to map environmental changes that may have affected salmon movements and spawning locations. Key respondents discussed a number of major themes, including observations of Chinook salmon behavior and environmental change, perspectives on declining Chinook salmon populations, potential causes of the decline, and concerns over management of the fishery. This project documented a rich body of local and traditional knowledge about the middle and upper Kuskokwim River regions.\"-- Source other than Library of Congress."], "digitized": true, "extract_timestamp": "2023-06-02T21:55:53.353Z", "group": ["catalog-split-13", "catalog", "main-catalog-split-13", "main-catalog"], "hassegments": false, "id": "http://lccn.loc.gov/2019401615", "image_url": [], "index": 1, "language": ["english"], "location": ["kuskokwim river", "stony river", "alaska", "mcgrath", "sleetmute", "aniak", "nikolai"], "number": ["n1111581712", "2019401615", "2020-09-04t07:29:30"], "original_format": ["book"], "partof": ["catalog"], "score": 29.024717, "shelf_id": "SH222.A4 M54 2019 SK49 .S93 no.450", "site": ["catalog"], "subject": ["kuskokwim river", "alaska", "stony river", "mcgrath", "salmon", "subsistence fishing", "traditional ecological knowledge", "sleetmute", "aniak", "nikolai"], "timestamp": "2023-07-10T16:18:30.165Z", "title": "Local traditional knowledge of salmon freshwater ecology in the middle and upper Kuskokwim River", "type": ["text"], "url": "//lccn.loc.gov/2019401615"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2023630517/", "http://www.loc.gov/item/2023630517/", "http://www.loc.gov/pictures/item/2023630517/", "https://www.loc.gov/pictures/collection/cph/item/2023630517/", "http://www.loc.gov/pictures/collection/cph/item/2023630517/", "https://hdl.loc.gov/loc.pnp/ppmsca.78013", "https://hdl.loc.gov/loc.pnp/ppmsca.78013", "http://www.loc.gov/resource/ppmsca.78013/", "http://lccn.loc.gov/2023630517"], "campaigns": [], "contributor": ["trikosko, marion s."], "date": "1958-01-01", "dates": ["1958"], "description": ["1 photograph : safety negative ; film width 35mm (roll format)"], "digitized": true, "extract_timest