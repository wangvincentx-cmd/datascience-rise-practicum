e no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.504336, "shard": "02", "shelf_id": "sn95063172, 1930-12-06, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/ak", "source_modified": "2000-01-01T12:00:00Z", "subject": ["alaska", "mcgrath", "takotna", "mcgrath (alaska)", "united states", "takotna (alaska)", "newspapers", "tokotna"], "subject_headings": ["McGrath (Alaska)--Newspapers", "Takotna (Alaska)--Newspapers", "Alaska--McGrath", "United States--Alaska--Takotna", "United States--Alaska--Tokotna", "United States--Alaska--McGrath"], "subjects": [{"alaska": "https://www.loc.gov/search/?fa=subject:alaska&fo=json"}, {"mcgrath": "https://www.loc.gov/search/?fa=subject:mcgrath&fo=json"}, {"mcgrath (alaska)": "https://www.loc.gov/search/?fa=subject:mcgrath+%28alaska%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"takotna": "https://www.loc.gov/search/?fa=subject:takotna&fo=json"}, {"takotna (alaska)": "https://www.loc.gov/search/?fa=subject:takotna+%28alaska%29&fo=json"}, {"tokotna": "https://www.loc.gov/search/?fa=subject:tokotna&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2024-05-22T18:46:43.242Z", "title": "The Kusko times (McGrath, Alaska), December 6, 1930", "type": ["issue"], "url": "https://www.loc.gov/item/sn95063172/1930-12-06/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95063172/", "http://lccn.loc.gov/sn95063172", "https://search.catalog.loc.gov/instances/a61b5ed1-d821-5dc7-837a-9f6c56bdf3ae"], "batch": ["ak_flatheadsole_ver01"], "campaigns": [], "date": "1921", "description": ["Weekly, June 9, 1923-<Dec. 24, 1937> Vol. 1, no. 1 (Jan. 19, 1921)- Published in Tokotna [i.e. Takotna], Alaska, June 9, 1923-<Dec. 24, 1937>. Vol. and issue numbering irregular. Vol. numbering starts over with v. 1, no. 1 with the Oct. 6, 1934 issue and also with the Feb. 5, 1937 issue. Suspended with Apr. 30, 1927 issue; resumed publication with Dec. 10, 1927 issue. Archived issues are available in digital format from the Library of Congress Chronicling America online collection."], "digitized": true, "extract_timestamp": "2026-06-05T18:25:11.512Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-02", "catalog", "united-states-newspaper-directory", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/sn95063172/", "image_url": [], "index": 1, "language": ["english"], "latlong": [62.94937, -155.571992], "location": ["alaska", "mcgrath", "takotna", "united states", "tokotna"], "location_str": "", "lonlat": [-155.571992, 62.94937], "number": ["2025-07-01t13:41:41.700000", "2026-04-13t21:30:13", "sn95063172", "1", "2993-6187", "http://www.loc.gov/item/sn95063172/1921-01-19/ed-1/", "2024-05-12t17:51:13.897021", "online resource", "718", "http://www.loc.gov/item/sn95063172/1937-12-10/ed-1/", "33430620"], "original_format": ["newspaper"], "partof": ["chronicling america", "directory of u.s. newspapers in american libraries", "serial and government publications division", "catalog", "the kusko times (mcgrath, alaska) 1921-19??"], "publication_frequency": ["weekly"], "score": 97.886475, "shelf_id": "Newspaper", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["alaska", "mcgrath", "takotna", "mcgrath (alaska)", "united states", "takotna (alaska)", "newspapers", "tokotna"], "timestamp": "2026-07-18T09:37:35.627Z", "title": "The Kusko times", "type": ["title"], "url": "https://www.loc.gov/item/sn95063172/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270629/"], "campaigns": [], "date": "1921", "dates": ["[1921 TO 1999]"], "description": ["Weekly, June 9, 1923-<Dec. 24, 1937> Began with vol. 1, no. 1 (January 19, 1921). Published in Tokotna [i.e. Takotna], Alaska, June 9, 1923-<Dec. 24, 1937>. Vol. and issue numbering irregular. Vol. numbering starts over with v. 1, no. 1 with the Oct. 6, 1934 issue and also with the Feb. 5, 1937 issue. Suspended with Apr. 30, 1927 issue; resumed publication with Dec. 10, 1927 issue. Vol. 1, No. 1 (January 19, 1921); title from masthead (Chroniclingamerica.loc.gov, viewed July 26, 2023). Vol. 1, No. 42 (December 10, 1937) (Chroniclingamerica.loc.gov, viewed July 26, 2023)."], "digitized": true, "extract_timestamp": "2026-05-19T21:38:10.033Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2023270629/", "image_url": [], "index": 2, "language": ["english"], "location": ["alaska", "mcgrath", "takotna", "united states", "tokotna"], "number": ["2023270629", "2026-04-13t21:30:13", "2993-6195", "online resource", "1391143866"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the kusko times (mcgrath, alaska;takotna, alaska) 1921-19?? [online resource]"], "publication_frequency": ["weekly"], "score": 88.67919, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["alaska", "mcgrath", "takotna", "mcgrath (alaska)", "united states", "takotna (alaska)", "newspapers", "tokotna"], "timestamp": "2026-05-26T21:08:46.277Z", "title": "The Kusko times", "type": ["title"], "url": "https://www.loc.gov/item/2023270629/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn95063172/1926-09-04/ed-1/", "http://www.loc.gov/resource/sn95063172/1926-09-04/ed-1/"], "batch": ["ak_flatheadsole_ver01"], "campaigns": [], "contributor": ["alaska state library historical collections"], "date": "1926-09-04", "dates": ["1926-09-04"], "description": ["McGrath, Alaska"], "digitized": true, "extract_timestamp": "2024-05-22T12:59:01.700Z", "group": ["ndnp/ak", "alaska-state-library-historical-collections-awardee"], "hassegments": true, "id": "http://www.loc.gov/item/sn95063172/1926-09-04/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_flatheadsole_ver01:data:sn95063172:0041418571A:1926090401:1138/full/pct:6.25/0/default.jpg#h=380&w=261", "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_flatheadsole_ver01:data:sn95063172:0041418571A:1926090401:1138/full/pct:12.5/0/default.jpg#h=761&w=522"], "index": 3, "language": ["english"], "location": ["alaska", "mcgrath", "takotna", "united states", "tokotna"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "number": ["0041418571a", "sn95063172", "1"], "numeric_shelf_id": 192609041, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "the kusko times (mcgrath, alaska) 1921-19??", "serial and government publications 