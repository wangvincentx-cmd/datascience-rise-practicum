 the Records and look over our Large Stock of Kodaks CXCCCCCCCOQOOOOOQOOQOOQCyOOOOOCOCOOOOOOOOOOOOO lllllllllllllilllllllllllllillllllllllllllliilllllH illlllllllSlillSlllllil lillllli I HARDWARE I Mr Farmer We wish to call your attention to the fact that spring is now approaching and that we are able to offer you some of the latest improvements for handling your farm and crop We especially call your attention to the fact that we sell J I Case Plowing and Threshing Machinery McMartins Steel Grain Bins any size Geo A Clark Sons Wind Motor Wind Mills and Towers Pumps of all descriptions Harness and Saddlery of all kinds Come in and let us show what we can do We"], "digitized": true, "extract_timestamp": "2023-06-25T23:48:52.823Z", "group": ["ndnp/sdhi", "south-dakota-state-historical-society-state-archives-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn95076637/1911-03-03/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_jamaica_ver01:data:sn95076637:00279523507:1911030301:0155/full/pct:3.125/0/default.jpg#h=274&w=196", "https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_jamaica_ver01:data:sn95076637:00279523507:1911030301:0155/full/pct:6.25/0/default.jpg#h=549&w=392", "https://tile.loc.gov/image-services/iiif/service:ndnp:sdhi:batch_sdhi_jamaica_ver01:data:sn95076637:00279523507:1911030301:0155/full/pct:12.5/0/default.jpg#h=1098&w=785", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/sdhi/batch_sdhi_jamaica_ver01/data/sn95076637/00279523507/1911030301/0155.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["timber lake", "south dakota", "united states", "dewey", "dewey county"], "location_city": ["timber lake"], "location_country": ["united states"], "location_county": ["dewey"], "location_state": ["south dakota"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "image/jpeg", "applicat