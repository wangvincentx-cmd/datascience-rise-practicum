6/1907-11-14/ed-1/?fo=json&sp=2"}, {"number": 3, "url": "https://www.loc.gov/resource/sn87065046/1907-11-14/ed-1/?fo=json&sp=3"}], "perpage": 1, "perpage_options": [25, 50, 100, 150], "previous": null, "results": "1 - 1", "to": 1, "total": 8}, "previous_resource": {"label": "Previous Issue", "url": "https://www.loc.gov/resource/sn87065046/1907-10-31/ed-1/?fo=json&sp=1"}, "related_items": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/2008621633", "http://www.loc.gov/item/2008621633/", "https://search.catalog.loc.gov/instances/761c04b4-de9c-5075-b7e4-d1693ed6ec05", "https://hdl.loc.gov/loc.gmd/g3984c.cw0268000", "http://www.loc.gov/resource/g3984c.cw0268000/"], "campaigns": [], "contributor": ["weyss, j. e.", "michler, n. (nathaniel)"], "date": "1862", "dates": ["1862"], "description": ["Relief shown by hachures. Sun print. Shows Confederate entrenchments in red and Union entrenchments in blue. \"Head Qs. of Genel. Buell,\" roads, railroads, vegetations, drainage, houses, fences, and the names of a few residents in the outlying areas. Description derived from published bibliography. Civil War salted paper maps. AL-37. LC Civil War maps (2nd ed.), 268 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:39:57.538Z", "group": ["gmd.mar", "catalog-split-15", "catalog", "general-maps", "main-catalog-split-15"], "hassegments": false, "id": "http://www.loc.gov/item/2008621633/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd398/g3984/g3984c/cw0268000.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd398/g3984/g3984c/cw0268000.gif#h=150&w=185", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd398:g3984:g3984c:cw0268000/full/pct:12.5/0/default.jpg#h=374&w=461", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd398:g3984:g3984c:cw0268000/full/pct:25/0/default.jpg#h=748&w=922"], "index": 1, "language": ["english"], "location": ["united states", "mississippi", "corinth"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t02:31:31.600000", "2008621633", "sheet", "2018-10-17t12:11:41"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "catalog", "civil war maps"], "score": 34.40121, "shelf_id": "G3984.C8 1862 .M5", "site": ["catalog"], "subject": ["mississippi", "corinth (miss.)", "united states", "salted paper prints", "corinth", "maps"], "timestamp": "2026-04-29T15:55:26.539Z", "title": "Topographical sketch of Corinth, Mississippi and its environs: showing the enemy's entrenchments, and the approach of the U.S. forces", "type": ["cartographic"], "url": "https://www.loc.gov/item/2008621633/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2008621634", "http://www.loc.gov/item/2008621634/", "https://search.catalog.loc.gov/instances/daf2713c-8eaa-5fb1-9fe0-5fc3bab28a5b", "https://hdl.loc.gov/loc.gmd/g3984c.cw0267100", "http://www.loc.gov/resource/g3984c.cw0267100/"], "campaigns": [], "contributor": ["matz, otto h."], "date": "1862", "dates": ["1862"], "description": ["Relief shown by hachures. Includes houses, names of residents, fences, roads, railroads, vegetation, fields, and drainage. Differs from G3984.C8S5 1862 .M3 CW 267: lacks address of lithographer. Description derived from published bibliography. LC Civil War maps (2nd ed.), 267.1 Available also through the Library of Congress Web site as a raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:02.288Z", "group": ["gmd.mar", "catalog-split-00", "catalog", "general-maps", "main-catalog-split-00"], "hassegments": false, "id": "http://www.loc.gov/item/2008621634/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd398/g3984/g3984c/cw0267100.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd398/g3984/g3984c/cw0267100.gif#h=187&w=150", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd398:g3984:g3984c:cw0267100/full/pct:12.5/0/default.jpg#h=1223&w=979", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd398:g3984:g3984c:cw0267100/full/pct:25/0/default.jpg#h=2447&w=1959"], "index": 2, "language": ["english"], "location": ["united states", "mississippi", "corinth"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2025-06-07t02:32:12.600000", "sheet", "2008621634", "2008-02-11t10:03:33"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "catalog", "civil war maps"], "score": 25.283283, "shelf_id": "G3984.C8S5 1862 .M32", "site": ["catalog"], "subject": ["mississippi", "corinth, battle of, corinth, miss", "united states", "corinth", "corinth (miss.), battle of", "maps"], "timestamp": "2026-04-29T15:55:26.539Z", "title": "Map of the country between Monterey, Tenn: & Corinth, Miss: showing the lines of entrenchments made & the routes followed by the U.S. forces under the command of Maj. Genl. Halleck, U.S. Army, in their advance upon Corinth in May 1862:", "type": ["cartographic"], "url": "https://www.loc.gov/item/2008621634/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/99446429", "http://www.loc.gov/item/99446429/", "https://search.catalog.loc.gov/instances/0709221e-0675-56f5-a421-23882e23004a", "https://hdl.loc.gov/loc.gmd/g3984c.cw0269000", "http://www.loc.gov/resource/g3984c.cw0269000/"], "campaigns": [], "contributor": ["theinert, f.", "shraag, f.", "prime, fred. e."], "date": "1862", "dates": ["1862"], "description": ["Relief shown by hachures and pictorially. Pen-and-ink in red and blue. Oriented with north to the bottom. In the right lower corner: Engineer Department, March 3, 1863. Received from Capt. Prime. See his letter of 19 January 1863 (P. 1266). Detailed topographic map showing Union and Confederate fortifications by the colors blue and red respectively, powder magazines, city streets and buildings (both unnamed), rural houses and names of a few residents, fences, roads, railroads, vegetation, drainage, and artesian wells. Copies imperfect: Edges of sheets torn. LC Civil War maps (2nd ed.), 269 Available also through the Library of Congress web site as raster image."], "digitized": true, "extract_timestamp": "2026-04-29T15:40:09.007Z", "group": ["gmd.mar", "catalog-split-15", "catalog", "general-maps", "main-catalog-split-15"], "hassegments": false, "id": "http://www.loc.gov/item/99446429/", "image_url": ["https://tile.loc.gov/storage-services/service/gmd/gmd398/g3984/g3984c/cw0269000.gif", "https://tile.loc.gov/storage-services/service/gmd/gmd398/g3984/g3984c/cw0269000.gif#h=150&w=145", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd398:g3984:g3984c:cw0269000/full/pct:12.5/0/default.jpg#h=3230&w=3129", "https://tile.loc.gov/image-services/iiif/service:gmd:gmd398:g3984:g3984c:cw0269000/full/pct:25/0/default.jpg#h=6460&w=6258"], "index": 3, "language": ["english"], "location": ["united states", "mississippi", "corinth"], "mime_type": ["image/gif", "image/tiff", "image/jpeg", "image/jp2"], "number": ["2009-10-28t17:54:28", "2025-06-06t18:59:54.300000", "sheet", "http://www.loc.gov/item/99446429", "99446429"], "online_format": ["image"], "original_format": ["map"], "partof": ["military battles and campaigns", "geography and map division", "catalog", "civil war maps"], "score": 25.283283, "shelf_id": "G3984.C8S5 1862 .S5", "site": ["catalog"], "subject": ["mississippi", "corinth, battle of, corinth, miss", "maps, manuscript", "united states", "corinth"], "timestamp": "2026-04-29T16:33:39.014Z", "title": "General plan of the field-fortifications around Corinth, Miss. : also exhibiting the rebel entrenchments and the approaches of the U.S. forces during May 1862 under Major Genl. H. W. Halleck, U.S.A.", "type": ["cartographic"], "url": "https://www.loc.gov/item/99446429/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/994