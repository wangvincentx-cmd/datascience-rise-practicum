l_format": ["photo, print, drawing"], "partof": ["farm security administration/office of war information black-and-white negatives", "prints & photographs online catalog (library of congress)", "prints and photographs division", "american memory", "catalog", "lot 504"], "score": 37.51285, "shelf_id": "LC-USF34- 058161-D [P&P] LOT 504  (corresponding photographic print)", "site": ["pictures", "catalog"], "subject": ["montana", "cascade county", "great falls", "united states", "safety film negatives"], "timestamp": "2022-04-25T23:48:10.261Z", "title": "Contour ploughing and strip cropping of wheat fields just north of Great Falls, Montana", "url": "https://www.loc.gov/item/2017807594/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn83045217/00295860728/1921031301/0840.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn83045217:00295860728:1921031301:0803/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn83045217/00295860728/1921031301/0840.pdf", "segment_count": 44, "url": "https://www.loc.gov/resource/sn83045217/1921-03-13/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn83045217/00295860728/1921031301/0840.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn83045217:00295860728:1921031301:0803/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn83045217/00295860728/1921031301/0840.pdf", "segment_count": 44, "url": "https://www.loc.gov/resource/sn83045217/1921-03-13/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn83045217/00295860728/1921031301/0840.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83045217/1921-03-13/ed-1/?sp=38"], "batch": ["mthi_bison_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/cascade/", "3/united states/montana/cascade/great falls/"], "contributor": ["montana historical society; helena, mt"], "date": "1921-03-13", "dates": ["1921-03-13"], "description": ["1 FOR AUTO BUSINESS 0 Importance of Motor Car in Economic and Social Life of Nation Emphasized By H A BIGGS VimPresident Studebaker Corporation The third largest industry in Amer ica and that means the whole world did not attain its place of eminence by mere acident or through any seas onal or faddish demand for the pro duct of its great institutions The automobile both passenger and commercial is an absolute necessity of a new eraand it will continue as a necessity until something newer and better takes its place However up to the present time no one even has an Inkling of something better The great majority of the people realize the economic value of the motor carit would be as impossible to con ceive of personal and business effi ciency without the automobile today as It would be to conceive of handling modern business without fast express trains fast freights telegraphs or long distance telephones The motor car has not only become an essential part of modern life but it has been greatly responsible for the develop ment of the way we live and do busi ness today It has indeed made pos sible the wonderful business"], "digitized": true, "extract_timestamp": "2023-07-03T13:44:49.258Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83045217/1921-03-13/ed-1/?sp=38", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn83045217:00295860728:1921031301:0840/full/pct:6.25/0/default.jpg#h=479&w=399", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_bison_ver01:data:sn83045217:00295860728:1921031301:0840/full/pct:12.5/0/default.jpg#h=959&w=799", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_bison_ver01/data/sn83045217/00295860728/1921031301/0840.xml&format=alto_xml"], "index": 38, "language": ["english"], "location": ["montana", "cascade county", "cascade", "great falls", "united states"], "location_city": ["great falls"], "location_country": ["united states"], "location_county": ["cascade"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["8", "0", "5", "2", "7", "1", "6", "0000000038", "9", "sn83045217"], "number_edition": ["1"], "number_lccn": ["sn83045217"], "number_page": ["0000000038"], "number_reel": ["0", "0", "2", "9", "5", "8", "6", "0", "7", "2", "8"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Tribune"], "partof": ["great falls tribune (great falls, mont.) 1921-current", "chronicling america", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["great falls tribune (great falls, mont.) 1921-current"], "publication_frequency": ["daily"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn83045217/1921-03-13/ed-1/?sp=38"}], "segmentof": ["http://www.loc.gov/resource/sn83045217/1921-03-13/ed-1/"], "shelf_id": "38", "site": ["chroniclingamerica"], "subject": ["newspapers", "montana", "cascade county", "cascade", "great falls (mont.)", "great falls", "cascade county (mont.)", "united stat