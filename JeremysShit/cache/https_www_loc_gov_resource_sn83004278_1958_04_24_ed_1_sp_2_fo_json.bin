d-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_ivy_ver01/data/sn83004278/00340581982/1958042401/0241.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_ivy_ver01:data:sn83004278:00340581982:1958042401:0240/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/mthi/batch_mthi_ivy_ver01/data/sn83004278/00340581982/1958042401/0241.pdf", "segment_count": 16, "url": "https://www.loc.gov/resource/sn83004278/1958-04-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/mthi/batch_mthi_ivy_ver01/data/sn83004278/00340581982/1958042401/0241.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn83004278/1958-04-24/ed-1/?sp=2"], "batch": ["mthi_ivy_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/richland/", "3/united states/montana/richland/sidney/"], "contributor": ["montana historical society; helena, mt"], "date": "1958-04-24", "dates": ["1958-04-24"], "description": ["2 THE STOWET HERALD Thursday April 24 1958 Vk SuLty JJratd C K HCKLI omoAL NxwapAFB or RICHLAND COUNTY MONTANA NAH ON At OJ VOUAI I kfi ASS MH 4M locution Entered at the Postoffice at Sidney Montana as Second Class Matter March 13 1908 under the Act of Mach 3 i78 j i I Published every Thursday at Sidney Richland County Montana SUBSCRIPTION RATES RictilandMcKenne Counties 300 year 3 5o a year in Montana 400 a year outside Montana Single copies 18c Foreign Countries 550 EDITORIALLY NEW SAFETY DEVICE The Ford Motor Company has developed an electronic device which will flash a warning to the driver following too closely behind a car It is an effort to prevent rearend collisions on the part of the automobile com pany and is a promising one A survey in the Detroit area revealed recently that of the many accidents occurring on the Detroit Expressway some 575 of the accidents in 1956 were rearend collisions The new safety device picks up the headlight illumination of the car behind and computes the distance If the car approaches too close the device trips a switch that flashes the red brake signal warning the following driver"], "digitized": true, "extract_timestamp": "2023-07-03T13:47:58.016Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn83004278/1958-04-24/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_ivy_ver01:data:sn83004278:00340581982:1958042401:0241/full/pct:6.25/0/default.jpg#h=458&w=349", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_ivy_ver01:data:sn83004278:00340581982:1958042401:0241/full/pct:12.5/0/default.jpg#h=917&w=698", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/mthi/batch_mthi_ivy_ver01/data/sn83004278/00340581982/1958042401/0241.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["montana", "richland", "united states", "sidney"], "location_city": ["sidney"], "location_country": ["united states"], "location_county": ["richland"], "location_state": ["montana"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["2", "0", "3", "9", "8", "0000000002", "sn83004278", "1", "4", "5"], "number_edition": ["1"], "number_lccn": ["sn83004278"], "number_page": ["0000000002"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "1", "9", "8", "2"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["the sidney herald (sidney, mont.) 1908-19??", "serial and government publications division",