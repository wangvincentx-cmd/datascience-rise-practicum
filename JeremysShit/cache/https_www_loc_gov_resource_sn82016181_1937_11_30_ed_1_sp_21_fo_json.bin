/1937113001/0976.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_bullock_ver01:data:sn82016181:00516999615:1937113001:0956/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/dlc/batch_dlc_bullock_ver01/data/sn82016181/00516999615/1937113001/0976.pdf", "segment_count": 40, "url": "https://www.loc.gov/resource/sn82016181/1937-11-30/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/dlc/batch_dlc_bullock_ver01/data/sn82016181/00516999615/1937113001/0976.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn82016181/1937-11-30/ed-1/?sp=21"], "batch": ["dlc_bullock_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/district of columbia/", "3/united states/district of columbia/washington/"], "contributor": ["library of congress, washington, dc"], "date": "1937-11-30", "dates": ["1937-11-30"], "description": ["It Was F Ds Score but the Tunes Were Herbs and Cals By RAYMOND CLAPPER Something tells me this is the wrong way to put it but it does seem as if in dealing with the business recession Presi dent Roosevelt is growing more like Hoover every day The only excuse for saying it that way at the risk of creating ap prehension among some is to emphasize again that Roosevelt is no revolutionary nor a collectivist but a good friend if a severe critic of the private capitalist sys hmgs tem ass Roosevelts housing message might well ssammg have come from the hand of Hoover him self Here is no Federal scoopshovel spending proposal There isnt a white rabbit in the whole message It is quite dull Roosevelt proposes that the Fed Clapper eral Government give encouragement to private business that it throw its guar I antee behind private construction enter I prises help reduce financing costs and I try to make it more practicable for pri l vate enterprises to engage in largescale housing operations for the mass market He doesnt propose that the Government compete with private enterprise nor supplant it On the con trary he offers"], "digitized": true, "extract_timestamp": "2025-09-28T04:52:14.430Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82016181/1937-11-30/ed-1/?sp=21", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_bullock_ver01:data:sn82016181:00516999615:1937113001:0976/full/pct:6.25/0/default.jpg#h=331&w=227", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_bullock_ver01:data:sn82016181:00516999615:1937113001:0976/full/pct:12.5/0/default.jpg#h=662&w=454", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_bullock_ver01/data/sn82016181/00516999615/1937113001/0976.xml&format=alto_xml"], "index": 21, "language": ["english"], "location": ["district of columbia", "united states", "washington", "washington d.c."], "location_city": ["washington"], "location_country": ["united states"], "location_state": ["district of columbia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["0", "sn82016181", "5", "1", "6", "9", "0000000021"], "number_edition": ["1"], "number_lccn": ["sn82016181"], "number_page": ["0000000021"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "9", "6", "1", "5"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "the washington daily news (washington, d.c.) 1921-1972", "serial and government publications division"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the washington daily news (washington, d.c.) 1921-1972"], "publication_frequency": ["daily"], "resourc