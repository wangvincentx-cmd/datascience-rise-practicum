["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["medford mail tribune (medford, oregon) 1909-1989"], "place_of_publication": "Medford, Oregon", "publication_frequency": ["daily"], "raw_lccn": "sn 97071090 ", "reel_numbers": ["00200298287"], "resources": [{"files": 6, "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:oru:batch_oru_iraryan_ver02:data:sn97071090:00200298287:1913102401:0562/full/pct:6.25/0/default.jpg", "url": "https://www.loc.gov/resource/sn97071090/1913-10-24/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "rights": ["<p>The Library of Congress believes that the newspapers in Chronicling America are in the public domain or have no known copyright restrictions.  Newspapers published in the United States more than 95 years ago are in the public domain in their entirety. Any newspapers in Chronicling America that were published less than 95 years ago are also believed to be in the public domain, but may contain some copyrighted third party materials. Researchers using newspapers published less than 95 years ago should be alert for modern content (for example, registered and renewed for copyright and published with notice) that may be copyrighted.  Responsibility for making an independent legal assessment of an item and securing any necessary permissions ultimately rests with persons desiring to use the item.</p>\n<p>The NEH awardee responsible for producing each digital object is presented in the Chronicling America page display, below the page image  \u2013 e.g. Image produced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.331948, "shard": "06", "shelf_id": "sn97071090, 1913-10-24, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/oru", "source_modified": "2000-01-01T12:00:00Z", "subject": ["jackson", "medford", "medford (or.)", "newspapers", "united states", "oregon"], "subject_headings": ["Medford (Or.)--Newspapers", "Oregon--Medford", "United States--Oregon--Jackson--Medford"], "subjects": [{"jackson": "https://www.loc.gov/search/?fa=subject:jackson&fo=json"}, {"medford": "https://www.loc.gov/search/?fa=subject:medford&fo=json"}, {"medford (or.)": "https://www.loc.gov/search/?fa=subject:medford+%28or.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"oregon": "https://www.loc.gov/search/?fa=subject:oregon&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2026-05-31T20:49:50.376Z", "title": "Medford mail tribune (Medford, Oregon), October 24, 1913, (SECOND EDITION)", "type": ["issue"], "url": "https://www.loc.gov/item/sn97071090/1913-10-24/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn97071090/", "http://lccn.loc.gov/sn97071090", "https://search.catalog.loc.gov/instances/7dedfe23-40ed-57d5-bbec-8e15132f2c53"], "batch": ["oru_hufnagel_ver03"], "campaigns": [], "date": "1909", "description": ["Daily, except Saturday Began with 4th year, no. 193 (November 1, 1909), ceased with 86th year, no. 23 (September 1, 1989). Some issues also have year designation of weekly edition. Also issued on microfilm from University of Oregon. Archived issues are available in digital format as part of the Historic Oregon Newspaper online collection. Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection. Formed by the union of the Medford morning mail, the Southern Oregonian (Medford, Or. : 1908), and the Medford daily tribune. 4th year, no. 193 (November 1, 1909); title from masthead. 86th year, no. 23 (September 1, 1989). Mail tribune (Medford, Or.) (DLC)sn 96061864 (OCoLC)34998867"], "digitized": true, "extract_timestamp": "2026-06-05T18:25:18.050Z", "group": ["newspaper-titles", "ndnp/newspapers", "catalog-split-02", "catalog", "united-states-newspaper-directory", "main-catalog-split-02"], "hassegments": false, "id": "http://www.loc.gov/item/sn97071090/", "image_url": [], "index": 1, "language": ["english"], "latlong": [42.326543, -122.872185], "location": ["jackson", "oregon", "united states", "medford"], "location_str": "", "lonlat": [-122.872185, 42.326543], "number": ["15508981", "2095", "sn97071093", "1", "univ of oregon libr", "2010260128", "http://www.loc.gov/item/sn97071090/1909-11-01/ed-1/", "sn96061864", "sn97071091", "2163-6699", "2026-04-13t21:30:13", "sn97071090", "2010260117", "microfilm master", "microfilm service copy", "2025-07-28t10:51:40.100000", "online resource", "http://www.loc.gov/item/sn97071090/1916-07-31/ed-1/"], "original_format": ["newspaper"], "other_title": ["Mail tribune"], "partof": ["medford mail tribune (medford, oregon) 1909-1989", "directory of u.s. newspapers in american libraries", "catalog", "chronicling america", "serial and government publications division"], "publication_frequency": ["daily"], "score": 57.14161, "shelf_id": "Newspaper AN2 .M4x", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["jackson", "medford", "serial publications", "medford (or.)", "newspapers", "united states", "oregon"], "timestamp": "2026-07-22T08:05:06.533Z", "title": "Medford mail tribune", "type": ["title"], "url": "https://www.loc.gov/item/sn97071090/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2012203858/"], "campaigns": [], "date": "1909", "dates": ["[1909 TO 1989]"], "description": ["Daily, except Saturday Began with 4th year, no. 193 (November 1, 1909); ceased in 86th year, no. 23 (Sep