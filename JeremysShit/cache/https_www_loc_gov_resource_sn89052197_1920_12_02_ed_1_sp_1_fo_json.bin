ndnp:cohi:batch_cohi_floresta_ver01:data:sn89052197:0051368096A:1920120201:0865/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/cohi/batch_cohi_floresta_ver01/data/sn89052197/0051368096A/1920120201/0865.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn89052197/1920-12-02/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/cohi/batch_cohi_floresta_ver01/data/sn89052197/0051368096A/1920120201/0865.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_floresta_ver01:data:sn89052197:0051368096A:1920120201:0865/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/cohi/batch_cohi_floresta_ver01/data/sn89052197/0051368096A/1920120201/0865.pdf", "segment_count": 12, "url": "https://www.loc.gov/resource/sn89052197/1920-12-02/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/cohi/batch_cohi_floresta_ver01/data/sn89052197/0051368096A/1920120201/0865.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn89052197/1920-12-02/ed-1/?sp=1"], "batch": ["cohi_floresta_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/colorado/", "2/united states/colorado/sedgwick/", "3/united states/colorado/sedgwick/julesburg/", "1/united states/nebraska/", "2/united states/nebraska/deuel/", "3/united states/nebraska/deuel/big springs/"], "contributor": ["history colorado"], "date": "1920-12-02", "dates": ["1920-12-02"], "description": ["JULESBURG GRITADVOCATE VOLUME XXII GEOLOGIST HERE MAKING SURVEY OF TERRITORY J W Smiley head geologist for the MidField Oil Co with headquarters at Wray Colo where he is actively engaged in the oil business at Wray has been a Julesburg visitor this week Mr Smiley has been conduct ing investigations near Julesburg rela tive to ascertaining conditions relat ing to the possibilities of there be ing oil in this territory Several local men have accompan jed Mr Smiley in his investigations In our interview with Mr Smiley Wed nesday afternoon he said he was not prepared to make a definite state ment as his investigations here had been only of a preliminary nature However he did state that he is not connected in any manner with any company local or otherwise that had for its purpose the drilling of oil in this locality and that he wished it strictly understood to that effect While Mr Smiley did not divulge to us anything regarding his investi gations here we did gain the infor mation that he was very favorably impressed with this section as to the possibilities of oil He further stated that in the event that a company was organized"], "digitized": true, "extract_timestamp": "2023-12-27T19:00:30.734Z", "group": ["ndnp/cohi", "history-colorado-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn89052197/1920-12-02/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_floresta_ver01:data:sn89052197:0051368096A:1920120201:0865/full/pct:6.25/0/default.jpg#h=324&w=222", "https://tile.loc.gov/image-services/iiif/service:ndnp:cohi:batch_cohi_floresta_ver01:data:sn89052197:0051368096A:1920120201:0865/full/pct:12.5/0/default.jpg#h=648&w=444", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/cohi/batch_cohi_floresta_ver01/data/sn89052197/0051368096A/1920120201/0865.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["big springs", "deuel", "colorado", "united states", "julesburg", "sedgwick", "nebraska"], "location_city": ["julesburg", "big springs"], "location_country": ["united states"], "location_county": ["sedgwick", "deuel"], "location_state": ["colorado", "nebraska"], "mime_type": ["i