907", "dates": ["[1907 TO 1972]"], "description": ["Weekly Began with volume 9, number 1 (November 8, 1907); ceased February 23, 1972. Ovid news appears inside The Julesburg grit-advocate Feb. 18, 1910-Sept. 8, 1910. Big Springs enterprise (Big Springs, Neb.) appears inside The Julesburg grit-advocate June 5, 1963-Feb. 23, 1972. Available on microfilm from the Colorado Historical Society. Volume 9, Number 1 (November 8, 1907); title from masthead (Chroniclingamerica.loc.gov, viewed December 29, 2022). Twenty-Fifth Year, Number 17 (January 31, 1924) (Chroniclingamerica.loc.gov, viewed December 29, 2022). Julesburg advocate"], "digitized": true, "extract_timestamp": "2026-05-19T21:38:07.851Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2022270802/", "image_url": [], "index": 2, "language": ["english"], "location": ["big springs", "deuel", "colorado", "united states", "julesburg", "sedgwick", "nebraska"], "number": ["online resource", "2835-6780", "1356480131", "2022270802", "2026-04-13t21:30:13", "2022270803"], "original_format": ["newspaper"], "other_title": ["Ovid news", "Big Springs enterprise", "Julesburg grit advocate and Big Springs enterprise"], "partof": ["serial and government publications division", "directory of u.s. newspapers in american libraries", "the julesburg grit-advocate (julesburg, colorado) 1907-1972 [online resource]"], "publication_frequency": ["weekly"], "score": 95.88472, "shelf_id": "ISSN RECORD", "site": ["usnd"], "subject": ["julesburg", "big springs", "newspapers", "deuel", "colorado", "united states", "julesburg (colo.)", "sedgwick", "nebraska"], "timestamp": "2026-05-26T21:06:42.779Z", "title": "The Julesburg grit-advocate", "type": ["title"], "url": "https://www.loc.gov/item/2022270802/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2024271113/"], "campaigns": [], "date": "1867", "dates": ["[1867 TO 1899]"], "description": ["Semiweekly, <1867