9046A/1914020601/0057.pdf", "segment_count": 8, "url": "https://www.loc.gov/resource/sn87093220/1914-02-06/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/wa/batch_wa_hoh_ver01/data/sn87093220/0020029046A/1914020601/0057.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/sn87093220/1914-02-06/ed-1/?sp=1"], "batch": ["wa_hoh_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/washington/", "2/united states/washington/grays harbor/", "3/united states/washington/grays harbor/aberdeen/"], "contributor": ["washington state library; olympia, wa"], "date": "1914-02-06", "dates": ["1914-02-06"], "description": ["TWENTYEIGHTH YEAR FORMER BLUNDER CAUSES TROUBLE Mayor France Opposes The Payment of Local Damages From The General Fund TERRACE HEIGHTS MIXUP Several Contracts Awarded By City Council Fill Dist rict No 2 Held Up A blunder of the city in the im provement of Terrace Heights streets enlivened the city council meeting Wednesday night and bids fair to involve the city in costly litgation before the matter is settled Owing to the grades several suits for dam ages are in sight and the council passed an ordinance creating a spec ial improvement district embracing the property affected which should bo assessed to cover such damages Fraser moved to recind the ordi nance to which Pearsall objected raising a point of order that Fraser being an interested party was dis qualified to vote The vote stood seven to five to recind and Mayor France held that a twothirds Vote would be necessary to recind th ordinance and unhesitantly stated that he was and would be opposed to saddling any cost of improving this distriot on the general fund and an nounced that he would veto the ordinance upon its passage It will require a twothirds vote to pass th ordinance over"], "digitized": true, "extract_timestamp": "2024-04-26T11:27:02.359Z", "group": ["ndnp/wa", "washington-state-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn87093220/1914-02-06/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:wa:batch_wa_hoh_ver01:data:sn87093220:0020029046A:1914020601:0057/full/pct:6.25/0/default.jpg#h=451&w=334", "https://tile.loc.gov/image-services/iiif/service:ndnp:wa:batch_wa_hoh_ver01:data:sn87093220:0020029046A:1914020601:0057/full/pct:12.5/0/default.jpg#h=902&w=668", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wa/batch_wa_hoh_ver01/data/sn87093220/0020029046A/1914020601/0057.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["aberdeen", "grays harbor", "washington", "united states"], "location_city": ["aberdeen"], "location_country": ["united states"], "location_county": ["grays harbor"], "location_state": ["washington"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["9", "a", "1", "2", "sn87093220", "4", "0000000001", "0", "6"], "number_edition": ["1"], "number_lccn": ["sn87093220"], "number_page": ["0000000001"], "number_reel": ["0", "0", "2", "0", "0", "2", "9", "0", "4", "6", "a"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["serial and government publications division", "chronicling america", "aberdeen herald (aberdeen, chehalis county, w.t.) 1886-1917"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["aberdeen herald (aberdeen, chehalis county, w.t.) 1886-1917"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn87093220/1914-02-06/ed-1/?sp=1"}], "segmentof": ["http://www.loc.gov/resource/sn87093220/1914-02-06/ed-1/"], "shelf_id": "1", "site": ["chroniclingamerica"], "subject": ["grays harbor", "washington", "aberdeen", "newspape