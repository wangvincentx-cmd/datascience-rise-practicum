composite_location": ["0/united states/", "1/united states/montana/", "2/united states/montana/chouteau/", "3/united states/montana/chouteau/fort benton/"], "contributor": ["montana historical society; helena, mt"], "date": "1907-10-23", "dates": ["1907-10-23"], "description": ["O There Is 17o Financial Panic in Sight Py LESLIE M SHAW Former Secretary of the Treasury UK farms produce mure than 0500000000 per an num ami TILE PROSPECT IS GOOD for an av erage crop Our mines yield more than 1500000 000 and our forests more than 1000000000 And neither of these sources of wealth has been exhausted The output of our factories in other than food prod ucts is approximately 12000000000 and no fires have been extin guished The railways earn more than 2000000000 and THEY ABE ALL IN SUCCESSFUL OPERATION The payrolls of our facto ries and railways aggregate approximately 3500000000 and the scale of wages has not been reduced IN OTHER WORD8 THE REAL 80URCES OF THE PEOPLE8 WEALTH HAVE NOT YET BEEN AFFECTED AND THE ABILITY OF INDUSTRIAL CONCERN8 TO PAY DIVIDENDS 18 NOT MEA8URED BY THE MARKET PRICE OF THEIR STOCKS I n By HENRY C FRICK of the United States Steel Corporation I FIND NOTHING IN UNDERLYING CONDITIONS TO WARRANT THE APPARENT GREAT LACK OF CONFIDENCE IN BUSINESS GEN ERALLY WHICH NOW 8EEM8 PREVALENT IF THERE 18 ANY THING TO JUSTIFY THAT FEELING IN TRADE CONDITIONS I DO NOT SEE IT I can"], "digitized": true, "extract_timestamp": "2023-07-03T13:45:18.514Z", "group": ["ndnp/mthi", "montana-historical-society-helena-mt-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn85053157/1907-10-23/ed-1/?sp=8", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_crane_ver01:data:sn85053157:0029586087A:1907102301:0363/full/pct:6.25/0/default.jpg#h=456&w=317", "https://tile.loc.gov/image-services/iiif/service:ndnp:mthi:batch_mthi_crane_ver01:data:sn85053157:0029586087A:1907102301:0363/full/pct:12.5/0/default.jpg#h=912&w=635", "https://tile