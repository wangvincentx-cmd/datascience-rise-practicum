te": "2024", "dates": ["2024"], "description": ["\"In recent years, the Willwood Irrigation District has performed several studies to identify areas of concern throughout the canal system.  These include the Willwood dam, several drop structures and chutes, and sections of canal reaches.  The identified facilities need rehabilitation to continue to service the Willwood Irrigation District (WID). This report provides a description of the proposed rehabilitation.\" Page 5"], "digitized": true, "extract_timestamp": "2025-09-30T15:01:16.732Z", "group": ["catalog-split-15", "catalog", "main-catalog-split-15"], "hassegments": false, "id": "http://lccn.loc.gov/2024438404", "image_url": [], "index": 2, "language": ["english"], "location": ["park", "wyoming", "park county"], "number": ["1483681773", "2025-07-10t17:35:39.200000", "2024438404"], "original_format": ["book"], "other_title": ["Willwood Irrigation District"], "partof": ["catalog"], "score": 38.219807, "shelf_id": "TC557.W8 J83 2024", "site": ["catalog"], "subject": ["wyoming", "park county", "park", "barrages", "maintenance and repair", "entretien et r\u00e9parations", "irrigation", "dams"], "timestamp": "2025-09-30T16:33:33.936Z", "title": "Willwood Irrigation District. Level II study", "type": ["text"], "url": "//lccn.loc.gov/2024438404"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2025465678", "http://www.loc.gov/item/2025465678/", "https://search.catalog.loc.gov/instances/34f3a88f-72b8-4e4d-9672-9bd9406cb4b3", "https://wyomingdigitalcollections.ptfs.com/aw-server/rest/product/purl/WSL/i/65c32d32-d03a-4f0c-8c64-f96bc469d22f", "https://wyomingdigitalcollections.ptfs.com/aw-server/rest/product/purl/WSL/i/5d795147-9591-48ae-961d-2f5644d8ea58"], "campaigns": [], "contributor": ["wyoming water development commission", "lakeview irrigation district", "engineering associates (cody, wyo.)"], "date": "2025", "dates": ["2025"], "description": ["\"The purpose of this study was centered around two main tasks, seepage analysis of specified sections of the Lakeview Irrigation District\u2019s (LID) main canal and the evaluation of a potential water exchange with the Cody Canal Irrigation District (CCID).\"- page 1"], "digitized": true, "extract_timestamp": "2025-12-13T19:53:25.457Z", "group": ["catalog-split-13", "catalog", "main-catalog-split-13"], "hassegments": false, "id": "http://lccn.loc.gov/2025465678", "image_url": [], "index": 3, "language": ["english"], "location": ["park", "wyoming", "park county"], "number": ["1542849589", "2025-12-03t12:00:03.900000", "2025465678"], "original_format": ["book"], "partof": ["catalog"], "score": 38.219807, "shelf_id": "http://lccn.loc.gov/2025465678", "site": ["catalog"], "subject": ["exploitation", "wyoming", "park county", "park", "ressources en eau", "water resources development", "irrigation"], "timestamp": "2025-12-13T20:48:03.690Z", "title": "Lakeview irrigation district rehabilitation: Level II study", "type": ["text"], "url": "//lccn.loc.gov/2025465678"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2017884773", "http://www.loc.gov/item/2017884773/", "https://hdl.loc.gov/loc.pnp/highsm.48142", "http://www.loc.gov/resource/highsm.48142/", "https://www.loc.gov/pictures/item/2017884773/", "http://www.loc.gov/pictures/item/2017884773/", "https://www.loc.gov/pictures/collection/highsm/item/2017884773/", "http://www.loc.gov/pictures/collection/highsm/item/2017884773/"], "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2015-01-01", "dates": ["2015"], "description": ["Title, date and keywords based on information provided by the photographer. This was one of ten internment camps for Japanese Americans evicted in the American West during World War II by executive order of President Franklin Roosevelt after the bombing of Pearl Harbor, Hawaii, by Japanese planes in December 1941 This had been an irrigation project sit. Construction of 650 military-style barracks and surrounding guard towers began in June 1942, and the camp opened on August 11. Gift; Carol M. Highsmith Photography, Inc.; 2017; (DLC/PP-2002:038-13). Forms part of: Gates Frontiers Fund Wyoming Collection within the Carol M. Highsmith Archive. Credit line: Gates Frontiers Fund Wyoming Collection within the Carol M. Highsmith Archive, Library of Congress, Prints and Photographs Division."], "digitized": true, "extract_timestamp": "2022-08-02T12:47:07.843Z", "group": ["catalog", "highsm", "catalog-split-15", "main-catalog", "carol-m-highsmith", "main-catalog-split-15"], "hassegments": false, "id": "http://www.loc.gov/item/2017884773/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48142/full/pct:3.125/0/default.jpg#h=178&w=267", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48142/full/pct:6.25/0/default.jpg#h=356&w=534", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48142/full/pct:12.5/0/default.jpg#h=712&w=1068", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48142/full/pct:25/0/default.jpg#h=1424&w=2137"], "index": 4, "language": ["english"], "location": ["united states", "wyoming", "park county"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2018-02-23t13:33:41", "2022-05-25t13:59:46", "http://www.loc.gov/item/hig2018005820", "http://www.loc.gov/item/2017884773", "http://www.loc.gov/item/20373334", "2017884773", "online resource"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["highsmith (carol m.) archive", "catalog", "prints and photographs division", "prints & photographs online catalog (library of congress)"], "score": 23.705465, "shelf_id": "LC-DIG-highsm- 48142", "site": ["catalog", "pictures"], "subject": ["digital photographs", "japanese-american internment camps", "park county", "america", "smokestacks", "united states", "heart mountain relocation center", "color", "wyoming"], "timestamp": "2022-08-02T12:50:46.415Z", "title": "Hospital's boiler house and smokestack at the onetime Heart Mountain Relocation Center in Park County, Wyoming", "type": ["still image"], "url": "https://www.loc.gov/item/2017884773/"}, {"access_restricted": false, "aka": ["https://www.loc.gov/pictures/item/2017884766/", "http://www.loc.gov/item/2017884766/", "http://www.loc.gov/pictures/item/2017884766/", "https://www.loc.gov/pictures/collection/highsm/item/2017884766/", "http://www.loc.gov/pictures/collection/highsm/item/2017884766/", "http://www.loc.gov/resource/highsm.48135/", "https://hdl.loc.gov/loc.pnp/highsm.48135", "http://lccn.loc.gov/2017884766"], "campaigns": [], "contributor": ["highsmith, carol m."], "date": "2015-01-01", "dates": ["2015"], "description": ["1 photograph : digital, tiff file, color."], "digitized": true, "extract_timestamp": "2021-08-30T23:03:55.980Z", "group": ["highsm", "catalog-split-01", "catalog", "carol-m-highsmith", "main-catalog-split-01", "main-catalog"], "hassegments": false, "id": "http://www.loc.gov/item/2017884766/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48135/full/pct:3.125/0/default.jpg#h=181&w=271", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48135/full/pct:6.25/0/default.jpg#h=362&w=543", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48135/full/pct:12.5/0/default.jpg#h=724&w=1086", "https://tile.loc.gov/image-services/iiif/service:pnp:highsm:48100:48135/full/pct:25/0/default.jpg#h=1448&w=2172"], "index": 5, "language": ["english"], "location": ["united states", "wyoming", "park county"], "mime_type": ["image/gif", "image/jpg", "image/tif"], "number": ["2018-02-23t13:33:21", "2017884766", "http://www.loc.gov/item/2017884766", "online resource", "http://www.loc.gov/item/20373326", "http://www.loc.gov/item/hig2018005813"], "online_format": ["image"], "original_format": ["photo, print, drawing"], "partof": ["highsmith (carol m.) archive", "prints & photographs online catalog (library of congress)