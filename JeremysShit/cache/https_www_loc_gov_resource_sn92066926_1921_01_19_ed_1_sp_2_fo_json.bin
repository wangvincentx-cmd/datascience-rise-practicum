rue, "extract_timestamp": "2023-05-31T13:48:27.162Z", "group": ["ndnp/wyu", "university-of-wyoming-libraries"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92066926/1921-01-19/ed-1/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_afton_ver01:data:sn92066926:00340588083:1921011901:0934/full/pct:6.25/0/default.jpg#h=348&w=240", "https://tile.loc.gov/image-services/iiif/service:ndnp:wyu:batch_wyu_afton_ver01:data:sn92066926:00340588083:1921011901:0934/full/pct:12.5/0/default.jpg#h=697&w=481", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/wyu/batch_wyu_afton_ver01/data/sn92066926/00340588083/1921011901/0934.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["park county", "park", "united states", "big horn county", "wyoming"], "location_country": ["united states"], "location_county": ["park"], "location_state": ["wyoming"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["5", "3", "0", "sn92066926", "1", "4", "8", "0000000002"], "number_edition": ["1"], "number_lccn": ["sn92066926"], "number_page": ["0000000002"], "number_reel": ["0", "0", "3", "4", "0", "5", "8", "8", "0", "8", "3"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "partof": ["chronicling america", "serial and government publications division", "the northern wyoming herald (cody, wyo.) 1916-1924"], "partof_collection": ["chronicling america"], "partof_division": ["serial and government publications division"], "partof_title": ["the northern wyoming herald (cody, wyo.) 1916-1924"], "publication_frequency": ["weekly"], "resources": [{"files": 1, "url": "https://www.loc.gov/resource/sn92066926/1921-01-19/ed-1/?sp=2"}], "segmentof": ["http://www.loc.gov/resource/sn92066926/1921-01-19/ed-1/"], "shelf_id": "2", "site": ["chroniclingamerica"], "subject": ["park county", "park", 