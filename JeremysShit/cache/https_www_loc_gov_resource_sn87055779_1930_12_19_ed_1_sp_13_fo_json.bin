y of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.332207, "shard": "07", "shelf_id": "sn87055779, 1930-12-19, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/in", "source_modified": "2000-01-01T12:00:00Z", "subject": ["saint joseph", "united states", "south bend", "south bend (ind.)", "newspapers", "indiana"], "subject_headings": ["South Bend (Ind.)--Newspapers", "Indiana--South Bend", "United States--Indiana--Saint Joseph--South Bend"], "subjects": [{"indiana": "https://www.loc.gov/search/?fa=subject:indiana&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"saint joseph": "https://www.loc.gov/search/?fa=subject:saint+joseph&fo=json"}, {"south bend": "https://www.loc.gov/search/?fa=subject:south+bend&fo=json"}, {"south bend (ind.)": "https://www.loc.gov/search/?fa=subject:south+bend+%28ind.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2024-05-19T01:38:48.089Z", "title": "South Bend news-times (South Bend, Ind.), December 19, 1930", "type": ["issue"], "url": "https://www.loc.gov/item/sn87055779/1930-12-19/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn87055779/", "http://lccn.loc.gov/sn87055779"], "batch": ["in_chapel_ver01"], "campaigns": [], "date": "1913", "description": ["Daily Vol. 30, no. 155 (June 2, 1913)-v. 55, no. 361 (Dec. 27, 1938). Archived issues are available in digital format from the Library of Congress Chronicling America online collection."], "digitized": true, "extract_timestamp": "2026-06-05