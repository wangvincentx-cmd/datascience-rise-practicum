ption Rates tingle Copy fbrae Months A1 tt MonthsTSl jDt Year I11 PHONE NO S Published Wednesday Afternoon at Pom fret and Canal Streets WEDNESDAY NOVEMBER 19 193C 1931 CHEVROLET ON DISPLAY AT PUTNAM BUICK HERALDED AS THE GREAT AMERICAN VALUE Prices On The New Cart Are The Lowest Chevrolets Have Ever Been Sold Chevrolets new cgr for 1931 priced substantially below current levels in now on display throughout the nation Heralded as The Treat American Value the new car boasts a twoinch increase in wheelbase larger and roomier bodies by Fisher with mohair or broadcloth as optional trimming and scores of refinements In appear ance and performance despite the new prices which bring the level for the 1931 car to a far lower figure than any Chevrolet four or six has ever sold Dealers throughout the United States put the new models on exhibi tion this morning for the first time nearly two months in advance of the customary date for the showing of the annual new car This move in"], "digitized": true, "extract_timestamp": "2023-09-09T22:54:59.007Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92051419/1930-11-19/ed-2/?sp=2", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_duracell_ver01:data:sn92051419:00517173733:1930111902:0526/full/pct:6.25/0/default.jpg#h=465&w=345", "https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_duracell_ver01:data:sn92051419:00517173733:1930111902:0526/full/pct:12.5/0/default.jpg#h=931&w=690", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ct/batch_ct_duracell_ver01/data/sn92051419/00517173733/1930111902/0526.xml&format=alto_xml"], "index": 2, "language": ["english"], "location": ["putnam", "connecticut", "windham", "windham county", "united states"], "location_city": ["putnam"], "location_country": ["united states"], "location_county": ["windham"], "location_state": ["connecticut"]