ss. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 13.167577, "shard": "09", "shelf_id": "sn84036287, 1938-01-07, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/mthi", "source_modified": "2000-01-01T12:00:00Z", "subject": ["carbon", "montana", "periodicals", "red lodge", "united states", "red lodge (mont.)"], "subject_headings": ["Red Lodge (Mont.)--Periodicals", "Montana--Red Lodge", "United States--Montana--Carbon--Red Lodge"], "subjects": [{"carbon": "https://www.loc.gov/search/?fa=subject:carbon&fo=json"}, {"montana": "https://www.loc.gov/search/?fa=subject:montana&fo=json"}, {"periodicals": "https://www.loc.gov/search/?fa=subject:periodicals&fo=json"}, {"red lodge": "https://www.loc.gov/search/?fa=subject:red+lodge&fo=json"}, {"red lodge (mont.)": "https://www.loc.gov/search/?fa=subject:red+lodge+%28mont.%29&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2023-07-05T17:45:41.274Z", "title": "Carbon County news (Red Lodge, Mont.), January 7, 1938", "type": ["issue"], "url": "https://www.loc.gov/item/sn84036287/1938-01-07/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn84036287/", "http://lccn.loc.gov/sn84036287", "https://search.catalog.loc.gov/instances/3c214411-5b0a-520f-9da5-8f94d65b7a56"], "batch": ["mthi_clarkia_ver01"], "campaigns": [], "date": "1936", "description": ["Weekly, Sept. 7, 1950- Vol. 13, no. 10 (May 8, 1936)- \"Official paper of Carbon County,\" 1936-Mar. 1939; 1943-July 1945; 1951- \"Official paper of City of Red Lodge,\" 1936-July 1945; 1951- Arc