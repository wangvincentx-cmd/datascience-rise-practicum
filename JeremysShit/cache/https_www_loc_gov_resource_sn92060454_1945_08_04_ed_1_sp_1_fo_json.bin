ss_restricted": false, "aka": ["http://www.loc.gov/resource/sn92060454/1945-08-04/ed-1/?sp=1"], "batch": ["ct_aetna_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/connecticut/", "2/united states/connecticut/new haven/", "3/united states/connecticut/new haven/new haven/"], "contributor": ["connecticut state library, hartford, ct"], "date": "1945-08-04", "dates": ["1945-08-04"], "description": ["Wit Union tEnne Official Weekly Labor Organ Voicing The Interests Of The American Federation of Labor FIGHT th Mar MARKET MB WE PLEDGE 1 BULLION DOLLARS IN WAR SAVINGS BONDS VOT XT 1 Entered as Second Class Matter May 5 1941 at the Post Office 1NO 1J at few Haven Conn under the Act of March 3 1879 NEW HAVEN CONN SATURDAY AUGUST 4 1945 asB i AFL NEWS SERVICE PRICE 5 CENTS British Vote Cited At Tull Work Hearing Conn Job Insurance Cuts Vacation Pay Unusual Ruling Prompts Appeal ByGarmentUnion State Department Regards Vacation Fund Benefits As Compensation For Loss Of Wages Approximately 6000 mem bers of the International Ladies Garment Workers Union and thousands of work ers in other industries in Con necticut are being deprived of unemployment benefits through an unusual interpre tation of the states unemploy ment compensation law which regards vacation fund benefits as compensation for loss of wages The union made these charged at hearings before the Assistant Attorney General of Connecticut held in Hartford The union was represented at the hearings by Sam Janis 1LGWU organizer in the area and by Grace Milgram a member of the unions Research Department DIFFERENT IN OTHER"], "digitized": true, "extract_timestamp": "2023-06-01T13:39:28.211Z", "group": ["ndnp/ct", "connecticut-state-library-hartford-ct-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn92060454/1945-08-04/ed-1/?sp=1", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ct:batch_ct_aetna_ver02:data:sn92060454:00393346759:1945080401:0130/ful