 "2024-05-25t20:25:50.256555", "baylor univ", "2993-9143", "2025-07-01t13:40:25.700000", "kansas state hist soc, newsp proj", "virginia historical society library", "online resource", "2685433", "wisconsin hist soc, newsp proj", "western rsv hist soc, newsp proj", "duke univ libr", "library of congress", "sn86050480", "univ of kentucky libr", "sn84023567", "original", "center for res libr, newsp proj", "panhandle-plains hist mus"], "original_format": ["newspaper"], "other_title": ["Saturday morning", "Montgomery advertiser and Alabama journal", "Montgomery advertiser/Alabama journal", "Daily advertiser"], "partof": ["directory of u.s. newspapers in american libraries", "the montgomery advertiser (montgomery, ala.) 1885-1982", "serial and government publications division", "catalog", "chronicling america"], "publication_frequency": ["daily"], "score": 61.58259, "shelf_id": "Newspaper AN", "site": ["chroniclingamerica", "usnd", "catalog"], "subject": ["montgomery", "montgomery county", "united states", "alabama", "newspapers", "montgomery county (ala.)", "montgomery (ala.)"], "timestamp": "2026-07-18T09:08:35.698Z", "title": "The Montgomery advertiser", "type": ["title"], "url": "https://www.loc.gov/item/sn84020645/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2013254326/"], "campaigns": [], "date": "1898", "dates": ["[1898 TO 1999]"], "description": ["Weekly Print began in 1898. Description based on: Volume 2, no. 20 (January 26, 1900); title from PDF masthead (Readex America's Historical Newspapers Web site, viewed May 22, 2013). Latest issue consulted: Volume 2, no. 20 (January 26, 1900) (viewed May 22, 2013)."], "digitized": true, "extract_timestamp": "2026-05-19T21:37:21.057Z", "group": ["ndnp/newspapers", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/2013254326/", "image_url": [], "index": 13, "language": ["english"], "location": ["alabama", "united states", "montgomery", "montgomery county"], "number": ["844394869", "online resource", "2835-6462", "2026-04-13t21:30:13", "2013254326"], "original_format": ["newspaper"], "other_title": ["Enterprise"], "partof": ["directory of u.s. newspapers in american libraries", "the montgomery enterprise (montgomery, ala.) 1898-19?? [online resource]", "serial and government publications division"], "publication_frequency": ["weekly"], "score": 52.468407, "shelf_id": "ISSN RECORD AN", "site": ["usnd"], "subject": ["montgomery", "african american", "african americans", "montgomery county", "united states", "alabama", "newspapers", "african american newspapers", "montgomery county (ala.)", "montgomery (ala.)"], "timestamp": "2026-05-26T20:48:57.173Z", "title": "The Montgomery enterprise", "type": ["title"], "url": "https://www.loc.gov/item/2013254326/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/2023270666/"], "campaigns": [], "date": "1885", "dates": ["[1885 TO 1982]"], "description": ["Daily Print began with new ser. v. 21, no. 24 (Aug. 16, 1885); ceased November 21, 1982. On Saturday published as: Saturday morning, Apr. 2, 1977-Apr. 1, 1978; The Montgomery advertiser/Alabama journal, Apr. 8, 1978-Nov. 20, 1982. On Sunday published as: Montgomery advertiser and Alabama journal, Dec. 1, 1940-Nov. 21, 1982. Publisher varies: Screws, Cory & Glass, August 16, 1885-; The Advertiser Co., <1887-1909> Numbering is irregular. New series, vol. 35, no. 323 (July 19, 1900) followed by vol. 71, no. 168 (July 20, 1900). Issues for Aug 16, 1885-July 19, 1899 called also old series v. 54-v. 68. Also issued on microfilm from the University of Alabama Library, and the Library of Congress, Photoduplication Services. Weekly eds.: Montgomery weekly advertiser, and: Weekly advertiser (Montgomery, Ala.), and: Montgomery advertiser (Montgomery, Ala. : Weekly). Volume LXXII, Number 125 (June 1, 1901); title from mashead (Chroniclingamerica.loc.gov, viewed August 10, 2023). Volume LXXX, Number 365 (December 31, 1909) (Chronicling