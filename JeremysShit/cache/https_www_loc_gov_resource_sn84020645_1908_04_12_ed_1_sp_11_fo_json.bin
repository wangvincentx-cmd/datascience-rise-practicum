NP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.141635, "shard": "05", "shelf_id": "sn84020645, 1908-04-12, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/au", "subject": ["montgomery", "montgomery county", "united states", "alabama", "newspapers", "montgomery county (ala.)", "montgomery (ala.)"], "subject_headings": ["Montgomery (Ala.)--Newspapers", "Montgomery County (Ala.)--Newspapers", "Alabama--Montgomery", "Alabama--Montgomery County", "United States--Alabama--Montgomery--Montgomery"], "subjects": [{"alabama": "https://www.loc.gov/search/?fa=subject:alabama&fo=json"}, {"montgomery": "https://www.loc.gov/search/?fa=subject:montgomery&fo=json"}, {"montgomery (ala.)": "https://www.loc.gov/search/?fa=subject:montgomery+%28ala.%29&fo=json"}, {"montgomery county": "https://www.loc.gov/search/?fa=subject:montgomery+county&fo=json"}, {"montgomery county (ala.)": "https://www.loc.gov/search/?fa=subject:montgomery+county+%28ala.%29&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2022-11-23T04:02:17.537Z", "title": "The Montgomery advertiser (Montgomery, Ala.), April 12, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn84020645/1908-04-12/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://www.loc.gov/item/sn83025485/1900-01-26/ed-1/", "http://www.loc.gov/resource/sn83025485/1900-01-26/ed-1/"], "batch": ["dlc_jean_ver01"], "campaigns": [], "contributor": ["library of congress, washington, dc"], "date": "1900-01-26", "dates": ["1900-01-26"], "description": ["Montgomery, Ala."], "digitized": true, "extract_timestamp": "2023-08-07T20:32:31.197Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8"], "hassegments": true, "id": "http://www.loc.gov/item/sn83025485/1900-01-26/ed-1/", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_jean_ver01:data:sn83025485:00220720457:1900012601:0001/full/pct:3.125/0/default.jpg#h=280&w=180", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_jean_ver01:data:sn83025485:00220720457:1900012601:0001/full/pct:6.25/0/default.jpg#h=560&w=361", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_jean_ver01:data:sn83025485:00220720457:1900012601:0001/full/pct:12.5/0/default.jpg#h=1120&w=722"], "index": 11, "language": ["english"], "location": ["alabama", "united states", "montgomery", "montgomery county"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg"], "number": ["1", "sn83025485", "00220720457"], "numeric_shelf_id": 190001261, "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "other_title": ["Enterprise"], "partof": ["serial and government publications division", "the montgomery enterprise (montgomery, ala.) 1898-1???", "chronicling america"], "publication_frequency": ["weekly"], "score": 64.37011, "shelf_id": "sn83025485, 1900-01-26, Edition 1", "site": ["chroniclingamerica"], "subject": ["montgomery", "african american", "african americans", "montgomery county", "united states", "alabama", "newspapers", "african american newspapers", "montgomery county (ala.)", "montgomery (ala.)"], "timestamp": "2023-08-08T11:12:37.199Z", "title": "The Montgomery enterprise (Montgomery, Ala.), January 26, 1900", "type": ["issue"], "url": "https://www.loc.gov/item/sn83025485/1900-01-26/ed-1/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/item/sn84020645/", "http://lccn.loc.gov/sn84020645", "https://search.catalog.loc.gov/instances/f