rvice", "horses", "equipment & supplies", "post office dept", "united states", "photographic prints", "alaska"], "timestamp": "2022-11-29T19:58:42.993Z", "title": "Horses pulling U.S. Mail sled", "type": ["still image"], "url": "https://www.loc.gov/item/99614288/"}], "resource": {"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_iceworm_ver02/data/2018270506/0027952696A/1908060101/0042.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_iceworm_ver02:data:2018270506:0027952696A:1908060101:0012/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ak/batch_ak_iceworm_ver02/data/2018270506/0027952696A/1908060101/0042.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/2018270506/1908-06-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}, "resources": [{"fulltext_file": "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_iceworm_ver02/data/2018270506/0027952696A/1908060101/0042.xml&format=alto_xml&full_text=1", "image": "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_iceworm_ver02:data:2018270506:0027952696A:1908060101:0012/full/pct:6.25/0/default.jpg", "pdf": "https://tile.loc.gov/storage-services/service/ndnp/ak/batch_ak_iceworm_ver02/data/2018270506/0027952696A/1908060101/0042.pdf", "segment_count": 32, "url": "https://www.loc.gov/resource/2018270506/1908-06-01/ed-1/", "word_coordinates": "https://tile.loc.gov/text-services/word-coordinates-service"}], "segment_id": "/service/ndnp/ak/batch_ak_iceworm_ver02/data/2018270506/0027952696A/1908060101/0042.xml", "segments": [{"access_restricted": false, "aka": ["http://www.loc.gov/resource/2018270506/1908-06-01/ed-1/?sp=31"], "batch": ["ak_iceworm_ver02"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/alaska/", "2/united states/alaska/nome/", "3/united states/alaska/nome/nome/"], "contributor": ["alaska state library historical collections"], "date": "1908-06-01", "dates": ["1908-06-01"], "description": ["NOME BANK TRUST CO In September 190G the Nome Bank Trust Co with a paidup capital of 135000 began doing a general bank ing business which has since increased until now it ranks as one of the largest financial institutions north of Puget Sound It was incorporated by men who have practically made their fortunes in Alas ka and as the shareholders are mostly Nome people it is a purely local bank and one which this district might well feel proud of Although the financial panic that oc curred in the States last fall more or less affected business in Alaska this institution has continued to increase their volume of business which is now double what it was a year ago A modern and uptodate assay office is conducted in connection with the bank where gold dust is melted and assayed and during the summer sea sons this is a busy department Last season their shipments of bullion amounted to over two and onehaif millions of dollars and there is every indication that they will handle as much if not more this year The Nome Bank Trust Companys building at the corner of Lanes Way and Front street is without"], "digitized": true, "extract_timestamp": "2024-05-22T13:00:32.557Z", "group": ["ndnp/ak", "alaska-state-library-historical-collections-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/2018270506/1908-06-01/ed-1/?sp=31", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_iceworm_ver02:data:2018270506:0027952696A:1908060101:0042/full/pct:6.25/0/default.jpg#h=450&w=338", "https://tile.loc.gov/image-services/iiif/service:ndnp:ak:batch_ak_iceworm_ver02:data:2018270506:0027952696A:1908060101:0042/full/pct:12.5/0/default.jpg#h=900&w=677", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ak/batch_ak_iceworm_ver02/data/2018270