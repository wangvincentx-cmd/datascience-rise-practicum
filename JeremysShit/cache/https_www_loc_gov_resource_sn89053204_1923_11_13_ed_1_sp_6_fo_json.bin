gmd:gmdvhs:gvhs:gvhs01:vhs00303/full/pct:12.5/0/default.jpg#h=367&w=234", "https://tile.loc.gov/image-services/iiif/service:gmd:gmdvhs:gvhs:gvhs01:vhs00303/full/pct:25/0/default.jpg#h=734&w=468"], "index": 9, "language": ["english"], "location": ["georgia", "andersonville", "andersonville prison", "sumter county", "united states"], "mime_type": ["image/gif", "image/jpeg", "image/jp2"], "number": ["2003-06-13t15:34:21"], "online_format": ["image"], "original_format": ["map"], "partof": ["geography and map division", "american memory", "military battles and campaigns", "civil war maps"], "score": 32.538933, "shelf_id": "http://www.loc.gov/item/001-CABIB20008140/", "site": ["ammem"], "subject": ["maps", "prisoners and prisons", "andersonville (ga.)", "georgia", "sumter county (ga.)", "andersonville prison", "sumter county", "civil war", "united states", "history"], "timestamp": "2022-03-30T06:52:52.845Z", "title": "Andersonville Prison", "url": "https://www.loc.gov/item/gvhs01.vhs00303/"}, {"access_restricted": false, "aka": ["http://lccn.loc.gov/2015669162", "http://www.loc.gov/item/2015669162/", "https://hdl.loc.gov/loc.afc/afc2010039.afc2010039_crhp0063", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0063/", "http://www.loc.gov/resource/afc2010039.afc2010039_crhp0063_mv02/", "http://www.loc.gov/resource/afc2010039text.afc2010039_crhp0063_Mahone_transcript/"], "campaigns": [], "contributor": ["mahone, sam", "civil rights history project (u.s.)", "jeffries, hasan kwame"], "date": "2013-01-01", "dates": ["2013"], "description": ["Sam Mahone discusses his experiences of racial segregation and discrimination in Americus, Georgia, and how he came to be involved in the Student Nonviolent Coordinating Committee (SNCC). After he joined SNCC, he participated in an array of activism: picketing a segregated movie theater, registering voters, and organizing in the black community. He also discusses the arrests that he and other activists experienced due to their activism, including the Americus Four case and the Leesburg Stockade. He concludes the interview by discussing his current involvement in showcasing African American art."], "digitized": true, "extract_timestamp": "2022-10-04T17:33:11.652Z", "group": ["afc2010039", "catalog-split-06", "catalog", "civil-rights-history-project", "main-catalog-split-06", "main-catalog"], "hassegments": true, "id": "http://www.loc.gov/item/2015669162/", "image_url": ["https://tile.loc.gov/storage-services/service/afc/afc2010039/afc2010039_crhp0063/afc2010039_crhp0063_mv02.gif", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:25/0/default.jpg#h=443&w=339", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:50/0/default.jpg#h=887&w=678", "https://tile.loc.gov/image-services/iiif/service:afc:afc2010039:afc2010039_crhp0063_Mahone_transcript:0001/full/pct:100/0/default.jpg#h=1774&w=1356"], "index": 10, "language": ["english"], "location": ["albany", "americus", "georgia", "united states"], "mime_type": ["image/gif", "image/jpeg", "image/jp2", "application/x-video"], "number": ["http://www.loc.gov/item/2015669162", "2015669162", "2020-02-20t11:58:30", "http://www.loc.gov/item/afc2010039_crhp0063", "online resource"], "online_format": ["image", "video"], "original_format": ["film, video"], "partof": ["catalog", "american folklife center", "civil rights history project"], "score": 24.12532, "shelf_id": "http://lccn.loc.gov/2015669162", "site": ["catalog"], "subject": ["oral histories", "interviews", "mahone, sam", "african american civil rights workers", "georgia", "civil rights movements", "video recordings", "student nonviolent coordinating committee (u.s.)", "discrimination in public accommodations", "united states", "civil rights demonstrations", "filmed interviews", "americus"], "timestamp": "2022-10-17T14:38:32.195Z", "title": "Sam Mahone oral history interview c