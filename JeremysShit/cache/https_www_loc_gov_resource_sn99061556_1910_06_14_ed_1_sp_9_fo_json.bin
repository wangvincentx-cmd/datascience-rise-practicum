1/?sp=9"], "batch": ["ncu_grandfather_ver01"], "campaigns": [], "composite_location": ["0/united states/", "1/united states/north carolina/", "2/united states/north carolina/wake/", "3/united states/north carolina/wake/raleigh/"], "contributor": ["university of north carolina at chapel hill library, chapel hill, nc"], "date": "1910-06-14", "dates": ["1910-06-14"], "description": ["WwiJiSiftiT I i THE FARMER AND MECHANIC UNPATRIOTIC ACT 4 X i V t OF BILLS t 9 i WEEK HAS IBM BEEN Cotton advanced in Face Good Weather Reports DUE TO COVERING SHORTS Ksperialy Wa3 This True of the Sum mer MonUis Options Bein Over sold Owing to Favorable WosUher JtciKrts Stock of Oerti floated Cot ton Itapidly Decreasing By the Associated Press New York June 10 Cotton has ad vanced in the face of weather condi tions over most sections that have been practically ideal Covering by large Wall Street shorts have been the great feature so far as the summer months are concerned The next crop months did not move materially until Thursday when there was a sharp ad vance These options had evidently become oversold owing to the favor able weather and the many reports of steady progress of the plant Yet of late excessive rains have occurred in many parts of the belt while in Texas maximum temperatures have been reported of 100 to 104 degrees These conditions have caused considerable covering and there has also been not a little new buying on the idea that quotations for the new crop months are too low"], "digitized": true, "extract_timestamp": "2023-08-12T17:35:08.013Z", "group": ["ndnp/ncu", "university-of-north-carolina-chapel-hill-library-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn99061556/1910-06-14/ed-1/?sp=9", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_grandfather_ver01:data:sn99061556:00415667474:1910061401:0380/full/pct:3.125/0/default.jpg#h=270&w=185", "https://tile.loc.gov/image-services/iiif/service:ndnp:ncu:batch_ncu_grand