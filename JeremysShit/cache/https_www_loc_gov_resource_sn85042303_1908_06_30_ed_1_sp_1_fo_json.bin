oduced by the Library of Congress. For more information on current NDNP awardees, see <a href=\"https://www.loc.gov/ndnp/listawardees.html\">https://www.loc.gov/ndnp/listawardees.html</a>.</p>\n<p>For more information on Library of Congress policies and disclaimers regarding rights and reproductions, see <a href=\"https://www.loc.gov/homepage/legal.html\">https://www.loc.gov/homepage/legal.html</a></p>"], "score": 14.45633, "shard": "04", "shelf_id": "sn85042303, 1908-06-30, Edition 1", "site": ["chroniclingamerica"], "source_group": "ndnp/okhi", "subject": ["carter", "ardmore (okla.)", "ardmore", "united states", "carter county (okla.)", "chickasaw nation, oklahoma", "newspapers", "carter county", "oklahoma"], "subject_headings": ["Ardmore (Okla.)--Newspapers", "Carter County (Okla.)--Newspapers", "Chickasaw Nation, Oklahoma--Newspapers", "Chickasaw Nation, Oklahoma", "Oklahoma--Ardmore", "Oklahoma--Carter County", "United States--Oklahoma--Carter--Ardmore"], "subjects": [{"ardmore": "https://www.loc.gov/search/?fa=subject:ardmore&fo=json"}, {"ardmore (okla.)": "https://www.loc.gov/search/?fa=subject:ardmore+%28okla.%29&fo=json"}, {"carter": "https://www.loc.gov/search/?fa=subject:carter&fo=json"}, {"carter county": "https://www.loc.gov/search/?fa=subject:carter+county&fo=json"}, {"carter county (okla.)": "https://www.loc.gov/search/?fa=subject:carter+county+%28okla.%29&fo=json"}, {"chickasaw nation, oklahoma": "https://www.loc.gov/search/?fa=subject:chickasaw+nation,+oklahoma&fo=json"}, {"newspapers": "https://www.loc.gov/search/?fa=subject:newspapers&fo=json"}, {"oklahoma": "https://www.loc.gov/search/?fa=subject:oklahoma&fo=json"}, {"united states": "https://www.loc.gov/search/?fa=subject:united+states&fo=json"}], "timestamp": "2022-11-18T17:13:05.223Z", "title": "The Daily Ardmoreite (Ardmore, Okla.), June 30, 1908", "type": ["issue"], "url": "https://www.loc.gov/item/sn85042303/1908-06-30/ed-1/"}, "locations": null, "method": "mets_filesec", "more_like_this": [{"access_restricted": false, "aka": ["http://lccn.loc.gov/sn85042303", "http://www.loc.gov/item/sn85042303/", "https://search.catalog.loc.gov/instances/770f95f4-34f3-5f45-bb91-1d337611f33a"], "batch": ["okhi_avocado_ver01"], "campaigns": [], "date": "1893", "description": ["Daily (except Monday), Sept. 22, 1992-Apr. 7, 1993 Began Oct. 28, 1893. Some Sunday issues published as: Sunday Ardmoreite-press. Suspended with Apr. 19, 1895 issues, resumed with May 7, 1895 issue. Title varies slightly: Ardmoreite (Nov. 1-2,5,12,26, 1893), Evening Ardmoreite (Nov. 1-3, 1893), and Morning Ardmoreite (Nov. 5,12,26, 1893). Archived issues are available in digital format as part of the Library of Congress Chronicling America online collection. Weekly eds.: Weekly Ardmoreite, <1894-1922>, and: Ardmore statesman and the weekly Ardmoreite, May 4,1922-<1927>, and: Weekly Ardmoreite combined with Ardmoreite statesman <1927>, and: Ardmore democrat, Aug. 31, 1931-<1981>. Description based on: Vol. 1, no. 5 (Nov. 1, 1893). Latest issue consulted: 124th yr., no. 251 (Sept. 28, 2018)."], "digitized": true, "extract_timestamp": "2026-06-05T18:24:58.817Z", "group": ["newspaper-titles", "catalog-split-10", "catalog", "ndnp/newspapers", "main-catalog-split-10", "united-states-newspaper-directory"], "hassegments": false, "id": "http://www.loc.gov/item/sn85042303/", "image_url": [], "index": 1, "language": ["english"], "latlong": [34.1725992, -97.1283816], "location": ["carter", "ardmore", "united states", "chickasaw nation", "carter county", "oklahoma"], "location_str": "", "lonlat": [-97.1283816, 34.1725992], "number": ["microfilm master", "microfilm service copy", "2025-11-07t15:12:46.400000", "http://www.loc.gov/item/sn85042303/1922-12-31/ed-1/", "http://www.loc.gov/item/sn85042303/1893-10-29/ed-1/", "oklahoma hist soc res libr", "sn85042303", "8876", "2026-04-13t21:30:13", "1", "12101538", "2020-05-29t09:29:54.540398", "franklin d roosevelt libr", "sn97070166", "kansas state hist soc, newsp 