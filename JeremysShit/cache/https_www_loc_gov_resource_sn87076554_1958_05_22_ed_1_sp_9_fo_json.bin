re matched as Bluffton outscored their two oppo nents combined Final score Bluffton 81 Wilmington Defiance 18 was 58 56 the 98 to set a Elbert Dubenion reached mark in the 100 yard dash new century mark and rangy Hank Nichols tied the pole vault and 120 yard high hurdle records Nichols hit 10 6 in the vault and raced over the hurdles in 156 Wilmingtons Morton burned off a 501 second 440 dash to set a new league record for the quarter Fred Howard Defiance set the other new Pirates Snap 880 Relay Record Logan Wins Four Events In Victory Over Ada Versatile Bob Logan swept four events and the Bluffton Pirates broke the school record for the 880 yard relay as they nosed out Ada 59 49 May 13 Logan put in his best performance of the year winning his special ties the 100 the 220 and the broad jump and adding a victory"], "digitized": true, "extract_timestamp": "2023-09-04T23:20:05.382Z", "group": ["ndnp/ohi", "ohio-historical-society-awardee"], "hassegments": false, "id": "http://www.loc.gov/resource/sn87076554/1958-05-22/ed-1/?sp=9", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_honeysuckle_ver01:data:sn87076554:00340580898:1958052201:0103/full/pct:3.125/0/default.jpg#h=294&w=218", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_honeysuckle_ver01:data:sn87076554:00340580898:1958052201:0103/full/pct:6.25/0/default.jpg#h=588&w=436", "https://tile.loc.gov/image-services/iiif/service:ndnp:ohi:batch_ohi_honeysuckle_ver01:data:sn87076554:00340580898:1958052201:0103/full/pct:12.5/0/default.jpg#h=1176&w=873", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/ohi/batch_ohi_honeysuckle_ver01/data/sn87076554/00340580898/1958052201/0103.xml&format=alto_xml"], "index": 9, "language": ["english"], "location": ["allen", "bluffton", "united states", "ohio"], "location_city": ["bluffton"], "location_country": ["united states"], "location_county": ["allen"], "location_state": ["ohio"], "mime_type": ["