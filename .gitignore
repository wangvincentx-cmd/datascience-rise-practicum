# Secrets — never commit API keys
.env
*.env
!.env.example

# Virtualenvs
.venv/
venv/

# Python
__pycache__/
*.py[cod]

# Scraper/API response caches
cache/
**/data/raw/

# Large regenerable corpora. Every one of these is rebuildable from cache/ or
# re-downloadable, and they run from tens to hundreds of MB:
#   pages.jsonl          ~46 MB   build_page_corpus.py, from cache/
#   pages_monthly.jsonl ~500 MB   scrape_monthly.py, the 1900-1963 scrape
#   claims_*.jsonl                extract_llm.py output
JeremysShit/data/pages.jsonl
# JeremysShit/data/monthly/
JeremysShit/claims_v2.jsonl
JeremysShit/claims_monthly.jsonl
JeremysShit/gold_extraction/pred_*.jsonl
JeremysShit/gold_extraction/log_*.txt

# Incomplete / regenerable grading output (commit the finished version deliberately
# with `git add -f JeremysShit/claims_graded.csv` once a full run has completed —
# an in-progress file is a partial corpus and shouldn't be committed by accident)
JeremysShit/claims_graded_test.csv
JeremysShit/claims_graded.csv

# OS
.DS_Store
Thumbs.db

# Spreadsheet working files — graders edit in Numbers/Excel, but only the
# exported CSV is the artifact (binary formats can't be diffed or read by kappa.py)
*.numbers
*.xlsx
!JeremysShit/*.xlsx

# Regenerable run logs
JeremysShit/grade_run.log

# Superseded by handgrade_newspapers/ (regenerated on every grading run)
JeremysShit/validation_sample.csv
.claude/settings.json
